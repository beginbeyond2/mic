public abstract class HW implements IHW {

    private static final String TAG = "HW";
    protected static final long SHIFTREG_INIT_VAL = 0xCDCDCDCDCDCDCDCDL;
    protected static final long SHIFTREG_INIT_VAL_MHO10008 = 0xFFFFFFFFFFFFFFFFL;
    protected int fpgaNums = 2;


    public HW(int fpgaNums){
        this.fpgaNums = fpgaNums;
        bakCofitBuf = ByteBuffer.allocate(getMaxCofitSize() + 1024);
    }

    public void sendShiftRegister(long val){
        Hardware.getInstance().sendShiftRegister( val, 64);
    }
    public void setChPgaGain(int []val){
        FPGACommand cmd = FPGACommand.getInstance();
        for(int i=0;i<fpgaNums;i++){
            cmd.SendAD8370Data(i, Arrays.copyOfRange(val,i*4,4 + i * 4));
        }
    }
    @Override
    public void ChPowerEnable(boolean bEnable) {

    }


    protected void usleep(int us){
        try {
            Thread.sleep(us/1000,(us % 1000)*1000);
        } catch (InterruptedException e) {
            e.printStackTrace();
        }
    }

    //校准部分---------------------------------------------------------------------------------------------
    protected static final String FACTORY_CALIBRATE_NAME = "factoryCalibrateData";
    protected static final String USER_CALIBRATE_NAME = "userCalibrateData";

    private static final int FACTORY_CALIBRATE_ADDR = 0x5600;

    private final int CODE_CH_CNT=0x12E0_5500;//低8位必须为0

    public static final int CODE_VER_1 = 1;
    public static final int CODE_VER_2 = 2;
    public static final int CODE_VER_3 = 3;
    public static final int CODE_VER = CODE_VER_3 ;

    private final int CODE_VER_MASK = 0x001F_0000;
    private volatile int code_ver = 0;

    public int getVer(){
        return code_ver;
    }
    public void setVer(int v){
        code_ver = v;
    }


    private int getCalibrateAddr(final String fileName){
        if(FACTORY_CALIBRATE_NAME.equals(fileName)){
            return getFactoryCalibrateAddr();
        }else if(USER_CALIBRATE_NAME.equals(fileName)){
            return getUserCalibrateAddr();
        }
        return getFactoryCalibrateAddr();
    }

    protected int getFactoryCalibrateAddr(){
        return FACTORY_CALIBRATE_ADDR;
    }
    protected abstract int getMaxCofitSize();

    protected int getUserCalibrateAddr(){
        return getFactoryCalibrateAddr() + getMaxCofitSize();
    }

    protected int getCalibrateStateAddr(){
        return getUserCalibrateAddr() + getMaxCofitSize();
    }
    protected abstract int getUseFlashMax();
    protected abstract int getFlashMax();


    protected int write(int addr,byte[] data){
        Hardware hw = Hardware.getInstance();
        int r = hw.writeE2PROM(addr,data);
        if(r <= 0){
            Log.e(TAG,"save writeE2PROM : " + Integer.toHexString(addr));
        }
        return r;
    }

    protected int read(int addr,byte[] data){
        Hardware hw = Hardware.getInstance();
        int r = hw.readE2PROM(addr,data);
        if(r <= 0){
            Log.e(TAG,"save readE2PROM : " + Integer.toHexString(addr));
        }
        return r;
    }

    private int getChNumCode(int chCnt){
        int v = getVer();
        if(v == 0){
            v = CODE_VER;
        }
        return (CODE_CH_CNT + (v << 16)) + chCnt;
    }
    protected int readCalibrateParam(final String fileName) {

        int xlen = 0;
        int maxCofitSize = getMaxCofitSize();
        byte[] bytes = new byte[maxCofitSize];
        xlen = read(getCalibrateAddr(fileName),bytes);

        if(xlen > 0 && bytes != null) {
            ByteBuffer byteBuffer = ByteBuffer.wrap(bytes);
            byteBuffer.order(ByteOrder.LITTLE_ENDIAN);

            int len = bytes.length;
            if (len >= maxCofitSize) {
                /*
                 * 读取校准数据，排列顺序如下：
                 * short crc；
                 * int len；
                 * int 通道数的识别码
                 * 校准数据
                 */
                short crc = byteBuffer.getShort(0);
                int dataLen = byteBuffer.getInt(2);
                int chNumCode = byteBuffer.getInt(6);
                if(Utils.CRC16(byteBuffer.array(), 2, len - 2) == crc
                        && dataLen == len){
                    int n = Scope.getInstance().getChNum();
                    code_ver = (chNumCode & CODE_VER_MASK) >> 16;
                    if((chNumCode & (~CODE_VER_MASK))
                            == (getChNumCode(n) & (~CODE_VER_MASK))){
                        int idx = ByteBuffer2cofit(byteBuffer, 10);
                        Log.i(TAG, "完成校准数据文件的读取: " + fileName + ",idx:" + idx + ",Ver:" + code_ver);
                        return 0;
                    }else{
                        Log.i(TAG, "完成校准数据文件的读取: " + fileName + ",chNumCode:" + chNumCode + ",Ver:" + code_ver);
                    }
                }else{
                    Log.e(TAG,"wavelen:" + dataLen + ",crc:" +crc);
                }
            }
        }

        Log.e(TAG, "read "+" error!!," +xlen);
        return 1;
    }
    private synchronized boolean saveCalibrateParam(final String fileName)
    {
        int maxCofitSize = getMaxCofitSize();
        ByteBuffer byteBuffer=ByteBuffer.allocate(maxCofitSize);
        byteBuffer.order(ByteOrder.LITTLE_ENDIAN);

        /*
         * 存储校准数据，排列顺序如下：
         * short crc；
         * int len；
         * int 通道数的识别码
         * 校准数据
         */
        byteBuffer.putInt(2, byteBuffer.limit());
        byteBuffer.putInt(6, getChNumCode(Scope.getInstance().getChNum()));

        int idx = cofit2ByteBuffer(byteBuffer, 10,true);

        short crc16 = Utils.CRC16(byteBuffer.array(), 2, byteBuffer.limit()-2);
        byteBuffer.putShort(0, crc16);

        long s = SystemClock.elapsedRealtime();
        int xlen = write(getCalibrateAddr(fileName),byteBuffer.array());

        if(xlen > 0){
            Log.i(TAG,"完成校准数据文件的存储: "+fileName + ",idx:" + idx + ",s:" + (SystemClock.elapsedRealtime() - s));
            return true;
        }else {
            Log.e(TAG,"saveCalibrateParam");
            return false;
        }

    }

    @Override
    public int loadCalibration(){
        int error = readCalibrateParam(USER_CALIBRATE_NAME);
        if(error != 0){
            Log.e(TAG,"read user calibrate param fail,error namber="+error);
            error = readCalibrateParam(FACTORY_CALIBRATE_NAME);
            if(error != 0){
                Log.e(TAG,"read factory calibrate param fail,error namber="+error);
                defaultVal(); //读取失败恢复默认校准系数
                clearCalibrationState();
                return -1; //读取用户校准信息和系统校准信息均失败，恢复默认设置；
            }
            Log.i(TAG,"read factory calibrate param succesful");
            return 1;//读取用户校准信息失败，但读取系统校准信息成功；
        }
        Log.i(TAG,"read User calibrate param succesful");
        return 0;//读取成功
    }
    @Override
    public boolean saveCalibration(){
        return saveFactoryCalibration() && saveUserCalibration();
    }
    @Override
    public boolean saveFactoryCalibration(){
        return saveCalibrateParam(FACTORY_CALIBRATE_NAME);
    }
    @Override
    public boolean saveUserCalibration(){
        return saveCalibrateParam(USER_CALIBRATE_NAME);
    }

    @Override
    public void backUpCabteRegister(){
        cofit2ByteBuffer(bakCofitBuf, 0);
    }
    @Override
    public void restoreCabteRegister(){
        ByteBuffer2cofit(bakCofitBuf, 0);
    }

