    protected int setString(String str,ByteBuffer buf,int idx){
        buf.position(idx);
        byte[] bytes = str.getBytes(StandardCharsets.US_ASCII);
        if(bytes != null) {
            buf.putInt(0x20250617);
            buf.putInt(bytes.length);
            buf.put(bytes);
        }
        return buf.position();
    }
    protected int getString(StringBuilder sb,ByteBuffer buf,int idx){
        buf.position(idx);
        if(0x20250617 == buf.getInt()) {
            int l = buf.getInt();
            if (l > 0 && l < 128) {
                byte[] bytes = new byte[l];
                buf.get(bytes);
                sb.append(new String(bytes, StandardCharsets.US_ASCII));
            }
        }
        return buf.position();
    }


