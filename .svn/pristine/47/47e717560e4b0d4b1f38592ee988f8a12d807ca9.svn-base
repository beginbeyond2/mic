<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape>
            <corners
                android:topLeftRadius="4dp"
                android:topRightRadius="4dp" />
            <solid android:color="@color/color_Backcolor_MainMenu2" />
            <stroke
                android:width="1px"
                android:color="@color/bglinecolorTopTitle" />
        </shape>
    </item>
    <item
        android:drawable="@color/color_Backcolor_MainMenu2"
        android:left="2px"
        android:right="2px"
        android:top="2px" />
</layer-list>