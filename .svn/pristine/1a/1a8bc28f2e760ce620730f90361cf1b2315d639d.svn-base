package com.micsig.tbook.tbookscope.top.layout.trigger.serials.bean;

/**
 * Created by yangj on 2017/5/17.
 */

public class SerialsDetailArinc429LabelData implements ISerialsDetail {
    private DataBean arinc429LabelDataLabel;
    private DataBean arinc429LabelDataData;
    private String arinc429LabelDataLabelTitle;
    private String arinc429LabelDataDataTitle;

    public String getArinc429LabelDataLabelTitle() {
        return arinc429LabelDataLabelTitle;
    }

    public void setArinc429LabelDataLabelTitle(String arinc429LabelDataLabelTitle) {
        this.arinc429LabelDataLabelTitle = arinc429LabelDataLabelTitle;
    }

    public String getArinc429LabelDataDataTitle() {
        return arinc429LabelDataDataTitle;
    }

    public void setArinc429LabelDataDataTitle(String arinc429LabelDataDataTitle) {
        this.arinc429LabelDataDataTitle = arinc429LabelDataDataTitle;
    }

    public DataBean getArinc429LabelDataLabel() {
        return arinc429LabelDataLabel;
    }

    public void setArinc429LabelDataLabel(int digits, String value) {
        if (this.arinc429LabelDataLabel == null) {
            this.arinc429LabelDataLabel = new DataBean();
        }
        this.arinc429LabelDataLabel.setDigits(digits);
        this.arinc429LabelDataLabel.setValue(value);
    }

    public DataBean getArinc429LabelDataData() {
        return arinc429LabelDataData;
    }

    public void setArinc429LabelDataData(int digits, String value) {
        if (this.arinc429LabelDataData == null) {
            this.arinc429LabelDataData = new DataBean();
        }
        this.arinc429LabelDataData.setDigits(digits);
        this.arinc429LabelDataData.setValue(value);
    }

    @Override
    public String toString() {
        return "SerialsDetailArinc429LabelData{" +
                "arinc429LabelDataLabel='" + arinc429LabelDataLabel + '\'' +
                ", arinc429LabelDataData='" + arinc429LabelDataData + '\'' +
                '}';
    }
}
