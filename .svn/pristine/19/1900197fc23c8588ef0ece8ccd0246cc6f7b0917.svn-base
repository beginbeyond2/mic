public class MainTopLayoutCenter extends RelativeLayout {

    private static final String TAG = "MainTopLayoutCenter";
    private Context context;
    private MTriggerTime slider;

    public MainTopLayoutCenter(Context context) {
        this(context, null);
    }

    public MainTopLayoutCenter(Context context, AttributeSet attrs) {
        this(context, attrs, 0);
    }

    public MainTopLayoutCenter(Context context, AttributeSet attrs, int defStyleAttr) {
        super(context, attrs, defStyleAttr);
        this.context = context;
        initView(context, attrs, defStyleAttr);
        initControl();
    }

    private void initView(Context context, AttributeSet attrs, int defStyleAttr) {
        View.inflate(context, R.layout.layout_maintop_center, this);
        slider = (MTriggerTime) findViewById(R.id.slider);
        this.setOnTouchListener(this::onTouchEvent);
    }

    float oldDown,oldDownY;
    boolean mScrolling;
    public Consumer<Boolean> OnClickEvent;
    private long lastClickTime = 0;
    private boolean isDoubleClick = false;

    private boolean onTouchEvent(View view, MotionEvent event) {
        boolean isFromMouse = event.isFromSource(InputDevice.SOURCE_MOUSE);//判断是否来自鼠标点击
        switch (event.getAction()){
            case MotionEvent.ACTION_DOWN:{
                oldDown=event.getX();
                oldDownY=event.getY();
                mScrolling=false;
                long clickTime = System.currentTimeMillis();
                if (clickTime - lastClickTime < 300) {
                    //双击事件
                    isDoubleClick = true;
                } else {
                    lastClickTime = clickTime;
                }
            }break;

            case MotionEvent.ACTION_UP:{
                double min= ViewConfiguration.get(getContext()).getScaledTouchSlop();
                if (Math.abs(oldDown - event.getX()) <=min && Math.abs(oldDownY-event.getY())<=min ) {
                    if (OnClickEvent!=null) {
                        try {
                            if (isDoubleClick && isFromMouse && checkDoubleClick((int) event.getX(), (int) event.getY())) {
                                OnClickEvent.accept(true);
                                isDoubleClick = false;
                            } else {
                                OnClickEvent.accept(false);
                            }
                        } catch (Exception e) {
                            e.printStackTrace();
                        } catch (Throwable e) {
                            e.printStackTrace();
                        }
                    }
                    mScrolling = true;
                } else {
                    mScrolling = false;
                }

            }break;
        }
        return mScrolling;
    }

    private boolean checkDoubleClick(int x, int y) {
        Rect rect = slider.getTriggerRect();
        Logger.d(TAG, "handleDoubleClick x = " + x + " ,y= " + y + " ,rect =" + rect);
        return rect.contains(x, y);
    }

    private void initControl() {
        RxBus.getInstance().getObservable(RxEnum.MAINWAVE_TRIGGERTIMEBASE).subscribe(consumerMainWaveTriggerTimeBase);
        //RxBus.getInstance().getObservable(RxEnum.MAINBOTTOM_TIMEBASE).subscribe(consumerMainBottomTimeBase);

        RxBus.getInstance().getObservable(RxEnum.MAIN_TOPRIGHT_GONE).subscribe(consumerTopRightGone);
        RxBus.getInstance().getObservable(RxEnum.MAIN_TOPCENTER_TEXT_GONE).subscribe(consumerTopRightGone);
        RxBus.getInstance().getObservable(RxEnum.WAVEZONE_WORKMODE_CHANGE).subscribe(consumerWorkModeChange);
        RxBus.getInstance().getObservable(RxEnum.TOPLAYOUT_SAMPLESEGMENTED_STATE).subscribe(consumerSegmentedState);
        RxBus.getInstance().getObservable(RxEnum.TOPLAYOUT_SAMPLEMODE).subscribe(consumerTopLayoutSampleMode);
        RxBus.getInstance().getObservable(RxEnum.TOPLAYOUT_SAMPLESEGMENTED).subscribe(consumerSampleSegment);
        RxBus.getInstance().dealObservable(RxEnum.MQ_CHANNEL_ACTIVE_CHANGE,this::OnChanActiveChange);
        RxBus.getInstance().getObservable(RxEnum.MQ_MSG_CHANNEL_SELECT_COLOR).subscribe(consumerSelectColor);

        EventFactory.addEventObserver(EventFactory.EVENT_SEGMENT_FRAMES, eventUIObserver);
        EventFactory.addEventObserver(EventFactory.EVENT_UI_SAMPLE_GRAPH, eventUIObserver);
        EventFactory.addEventObserver(EventFactory.EVENT_UI_DEPTH_SAMPFRE_REFLASH, uiObserver);
    }



    public boolean containsRect(MotionEvent event){
        if (MotionEvent.ACTION_UP==event.getAction()){
            int x=(int)event.getRawX();
            int y=(int)event.getRawY();
            Rect r1=new Rect();

            this.getGlobalVisibleRect(r1);
            if (r1.contains(x,y) && this.getVisibility()==View.VISIBLE){
                return true;
            }else {
                return false;
            }
        }else {
            return false;
        }
    }

    private Consumer<MainWaveMsgTriggerTimeBase> consumerMainWaveTriggerTimeBase = new Consumer<MainWaveMsgTriggerTimeBase>() {
        @Override
        public void accept(MainWaveMsgTriggerTimeBase msgTimeBase) throws Exception {
            long x = msgTimeBase.getX();
            double iconTPercent = x * 1.0 / 7;
            long ps = HorizontalAxis.getInstance().getTimePosOfView();//单位：1e-13s
            slider.setIconTPercent((float) iconTPercent);
//                        .setTipPercent(40)
            slider.setTrigger(TBookUtil.getTime3FromPs(ps))
                    .updateUI();
        }
    };


