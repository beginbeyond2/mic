package com.micsig.tbook.tbookscope.top.layout.trigger.serials.bean;

/**
 * Created by yangj on 2017/5/17.
 */

public class SerialsDetailCanIdData implements ISerialsDetail {
    private DataBean canIdDataId;
    private DataBean canIdDataDlc;
    private DataBean canIdDataData;
    private String canIdDataIdTitle;
    private String canIdDataDlcTitle;
    private String canIdDataDataTitle;

    public String getCanIdDataIdTitle() {
        return canIdDataIdTitle;
    }

    public void setCanIdDataIdTitle(String canIdDataIdTitle) {
        this.canIdDataIdTitle = canIdDataIdTitle;
    }

    public String getCanIdDataDlcTitle() {
        return canIdDataDlcTitle;
    }

    public void setCanIdDataDlcTitle(String canIdDataDicTitle) {
        this.canIdDataDlcTitle = canIdDataDicTitle;
    }

    public String getCanIdDataDataTitle() {
        return canIdDataDataTitle;
    }

    public void setCanIdDataDataTitle(String canIdDataDataTitle) {
        this.canIdDataDataTitle = canIdDataDataTitle;
    }

    public DataBean getCanIdDataId() {
        return canIdDataId;
    }

    public void setCanIdDataId(int digits, String value) {
        if (this.canIdDataId == null) {
            this.canIdDataId = new DataBean();
        }
        this.canIdDataId.setDigits(digits);
        this.canIdDataId.setValue(value);
    }

    public DataBean getCanIdDataDlc() {
        return canIdDataDlc;
    }

    public void setCanIdDataDlc(int digits, String value) {
        if (this.canIdDataDlc == null) {
            this.canIdDataDlc = new DataBean();
        }
        this.canIdDataDlc.setDigits(digits);
        this.canIdDataDlc.setValue(value);
    }

    public DataBean getCanIdDataData() {
        return canIdDataData;
    }

    public void setCanIdDataData(int digits, String value) {
        if (this.canIdDataData == null) {
            this.canIdDataData = new DataBean();
        }
        this.canIdDataData.setDigits(digits);
        this.canIdDataData.setValue(value);
    }

    @Override
    public String toString() {
        return "SerialsDetailCanIdData{" +
                "canIdDataId='" + canIdDataId + '\'' +
                ", canIdDataDlc='" + canIdDataDlc + '\'' +
                ", canIdDataData='" + canIdDataData + '\'' +
                '}';
    }
}
