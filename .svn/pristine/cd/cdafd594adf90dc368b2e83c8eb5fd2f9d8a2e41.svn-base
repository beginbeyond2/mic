    @Override
    public boolean dispatchTouchEvent(MotionEvent ev) {
        boolean r = super.dispatchTouchEvent(ev);
        if(ev.getAction() == MotionEvent.ACTION_UP){
            if(mainViewGroup.isUserTouch()){
                mainViewGroup.setUserTouch(false);
            }
        }
        return r;
    }

    @Override
    public boolean onGenericMotionEvent(MotionEvent event){

        if (0 != (event.getSource() & InputDevice.SOURCE_CLASS_POINTER)) {

            switch (event.getAction()) {
                case MotionEvent.ACTION_SCROLL:
                    AutoSave autoSave = AutoSave.getInstance();
                    if(autoSave.isRun() && autoSave.isSaving()){
                        break;
                    }
                    autoSave.setUserInput(true);
                    int x = Math.round(event.getX() - previewTextureViewX);
                    if(x > 0 &&  x < ScopeBase.getWidth()) {
                        mScope.horizontalAxisScale(x
                                , event.getAxisValue(MotionEvent.AXIS_VSCROLL) > 0 ? 1 : -1);
                    }


//                    int chIdx = ChannelFactory.getChActivate();
//                    if(ChannelFactory.isDynamicCh(chIdx)) {
//                        HorizontalAxis horizontalAxis = HorizontalAxis.getInstance();
//
//                        int scaleId = (int) (horizontalAxis.getTimeScaleIdOfView() + val + 0.01f);
//                        if (HorizontalAxis.getMinGear() > scaleId) {
//                            scaleId = HorizontalAxis.getMinGear();
//                        } else if (HorizontalAxis.getMaxGear() < scaleId) {
//                            scaleId = HorizontalAxis.getMaxGear();
//                        }
//                        horizontalAxis.setTimeScaleIdOfView(scaleId);
//                    }else if(ChannelFactory.isRefCh(chIdx)){
//                        RefChannel refChannel = ChannelFactory.getRefChannel(chIdx);
//                        HorizontalAxisRef ref = refChannel.getHorizontalAxisRef();
//
//                    }



                    //mScope.doubleClicked();
                    return true;
            }
        }
        return super.onGenericMotionEvent(event);
    }

    public void initMathRef() {
        int[] refColors = SvgNodeInfo.getRefColorsInt();
        int[] mathColors = SvgNodeInfo.getMathColorsInt();
        ChannelFactory.initRef(refColors);
        ChannelFactory.initMath(mathColors);
    }

    public void changeColor(int chIndex) {
        initMathRef();
        ChannelFactory.getInstance().changeChannelColor(chIndex);
    }


