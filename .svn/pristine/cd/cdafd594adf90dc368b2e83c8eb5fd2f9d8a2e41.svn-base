    public void setScreenshotParam() {
        Intent i = new Intent("android.intent.action.setScreenshotParam");
        i.putExtra("timestamp", CacheUtil.get().getBoolean(CacheUtil.TOP_SLIP_USERSET_TIMESTAMP));
        i.putExtra("invert", CacheUtil.get().getBoolean(CacheUtil.TOP_SLIP_USERSET_SCREENINVERT));
        i.putExtra("filePath", CacheUtil.get().getOtherString(CacheUtil.TOP_SLIP_SAVE_PICTURE_PATH_CURRENT));
        i.putExtra("fileName", getPictureName());
        sendBroadcast(i);
    }
    @Override
    protected void onResume() {
        super.onResume();
        Log.d(TAG, "activity onResume");



        mScope.resume();
//        loadParam();
        WorkModeManage.getInstance().onResume();
//        if (waveZoneDisplay_yt != null) {
//            waveZoneDisplay_yt.onResume();
//        }
        App.setDropDownBoxVisiable(this,false);

        HwManager.setString("im.emoji", "0");


        keyService.setDealKeys(true);
        boolean runStop = CacheUtil.get().getBoolean(CacheUtil.MAIN_LEFT_RUNSTOP);

        if (!runStop) {
            drawRefresh = 0;
            mainHandler.sendEmptyMessageDelayed(MSG_REFRESH_WAVE, 1000);
        }
        if(!App.isMainActivity()) {
            closeSplashActivity();
        }

        RxBus.getInstance().post(RxEnum.EXTERNALKEY_TOMCU, new ExternalKeysMsg_ToMCU(ExternalKeysMsg_ToMCU.TYPE_ZOOM,
                CacheUtil.get().getBoolean(CacheUtil.MAIN_BOTTOM_SLIP_ZOOM)? ExternalKeysMsg_ToMCU.STATE_LED_ON : ExternalKeysMsg_ToMCU.STATE_LED_OFF) );

        RxBus.getInstance().post(RxEnum.EXTERNALKEY_TOMCU, new ExternalKeysMsg_ToMCU(ExternalKeysMsg_ToMCU.TYPE_RUNSTOP,
                CacheUtil.get().getBoolean(CacheUtil.MAIN_LEFT_RUNSTOP) ? ExternalKeysMsg_ToMCU.STATE_LED_GREEN : ExternalKeysMsg_ToMCU.STATE_LED_RED));

        mainHandler.sendEmptyMessageDelayed(MSG_REDRAWREF, 200);

        //刷新U盘图标状态
//        mainTopLayoutLeft.refreshUdiskIcon();
        statusBar.refreshUdiskIcon();
        App.setMainActivityAlive(true);
        App.setMainActivity(this);

//        changeWaveArea();
    }

    private void changeWaveArea() {
        //先找出来测量项的多少
        String channelStrings = CacheUtil.get().getString(CacheUtil.TOP_SLIP_MEASURE_SELECT_LIST_CHANNEL);
        Logger.d(TAG, "measureItem channelStrings= " + channelStrings);
        ArrayList<String> channelList = StrUtil.getListFromString(channelStrings, CacheUtil.MEASURE_SELECT_LIST_SLIP);
        int measureCount = channelList.size();
        String measureStr;
        if (measureCount == 0) {//没有测量项
            measureStr = false + CommandMsgToUI.PARAM_SPLIT + 0;
        } else if (measureCount <= 10) {//一行测量项
            measureStr = true + CommandMsgToUI.PARAM_SPLIT + 1;
        } else {//两行测量项
            measureStr = true + CommandMsgToUI.PARAM_SPLIT + 11;
        }
        Logger.d(TAG, "measureItem measureStr= " + measureStr);
        RxBus.getInstance().post(RxEnum.MQ_MSG_MEASURE_ITEM_COUNT, measureStr);
    }


    private void closeSplashActivity() {

        new Thread(new Runnable() {
            @Override
            public void run() {
                Thread.currentThread().setName("Main_CloseSplashActivity");

                CacheUtil.get().setLoadMenuState(CacheUtil.LOAD_WaveZoneDisplayManage, false);
                int count = 0;
                while (CacheUtil.get().isLoadParamComplete() == false && count++ < 100) {
                    Tools.sleep(100);
                }


                //mMainHolderBottomQuick.initMediaProjection();
                //设置timeBasePos位置
                TriggerTimebase.getInstance().setCache();
                Tools.sleep(1000);
                if(!mainHandler.hasMessages(MSG_SPLASH)) {
                    mainHandler.sendEmptyMessage(MSG_SPLASH);
                }
                Tools.sleep(100);
                Logger.i(TAG, "loadComplete sendemptyMessage:" );
                mScope.enableCommand(true);


                int chIdx = ChannelFactory.getChActivate();
                if(ChannelFactory.isMathCh(chIdx)){
                    MathChannel mathChannel = ChannelFactory.getMathChannel(chIdx);
                    mathChannel.activate();;
                }
            }
        }).start();

    }

    @Override
    protected void onPause() {
        Log.d(TAG, "MainActivity onPause!");
        super.onPause();

        SaveBin.getInstance().stop();

        CacheUtil.get().putMap(CacheUtil.MAIN_RECOVERY_CHANNEL_SELECT + "-1", String.valueOf(ChannelFactory.getChActivate()), true);
        WorkModeManage.getInstance().onPause();
//        if (waveZoneDisplay_yt != null) {
//            waveZoneDisplay_yt.onPause();
//        }
        SplashDialog.get().closeDialog();

        App.setDropDownBoxVisiable(this,true);
        keyService.setDealKeys(false);
        mScope.pause();
        CacheUtil.get().pause();

        HwManager.setString("im.emoji", "1");
    }

    @Override
    protected void onStop() {
        Log.i(TAG, "onStop");
        super.onStop();
        RxBus.getInstance().post(RxEnum.ACTIVITY_ACTIVITYONSTOP, new ActivityMsgOnStop());
    }

    @Override
    protected void onSaveInstanceState(@NonNull Bundle outState) {
//        super.onSaveInstanceState(outState);
        long bundleSize = BundleUtil.getBundleSize(outState);
        Log.w("MainActivity", "getBundleSize= " + bundleSize);
    }

    @Override
    protected void onActivityResult(int requestCode, int resultCode, Intent data) {
        ActivityMsgResult result = new ActivityMsgResult(requestCode, resultCode, data);
        RxBus.getInstance().post(RxEnum.ACTIVITY_ACTIVITYRESULT, result);
    }

    @Override
    protected void onDestroy() {
        Log.d(TAG, "onDestory");
        mScope.standby();

        if (rxBusRegister != null) rxBusRegister.unRegister();
        BroadcastManager.getInstance().unregisterReceiver();
        keyService.unBind();
        scpiService.unBind();
        App.setMainActivityAlive(false);
        App.finish();
        Log.d(TAG, "onDestory end");
        super.onDestroy();
    }


