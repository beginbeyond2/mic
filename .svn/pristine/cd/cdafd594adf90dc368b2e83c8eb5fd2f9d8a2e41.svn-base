//            if (channel2 != null) {
//                channel2.inflate();
//            }
//        } else {//channelNumber == 4
//            if (channel4 != null) {
//                channel4.inflate();
//            }
//        }
        new MainHolderTriggerLevel(mainViewGroup);
        mMainHolderBottomQuick = new MainHolderBottomQuick(mainViewGroup, savedInstanceState);
        mMainHolderBottomQuick.setMainActivity(MainActivity.this);
        mainHolderBottom = new MainHolderBottom(mainViewGroup, MainActivity.this);
        new MainHolderRightChannels(mainViewGroup);
        new MainHolderLeftMenu(mainViewGroup);
        new MainBottomOtherChannels(mainViewGroup);
        topSlipMenuBar_Quick = (TopLayoutPopWindow) mainViewGroup.findViewById(R.id.topSlipMenuBar_Quick);
        topSlipMenuBar_Quick.setSavedInstanceState(savedInstanceState);


        Looper.myQueue().addIdleHandler(new MessageQueue.IdleHandler() {
            @Override
            public boolean queueIdle() {
                Logger.i(TAG,"loadparam");
                try {
                    //preMainLoadCahceProcess();
                    mScope.enableCommand(false);
                    mScope.setRun(true);
                    CacheUtil.get().getCacheMap();
                    CacheUtil.get().startUp();
                    //CacheUtil.get().checkCacheParam();
                    updateMainLoadCaheProcess(false);


                }catch (Exception e){
                    //跑到这里界面 一致在loading 下面是补救措施。
                    e.printStackTrace();

                    CacheUtil.get().clearCacheMap();
                    CacheUtil.get().clearOtherMap();
                    updateMainLoadCaheProcess(false);
                }finally {
                    findViewById(R.id.loading).setVisibility(View.GONE);
                }
                return false;
            }
        });

    }

