    /***
     * 在CacheUtil重新载入【MAIN_LOAD_CACHE】前清理环境为标准状态
     */
    public void preMainLoadCahceProcess() {
        mScope.setRun(false);
        for(int i=0;i<ChannelFactory.CHANNEL_CNT;i++){
            ChannelFactory.chClose(i);
        }
        mScope.clearWave();
        mScope.setZoomFlags(DisplayAction.FLAGS_RESET_BAKSCALEID);
        mScope.setZoom(false);
        WorkModeManage.getInstance().setWorkMode(IWorkMode.WorkMode_YT, false);
        mainViewGroup.hideAllSlip();
    }

    /***
     * 载入CacheUtil内的配置，如果CacheUtil内为空配置，则载入默认设置信息
     */
    public void updateMainLoadCaheProcess(boolean isFromRecovery) {
        //外部按键预选框的初始化需要在cache设置恢复之后
        double normalScale = 0;
        double zoomLargeScale = 0;
        double zoomLargeScaleFull = 0;
        boolean bRun = mScope.isRun();
        mScope.setRun(true);
        CacheUtil.get().checkCacheParam();
        mScope.setUsersetReset(true);
        mScope.setRun(bRun);
        boolean bTmpZoom = false;

        bTmpZoom = CacheUtil.get().getBoolean(CacheUtil.MAIN_BOTTOM_SLIP_ZOOM);
//        boolean runStop = CacheUtil.get().getBoolean(CacheUtil.MAIN_LEFT_RUNSTOP);
//        if (!runStop) {
//            CacheUtil.get().putMapInForce(CacheUtil.MAIN_LEFT_RUNSTOP, "true");
//        }
        if(bTmpZoom){
            normalScale = TBookUtil.getSFromTime(CacheUtil.get().getString(CacheUtil.MAIN_BOTTOM_TIMEBASE_NORMAL_SCALE));
            zoomLargeScale = TBookUtil.getSFromTime(CacheUtil.get().getString(CacheUtil.ZOOM_BOTTOM_TIMEBASE_LARGE_SCALE));
            CacheUtil.get().putMap(CacheUtil.MAIN_BOTTOM_SLIP_ZOOM, String.valueOf(false),true);
        }
        long x =  CacheUtil.get().getLong(CacheUtil.MAIN_WAVE_TIMEBASE_POSITION_NORMAL);
        int channelsSelect = CacheUtil.get().getInt(CacheUtil.MAIN_CENTER_CHANNELS_SELECT);
        ExternalKeysManager.get().init(mainViewGroup);

        HorizontalAxis.setMaxGear(CacheUtil.get().getInt(CacheUtil.MAIN_WAVE_TIMEBASE_MAX));
        HorizontalAxis.setMinGear(CacheUtil.get().getInt(CacheUtil.MAIN_WAVE_TIMEBASE_MIN));
        HorizontalAxis.getInstance().initXAxis();


        RxBus.getInstance().post(RxEnum.MAIN_LOAD_CACHE, new LoadCache());
        //bug bug, all bug
        CacheUtil.get().putMap(CacheUtil.MAIN_CENTER_CHANNELS_SELECT,String.valueOf(channelsSelect),true);
        CacheUtil.get().putMap(CacheUtil.MAIN_CENTER_CHANNELS_SELECT_WILL_NULL,String.valueOf(channelsSelect),true);
        RxBus.getInstance().post(RxEnum.MAIN_LOAD_CACHE_EX,new LoadCache());
        CacheUtil.get().putMap(CacheUtil.MAIN_WAVE_TIMEBASE_POSITION_NORMAL, String.valueOf(x),true);
        if(bTmpZoom){
            CacheUtil.get().putMap(CacheUtil.MAIN_BOTTOM_SLIP_ZOOM, String.valueOf(bTmpZoom),true);

            Command.get().getDisplay().setRoutineTimeBaseMode(Command_Display.RoutineTimeBaseMode_YT, true);
            Command.get().getDisplay().Zoom(true, false);
            Scope.getInstance().setZoom(true);
            RxBus.getInstance().post(RxEnum.WAVEZONE_DISPLAY_YTZOOM, new YTZoomMsgDisplay(true));
            WorkModeManage.getInstance().setWorkMode(IWorkMode.WorkMode_YTZOOM, false);

            HorizontalAxis horizontalAxis = HorizontalAxis.getInstance();
            horizontalAxis.setTimeScaleIdOfView(HorizontalAxis.WPI_STANDARD, horizontalAxis.timeValtoTimeScaleId(normalScale));
            horizontalAxis.setTimeScaleIdOfView(HorizontalAxis.WPI_LARGE, horizontalAxis.timeValtoTimeScaleId(zoomLargeScale));
        }

        TChan.foreachChan((i) -> {
            Channel channel = ChannelFactory.getDynamicChannel(TChan.toFpgaChNo(i));
            if (channel != null) {
                for (int j = VerticalAxis.getMinGear(); j <= VerticalAxis.getMaxGear(); j++) {
                    int pos = CacheUtil.get().getInt(CacheUtil.MAIN_WAVE_CH_Y_ZERO_POSITION + i + j);
                    channel.setZero(j, pos);
                }
            }
        });

        TChan.foreachMath1ToR8(chan -> {
            String selectColor = CacheUtil.get().getString(CacheUtil.MAIN_CHANNEL_COLOR + chan);
            SvgNodeInfo.setChannelColor(chan, selectColor);//改变颜色值
            RxBus.getInstance().post(RxEnum.MQ_MSG_CHANNEL_SELECT_COLOR, chan + ";" + selectColor);//发消息通知颜色值改变了
        });
//        int pos = 0;
//        Channel channel;
//        for(int i=IWave.Ch1;i<=IWave.Ch4;i++){
//            channel = ChannelFactory.getDynamicChannel(i-IWave.Ch1);
//            if(channel != null) {
//                for (int j = VerticalAxis.getMinGear(); j <= VerticalAxis.getMaxGear(); j++) {
//                    pos = CacheUtil.get().getInt(CacheUtil.MAIN_WAVE_CH_Y_ZERO_POSITION + i + j);
//                    channel.setZero(j, pos);
//                }
//            }
//        }
        if (!isFromRecovery) {//重启之后恢复活动通道
            int recoverySelect = CacheUtil.get().getInt(CacheUtil.MAIN_RECOVERY_CHANNEL_SELECT + "-1");
            RxBus.getInstance().post(RxEnum.MQ_MSG_RECOVERY_SELECT, recoverySelect);
        }

//        if (!runStop) {
//            RxBus.getInstance().post(RxEnum.MAINLEFT_MENU_RUNSTOP, new MainLeftMsgMenuRunStop(MainLeftMsgMenuRunStop.STOP));
//            CacheUtil.get().putMapInForce(CacheUtil.MAIN_LEFT_RUNSTOP, "false");
//        }
        //0010993
        long l = CacheUtil.get().getLong(CacheUtil.MAIN_WAVE_TIMEBASE_POSITION_NORMAL);
        HorizontalAxis horizontalAxis = HorizontalAxis.getInstance();
        horizontalAxis.setTimePosOfView(
                HorizontalAxis.WPI_STANDARD,
                horizontalAxis.getTimePose(HorizontalAxis.WPI_STANDARD, ScopeBase.getWidth() / 2 - l)
        );
//        HorizontalAxis.getInstance().setTimePoseOfViewPix(ScopeBase.getWidth() / 2 - l);
        mScope.setUsersetReset(false);

    }

    /***
     * 等待CacheUtil重新载入【MAIN_LOAD_CACHE】后执行一些功能：比方说启动示波器运行、启动zoom等
     */
    public void postMainLoadCacheProcess() {
        closeSplashActivity();//启动示波器为运行状态，启动zoom状态
    }

    private int drawRefresh = 0;

    class MainHandler extends Handler {
        @Override
        public void handleMessage(Message msg) {
            switch (msg.what) {
                case MSG_SPLASH: {
                    {//zoom的初始化改在了这里，不在loadCache中进行
                        //打个补丁吧，哈哈
                        SplashDialog.get().closeDialog();
                        boolean runStop = CacheUtil.get().getBoolean(CacheUtil.MAIN_LEFT_RUNSTOP);

                        ChannelFactory.forEachCh(channel -> {
                            if(channel.getVerticalMode() == Channel.VERTICAL_MODE_SCREEN_CENTER){
                                channel.setPos(Tools.getYTChannelPosition((channel.getChId() - ChannelFactory.CH1)  + 1));
                            }
                        });
                        ChannelFactory.forEachMath(mathChannel -> mathChannel.setMathType(mathChannel.getMathType()));

                        ChannelFactory.chActivate(ChannelFactory.getChActivate()); //	bug 0006536
                        if(CacheUtil.get().getInt(CacheUtil.TOP_SLIP_DISPLAY_COMMON_TIMEBASE) == 1){
                            Display.getInstance().setDisplayMode(Display.DISPLAY_XY);
                        }

                        if (mScope.isRun() && mScope.isInScrollMode()) {

                            CacheUtil.get().putMap(CacheUtil.MAIN_BOTTOM_SLIP_ZOOM, String.valueOf(false));
                            RxBus.getInstance().post(RxEnum.EXTERNALKEY_TOMCU,
                                    new ExternalKeysMsg_ToMCU(ExternalKeysMsg_ToMCU.TYPE_ZOOM,
                                            ExternalKeysMsg_ToMCU.STATE_LED_OFF));
                        }

                        boolean zoom = CacheUtil.get().getBoolean(CacheUtil.MAIN_BOTTOM_SLIP_ZOOM);
                        if (zoom) {
                            double x =  TBookUtil.getSFromTime(CacheUtil.get().getString(CacheUtil.ZOOM_BOTTOM_TIMEBASE_LARGE_SCALE));
                            HorizontalAxis.getInstance().setTimePoseOfViewPix(0);
                            HorizontalAxis.getInstance().correctTimePose_poseMove();
                            YTZoomMsgDisplay ytZoomMsgDisplay = new YTZoomMsgDisplay(true);
                            ytZoomMsgDisplay.setReloadLargeTimeScale(true);
                            ytZoomMsgDisplay.setPlaySound(false);
                            RxBus.getInstance().post(RxEnum.WAVEZONE_DISPLAY_YTZOOM, ytZoomMsgDisplay);
//                            HorizontalAxis.getInstance().setTimePoseOfViewPix(ScopeBase.getWidth() / 2 - x);
                            HorizontalAxis.getInstance().setTimePosOfView(
                                    HorizontalAxis.WPI_LARGE,
                                    HorizontalAxis.getInstance().getTimePose(HorizontalAxis.WPI_LARGE, (long) (ScopeBase.getWidth() / 2 - x))
                            );
                            HorizontalAxis.getInstance().correctTimePose_poseMove();
                            TriggerTimebase.getInstance().movePix(0);
                        }
//                        if(!mScope.isRun()){
//                            mScope.clearWave();
//                        }
                        Display display = Display.getInstance();
                        display.setCCT(display.isCCT());
                        display.setPersistType(display.getPersistType());
                        mScope.setRun(runStop);
                        mScope.setUI(true);
                        setScreenshotParam();
                        ChannelFactory.forEachCh((channel)->{
                            MainHolderTriggerLevel.changeSerialTrigVol_channel(TChan.toUiChNo(channel.getChId()));
                        });
                        HwManager.setString("app.micsig","2");
                    }
                }
                break;
                case MSG_REDRAWREF: {
                    if (CacheUtil.get().getBoolean(CacheUtil.MAIN_RIGHT_REF)) {
                        RefChannel refChannel;

                        if (CacheUtil.get().getBoolean(CacheUtil.MAIN_CHANNEL_OPEN_STATE+TChan.Ch1)) {

                            ChannelFactory.getRefChannel(ChannelFactory.REF1).setPos(Tools.getYTChannelPosition(TChan.R1));
                        }
                        if (CacheUtil.get().getBoolean(CacheUtil.MAIN_CHANNEL_OPEN_STATE+TChan.Ch2)) {

                            ChannelFactory.getRefChannel(ChannelFactory.REF2).setPos(Tools.getYTChannelPosition(TChan.R2));
                        }
                        if (CacheUtil.get().getBoolean(CacheUtil.MAIN_CHANNEL_OPEN_STATE+TChan.Ch3)) {

                            ChannelFactory.getRefChannel(ChannelFactory.REF3).setPos(Tools.getYTChannelPosition(TChan.R3));
                        }
                        if (CacheUtil.get().getBoolean(CacheUtil.MAIN_CHANNEL_OPEN_STATE + TChan.Ch4)) {
                            ChannelFactory.getRefChannel(ChannelFactory.REF4).setPos(Tools.getYTChannelPosition(TChan.R4));
                        }
                        if (CacheUtil.get().getBoolean(CacheUtil.MAIN_CHANNEL_OPEN_STATE + TChan.Ch5)) {
                            refChannel = ChannelFactory.getRefChannel(ChannelFactory.REF5);
                            if (refChannel == null) return;
                            refChannel.setPos(Tools.getYTChannelPosition(TChan.R5));
                        }
                        if (CacheUtil.get().getBoolean(CacheUtil.MAIN_CHANNEL_OPEN_STATE + TChan.Ch6)) {
                            refChannel = ChannelFactory.getRefChannel(ChannelFactory.REF6);
                            if (refChannel == null) return;
                            refChannel.setPos(Tools.getYTChannelPosition(TChan.R6));
                        }
                        if (CacheUtil.get().getBoolean(CacheUtil.MAIN_CHANNEL_OPEN_STATE + TChan.Ch7)) {
                            refChannel = ChannelFactory.getRefChannel(ChannelFactory.REF7);
                            if (refChannel == null) return;
                            refChannel.setPos(Tools.getYTChannelPosition(TChan.R7));
                        }
                        if (CacheUtil.get().getBoolean(CacheUtil.MAIN_CHANNEL_OPEN_STATE + TChan.Ch8)) {
                            refChannel = ChannelFactory.getRefChannel(ChannelFactory.REF8);
                            if (refChannel == null) return;
                            refChannel.setPos(Tools.getYTChannelPosition(TChan.R8));
                        }

                    }
                }
                break;
                case MSG_REFRESH_WAVE: {
                    if (drawRefresh < 3) {
                        mainHandler.sendEmptyMessageDelayed(MSG_REFRESH_WAVE, 150);
                        drawRefresh++;
                    }
                    mScope.Refresh();
                }
                break;
                case MSG_SAVE_PICTURE:{
                    String picturePath = CacheUtil.get().getOtherString(CacheUtil.TOP_SLIP_SAVE_PICTURE_PATH_CURRENT);
                    String pictureName = getPictureName();
                    doSavePicture(picturePath, pictureName);
                }
                break;
            }
        }
    }

    private String getPictureName() {
        String pictureName = CacheUtil.get().getOtherString(CacheUtil.TOP_SLIP_SAVE_PICTURE_NAME);
        if (pictureName.isEmpty()) {
            pictureName = Tools.generateName();
        }
        boolean isFileNumAddCheck = CacheUtil.get().getOtherBoolean(CacheUtil.TOP_SLIP_SAVE_PICTURE_SUFFIX_CHECK);
        String suffixNum = CacheUtil.get().getOtherString(CacheUtil.TOP_SLIP_SAVE_PICTURE_SUFFIX_CHECK_NUM);
        if (isFileNumAddCheck) {
            pictureName = pictureName + "_" + suffixNum + ".png";
        } else {
            pictureName = pictureName + ".png";
        }
        return pictureName;
    }

    public void autoSaveScreenShot() {
        String picturePath = CacheUtil.get().getString(CacheUtil.TOP_SLIP_SAVE_PICTURE_PATH_AUTO_SAVE);
        String pictureName = CacheUtil.get().getString(CacheUtil.TOP_SLIP_SAVE_PICTURE_AUTO_SAVE_NAME);
        Logger.i(TAG, "screenShot filePath= " + picturePath + " ,fileName= " + pictureName);
        doAutoSavePicture(picturePath, pictureName);
    }


    public void screenShot() {
        String picturePath = CacheUtil.get().getOtherString(CacheUtil.TOP_SLIP_SAVE_PICTURE_PATH_CURRENT);
        String pictureName = getPictureName();
        Logger.i(TAG, "screenShot filePath= " + picturePath + " ,fileName= " + pictureName);

        if (SaveManage.getInstance().checkFileExists(picturePath + File.separator + pictureName)) {
            ((DialogOkCancel) mainViewGroup.getDialog(MainViewGroup.DIALOG_OKCANCEL))
                    .setData(null, R.string.top_slip_save_file_exists, null, null, onOkCancelClickListener);
        } else {
            doSavePicture(picturePath, pictureName);
        }
    }

    private void doSavePicture(String path, String name) {
        keyService.screenshot(CacheUtil.get().getBoolean(CacheUtil.TOP_SLIP_USERSET_TIMESTAMP),
                CacheUtil.get().getBoolean(CacheUtil.TOP_SLIP_USERSET_SCREENINVERT), path, name);

        RxBus.getInstance().post(RxEnum.MQ_MSG_SAVE_CAPTURE_SUCCESS, true);
    }

    private void doAutoSavePicture(String path, String name) {
        keyService.screenshot(CacheUtil.get().getBoolean(CacheUtil.TOP_SLIP_USERSET_TIMESTAMP),
                CacheUtil.get().getBoolean(CacheUtil.TOP_SLIP_USERSET_SCREENINVERT), path, name,true);

    }

    private DialogOkCancel.OnOkCancelClickListener onOkCancelClickListener = new DialogOkCancel.OnOkCancelClickListener() {
        @Override
        public void onOkClick(View v, Object data) {
//            if (v == null || data == null) return;
            String picturePath = CacheUtil.get().getOtherString(CacheUtil.TOP_SLIP_SAVE_PICTURE_PATH_CURRENT);
            String pictureName = getPictureName();
            if (FileUtils.deleteFile(picturePath + File.separator + pictureName)) {
//                doSavePicture(picturePath, pictureName);
                mainHandler.sendEmptyMessageDelayed(MSG_SAVE_PICTURE, 50);
            }
        }

        @Override
        public void onCancelClick(View v, Object data) {
            //Do nothing
            Logger.i("Click cancel");
        }

        @Override
        public void onDialogClose(View view) {
        }
    };

    public void unbindWirelessId(){
        keyService.unbindWirelessId();
    }

    public void sendAutoSave(boolean bAutoSave){
        keyService.sendAutoSave(bAutoSave);
    }

    @Override
    public boolean onKeyDown(int keyCode, KeyEvent event) {
        if (KeyEventUtil.isIgnoreKey(event)) return true;
        if(event.getAction() == KeyEvent.ACTION_DOWN){
            if(event.getScanCode() == 194){
                if(!Scope.getInstance().isStandby()) {
                    ScopeMessage.getInstance().probeEvent();
                }
            }
        }
        return super.onKeyDown(keyCode, event);
    }

    public MTriggerTime getSlider() {
        return slider;
    }

}