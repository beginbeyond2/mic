    private void loadParam(Bundle savedInstanceState) {
        mainViewGroup.initLayout();
//        ViewStub channel4 = (ViewStub) findViewById(R.id.menu_right_channel_number4_viewStub);
//        ViewStub channel2 = (ViewStub) findViewById(R.id.menu_right_channel_number2_viewStub);
