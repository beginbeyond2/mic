public interface ICharacterEncoding {
    /** 十六进制 */
    public static final int Hex=0x16;
    /** 二进制 */
    public static final int Binary=0x02;
    /** 八进制 */
    public static final int Octal =0x08;
    /** 十进制 */
    public static final int Decimal=0x10;
    /** ASCII  */
    public static final int ASCII=0xAC;

}
