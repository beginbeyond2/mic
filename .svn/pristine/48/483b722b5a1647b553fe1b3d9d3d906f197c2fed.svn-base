package com.micsig.tbook.scope.fpga;

import android.content.Context;
import android.os.Build;
import android.os.Environment;
import android.os.Looper;

import com.micsig.tbook.hardware.Hardware;
import com.micsig.tbook.hardware.HardwareProduct;
import com.micsig.tbook.scope.Event.EventBase;
import com.micsig.tbook.scope.Event.EventFactory;
import com.micsig.tbook.scope.R;
import com.micsig.tbook.scope.ScopeMessage;

import java.io.File;
import java.io.FileInputStream;
import java.io.FileNotFoundException;
import java.io.IOException;
import java.io.InputStream;

/**
 * Created by zhuzh on 2018/3/16.
 */

public class FPGABoot {

    private static volatile FPGABoot instance = null;
    public static FPGABoot getInstance(){
        return instance;
    }

    public static FPGABoot getInstance(Context context) {
        if (instance == null) {
            synchronized (FPGABoot.class) {
                if (instance == null && context != null) {
                    instance = new FPGABoot(context);
                }
            }
        }
        return instance;
    }
    public static final int FPGA_TYPE_NONE = -1;
    public static final int FPGA_TYPE_NORMAL = 0;
    public static final int FPGA_TYPE_TXT = 1;
    private boolean fpgaBootOK = false;
    private Context mContext;
    private int fpgaType = FPGA_TYPE_NONE;
    private FPGABoot(Context context){
        mContext = context;
    }
    public int getFpgaType(){
        return fpgaType;
    }
    public void reset(){
        fpgaType = FPGA_TYPE_NONE;
    }

    public void resume(){
        int xType = fpgaType;
        if(xType == FPGA_TYPE_NONE) {
            xType = FPGA_TYPE_NORMAL;
        }
        loadFpga(xType);
    }
    public boolean isFpgaBootOK(){
        return fpgaBootOK;
    }
    public void loadFpga(int fpgaType){
//        if(HardwareProduct.isMHO()){
//            HwDevice hwDevice = DeviceFactory.allocDevice();
//            if(!hwDevice.isOpen()) {
//                hwDevice.openDevice();
//            }
//            setFpgaBootOK(true);
//        }
//        else
        {
            fpgaBootOK = false;
            setFpgaBootOK(fpgaBootOK);
            if (isMainThread()) {
                loadFpgaMainThread(fpgaType);
            } else {
                int ret = EventFactory.EVENT_FPGA_LOAD_ERR;
                if(!fpgaBootOK || this.fpgaType != fpgaType) {
                    if (loadFpgaOtherThread(fpgaType)) {
                        ret = EventFactory.EVENT_FPGA_LOAD_OK;
                    }
                }
                //EventFactory.sendEvent(new EventBase(ret, fpgaType));
            }
        }
    }
    public void setFpgaBootOK(boolean b){
        fpgaBootOK = b;
        EventFactory.sendEvent(new EventBase(EventFactory.EVENT_FPGA_STATUS, fpgaBootOK));
    }

    private boolean loadFpgaMainThread(int fpgaType){
        return ScopeMessage.getInstance().sendFpgaBoot(fpgaType);
    }
    public boolean loadFpgaOtherThread(int fpgaType){
        boolean ret = false;
        InputStream is = getInputStream(fpgaType);
        if(is != null){
            try{
                byte [] fpga = new byte[is.available()];
                int len = is.read(fpga);
                is.close();
                this.fpgaType = FPGA_TYPE_NONE;
                while(!ret){
                    ret = Hardware.getInstance().loadFpgaCode(fpga);
                    if (ret) {
                        this.fpgaType = fpgaType;
                        break;
                    }
                    try {
                        Thread.sleep(1000);
                    } catch (InterruptedException e) {
                        e.printStackTrace();
                    }
                }
            }catch (IOException e){
                e.printStackTrace();
            }
        }
        return ret;
    }
    private InputStream getInputStream(int fpgaType){

        InputStream inputStream = getDebugInputStream(fpgaType);
        if(inputStream == null) {
            int fpga_top_id = R.raw.fpga_top_mho_10008_v2;
            switch (fpgaType) {
                default:
                case FPGA_TYPE_NORMAL:
                    switch (Build.PRODUCT){
                        case HardwareProduct.RK3588_MHO68_V1:
                            fpga_top_id = R.raw.fpga_top_mho_10008;break;
                        case HardwareProduct.RK3588_MHO68_V2:
                            fpga_top_id = R.raw.fpga_top_mho_10008_v2;break;
                        case HardwareProduct.RK3588_MHO38_V1:
                            fpga_top_id = R.raw.fpga_top_mho_38;break;
                        case HardwareProduct.RK3588_MHO28_V1:
                            fpga_top_id = R.raw.fpga_top_mho_28;break;
                    }

                    break;
                case FPGA_TYPE_TXT:
                    switch (Build.PRODUCT){
                        case HardwareProduct.RK3588_MHO68_V1:
                            fpga_top_id = R.raw.fpga_top_txt_mho_10008;break;
                        case HardwareProduct.RK3588_MHO68_V2:
                            fpga_top_id = R.raw.fpga_top_txt_mho_10008_v2;break;
                        case HardwareProduct.RK3588_MHO38_V1:
                            fpga_top_id = R.raw.fpga_top_txt_mho_38;break;
                        case HardwareProduct.RK3588_MHO28_V1:
                            fpga_top_id = R.raw.fpga_top_txt_mho_28;break;
                    }
                    break;
            }
            return mContext.getResources().openRawResource(fpga_top_id);
        }
        return inputStream;
    }
    private boolean isMainThread() {
        return Looper.getMainLooper() == Looper.myLooper();
    }

    private InputStream getDebugInputStream(int fpgaType){
        String path = Environment.getExternalStorageDirectory().toString();
        String fileName = "fpga_debug.bin";
        if (fpgaType == FPGA_TYPE_TXT) {
            fileName = "fpga_debug_txt.bin";
        }
        File f = new File(path + File.separator + "debug" + File.separator + fileName);
        if(f.exists()){
            try {
                return new FileInputStream(f);
            } catch (FileNotFoundException e) {
                e.printStackTrace();
            }
        }
        return null;
    }
}
