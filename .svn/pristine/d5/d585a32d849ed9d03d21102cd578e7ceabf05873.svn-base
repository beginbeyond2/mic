package com.micsig.tbook.tbookscope.top.layout.save;

public class TopMsgSaveWave implements ISaveDetail {
    private boolean[] saveTypeEnable;

    public TopMsgSaveWave(boolean[] saveTypeEnable) {
        this.saveTypeEnable = saveTypeEnable;
    }

    public boolean[] getSaveTypeEnable() {
        return saveTypeEnable;
    }

    public void setSaveTypeEnable(int index, boolean saveTypeEnable) {
        this.saveTypeEnable[index] = saveTypeEnable;
    }

    public void setSaveTypeEnable(boolean[] saveTypeEnable) {
        this.saveTypeEnable = saveTypeEnable;
    }
}
