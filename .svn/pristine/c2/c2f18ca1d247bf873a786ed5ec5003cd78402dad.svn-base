package com.micsig.tbook.scope.Data;

import static com.micsig.tbook.scope.math.MathNative.byteBufferToIntArray;

import android.annotation.SuppressLint;
import android.util.Log;

import com.micsig.tbook.scope.ScopeBase;
import com.micsig.tbook.scope.channel.ChannelFactory;
import com.micsig.tbook.scope.channel.IChannel;
import com.micsig.tbook.scope.mem.Memory;

import java.io.File;
import java.io.FileWriter;
import java.io.IOException;
import java.text.DecimalFormat;
import java.util.ArrayList;
import java.util.Comparator;
import java.util.concurrent.ExecutorService;
import java.util.concurrent.Executors;
import java.util.concurrent.atomic.AtomicBoolean;

public class SaveCsv {
    private static final String TAG = "SaveCsv";
    public interface ISaveCsvProgress{
        void onProgress(int val);
    }
    ISaveCsvProgress saveCsvProgress;

    private static final int MAXS = ChannelFactory.REF_CNT + 4;

    ArrayList<IChannel>[] list = new ArrayList[MAXS];
    ArrayList<WaveData>[] wds = new ArrayList[MAXS];

    boolean bFinish = false;
    int progressVal = -1;

    public int getProgress(){
        return progressVal;
    }
    public boolean isFinish(){
        return bFinish;
    }
    ExecutorService executorService = Executors.newSingleThreadExecutor();

    private static SaveCsv instance;
    public static synchronized SaveCsv getInstance(){
        if(instance == null){
            instance = new SaveCsv();
        }
        return instance;
    }
    private SaveCsv(){
        for(int i=0;i<list.length;i++){
            list[i] = new ArrayList<>();
            wds[i] = new ArrayList<>();
        }
    }
    public void setSaveCsvProgress(ISaveCsvProgress progress){
        this.saveCsvProgress = progress;
    }

    public synchronized void clear(){
        for (ArrayList<IChannel> iChannels : list) {
            iChannels.clear();
        }
        for(ArrayList<WaveData> w :wds){
            w.clear();
        }
        bFinish = false;
        progressVal = -1;
    }
    public static int getChannelType(int chIdx){
        if(ChannelFactory.isDynamicCh(chIdx)){
            return 0;
        }else if(ChannelFactory.isMathCh(chIdx)){
            if(ChannelFactory.isMath_FFT_Ch(chIdx)) {
                return 1;
            }
            return 0;
        }else if(ChannelFactory.isRefCh(chIdx)){
            return 2 + chIdx - ChannelFactory.REF1;
        }
        return -1;
    }

    public synchronized boolean add(IChannel channel){
        if(ChannelFactory.isMath_FFT_Ch(channel.getChId())){
            return false;
        }
        int i = getChannelType(channel.getChId());
        if(i >= 0 &&  i < list.length){
            list[i].add(channel);
        }
        return true;
    }
    public long calcStorageSize(){
        long sum = 0;
        for (ArrayList<IChannel> iChannels : list) {
            if(iChannels.size() > 0){
                long a = 0;
                IChannel channel = iChannels.get(0);
                WaveData waveData = (WaveData) (channel.obtain());
                if (waveData != null) {
                    a = waveData.getWaveLength();
                    channel.recycle(waveData);
                }
                sum += a * (iChannels.size() + 1);
            }
        }
        return sum * 16 + 1024*1024;
    }
    private AtomicBoolean foreStop = new AtomicBoolean(false);
    public void stop(){
        Log.d(TAG, "stop() called");
        foreStop.set(true);
    }

    public void save(String pathName){
        bFinish = false;
        foreStop.set(false);
        executorService.execute(()->{
            synchronized (SaveCsv.this) {
                onProgress(0);
                for (ArrayList<IChannel> iChannels : list) {
                    iChannels.sort(new Comparator<IChannel>() {
                        @Override
                        public int compare(IChannel o1, IChannel o2) {
                            return Integer.compare(o1.getChId(), o2.getChId());
                        }
                    });
                }

                for (int i = 0; i < list.length; i++) {
                    for (int j = 0; j < list[i].size(); j++) {
                        WaveData waveData = (WaveData) (list[i].get(j).obtain());
                        wds[i].add(waveData);
                    }
                }
                boolean b = saveCSV(pathName);

                for (int i = 0; i < list.length; i++) {
                    for (int j = 0; j < list[i].size(); j++) {
                        WaveData waveData = wds[i].get(j);
                        if (waveData != null) {
                            list[i].get(j).recycle(waveData);
                        }
                    }
                }
                onProgress(b ? 100 : -1);
                bFinish = true;
            }
        });
    }


    private static final int CACHE_SIZE = 10 * 1024 * 1024;
    @SuppressLint("DefaultLocale")
    private boolean saveCSV(String pathName) {
        File file = new File(pathName);
        if(file.exists()){
            file.delete();
        }
//        if (!file.exists())
        {
            FileWriter fileWriter = null;
            try {
                if (file.createNewFile()
                        && !foreStop.get()) {
                    fileWriter = new FileWriter(file);
                    StringBuilder stringBuilder = new StringBuilder(CACHE_SIZE + 1024);

                    for (int i = 0; i < WaveData.cvsItem.length; i++) {
                        for(int j=0;j<list.length;j++){
                            if(wds[j].size() > 0) {
                                stringBuilder.append(WaveData.cvsItem[i]).append(",");
                                for (int k=0;k<wds[j].size();k++) {
                                    WaveData w = wds[j].get(k);
                                    if (w != null) {
                                        int chIdx = list[j].get(k).getChId();
                                        stringBuilder.append(w.getCSVItemVal(i,chIdx));
                                    }
                                    stringBuilder.append(",");
                                    if(foreStop.get()){
                                        break;
                                    }
                                }
                                stringBuilder.append(",");
                            }
                            if(foreStop.get()){
                                break;
                            }
                        }
                        stringBuilder.append("\n");
                        if(foreStop.get()){
                            break;
                        }
                    }

                    if(!foreStop.get()) {
                        fileWriter.write(stringBuilder.toString());
                        fileWriter.flush();
                        stringBuilder.setLength(0);

                        int nums = 0;
                        ArrayList<int[]>[] buf = new ArrayList[wds.length];
                        double[] V = new double[wds.length];
                        double[] SampleInterval = new double[wds.length];
                        int[] sampleLength = new int[wds.length];
                        for (int i = 0; i < wds.length; i++) {
                            WaveData w = null;
                            buf[i] = new ArrayList<>();
                            for (int j = 0; j < wds[i].size(); j++) {
                                int[] xb = null;
                                w = wds[i].get(j);
                                if (w != null) {
                                    if (w.getWaveLength() > nums) {
                                        nums = w.getWaveLength();
                                    }
                                    xb = byteBufferToIntArray(w.getDirectBuffer());
                                }
                                buf[i].add(xb);
                                if (foreStop.get()) {
                                    break;
                                }
                            }
                            if (w != null) {
                                V[i] = w.getTimeScaleVal() * ScopeBase.getHorizonGridCnt() / 2 - w.getXPos() / 1e13;
                                SampleInterval[i] = (1.0 / w.getSampRate());
                                sampleLength[i] = w.getWaveLength();
                            }
                            if (foreStop.get()) {
                                break;
                            }
                        }
                        if(!foreStop.get()) {
                            DecimalFormat decimalFormat = new DecimalFormat("0.00000000E00");
                            for (int i = 0; i < nums; i++) {
                                for (int j = 0; j < buf.length; j++) {
                                    if (buf[j].size() > 0) {
                                        if (i < sampleLength[j]) {
                                            stringBuilder.append(decimalFormat.format(i * SampleInterval[j] - V[j]));
                                        }
                                        stringBuilder.append(",");
                                        for (int k = 0; k < buf[j].size(); k++) {
                                            if (i < sampleLength[j]) {
                                                int[] xb = buf[j].get(k);
                                                if (xb != null) {
                                                    WaveData w = wds[j].get(k);
                                                    if (i < xb.length) {
                                                        stringBuilder.append(decimalFormat.format(xb[i] * w.getVerticalPerPix()));
                                                    }
                                                }
                                            }
                                            stringBuilder.append(",");
                                            if(foreStop.get()) {
                                               break;
                                            }
                                        }
                                        stringBuilder.append(",");
                                    }
                                    if (foreStop.get()) {
                                        break;
                                    }
                                }
                                stringBuilder.append("\n");

                                if (stringBuilder.length() >= CACHE_SIZE) {
                                    fileWriter.write(stringBuilder.toString());
                                    stringBuilder.setLength(0);
                                }
                                onProgress(100 * i / nums);
                                if (foreStop.get()) {
                                    break;
                                }
                            }
                            if(!foreStop.get()) {
                                if (stringBuilder.length() > 0) {
                                    fileWriter.write(stringBuilder.toString());
                                }
                                fileWriter.flush();
                            }
                        }
                    }
                }
            } catch (IOException e) {
                e.printStackTrace();
            }finally {
                if(fileWriter != null){
                    try {
                        fileWriter.close();
                    } catch (IOException e) {
                        e.printStackTrace();
                    }
                }
                Memory.Sync();
            }
            if(fileWriter != null){
                if(foreStop.get()){
                    if(file.exists()){
                        file.delete();
                    }
                    foreStop.set(false);
                    return false;
                }
                return true;
            }
        }
        return false;
    }

    private void onProgress(int val){
        if(progressVal != val){
            progressVal = val;
            if(saveCsvProgress != null){
                saveCsvProgress.onProgress(val);
            }
        }
    }

}
