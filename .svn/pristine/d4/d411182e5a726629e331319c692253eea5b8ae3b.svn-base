    }

    public void setWaveTextureView(PreviewTextureView waveTextureView){
        this.waveTextureView=waveTextureView;
    }

    /**
     *  从bmp中返回选择的通道号
     * @param x 点击的位置 X
     * @param y  点击的位置 Y
     * @return  返回通道号  返回-1说明没有选择
     */
    private  int selectCursorByBmp(int x,int y){
        if (!clickSelectEnable) return -1;
        int selectIndex = -1;

        ByteBuffer byteBuffer = this.waveTextureView.getBuffer();
        if(byteBuffer != null && chColorHSV != null){
            int stride = waveTextureView.getStride();
            int T = 0;
            if(WorkModeManage.getInstance().getmWorkMode()==IWorkMode.WorkMode_YTZOOM){
                T = GlobalVar.get().getRectZoom().height();
            }
            selectIndex = selectCursorTobmp(byteBuffer,ScopeBase.getWidth(),ScopeBase.getNewHeight(),stride,x, y+T,T);
            Logger.d(TAG,"selectIndex:" + selectIndex);
        }

        if (selectIndex == TChan.RefActive || selectIndex == TChan.MathActive) selectIndex = getCurCh();

        if (TChan.isChan(selectIndex)) channelWaveManage.setSelectCursor(selectIndex);
        if (TChan.isMathToR8(selectIndex)) mathRefWaveManage.setSelectCursor(selectIndex);
        return selectIndex;
    }
    private  int selectCursorByBmp(int x,int y,int curChan){
        if (!clickSelectEnable) return -1;
        int selectIndex = -1;

        ByteBuffer byteBuffer = this.waveTextureView.getBuffer();
        if(byteBuffer != null){
            int stride = waveTextureView.getStride();
            int T = 0;
            if(WorkModeManage.getInstance().getmWorkMode()==IWorkMode.WorkMode_YTZOOM){
                T = GlobalVar.get().getRectZoom().height();
            }
            selectIndex = selectCursorTobmp(byteBuffer, ScopeBase.getWidth(), ScopeBase.getNewHeight(), stride, x, y + T, T);
        }

        if (selectIndex == TChan.RefActive || selectIndex == TChan.MathActive) selectIndex = getCurCh();

        if (TChan.isChan(selectIndex) && curChan!=selectIndex) channelWaveManage.setSelectCursor(selectIndex);
        if (TChan.isMathToR8(selectIndex) && curChan!=selectIndex) mathRefWaveManage.setSelectCursor(selectIndex);
        return selectIndex;
    }
    /***
     * 如果在波形通道选择器中，没有选到，就在图片中进行选择。
     * @param x
     * @param y
     * @return
     */
    private int selectCursorTobmp(ByteBuffer byteBuffer,int width,int height,int stride,int x, int y,int T) {

        //y=GlobalVar.get().getWaveZoneHeight_Pix(WorkModeManage.getInstance().getmWorkMode())-y;
        int selectIndex = -1;
        int N, S, W, E;
        if (x <= 0 || y <= 0 || x >= width || y >= height) return selectIndex;
        N = S = y;
        E = W = x;
        if (N <= 1) N = 1;
        if (S >= height - 1) S = height - 1;
        if (W <= 1) W = 1;
        if (E >= width - 1) E = height - 1;
        if(S < T) S = T + 1;
        int nums = 0;
        while (N > 1 || S < height - 1 || W > 1 || E < width - 1) {

            if(++nums > 100){
                break;
            }

            if(N < T) N = T + 1;


            if ((selectIndex = cacl_Channel(byteBuffer, stride, N, x)) > 0) return selectIndex;
            if ((selectIndex = cacl_Channel(byteBuffer, stride, S, x)) > 0) return selectIndex;
            if ((selectIndex = cacl_Channel(byteBuffer, stride, y, W)) > 0) return selectIndex;
            if ((selectIndex = cacl_Channel(byteBuffer, stride, y, E)) > 0) return selectIndex;
            if ((selectIndex = cacl_Channel(byteBuffer, stride, N, W)) > 0) return selectIndex;
            if ((selectIndex = cacl_Channel(byteBuffer, stride, N, E)) > 0) return selectIndex;
            if ((selectIndex = cacl_Channel(byteBuffer, stride, S, W)) > 0) return selectIndex;
            if ((selectIndex = cacl_Channel(byteBuffer, stride, S, E)) > 0) return selectIndex;


            N--;
            W--;
            E++;
            S++;
            if (N <= 1) N = 1;
            if (S >= height - 1) S = height - 1;
            if (W <= 1) W = 1;
            if (E >= width - 1) E = width - 1;
        }
        return selectIndex;
    }

    private boolean isRef(int idx){
       return  idx >= IChan.R1.getValue()  && idx <= IChan.R8.getValue();
    }
    private boolean isMath(int idx){
        return  idx >= IChan.Math1.getValue()  && idx <= IChan.Math8.getValue();
    }
    private boolean isCh(int idx){
        return idx >= IChan.CH1.getValue() && idx <= IChan.CH8.getValue();
    }


    private int cacl_Channel(ByteBuffer byteBuffer, int rowWidth, int row, int col) {
        int selectIndex = -1;
        int pix = byteBuffer.getInt((rowWidth * row + col) * 4);
        pix = (pix & 0xFF) << 24 | ((pix >> 8) & 0xFFFFFF);
        if(pix != 0) {
            float[] hsv = {0, 0, 0};
            Color.colorToHSV(pix, hsv);
//            Logger.d(TAG,"pix:" + Integer.toHexString(pix&0xFFFFFF) + ",h:"
//                    + hsv[0] + ",s:" + hsv[1] + ",v:" + hsv[2]);
            if (hsv[2] > 0.3 && hsv[1] > 0.3){
                for(int i=0;i<chColorHSV.length;i++){
//                    Logger.d(TAG,"i:" + i + ",h:" + chColorHSV[i][0] + ",s:" + chColorHSV[i][1] + ",v:" + chColorHSV[i][2]);
                    if(Math.abs(hsv[0] - chColorHSV[i][0]) < 3){
                        if(isCh(i)){
                            return TChan.Ch1 + i;
                        }else {
                            int idx = SvgNodeInfo.getHsv2Ch(hsv);
                            if(idx > 0){
                                return idx;
                            }
                        }
                    }
                }
            }
        }
        return selectIndex;
    }




    public void refresh(){
        channelWaveManage.refresh();
        mathRefWaveManage.refresh();
    }

