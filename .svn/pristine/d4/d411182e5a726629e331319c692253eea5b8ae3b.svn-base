        synchronized (this) {
            if (channelWaveManage.isSelected() != -1) {
                //canvas.drawBitmap(bmp, 0, 0, false);
                mathRefWaveManage.draw(canvas);
                channelWaveManage.draw(canvas);
            } else {
                //canvas.drawBitmap(bmp, 0, 0, false);
                channelWaveManage.draw(canvas);
                mathRefWaveManage.draw(canvas);
            }
        }
    }

