    public WaveManage_YT(IWave.OnMovingWaveEvent onMovingWaveEvent, IWave.OnSelectChangeEvent onSelectChangeEvent) {
        initResBmp();

        channelWaveManage = new ChannelWaveManage_YT(resBmp, onMovingWaveEvent, onSelectChangeEvent);
        mathRefWaveManage = new MathRefWaveManage(resBmp, onMovingWaveEvent, onSelectChangeEvent);

    }

    private void handleColor() {
        System.arraycopy(SvgNodeInfo.getColorsIntForView(), 0, chArrayColorId, 0, 24);
        int color;
        float[] hsv = {0, 0, 0};
        chColorHSV = new float[chArrayColorId.length][hsv.length];
        for (int i = 0; i < chArrayColorId.length; i++) {
            color = chArrayColorId[i];
            Color.colorToHSV(color, hsv);
            System.arraycopy(hsv, 0, chColorHSV[i], 0, hsv.length);
        }
    }

    public void setWaveChange(int height) {
        channelWaveManage.setWaveChange(height);
        mathRefWaveManage.setWaveChange(height);
        SerialBusManage.getInstance().changeSerialRect();
        refresh();
    }

    public void changeColor(int chIndex, String colorStr) {
        if (!TChan.isCh1ToR8(chIndex)) return;
        resBmp[chIndex][0] = SvgManager.createSvg(SvgNodeInfo.getStandardPath(chIndex), SvgNodeInfo.getNColors(chIndex), 32, 24);
        resBmp[chIndex][1] = SvgManager.createSvg(SvgNodeInfo.getDownPath(chIndex), SvgNodeInfo.getNColors(chIndex), 24, 32);
        resBmp[chIndex][2] = SvgManager.createSvg(SvgNodeInfo.getUpPath(chIndex), SvgNodeInfo.getNColors(chIndex), 24, 32);
        resBmp[chIndex][3] = SvgManager.createSvg(SvgNodeInfo.getStandardPath(chIndex), SvgNodeInfo.getSColors(chIndex), 32, 24);
        resBmp[chIndex][4] = SvgManager.createSvg(SvgNodeInfo.getDownPath(chIndex), SvgNodeInfo.getSColors(chIndex), 24, 32);
        resBmp[chIndex][5] = SvgManager.createSvg(SvgNodeInfo.getUpPath(chIndex), SvgNodeInfo.getSColors(chIndex), 24, 32);
        mathRefWaveManage.updateResBmp(chIndex, resBmp);
        handleColor();
    }

