        resBmp[TChan.R6][4] = SvgManager.createSvg(SvgNodeInfo.getDownPath(TChan.R6), SvgNodeInfo.getSColors(TChan.R6), 24, 32);
        resBmp[TChan.R6][5] = SvgManager.createSvg(SvgNodeInfo.getUpPath(TChan.R6), SvgNodeInfo.getSColors(TChan.R6), 24, 32);

        resBmp[TChan.R7][0] = SvgManager.createSvg(SvgNodeInfo.getStandardPath(TChan.R7), SvgNodeInfo.getNColors(TChan.R7), 32, 24);
        resBmp[TChan.R7][1] = SvgManager.createSvg(SvgNodeInfo.getDownPath(TChan.R7), SvgNodeInfo.getNColors(TChan.R7), 24, 32);
        resBmp[TChan.R7][2] = SvgManager.createSvg(SvgNodeInfo.getUpPath(TChan.R7), SvgNodeInfo.getNColors(TChan.R7), 24, 32);
        resBmp[TChan.R7][3] = SvgManager.createSvg(SvgNodeInfo.getStandardPath(TChan.R7), SvgNodeInfo.getSColors(TChan.R7), 32, 24);
        resBmp[TChan.R7][4] = SvgManager.createSvg(SvgNodeInfo.getDownPath(TChan.R7), SvgNodeInfo.getSColors(TChan.R7), 24, 32);
        resBmp[TChan.R7][5] = SvgManager.createSvg(SvgNodeInfo.getUpPath(TChan.R7), SvgNodeInfo.getSColors(TChan.R7), 24, 32);

        resBmp[TChan.R8][0] = SvgManager.createSvg(SvgNodeInfo.getStandardPath(TChan.R8), SvgNodeInfo.getNColors(TChan.R8), 32, 24);
        resBmp[TChan.R8][1] = SvgManager.createSvg(SvgNodeInfo.getDownPath(TChan.R8), SvgNodeInfo.getNColors(TChan.R8), 24, 32);
        resBmp[TChan.R8][2] = SvgManager.createSvg(SvgNodeInfo.getUpPath(TChan.R8), SvgNodeInfo.getNColors(TChan.R8), 24, 32);
        resBmp[TChan.R8][3] = SvgManager.createSvg(SvgNodeInfo.getStandardPath(TChan.R8), SvgNodeInfo.getSColors(TChan.R8), 32, 24);
        resBmp[TChan.R8][4] = SvgManager.createSvg(SvgNodeInfo.getDownPath(TChan.R8), SvgNodeInfo.getSColors(TChan.R8), 24, 32);
        resBmp[TChan.R8][5] = SvgManager.createSvg(SvgNodeInfo.getUpPath(TChan.R8), SvgNodeInfo.getSColors(TChan.R8), 24, 32);


        handleColor();
    }

    int[] chArrayColorId = new int[24];
    private float[][] chColorHSV;


