    /***
     * 在波形通道选择器中选择前，先判断通道选择器是否打开。
     * 首先在波形通道选择器中选择，再从图片中进行选择。
     *
     * @param x
     * @param y
     * @return 返回通道号  -1为没有选择
     */
    @Override
    public int selectCursor(int x, int y) {
        int selectIndex = -1;
        selectIndex = channelWaveManage.selectCursor(x, y);
        if (selectIndex < 0) selectIndex = mathRefWaveManage.selectCursor(x, y);
        //if (selectIndex < 0) selectIndex = this.selectCursorTobmp(x, y);
        if (selectIndex < 0) selectIndex = this.selectCursorByBmp(x, y);
        //if (selectIndex != -1) setWaveLayer();

        return selectIndex;
    }
    public int selectCursor(int x,int y,int curChan){
        int selectIndex = -1;
        selectIndex = channelWaveManage.selectCursor(x, y,curChan);
        if (selectIndex < 0) selectIndex = mathRefWaveManage.selectCursor(x, y,curChan);
        if (selectIndex < 0) selectIndex = this.selectCursorByBmp(x, y,curChan);
        return selectIndex;
    }
