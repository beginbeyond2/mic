    }

    private int labelSelectChan = -1;

    public boolean isLabelContains(int x, int y) {
        if (channelWaveManage.contains(x, y) || mathRefWaveManage.contains(x, y)) {
            if (channelWaveManage.contains(x, y)) {
                labelSelectChan = channelWaveManage.getLabelSelectChan();
            }
            if (mathRefWaveManage.contains(x, y)) {
                labelSelectChan = mathRefWaveManage.getLabelSelectChan();
            }
            return true;
        } else {
            return false;
        }
    }

    public int getLabelSelectChan() {
        return labelSelectChan;
    }


    public void changeLabelPos(int selectChan, int x) {
        if (labelSelectChan < 0 ) return;
        channelWaveManage.changeLabelPos(selectChan, x);
        mathRefWaveManage.changeLabelPos(selectChan, x);
    }

