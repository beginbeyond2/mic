package com.micsig.tbook.tbookscope.top.layout.sample;

public class TopMsgSegmentedState {
    private boolean isFromEventBus;
    private boolean isYtMode;
    private boolean isRoll;
    private boolean isTxtSerial;

    public TopMsgSegmentedState(boolean isFromEventBus) {
        this.isFromEventBus = isFromEventBus;
    }

    public boolean isFromEventBus() {
        return isFromEventBus;
    }

    public void setFromEventBus(boolean fromEventBus) {
        isFromEventBus = fromEventBus;
    }

    public boolean isYtMode() {
        return isYtMode;
    }

    public void setYtMode(boolean ytMode) {
        isYtMode = ytMode;
    }

    public boolean isRoll() {
        return isRoll;
    }

    public void setRoll(boolean roll) {
        isRoll = roll;
    }

    public boolean isTxtSerial() {
        return isTxtSerial;
    }

    public void setTxtSerial(boolean txtSerial) {
        isTxtSerial = txtSerial;
    }
}
