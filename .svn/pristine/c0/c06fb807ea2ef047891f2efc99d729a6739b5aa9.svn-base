<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android">

    <View
        android:id="@+id/outView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:id="@+id/showKeyBoardLayout"
        android:layout_width="wrap_content"
        android:layout_height="356px"
        android:layout_x="0px"
        android:layout_y="@dimen/rightDialogNumberKeyBoardRow0"
        android:background="@drawable/shape_frame_bg_black"
        android:clickable="true"
        android:orientation="vertical">

        <EditText
            android:id="@+id/show"
            style="@style/editTextStyle"
            android:layout_width="550px"
            android:layout_height="54px"
            android:layout_marginStart="15px"
            android:layout_marginTop="15px"
            android:layout_marginEnd="8px"
            android:gravity="center_vertical|start"
            android:inputType="textNoSuggestions"
            android:maxLines="1" />

        <RelativeLayout
            android:id="@+id/gridView"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginStart="8px"
            android:layout_marginTop="7px"
            android:layout_marginEnd="8px"
            android:layout_marginBottom="8px">

            <Button
                android:id="@+id/key_7"
                style="@style/numberKeyBoardKey"
                android:layout_alignParentStart="true"
                android:layout_alignParentTop="true"
                android:tag="0"
                android:text="7" />

            <Button
                android:id="@+id/key_8"
                style="@style/numberKeyBoardKey"
                android:layout_alignParentTop="true"
                android:layout_toEndOf="@id/key_7"
                android:tag="1"
                android:text="8" />

            <Button
                android:id="@+id/key_9"
                style="@style/numberKeyBoardKey"
                android:layout_alignParentTop="true"
                android:layout_toEndOf="@id/key_8"
                android:tag="2"
                android:text="9" />

            <RadioButton
                android:id="@+id/key_bs"
                style="@style/numberKeyBoardKey"
                android:layout_alignParentTop="true"
                android:layout_toEndOf="@id/key_9"
                android:tag="3"
                android:text="b/s" />

            <RadioButton
                android:id="@+id/key_kbs"
                style="@style/numberKeyBoardKey"
                android:layout_alignParentTop="true"
                android:layout_toEndOf="@id/key_bs"
                android:tag="4"
                android:text="kb/s" />

            <RadioButton
                android:id="@+id/key_Mbs"
                style="@style/numberKeyBoardKey"
                android:layout_alignParentTop="true"
                android:layout_toEndOf="@id/key_kbs"
                android:tag="5"
                android:text="Mb/s" />

            <Button
                android:id="@+id/key_4"
                style="@style/numberKeyBoardKey"
                android:layout_below="@id/key_7"
                android:layout_alignParentStart="true"
                android:tag="6"
                android:text="4" />

            <Button
                android:id="@+id/key_5"
                style="@style/numberKeyBoardKey"
                android:layout_below="@id/key_7"
                android:layout_toEndOf="@id/key_7"
                android:tag="7"
                android:text="5" />

            <Button
                android:id="@+id/key_6"
                style="@style/numberKeyBoardKey"
                android:layout_below="@id/key_7"
                android:layout_toEndOf="@id/key_8"
                android:tag="8"
                android:text="6" />

            <Button
                android:id="@+id/key_A"
                style="@style/numberKeyBoardKey"
                android:layout_below="@id/key_7"
                android:layout_toEndOf="@id/key_9"
                android:tag="9"
                android:text="A" />

            <Button
                android:id="@+id/key_B"
                style="@style/numberKeyBoardKey"
                android:layout_below="@id/key_7"
                android:layout_toEndOf="@id/key_bs"
                android:tag="10"
                android:text="B" />

            <Button
                android:id="@+id/key_del"
                style="@style/numberKeyBoardKey"
                android:layout_below="@id/key_7"
                android:layout_toEndOf="@id/key_kbs"
                android:tag="11"
                android:text="←" />

            <Button
                android:id="@+id/key_1"
                style="@style/numberKeyBoardKey"
                android:layout_below="@id/key_4"
                android:layout_alignParentStart="true"
                android:tag="12"
                android:text="1" />

            <Button
                android:id="@+id/key_2"
                style="@style/numberKeyBoardKey"
                android:layout_below="@id/key_4"
                android:layout_toEndOf="@id/key_7"
                android:tag="13"
                android:text="2" />

            <Button
                android:id="@+id/key_3"
                style="@style/numberKeyBoardKey"
                android:layout_below="@id/key_4"
                android:layout_toEndOf="@id/key_8"
                android:tag="14"
                android:text="3" />

            <Button
                android:id="@+id/key_C"
                style="@style/numberKeyBoardKey"
                android:layout_below="@id/key_4"
                android:layout_toEndOf="@id/key_9"
                android:tag="15"
                android:text="C" />

            <Button
                android:id="@+id/key_D"
                style="@style/numberKeyBoardKey"
                android:layout_below="@id/key_4"
                android:layout_toEndOf="@id/key_bs"
                android:tag="16"
                android:text="D" />

            <Button
                android:id="@+id/key_point"
                style="@style/numberKeyBoardKey"
                android:layout_below="@id/key_1"
                android:layout_alignParentStart="true"
                android:tag="17"
                android:text="." />

            <Button
                android:id="@+id/key_0"
                style="@style/numberKeyBoardKey"
                android:layout_below="@id/key_1"
                android:layout_toEndOf="@id/key_7"
                android:tag="18"
                android:text="0" />

            <Button
                android:id="@+id/key_X"
                style="@style/numberKeyBoardKey"
                android:layout_below="@id/key_1"
                android:layout_toEndOf="@id/key_8"
                android:tag="19"
                android:text="X" />

            <Button
                android:id="@+id/key_e"
                style="@style/numberKeyBoardKey"
                android:layout_below="@id/key_1"
                android:layout_toEndOf="@id/key_9"
                android:tag="20"
                android:text="E" />

            <Button
                android:id="@+id/key_F"
                style="@style/numberKeyBoardKey"
                android:layout_below="@id/key_1"
                android:layout_toEndOf="@id/key_bs"
                android:tag="21"
                android:text="F" />

            <Button
                android:id="@+id/key_Enter"
                style="@style/numberKeyBoardKey"
                android:layout_height="122px"
                android:layout_below="@id/key_4"
                android:layout_toEndOf="@id/key_kbs"
                android:tag="22"
                android:text="Enter" />
        </RelativeLayout>
    </LinearLayout>
</merge>