<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@drawable/layer_screen_shot_disable" android:state_enabled="false" />
    <item android:drawable="@drawable/layer_screen_shot_select" android:state_checked="true" />
    <item android:drawable="@drawable/layer_screen_shot_select" android:state_pressed="true" />
    <item android:drawable="@drawable/layer_screen_shot_select" android:state_selected="true" />
    <item android:drawable="@drawable/layer_screen_shot" />
</selector>