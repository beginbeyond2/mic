<?xml version="1.0" encoding="utf-8"?>

<com.micsig.tbook.tbookscope.rightslipmenu.RightLayoutChannel xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rightslipmenubar_channel1"
    android:layout_width="@dimen/rightSlipChannelWidth"
    android:layout_height="match_parent"
    android:layout_x="@dimen/rightSlipX"
    android:layout_y="@dimen/rightSlipY"
    android:background="@drawable/bg_rightslipmenu"
    android:clickable="true"
    android:elevation="100px"
    android:outlineAmbientShadowColor="@android:color/transparent"
    android:outlineSpotShadowColor="@android:color/transparent"
    android:translationZ="100px"
    app:channelNumber="channel1" />