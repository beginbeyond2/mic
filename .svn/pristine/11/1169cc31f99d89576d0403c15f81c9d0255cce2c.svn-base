package com.micsig.tbook.scope.Auto;


import com.micsig.base.Logger;
import com.micsig.tbook.scope.Calibrate.HwConfig;
import com.micsig.tbook.scope.Scope;
import com.micsig.tbook.scope.Trigger.Trigger;
import com.micsig.tbook.scope.Trigger.TriggerFactory;
import com.micsig.tbook.scope.channel.Channel;
import com.micsig.tbook.scope.channel.ChannelFactory;
import com.micsig.tbook.scope.fpga.FPGA_Status;

import java.util.Arrays;

/**
 * Created by zhuzh on 2018-7-3.
 */

public class EdgeAutoAtion extends AutoAtion {

    AutoChannel [] autoChannels = new AutoChannel[ChannelFactory.CH_CNT];

    private int state = 0;
    private int auto_cnt = 0;


    public EdgeAutoAtion(Auto auto) {
        super(auto);
        ChannelFactory.forEachCh(channel -> {
            autoChannels[channel.getChId()] = new AutoChannel(auto,channel);
        });

    }

    @Override
    public void onModifyVertical(int chIdx) {
        if(ChannelFactory.isDynamicCh(chIdx)){
            autoChannels[chIdx].modifyVertical();
        }
    }

    @Override
    public void onModifyTimebase() {
        Trigger trigger = TriggerFactory.getTriggerObj();
        int chIdx = trigger.getTriggerSource();
        if(ChannelFactory.isDynamicCh(chIdx)){
            autoChannels[chIdx].modifyTimebase();
        }
    }

    @Override
    public void onModifyLevel() {
        Trigger trigger = TriggerFactory.getTriggerObj();
        int chIdx = trigger.getTriggerSource();
        if(ChannelFactory.isDynamicCh(chIdx)){
            autoChannels[chIdx].modifyLevel();
        }
    }



    @Override
    public boolean onAtion(FPGA_Status fpgaStatus) {

        boolean bRet = false;
        if(fpgaStatus.getAuto(0).isVaild()){

            bRet = autoWork(fpgaStatus);

            switch (state){
                case 1:
                    if(!bRet){
                        auto_cnt = 0;
                        state = 2;
                        break;
                    }
                case 0:
                    if(auto.isAutoRangeEnable()){
                        state = 1;
                    }else{
                        if(++auto_cnt >5) {
                            dealTiny();
                            state = 1;
                        }
                    }
                    break;
                case 2:
                    if(++auto_cnt > 5) {
                        if(!auto.isAutoRangeEnable())
                            state = 3;
                        auto_cnt = 0;
                    }
                    break;
            }
            if(auto.isAutoRangeEnable() && isAutoRangeEnd()){
                state = 3;
            }
        }
        return state == 3;
    }

    boolean autoWork(FPGA_Status fpgaStatus){


        boolean [] bRet = new boolean[ChannelFactory.CH_CNT];
        Arrays.fill(bRet,true);
        Scope scope = Scope.getInstance();
        boolean [] sel = new boolean[ChannelFactory.CH_CNT];
        int cnt = scope.getChannelSampOnCnt(true,sel);
        int idx = 0;
        int k = ChannelFactory.CH_CNT / cnt;
        int maxChIdx = ChannelFactory.getMaxChIdx();
        HwConfig hwConfig = HwConfig.getInstance();
        int nums = hwConfig.getAdcMaxChNums();
        int mm = ChannelFactory.CH_CNT / hwConfig.getFpgaNums();
        for(int i=0;i<maxChIdx;i++){
            if(sel[i]){
                if(cnt <= 2){
                    idx = ((i % mm) / nums) * nums + (i / mm) * mm;
                }
                FPGA_Status.FpgaAuto fpgaAuto = null;
                fpgaAuto = fpgaStatus.getAuto(idx);
                bRet[i] = autoChannels[i].autoWork(
                        fpgaAuto.getMinVal(),
                        fpgaAuto.getMaxVal(),
                        fpgaAuto.getCycle()
                );
                idx += k;
            }
        }

        for (boolean v:bRet){
            if(!v){
                return false;
            }
        }
        return true;
    }

    boolean isAutoRangeEnd(){

        Scope scope = Scope.getInstance();
        Trigger trigger = TriggerFactory.getTriggerObj();
        int chIdx = trigger.getTriggerSource();
        boolean[] bEnd = {!(autoChannels[chIdx].isTriggerLevelAuto()
                || autoChannels[chIdx].isHorizontalAuto())};

        if(bEnd[0]) {
            ChannelFactory.forEachCh(channel -> {
                int i = channel.getChId();
                if (scope.isChannelInSample(i)) {
                    bEnd[0] = bEnd[0] && !autoChannels[i].isVerticalAuto();
                }
            });
        }

        return bEnd[0];
    }



    void dealTiny(){

        double MaxPeak = 0;
        int MaxCh = -1;
        double val = 0;
        int cnt = 0;
        //适配外部触发越界问题
        boolean[] off = {false, false, false, false, false, false, false, false, false};
        Scope scope = Scope.getInstance();

        for(int i=0;i<scope.getChNum();i++){
            if(ChannelFactory.isChOpen(i)){
                val = autoChannels[i].getPeakVal();
                if(MaxCh < 0){
                    MaxCh = i;
                    MaxPeak = val;
                }
                if(auto.isAutoChannelEnable()){
                    if(val < auto.getAutoThresholdLevel()){
                        off[i] = true;
                    }else{
                        cnt++;
                    }
                }

                if(auto.getAutoTriggerSource() == 1){
                    Logger.d("i:" + i + "val:" + val + "MaxPeak:" + MaxPeak);
                    if( val > MaxPeak){
                        MaxPeak = val;
                        MaxCh = i;
                    }
                }
            }
        }

        Trigger trigger = TriggerFactory.getTriggerObj();
        int chIdx = trigger.getTriggerSource();
//        if(auto.isAutoChannelEnable())
        {
            if (auto.getAutoTriggerSource() == 1) {
                if(ChannelFactory.isDynamicCh(MaxCh)) {
                    if (chIdx != MaxCh) {
                        trigger.setTriggerSource(MaxCh);
                    }
                    off[MaxCh] = false;
                }
            } else {
                if (cnt == 0) {
                    off[chIdx] = false;
                }
                if (auto.isAutoChannelEnable()) {
                    if (off[chIdx]) {
                        for (int i = 0; i < scope.getChNum(); i++) {
                            if (!off[i]) {
                                trigger.setTriggerSource(i);
                                break;
                            }
                        }
                    }
                }
            }
        }

        boolean bTz = false;
        if(auto.isAutoChannelEnable()) {
            for(int i=0;i<scope.getChNum();i++) {
                if(ChannelFactory.isChOpen(i) && off[i]) {
                    ChannelFactory.chClose(i);
                    bTz = true;
                }
            }
        }

        if(bTz) {
            resetChPos();
        }

    }
}
