    //region interface IWaveShowManage

    @Override
    public int isSelected() {


        for (SerialBus c : mapSerialBus.values()) {
            if(c.isSelected()){
                return c.getLineNameID();
            }
        }
        return -1;
    }

    @Override
    public void setOffsetY(int offsetY) {
        for (SerialBus c : mapSerialBus.values()) {
            if (c.isSelected() == true) {
                c.setY(c.getY() - offsetY);
            }
        }
    }

    public void setPositionY(int serialsId, double position) {
        for (SerialBus c : mapSerialBus.values()) {
            if (c.getLineNameID() == serialsId) {
                c.setY(position);
                break;
            }
        }
    }

    @Override
    public void draw(Canvas canvas) {

    }

    @Override
    public void draw(ICanvasGL canvas) {
        for (SerialBus c : mapSerialBus.values()) {
            c.draw(canvas);
        }
    }

