    //region 私有变量
    public class DataBean{
        private ByteBuffer SerialByteBuffer=ByteBuffer.allocate(1024*1024);
        private long timeToPix;
        private int startX,endX;
    }

    private Object lock=new Object();
    private Map<Integer, SerialBus> mapSerialBus = new HashMap<>();
//    private ByteBuffer serialByteBufferS1 = ByteBuffer.allocate(1024 * 1024);
//    private ByteBuffer serialByteBufferS2 = ByteBuffer.allocate(1024 * 1024);
