            channel = ChannelFactory.getDynamicChannel(i);
            if (channel != null) {
                val = channel.getResistanceType();
                regResistance.setResistance(i - beginIdx, val);
                regResistance.setResistanceSel(i - beginIdx, 0);
//                dang = CabteRegister.getRatioIdx(channel.getResistanceType(),channel.getVScaleVal() / channel.getProbeRate());
//                if (channel.getResistanceType() == Channel.RESISTANCE_50) {
//                    if (dang == CabteRegister.RATIO_DANG_1) {
//                        if (i > ChannelFactory.CH4) {
//                            regResistance.setResistanceSel(i - beginIdx, 1);
//                        }
//                    }
//                }
            }
        }
        TriggerCommon triggerCommon = TriggerFactory.getInstance().getTriggerCommon();
        regResistance.setExtTrigger(triggerCommon.getExtTriggerInputRes());
        sendCmd(regResistance);
    }

    public void ChangeProbeDa(int fpgaIdx) {
        FPGAReg_PROBE_DA12 regProbeDa12 =
                (FPGAReg_PROBE_DA12) getFPGAReg(fpgaIdx, FPGAReg.FPGA_PROBE_DA12);
        Channel channel;
        int beginIdx = beginChIdx(fpgaIdx);
        int endIdx = endChIdx(fpgaIdx);
        for (int i = beginIdx; i < endIdx; i++) {
            channel = ChannelFactory.getDynamicChannel(i);
            if (channel != null) {
                BaseProbe baseProbe = channel.getProbe();
                if (baseProbe != null && baseProbe.isDa()) {
                    Log.d(TAG,"zhuzh" + ",ch:" + i  +",daVal:" +  baseProbe.getDaValue());
                    regProbeDa12.setDaValue(i - beginIdx, baseProbe.getDaValue());
                } else {
                    regProbeDa12.setDaValue(i - beginIdx, 0);
                }
            }
        }

        sendCmd(regProbeDa12);

    }

    public void sendFpga_gain_bc(int fpgaIdx, float[] pgain_bc) {
        // 发送增益补偿系数给fpga
        short[] bc = {0, 0, 0, 0};
        FPGAReg reg = new FPGAReg(FPGAReg.FPGA_GAIN_BC_AD, 2 * 4);
        reg.setFpgaIdx(fpgaIdx);
        for (int i = 0; i < bc.length; i++) {
            short ix = (short) (pgain_bc[i] * 4096 + 0.5);
            if (ix < 4096) ix = 4096;
            bc[i] = ix;
        }
        reg.setVal(bc);
        sendCommand(reg);
    }

    static int[] Val0x31_last = {-1, -1};
    static int[] Val0x3A_last = {-1, -1};
    static int[] Val0x3B_last = {-1, -1};
    static int[] cnt_last = {-1, -1};
    static boolean[] sampleChState = {false,false,false,false,false,false,false,false};

    public boolean SendAdc_ch_change(int fpgaIdx) {
        if(!scope.isRun()){
            return false;
        }

        boolean[] sle = new boolean[ChannelFactory.CH_CNT];
        int cnt = scope.getChannelSampOnCnt(scope.isRun(true), sle);

        boolean bChange = false;
        for (int i = 0; i < sle.length; i++) {
            if (sampleChState[i] != sle[i]) {
                bChange = true;
                break;
            }
        }
        System.arraycopy(sle, 0, sampleChState, 0, sle.length);
        if (bChange) {
            ChannelHardw channelHardw = ChannelHardw.getInstance();
            if(adc.isChChangeReset()) {

                for (int i = 0; i < fpgaNums; i++) {
                    cmdFpgaPause(i);
                    resetChOffset(i);
                }
                channelHardw.ChPowerEnable(false);
                ms_sleep(10);
                adc.setChannel(cnt, sle);
                channelHardw.ChPowerEnable(true);
                channelHardw.wrte_ad_gain(1);
                channelHardw.wrte_ad_gain(0);
                adc.setCalibrate();
                channelHardw.changeChVolScale();
                for (int i = 0; i < fpgaNums; i++) {
                    gntR_ChOffsetDa(i);
                }

                cmdDevice(100);
                cmdFpgaResume(1);
                cmdFpgaResume(0);

            }else {
                adc.setChannel(cnt, sle);
                channelHardw.wrte_ad_gain(fpgaIdx);
                adc.setCalibrate();
            }
            cmdChNoise(fpgaIdx);
        }
        return bChange;
    }

