    public void ExtTriggerLevel(int fpgaIdx){
        FPGAReg_ExtTriggerLevel level = (FPGAReg_ExtTriggerLevel)getFPGAReg(fpgaIdx,FPGAReg.FPGA_EXT_GRIGGER_LEVEL);
        TriggerCommon triggerCommon = TriggerFactory.getInstance().getTriggerCommon();
        int tempVal = (int) Math.round(triggerCommon.getExtTriggerLevel() * 65536 / 5);
        if (tempVal >= 65536) {
            tempVal = 65535;
        }
        level.setLevel(tempVal);
        sendCmd(level);
    }

