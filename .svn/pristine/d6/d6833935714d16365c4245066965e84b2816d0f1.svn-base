    int debugPGA = -1;
    public void setDebugPGA(int val){
        debugPGA = val;
    }
    public void SendAD8370Data(int fpgaIdx, int[] val) {
        if(BuildConfig.DEBUG) {
            if (debugPGA > 0) {
                Arrays.fill(val, debugPGA);
            }
        }
        StringBuilder str = new StringBuilder();
        for (int j : val) {
            str.append(Integer.toHexString(j & 0xFFFF));
            str.append(",");
        }
        Log.d("MHO38V1", "fpgaIdx:" + fpgaIdx + ",pga val:" + str);

        FPGAReg_SPI_EXT reg = (FPGAReg_SPI_EXT) getFPGAReg(fpgaIdx, FPGAReg.FPGA_SPI_EXT);
        reg.setType(FPGAReg_SPI_EXT.SPI_EXT_CHGAIN);
        reg.setDataLength(4);
        reg.setByteValid(0);
        reg.setVGAIdx(0);
        reg.setCh(0xF);
        for (int i = 0; i < val.length; i++) {
            reg.setVal(1 + i, val[i]);
        }
        sendCommand(reg);
    }
    public void SendChPD(int pdVal){
        //Log.d("MHO68V2", "SendChPD() called with: pdVal = [" + Integer.toHexString(pdVal) + "]");

        SendChPD(0,(pdVal & 0xF) | (pdVal>>12) & 0xF0);
        SendChPD(1,((pdVal>>4) & 0xF) | (pdVal>>16) & 0xF0);
    }
    public void SendChPD_v2(long pdVal){
        Log.d("MHO68V2", "SendChPD_v2() called with: pdVal = [" + Long.toHexString(pdVal) + "]");
        SendChPD(0,(int)(pdVal & 0xFFFFFFFFL));
        SendChPD(1,(int)((pdVal >> 32) & 0xFFFFFFFFL));
    }
    public void SendChPD(int fpgaIdx,int val){
        Log.d(TAG, "SendChPD() called with: fpgaIdx = [" + fpgaIdx + "], val = [" + Integer.toHexString(val & 0xFF) + "]");
        FPGAReg_SPI_EXT reg = (FPGAReg_SPI_EXT) getFPGAReg(fpgaIdx,FPGAReg.FPGA_SPI_EXT);
        reg.setType(FPGAReg_SPI_EXT.SPI_EXT_CHPD);
        reg.setDataLength(1);
        reg.setByteValid(0);
        reg.setVal(1,val);
        sendCommand(reg);
    }
    public void SendClkInOut(int fpgaIdx,int val){

        Log.d(TAG, "SendClkInOut() called with: val = [" + Integer.toHexString(val&0xFFFFFFFF) + "]");
