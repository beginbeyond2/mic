    public void cmdFpgaGetData(int fpgaIdx) {

        int ch = 0;
        int status = 0;
        long num = 0;
        SaveBin bin = SaveBin.getInstance();

        ch = bin.getChIdx();
        if(chIdxToFpgaIdx(ch) != fpgaIdx){
            return;
        }


        status = bin.getStatus();
        num = bin.getNums();

        FPGAReg_SEGMENT_NUMS regNums = new FPGAReg_SEGMENT_NUMS();
        FPGAReg_SEGMENT_START regStart = new FPGAReg_SEGMENT_START();
        regNums.setFpgaIdx(fpgaIdx);
        regStart.setFpgaIdx(fpgaIdx);
        int n = 1;
        int segmentLen = bin.getSegmentspace();

        if (segmentLen > SaveBin.MAX_GET_VAL) {
            n = 1;
        } else {
            n = (int) num / segmentLen;
            if (num % segmentLen > 0) {
                n++;
            }
            segmentLen *= n;
        }
        regStart.setVal(0, bin.getSegmentIdx());
        regNums.setVal(0, n);
        sendCommand(regStart);
        sendCommand(regNums);

        if (scope.isSegmentEnable(scope.isRun(true))) {
            if (num > segmentLen) {
                num = segmentLen;
            }
        }
        this.updataRegEx(fpgaIdx);

        Logger.d(
                TAG,
                "num:"
                        + num
                        + ",segmentLen:"
                        + segmentLen
                        + ",idx:"
                        + bin.getSegmentIdx()
                        + ",n:"
                        + n);
        FPGAReg_GET_DATA reg = new FPGAReg_GET_DATA();
        boolean[] sle = new boolean[ChannelFactory.CH_CNT];
        int cnt = scope.getChannelSampOnCnt(scope.isRun(true), sle);
        switch (cnt) {
            case 2:
                ch = 0;
                break;
            case 4:
                if(HardwareProduct.isMHO68V1()){
                    ch = ch % 2;
                }else {
                    ch = (ch % 4) / 2;
                }
                break;
            default:
                break;
        }
        reg.setFpgaIdx(fpgaIdx);
        reg.setReg(ch % 4, status, (int) num);

        sendCommand(reg);
    }

    public void cmdTrigOffset(int fpgaIdx) {

        int cnt = 0;
        cnt = (int) (1e6 / Scope.getInstance().maxSampClk() + 0.1);
        int dang = 0;
        for (int i = 0; i < ChannelFactory.CH_CNT; i++) {
            Channel channel = ChannelFactory.getDynamicChannel(i);
            FPGAReg_TRIG_OFFSET fpgaReg_trig_offset = new FPGAReg_TRIG_OFFSET(FPGAReg.FPGA_TRIG_OFFSET1 + i);
            if (channel != null) {
                int xd = 0;
                dang = CabteRegister.getRatioIdx(channel.getResistanceType(),channel.getVScaleVal()/channel.getProbeRate());
                if(HardwareProduct.isMHO68V1()){
                    if (channel.getResistanceType() == Channel.RESISTANCE_1M) {
                        switch (dang) {
                            case HW.RATIO_DANG_1:
                                xd = 0;
                                break;
                            case HW.RATIO_DANG_3:
                            case HW.RATIO_DANG_2:
                            case HW.RATIO_DANG_4:
                                xd = -2666;
                                break;
                        }
                    } else {
                        xd = 667;
                    }
                }else if(HardwareProduct.isMHO68V2()) {
                    if (channel.getResistanceType() == Channel.RESISTANCE_1M) {
                        switch (dang) {
                            case HW.RATIO_DANG_1:
                                xd = 0;
                                break;
                            case HW.RATIO_DANG_3:
                            case HW.RATIO_DANG_2:
                                xd = -2666;
                                break;
                        }
                    } else {
                        xd = 667;
                    }
                }

//                Log.d(TAG,"chid:" + channel.getChId() + ",xd:" + xd);
                int delay = channel.getDelay() + xd;
                int n = delay / cnt;
                int m = delay % cnt;
                if (m > 0) {
                    n += 1;
                    m = cnt - Math.abs(m);
                } else {
                    m = Math.abs(m);
                }
                fpgaReg_trig_offset.setChOffset(i, n, m * 100 / cnt);
            }
            if (fpgaReg_trig_offset.getFpgaIdx() != fpgaIdx) {
                fpgaReg_trig_offset.setFpgaIdx(fpgaIdx);
            }
            sendCommand(fpgaReg_trig_offset);
        }
    }

    public void setDataFreq(int fpgaIdx, int bmpFreq, int waveFreq) {

        FPGAReg_SIGNAL_FREQ regSignalFreq =
                (FPGAReg_SIGNAL_FREQ) getFPGAReg(fpgaIdx, FPGAReg.FPGA_SIGNAL_FREQ);
        regSignalFreq.setSignalFreq(60, 60);
//        if (!HardwareProduct.isMHO())
        {
            sendCommand(regSignalFreq);
        }
    }

    public void setChNosie(int fpgaIdx,int [] val){
        FPGAReg_SIGNAL_FREQ regSignalFreq =
                (FPGAReg_SIGNAL_FREQ) getFPGAReg(fpgaIdx, FPGAReg.FPGA_SIGNAL_FREQ);
        for(int i=0;i<val.length;i++) {
            regSignalFreq.setChNosie(i, val[i]);
        }
        sendCommand(regSignalFreq);
    }
}
