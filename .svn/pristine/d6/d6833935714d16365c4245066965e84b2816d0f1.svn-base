    public void gntR_trigCouple(int fpgaIdx) {

        FPGAReg_TRIG_COUPLE reg =
                (FPGAReg_TRIG_COUPLE) getFPGAReg(fpgaIdx, FPGAReg.FPGA_TRIG_COUPLE);

        TriggerEdge triggerEdge =
                (TriggerEdge) TriggerFactory.getInstance().getTrigger(Trigger.TRIG_TYPE_EDGE);

        int[] coef_fpga = null;
        reg.setVal(0, 0);
        switch (triggerEdge.getTriggerCouple()) {
            case TriggerEdge.COUPLING_DIRECT: // 直流耦合
                coef_fpga = null;
                reg.setDC(1);

                break;
            case TriggerEdge.COUPLING_AC: // 交流耦合
                coef_fpga = cnTrigCoup_AC;
                reg.setAC(1);
                break;
            case TriggerEdge.COUPLING_HFRS: // 高频抑制
                coef_fpga = cnTrigCoup_HFRS;
                reg.setHig(1);
                break;
            case TriggerEdge.COUPLING_LFRS: // 低频抑制
                coef_fpga = cnTrigCoup_LFRS;
                reg.setLow(1);
                break;
            case TriggerEdge.COUPLING_NOISERS: // 噪声抑制
                coef_fpga = cnTrigCoup_NOISERS;
                reg.setNoi(1);
                break;
            default:
                coef_fpga = null;
                break;
        }
        sendCommand(reg);
        /*
        if (coef_fpga != null) {
            FPGAReg regx = new FPGAReg(FPGAReg.FPGA_COUP_COEF, 20);
            regx.setVal(coef_fpga);
            sendCommand(regx);
        }
         */
    }

    private boolean isChOpen(int chIdx) {
        Scope scope = Scope.getInstance();
        Channel channel = ChannelFactory.getDynamicChannel(chIdx);
        if (channel != null) {
            if (scope.isRun(true)) {
                return channel.isOpen();
            } else {
                return ScopeFrozen.getInstance().isChSamped(chIdx) && channel.isOpen();
            }
        }
        return false;
    }

    public void disDianZhengTuCheng(int fpgaIdx) {

        Scope scope = Scope.getInstance();
        FPGAReg_CH_DISPLAY chDisplayReg =
                (FPGAReg_CH_DISPLAY) getFPGAReg(fpgaIdx, FPGAReg.FPGA_CH_DISPLAY);
        Channel channel;
        int beginIdx = beginChIdx(fpgaIdx);
        int endIdx = endChIdx(fpgaIdx);
        for (int i = beginIdx; i < endIdx; i++) {
            chDisplayReg.setChEnable(i - beginIdx, 0);
        }
        boolean[] sle = new boolean[ChannelFactory.CH_CNT];
        int ChOpenCnt = scope.getChannelSampOnCnt(scope.isRun(true), sle);
        switch (ChOpenCnt) {
            case 4:
            case 2:
                {
                    int k = 0;
                    for (int i = beginIdx; i < endIdx; i++) {
                        if (sle[i]) {
                            if (isChOpen(i)) {
                                chDisplayReg.setChEnable(k, 1);
                                if (k == 0) chDisplayReg.setCh1Color(i - beginIdx);
                                else chDisplayReg.setCh2Color(i - beginIdx);
                            }
                            k++;
                        }
                    }
                    break;
                }

            case 8:
            default:
                {
                    for (int i = beginIdx; i < endIdx; i++) {
                        if (sle[i] && isChOpen(i)) {
                            chDisplayReg.setChEnable(i - beginIdx, 1);
                        }
                    }
                    break;
                }
        }

        // 反向
        int bitsWidth;
        int bitsVal;

        int val;
        int startBit = 0;

        switch (ChOpenCnt) {
            case 2:
                bitsWidth = 2;
                bitsVal = 0x03;
                break;
            case 4:
            case 8:
            default:
                bitsWidth = 1;
                bitsVal = 0x01;
                break;
        }

        for (int i = beginIdx; i < endIdx; i++) {
            if (sle[i]) {
                channel = ChannelFactory.getDynamicChannel(i);
                if (channel != null) {
                    val = channel.isInvert() ? bitsVal : 0;
                    chDisplayReg.setVal(16 + startBit, bitsWidth, val);
                    startBit += bitsWidth;
                }
            }
        }

        sendCommand(chDisplayReg);
    }

    private void huidu_yingse(int fpgaIdx, int light) {
        int high = 200;
        int low = 150 * light / 100;
        int max1 = 25 * 2048 / 255;
        int min1 = 1;

        high = 200 + 40 * light / 100;
        low = (150 + 50 * light / 100) * light / 100;
        max1 = 25 * 2047 / 255;
        if (light < 20) max1 = max1 + (20 - light) * 1024 / 20;

        FPGAReg xreg = new FPGAReg(FPGAReg.FPGA_GRAY_LEVEL, 2048);
        xreg.setFpgaIdx(fpgaIdx);
        for (int n = 0; n < 2048; n++) {
            double temp = n + 1;
            if (temp < min1) temp = temp * low / min1;
            else if (temp < max1) temp = low + (high - low) * (temp - min1) / (max1 - min1);
            else temp = high + (255 - high) * (temp - max1) / (2048 - max1);
            xreg.byteBuffer.put(n + FPGAReg.FPGA_REG_HEADER_LEN, (byte) Math.round(temp));
        }

        sendCommand(xreg);
    }

    public void gntR_disMode(int fpgaIdx) {
        Display display = Display.getInstance();
        FPGAReg_DIS_MODE reg = (FPGAReg_DIS_MODE) getFPGAReg(fpgaIdx, FPGAReg.FPGA_DIS_MODE);

        int beginIdx = beginChIdx(fpgaIdx);
        int endIdx = endChIdx(fpgaIdx);
        int cnt = scope.getChannelSampOnCnt(scope.isRun(true));

        switch (cnt) {
            case 2:
                reg.setChNum(0);
                break;
            case 4:
                reg.setChNum(2);
                break;
            case 8:
            default:
                reg.setChNum(4);
                break;
        }
        for (int i = beginIdx; i < endIdx; i++) {
            reg.setChValid(i - beginIdx, scope.isChannelInSample(i, scope.isRun(true)));
        }
        reg.setMaxGray(255);
        reg.setZoom(display.isZoom() ? 1 : 0);
        reg.setNeedStaticBitBuf(1);

        reg.setNeedStaticWave(isCalibrate() ? 1 : 0);
        reg.setDisType(display.getDrawType() == Display.DRAWTYPE_DOTS ? 1 : 0);
        disDianZhengTuCheng(fpgaIdx);

        sendCommand(reg);

        huidu_yingse(fpgaIdx, Display.getInstance().getBrightness());

        FPGAReg_DISP_RESOLUTION r =
                (FPGAReg_DISP_RESOLUTION) getFPGAReg(fpgaIdx, FPGAReg.FPGA_DISP_RESOLUTION);
        r.setWidth(ScopeBase.getWidth());
        r.setHeight(ScopeBase.getHeight());
        sendCommand(r);

        cmdTrigOffset(fpgaIdx);
    }
    public void gntR_yuHui(int fpgaIdx) {
        //临时配合tBookMini网表，smart就没有这个参�?

        FPGAReg regx = new FPGAReg(FPGAReg.FPGA_DISP_YUHUI, 4);
        Display display = Display.getInstance();
        regx.setFpgaIdx(fpgaIdx);
        if (display.getPersistType() == Display.PERSIST_TYPE_NONE) {
            regx.setVal(0, 32, 1 << 15);
        } else {
            regx.setVal(0, 32, 0);
        }

        sendCommand(regx);
    }

    public int num_chazhi(double chaZhiNumIn, int[] chaZhiNumOut) {
        if (chaZhiNumIn < 0.999) {
            if (chaZhiNumOut[0] != 0) chaZhiNumOut[0] = 0;
            return 0;
        }

        // printf("chazhiNumIn=%f\n", chaZhiNumIn);

        // 处理带小数的插值倍数
        long k = (long) (chaZhiNumIn * 100 + 0.01);
        int base = 1;
        if (k % 100 != 0) {
            k *= 2;
            base = 2;
            if (k % 100 != 0) {
                k *= 2;
                base = 4;
                if (k % 100 != 0) {
                    k *= 2;
                    base = 8;
                    if (k % 100 != 0) {
                        Log.e(TAG, "!!!!chaZhi error,chaZhiNumIn=" + chaZhiNumIn + ",k:" + k );
                        return  0;
                    }
                }
            }
        }

        k /= 100;

        // 处理8倍�?0倍和80倍插值，处理后每�?.25个数�?
        int len = ScopeBase.getWidth() * base;
        if (k % 8 == 0) {
            k = k * 5 / 4;
            len = len * 5 / 4;
        }

        if (k > 100) {
            k = 0;
            len = 0;
        }
        if (chaZhiNumOut[0] != 0) chaZhiNumOut[0] = (int) k;
        return len;
    }

    public void gntR_Dis(int fpgaIdx) {
        gntR_Dis(fpgaIdx, scope.isRun(true), 0);
    }

    private boolean bPrintf = true;

    public void gntR_Dis(int fpgaIdx, boolean isRun, int screenNum) {
        if (bPrintf) Logger.i("=============gntR_Dis()=======start===>");
        Logger.i("isRun:" + isRun + " screenNum:" + screenNum);
        Display display = Display.getInstance();
        Scope scope = Scope.getInstance();

        ScopeFrozen scopeFrozen = ScopeFrozen.getInstance();
        long zunDepth = scope.zunMemDepth(isRun);
        double num1 = scope.screenNum_Main(isRun);
        if (screenNum == 1) num1 = 1;
        int x0 = ScopeBase.getWidth();
        double num2 = 1;
        boolean zoom = display.isZoom();
        if (zoom) {
            num2 = scope.screenNum_zoom(isRun);
            if (screenNum == 1) num2 = 1;
        }

        double cols1, cols2; // 存储深度对应的总列�?
        cols1 = num1 * x0;
        cols2 = num2 * x0;
        if (cols1 < 1.0) cols1 = 1.0;
        if (cols2 < 1.0) cols2 = 1.0;
        if (bPrintf) {
            Logger.i("x0:" + x0 + " zoom:" + zoom + " zunDepth:" + zunDepth);
            Logger.i("num1:" + num1 + " num2:" + num2 + " cols1:" + cols1 + " cols2:" + cols2);
        }

        num2 *= num1;
        cols2 *= num1;

        // 1. 插值计算----------------------------------------------------------------------------------
        // 计算每列有多少组数据
        // 在zoom模式，只有放大窗口需要插值，缩略窗口不需要插�?
        double lie = 0;

        int[] chaZhiNum = {1}; // 插值倍数（最终结果）
        int noDisp = 0;
        FPGAReg_DISP_CHA disChaZhiReg =
                (FPGAReg_DISP_CHA) getFPGAReg(fpgaIdx, FPGAReg.FPGA_DISP_CHA1);
        disChaZhiReg.setNeedChaZhi(0);

        if (!isRun && !ScopeFrozen.getInstance().isValid()) {
            noDisp = 1;
        } else {
            double temp; // 插值倍数
            if (zoom) {
                temp = (num2 * x0) / zunDepth;
            } else {
                temp = (num1 * x0) / zunDepth;
            }

            if (bPrintf) Logger.i("chaZhiRateTemp:" + temp);

            if (temp > 1.001) {
                double c = temp;
                double [] r={1.6,3.2,160};
                for (double v: r) {
                    if(DoubleUtil.FuzzyCompare(temp, v)){
                        temp  = temp * 5 / 4;
                        break;
                    }
                }

                long k = DoubleUtil.floor(temp);
                if(k <= 100) {
                    if (100 % k != 0) {
                        if (k % 8 == 0) {
                            temp = temp * 5 / 4;
                        }
                    }
                }

                r = new double[]{0.5,0.25};
                k = DoubleUtil.floor(temp);
                for(int i=0;i < r.length;i++){
                    if(DoubleUtil.FuzzyCompare(temp -  k,r[i])){
                        temp *= Math.pow(2,i + 1);
                        break;
                    }
                }

                int len = 0;
                k = DoubleUtil.floor(temp);
                if(k <= 200){
                    if(k != 200) {
                        if (100 % k == 0) {
                            len = (int)DoubleUtil.floor(ScopeBase.getWidth() * temp / c);
                        } else {
                            Log.e(TAG, "k:" + k + ",temp:" + temp);
                        }
                        chaZhiNum[0] = (int)k;
                    }else {
                        len = (int)ScopeBase.getWidth();
                        chaZhiNum[0] = 100;
                    }
                }

                if (len == 0) {
                    noDisp = 2; // noDisp = 2;
                } else {
                    disChaZhiReg.setTotalMul(chaZhiNum[0]);
                    disChaZhiReg.setFirstCoefJianGe(100 / chaZhiNum[0]);

                    if(k == 200){
                        chaZhiNum[0] = 200;
                    }

                    disChaZhiReg.setDataNFirstCha(
                            len / chaZhiNum[0] + (len % chaZhiNum[0] == 0 ? 0 : 1));
                    disChaZhiReg.setNeedChaZhi(1);

                    disChaZhiReg.setChaZhi200(k > 100 ? 1 : 0);
                }

                if (bPrintf) Logger.i("chaZhiRate:" + temp + " - " + chaZhiNum[0] + ", len:" + len);

            }

            lie = 1 / temp;

            if (bPrintf) Logger.i("chaZhiRateTemp:" + temp + ", lie:" + lie);

        }
        // 注意：设置的值必须能被虚拟屏幕列数整除
        // 注：只有在示波器设置采样模式为平均或包络时才进行点阵抽样
        int cnDataCyNum1 = 350 * 1000; // 点阵抽样
        int cnDataCyNum2 = 280 * 1000; // 点阵抽样
        int cnDataCyNum3 = 175 * 1000; // 点阵抽样

        FPGAReg_DISP_PLACE_MAIN disWavePlaceMainReg =
                (FPGAReg_DISP_PLACE_MAIN) getFPGAReg(fpgaIdx, FPGAReg.FPGA_DISP_PLACE_MAIN);
        FPGAReg_DISP_WAVE disStaticWave =
                (FPGAReg_DISP_WAVE) getFPGAReg(fpgaIdx, FPGAReg.FPGA_DISP_WAVE);
        long dataLen = 0;
        // 缩略视图的xstart和xend计算
        if (zoom) {
            long datasPerLie;
            FPGAReg_ZoomSmallPlace zoomSmallPlace =
                    (FPGAReg_ZoomSmallPlace) getFPGAReg(fpgaIdx, FPGAReg.FPGA_ZOOM_SMALL_PLACE);
            FPGAReg_DISP_SL disSlReg = (FPGAReg_DISP_SL) getFPGAReg(fpgaIdx, FPGAReg.FPGA_DISP_SL);
            FPGAReg_DISP_PLACE_SL dispWavePlaceSlReg =
                    (FPGAReg_DISP_PLACE_SL) getFPGAReg(fpgaIdx, FPGAReg.FPGA_DISP_PLACE_SL);

            datasPerLie = (int) (zunDepth *  4 / cols1 + 0.1);
            if (datasPerLie == 0) datasPerLie = 1; // 防护一�?

            if (bPrintf) {
                Logger.i(TAG, "datasPerLie : " + datasPerLie);
            }

            dispWavePlaceSlReg.setNumsPerLie((int)(datasPerLie / 4));
            disWavePlaceMainReg.setNumsPerLie2((int)(datasPerLie % 4) << 2);
            dispWavePlaceSlReg.setDaoShuLieNum((int)((262144 * 4) / datasPerLie));
            dispWavePlaceSlReg.setNeedCouY(0);
            dispWavePlaceSlReg.setNumCouY(1);

            long timeOneScreen = scope.timeOneScreen_main();

            double tm3;
            tm3 = num1 * timeOneScreen / 2;

            long halfDataTime = (long) (tm3 + 0.1);

            HorizontalAxis horizontalAxis = HorizontalAxis.getInstance();
            long t_small = horizontalAxis.getTimePosOfView(HorizontalAxis.WPI_SMALL);

            long t = scopeFrozen.getTimePosOfView();

            Log.d(TAG,"zoom t:" + t + ",halfDataTime:" + halfDataTime + ",t_small:" + t_small);

            if (t < -halfDataTime) {
                t = 2 * halfDataTime + t_small;
            } else {
                t =
                        halfDataTime
                                - t
                                + t_small
                                + (t
                                % (1000
                                * 1000
                                * 10
                                / scope.maxSampClk())); // 数据头距离屏幕中心的时间计算
            }

            long halfScreen = timeOneScreen / 2;

            int place = 0; // 取数相对位置
            int start = 0; // 显示起始位置
            int end = x0 - 1; // 显示结束位置

            if (t < halfScreen) {

                // 数据头在屏幕中
                place = 0;
                BigInteger t3 = BigInteger.valueOf(halfScreen - t);
                t3 = t3.multiply(BigInteger.valueOf(x0));
                t3 = t3.divide(BigInteger.valueOf(timeOneScreen));
                start = t3.intValue();
                if (start >= x0) {
                    start = x0;
                }
            } else {
                start = 0;
                // 计算取数位置
                BigInteger t3 = BigInteger.valueOf(t - halfScreen);
                t3 = t3.multiply(BigInteger.valueOf(zunDepth));
                t3 = t3.divide(BigInteger.valueOf(halfDataTime * 2));
                if (t3.compareTo(BigInteger.valueOf(zunDepth)) >= 0) {
                    t3 = BigInteger.valueOf(zunDepth);
                }
                place = t3.intValue();
            }

            {
                BigInteger t3 = BigInteger.valueOf(halfDataTime * 2);
                t3 = t3.subtract(BigInteger.valueOf(t));
                t3 = t3.add(BigInteger.valueOf(halfScreen));
                if (t3.compareTo(BigInteger.ZERO) < 0) {
                    start = x0;
                    end = x0;
                } else if (t3.compareTo(BigInteger.valueOf(timeOneScreen)) < 0) {
                    BigInteger t2 =
                            t3.multiply(BigInteger.valueOf(x0))
                                    .divide(BigInteger.valueOf(timeOneScreen));
                    end = t2.intValue() - 1;
                    if (isRun) {
                        long a = timeOneScreen / x0;
                        t3 = BigInteger.valueOf(timeOneScreen).subtract(t3);
                        long b = t3.longValue();
                        if (bPrintf) Logger.i("b:" + b + " a:" + a);
                        if (b > 0 && b < a) {
                            end++;
                        }
                    }
                }
            }
            dataLen = datasPerLie * (end + 1 - start) / 4;

            if (isRun) {

                disSlReg.setXStart(0);
                disSlReg.setXEnd(x0 - 1);

                zoomSmallPlace.setPlace(place);
                zoomSmallPlace.setNums((int)dataLen);
            }
            else
            {

                int validLie = scopeFrozen.getVaildAddr();
                if (scopeFrozen.isRool()) {
                    dataLen = ((x0 - validLie) * zunDepth / x0);
                    start = (int)(end - dataLen * 4 / datasPerLie + 1);
                    if (start < 0) start = 0;
                    disSlReg.setXStart(start);
                    disSlReg.setXEnd(end);
                    place = (int)((end - start + 1) * datasPerLie / 4);

                    zoomSmallPlace.setPlace((int)(dataLen - place));
                    zoomSmallPlace.setNums(place);
                } else if (scopeFrozen.isSlowScale()) {
                    dataLen = (int) ((validLie + 1) * zunDepth / x0);
                    validLie = (int)(dataLen * 4 / datasPerLie);
                    int e = start + validLie - 1;
                    if (e < end) {
                        end = e;
                    }
                    dataLen = (end - start + 1) * datasPerLie / 4;
                    disSlReg.setXStart(start);
                    disSlReg.setXEnd(end);
                    zoomSmallPlace.setPlace(place);
                    zoomSmallPlace.setNums((int)dataLen);

                    if (scopeFrozen.isSegmentEnable()) {
                        disSlReg.setXLastStart(0);
                        disSlReg.setXLastEnd(x0 - 1);
                    }

                } else {
                    disSlReg.setXStart(start);
                    disSlReg.setXEnd(end);
                    zoomSmallPlace.setPlace(place);
                    zoomSmallPlace.setNums((int)dataLen);
                }
                if (noDisp == 1) {
                    disSlReg.setXStart(x0);
                    disSlReg.setXEnd(x0);
                }
            }
            sendCommand(disSlReg);
            sendCommand(dispWavePlaceSlReg);
            sendCommand(zoomSmallPlace);
        } else {
            disWavePlaceMainReg.setNumsPerLie2(0);
        }

        // config.flagNoDispInterpWave(1) = (noDisp?true:false);
        if (noDisp != 0) {
            // 此时波形数据无效，对应测量和光标无效
            disWavePlaceMainReg.setXStart(x0);
            disWavePlaceMainReg.setXEnd(x0);
            disWavePlaceMainReg.setLastXStart(x0);
            disWavePlaceMainReg.setLastXEnd(x0);
            disWavePlaceMainReg.setLen(0);
            disWavePlaceMainReg.setLastLen(0);
            disWavePlaceMainReg.setPlace(0);
            disWavePlaceMainReg.setNumsPerLie1(1);
            disWavePlaceMainReg.setNumsPerLie2(0);
            disWavePlaceMainReg.setDaoShuLieNum(262144);
            disWavePlaceMainReg.setNeedCouY(0);
            disWavePlaceMainReg.setNumCouY(1);

            disStaticWave.setCouY(1);
            disStaticWave.setNeedCY(0);
            disStaticWave.setLen(0);
            disStaticWave.setWavePlace(0);
        }

        {
            // 2.
            // 缩略视图取数计算-----------------------------------------------------------------------------------
            long datasPerLie; // 每列有多少组数据
            int cou = 1; // 数据的抽样比
            // 缩略视图
            // 计算每屏的数据量tm2:非zoom时主视图，或zoom时缩略视�?
            // int tm1 = (int) (num1 * 100 + 0.1);

            long zunDepth1 = zunDepth / cou;

            //            if (zoom) {
            //                int num = 4;//4列的数据肯定为整�?
            //                datasPerLie = (int) (zunDepth1 * num / cols1 + 0.1);
            //                if (datasPerLie == 0) datasPerLie = 1;//防护一�?
            //                if(bPrintf){
            //                    Logger.i(TAG,"datasPerLie : " + datasPerLie);
            //                }
            //                FPGAReg_DISP_PLACE_SL dispWavePlaceSlReg = (FPGAReg_DISP_PLACE_SL)
            // getFPGAReg(FPGAReg.FPGA_DISP_PLACE_SL);
            //
            //                dispWavePlaceSlReg.setNumsPerLie(datasPerLie / 4);
            //                disWavePlaceMainReg.setNumsPerLie2((datasPerLie % 4) << 2);
            //                dispWavePlaceSlReg.setDaoShuLieNum((262144 * num) / datasPerLie);
            //                dispWavePlaceSlReg.setNeedCouY(cou > 1 ? 1 : 0);
            //                dispWavePlaceSlReg.setNumCouY(cou);
            //                sendCommand(dispWavePlaceSlReg);
            //            } else {
            //                disWavePlaceMainReg.setNumsPerLie2(0);
            //            }

            // 3.
            // 计算主视图抽样后每列的数据量-----------------------------------------------------------------------------------
            double cols; // 存储深度对应的总列�?主视�?
            if (zoom) // 放大模式
            {
                // 主视图，即放大视图
                // 计算每屏的数据量: 主视图
                //                tm1 = (int) (num2 * 100 + 0.1);
                //                int tm2;
                //                if (tm1 < 100) {//小于1�?
                //                    tm2 = (int) zunDepth;
                //                } else {
                //                    tm2 = (int) (zunDepth * 100 / tm1);
                //                }
                cou = 1;
                // 抽样�?.2M�?.5M

                zunDepth1 = zunDepth / cou;

                cols = cols2;
            } else {
                cols = cols1;
            }
            int num = 4; // 4�?
            if (bPrintf)
                Logger.i(
                        "zoom:"
                                + zoom
                                + " cols:"
                                + cols
                                + " num:"
                                + num
                                + " zunDepth1:"
                                + zunDepth1);
            // 抽样以及插值后，每列的数据组数(可能�?n.25�?n.5的小�?�?4整数化。实际列数传递时
            // 反向处理可能不整�?，需要进行余数传递，余数形式�?�?�?
            datasPerLie = (int) (zunDepth1 * chaZhiNum[0] * num / cols + 0.1);
            if (bPrintf) Logger.i("--datasPerLie:" + datasPerLie);

            if (noDisp == 0) {
                if (scopeFrozen.isSlowScale() && !isRun) {
                    if (bPrintf) Logger.i("InSlowScale and Scope is Stop ===> ");
                    // datasPerLie时按照全屏波形计算的，对于滚屏非满屏时放大一些位置并不合适，
                    // 所以这里要重新修正计算，以保证参数numsPerLie1设置正确
                    int validLie = scopeFrozen.getVaildAddr();
                    if (validLie > 0) {
                        int waveLen = validLie + 1;
                        int dataLenx = (int) (waveLen * zunDepth / x0);

                        if (bPrintf)
                            Logger.i(
                                    "waveLen:"
                                            + waveLen
                                            + " dataLenX:"
                                            + dataLenx
                                            + " datasPerLie:"
                                            + datasPerLie
                                            + " num:"
                                            + num
                                            + " num1:"
                                            + num1);
                        if (dataLenx < datasPerLie / num && num1 < 1) {
                            int _datasPerLie = dataLenx;
                            if (_datasPerLie != 0) datasPerLie = _datasPerLie;
                            if (bPrintf) Logger.i("refresh datasPerLie:" + datasPerLie);
                        }
                    }
                }

                disWavePlaceMainReg.setNumsPerLie1((int)(datasPerLie / 4));
                if (num1 > 2.0 / 14)
                    disWavePlaceMainReg.setNumsPerLie2((int)
                            (disWavePlaceMainReg.getNumsPerLie2() | datasPerLie % 4));
                disWavePlaceMainReg.setDaoShuLieNum((int)((262144 * num) / datasPerLie));
            }

            // 4. 主视图取数计�?----------------------------------------------------------
            long t_sy = 0;
            // S64 t_sy=0;//计算取数位置对应时间精确到数据点后，还有余数，单�?.1ps
            if (noDisp == 0) {
                int place = 0; // 取数相对位置
                int start = 0; // 显示起始位置
                int end = x0 - 1; // 显示结束位置

                double tm3; // 数据总列�?
                tm3 = num1 * scope.timeOneScreen_main() / 2; // 数据总时�?2

                long halfDataTime = (long) (tm3 + 0.1); // 1半数据的时间
                if (bPrintf) {
                    Logger.i("num1:" + num1 + " timeOneScreen_main:" + scope.timeOneScreen_main());
                    Logger.i("fullDataTime:" + tm3 + ",halfDataTime:" + halfDataTime);
                }

                // 计算数据头距离缩略窗口中心的时间: tst
                long t_std =
                        HorizontalAxis.getInstance().getTimePosOfView(HorizontalAxis.WPI_STANDARD);

                long tst; // 触发位置距离数据中心的时�?
                if (isRun) tst = t_std;
                else tst = scopeFrozen.getTimePosOfView(); // config.freezeWave.timePosOfView;
                if (bPrintf) Logger.i("t_std:" + t_std + " tst:" + tst);

                long t_main; // 主视图的触发位置
                long oneScreenTime; // 主视图一屏的时间:
                // oneScreenTime：主视图1屏对应的时间
                // t_main: 主视图触发位置距离屏幕中心的时间�?
                if (zoom) {
                    if (screenNum == 1) {
                        t_main = t_std; // config.timePosOfView(0, Wave::WPI_STANDARD);
                        oneScreenTime = scope.timeOneScreen_main();
                    } else {
                        t_main =
                                HorizontalAxis.getInstance()
                                        .getTimePosOfView(HorizontalAxis.WPI_LARGE);
                        oneScreenTime = scope.timeOneScreen_zoom();
                    }
                } else {
                    t_main = t_std;
                    oneScreenTime = scope.timeOneScreen_main();
                }
                if (bPrintf) Logger.i("t_main:" + t_main + " oneScreenTime:" + oneScreenTime);
                if (tst < -halfDataTime) { // 触发位置在右，并且到达数据尾巴还超过，这时候单屏时，屏幕左边应该有空白显示�?
                    // 即触发位置位于数据的最后一个；
                    // 主视图左右不对称
                    // 详细公式：t = halfDataTime*2+t+(config.timePosOfView(0, Wave::WPI_STANDARD)-t)
                    //        +(config.timePosOfView(0, Wave::WPI_LARGE)
                    //        -config.timePosOfView(0, Wave::WPI_STANDARD));
                    tst = halfDataTime * 2 + t_main; // 数据头距离屏幕中心的时间计算
                } else {
                    // 详细公式：t = halfDataTime+(config.timePosOfView(0, Wave::WPI_STANDARD)-t)
                    //        +(config.timePosOfView(0, Wave::WPI_LARGE)
                    //        -config.timePosOfView(0, Wave::WPI_STANDARD));
                    // tst = halfDataTime - tst + t_main;//数据头距离屏幕中心的时间计算
                    // 还需要考虑动态时，触发不在采样点上；
                    tst =
                            halfDataTime
                                    - tst
                                    + t_main
                                    + (tst
                                            % (1000
                                                    * 1000
                                                    * 10
                                                    / scope.maxSampClk())); // 数据头距离屏幕中心的时间计算
                }
                // 计算主窗口的取数位置
                long halfScreen = oneScreenTime / 2; // 半屏对应的时�?
                if (bPrintf) Logger.i("new tst:" + tst + " halfScreen:" + halfScreen);

                if (halfScreen > tst) { // 数据头在屏幕�?

                    // 数据头在屏幕中

                    // 显示窗口的左边有"无波形区"
                    place = 0;
                    // 计算起始�?
                    BigInteger t3 = BigInteger.valueOf(halfScreen - tst);
                    t3 = t3.multiply(BigInteger.valueOf(x0));
                    t3 = t3.divide(BigInteger.valueOf(oneScreenTime));

                    start = t3.intValue();
                    if (start > x0 - 1) {
                        start = x0;
                    }
                } else {
                    start = 0; // 从第0列开始显�?
                    // 计算取数位置
                    BigInteger t3 = BigInteger.valueOf(tst - halfScreen);
                    BigInteger temp = BigInteger.valueOf(tst - halfScreen);
                    t3 = t3.multiply(BigInteger.valueOf(zunDepth));
                    BigInteger th = BigInteger.valueOf(halfDataTime * 2);
                    BigInteger tn = t3.divide(th);
                    BigInteger tm = t3.mod(th);

                    if (tm.compareTo(th.divide(BigInteger.valueOf(2))) > 0) {
                        t3 = tn.add(BigInteger.ONE);
                    } else {
                        t3 = tn;
                    }

                    if (t3.compareTo(BigInteger.valueOf(zunDepth - 1)) > 0) {
                        t3 = BigInteger.valueOf(zunDepth - 1);
                    }
                    place = t3.intValue();
                    t3 = BigInteger.valueOf(place);
                    t3 =
                            t3.multiply(BigInteger.valueOf(halfDataTime * 2))
                                    .divide(BigInteger.valueOf(zunDepth));
                    t3 = temp.subtract(t3);
                    t_sy = t3.longValue();

                    if (t_sy < 0) t_sy = 0;
                }
                // 计算结束�?
                {
                    BigInteger t3 = BigInteger.valueOf(halfDataTime * 2);
                    t3 = t3.subtract(BigInteger.valueOf(tst));
                    t3 = t3.add(BigInteger.valueOf(halfScreen));
                    if (t3.compareTo(BigInteger.ZERO) < 0) {
                        start = x0;
                        end = x0;
                    } else if (t3.compareTo(BigInteger.valueOf(oneScreenTime)) < 0) {

                        BigInteger t2 =
                                t3.multiply(BigInteger.valueOf(x0))
                                        .divide(BigInteger.valueOf(oneScreenTime));
                        end = t2.intValue() - 1;
                        // 静态波形多一列可能多屏是错误。待验证
                        //if (isRun)
                        {
                            long a = oneScreenTime / x0;
                            t3 = BigInteger.valueOf(oneScreenTime).subtract(t3);
                            long b = t3.longValue();
                            if (bPrintf) Logger.i("b:" + b + " a:" + a);
                            if (b > 0 && b < a) {
                                end++;
                            }
                        }
                    }
                }
                if (bPrintf) Logger.i("place:" + place + " start:" + start + " end:" + end);

                if (start == x0) end = x0;
                if (start > end) end = start;
                int lastStart = start;
                int lastEnd = end;
                int lastLen = (int)dataLen;
                if (!isRun) {
                    if (bPrintf) {
                        Logger.i("Scope is stop===> validAdr:" + scopeFrozen.getVaildAddr());
                        Logger.i(
                                "isRoll:"
                                        + scopeFrozen.isRool()
                                        + " isSlow:"
                                        + scopeFrozen.isSlowScale());
                    }
                    if (scopeFrozen.isRool()) {
                        // 静态滚屏时处理
                        long startD = scopeFrozen.getVaildAddr();

                        // 计算无效数据�?
                        startD = startD * zunDepth / x0;
                        place -= startD;
                        if (bPrintf) Logger.i("is roll!! new place:" + place);
                        if (place < 0) {
                            // 修正start的�?
                            if (start < x0) {
                                long tm1x = start;
                                tm1x -= (long) (place / lie - 0.1);
                                if (tm1x > x0 - 1) {
                                    start = x0;
                                    end = x0;
                                } else {
                                    start = (int) tm1x;
                                }
                                if (bPrintf)
                                    Logger.i(
                                            "ROLL new start:"
                                                    + start
                                                    + " end:"
                                                    + end
                                                    + " place = 0");
                            }
                            place = 0;
                        }
                    } else if (scopeFrozen.isSlowScale()) {

                        long xn = scope.getSegmentFrameNums();
                        long xno = SegmentSample.getInstance().getFrameNo();
//                        Log.d(TAG,"xn:" + xn + ",xno:" + xno);

                        long endD = scopeFrozen.getVaildAddr();

                        if(xn > 0 && xno >=0 ){
                            if((xno + 1) != xn){
                                endD = ScopeBase.getWidth() - 1;
                            }
                        }

                        endD = (long) ((endD + 1) * zunDepth / x0 - lie + 0.1);
                        long tm1x = (long) place;
                        tm1x += (long) ((end - start + 1) * lie + 0.1);
                        tm1x = endD - tm1x;
                        if (bPrintf) {
                            Logger.i(
                                    "is slow!! zunDepth:"
                                            + zunDepth
                                            + " lie:"
                                            + lie
                                            + " endD:"
                                            + endD);
                            Logger.i(
                                    "place:" + place + " end:" + end + " start:" + start + " tm1x:"
                                            + tm1x);
                        }
                        if (tm1x < 0) {
                            // 修正end的�?
                            if (end < x0) {
                                tm1x = end + (long) (tm1x / lie + 0.1);
                                if (tm1x < 0) {
                                    start = x0;
                                    end = x0;
                                } else {
                                    end = (int) tm1x;
                                }
                                if (bPrintf)
                                    Logger.i(
                                            "SLOW new start:"
                                                    + start
                                                    + " end:"
                                                    + end
                                                    + " place = "
                                                    + place);
                            }
                        }
                    }
                }
                if (start == x0) end = x0;
                if (start > end) end = start;
                // bug 0004915
                if (screenNum == 1) {
                    if (!isRun) {
                        if (scopeFrozen.isSlowScale()) {
                            end = end + start;
                            start = 0;
                            if (end >= x0) end = x0 - 1;
                            place = 0;

                        } else if (scopeFrozen.isRool()) {

                        } else {
                            start = 0;
                            end = x0 - 1;
                            place = 0;
                        }
                        if (bPrintf)
                            Logger.i(
                                    "screenNum=1 and ScopeIsStop ==> start:"
                                            + start
                                            + " end:"
                                            + end
                                            + " place:"
                                            + place);
                    }
                }
                dataLen = (int)(datasPerLie * (end + 1 - start) / num);
                lastLen = (int)(datasPerLie * (lastEnd + 1 - lastStart) / num);
                if (bPrintf) Logger.i("wavelen:" + dataLen + ",datasPerLie:"
                        + datasPerLie + ",end:" + end + ",start:"
                        + start + ",num:" +num);

                // 防止压缩时，误差导致数据变多
//                if (!isRun) {
//                    int validLine = x0;
//                    if (scopeFrozen.isRool()) {
//                        validLine = x0 - scopeFrozen.getVaildAddr();
//                    } else if (scopeFrozen.isSlowScale()) {
//                        validLine = scopeFrozen.getVaildAddr() + 1;
//                    }
//
////                    if(lie < 1) {
////                        temp /= lie;
////                    }
//                    if (bPrintf) Logger.i("validLine:" + validLine + ",lie:" + lie);
//                    int temp = (int) (zunDepth * validLine / x0);
//
//                    if (bPrintf) Logger.i( "dataLen:" + dataLen + ",temp:" + temp);
//                    if (dataLen > temp) {
//                        if (scopeFrozen.isRool() || scopeFrozen.isSlowScale()) {
//                            dataLen = temp;
//                            end -= 1;
//                            if (end < start)
//                                end = start;
//                        }
//                        if (bPrintf)
//                            Logger.i("start:" + start + " end:" + end + " wavelen:" + dataLen);
//                    }
//
//
//                }

                int len;
                len = (int)dataLen;

                disWavePlaceMainReg.setPlace(place);
                disWavePlaceMainReg.setXStart(start);
                disWavePlaceMainReg.setXEnd(end);
                disWavePlaceMainReg.setLen(len);

                if (scopeFrozen.isSlowScale() && scopeFrozen.isSegmentEnable()) {
                    disWavePlaceMainReg.setLastXStart(lastStart);
                    disWavePlaceMainReg.setLastXEnd(lastEnd);
                    disWavePlaceMainReg.setLastLen(lastLen);
                }

                disWavePlaceMainReg.setNeedCouY(cou > 1 ? 1 : 0);
                disWavePlaceMainReg.setNumCouY(cou);

                double lieT = (double) oneScreenTime / x0;
                double sLast = (((zunDepth - place) / lie) * lieT / 4e4 + 13);
                double sLen =  (lieT * (end - start + 1) / 4e4);
                //Logger.d(TAG, "lieT:" + lieT + ",sLast:" + sLast + ",sLen:" + sLen + ",place:" + place + ",lie:" + place + ",zunDepth:" + zunDepth);

                FPGAReg_DISP_SERI dispSeriReg =
                        (FPGAReg_DISP_SERI) getFPGAReg(fpgaIdx, FPGAReg.FPGA_DISP_SERI);
                dispSeriReg.setCodepos((int) sLast);
                dispSeriReg.setCodelen((int) sLen);
                dispSeriReg.setZipparam((int) (lieT / 4e4));
                sendCommand(dispSeriReg);
            }

            if (chaZhiNum[0] > 1 && noDisp == 0) {

                // fpga的最高采样频率为双通道1G,所以采样时间的精度只有1ns

                // AD采样精度�?G，即1ns=10*1000(0.1ps)
                // AD采样精度�?00M，即2ns=20*1000(0.1ps)
                // int step = 1000*1000*10/IModuleDevice::instance()->maxInputClk_AD();
                // 计算采样精度
                double fx = scope.getSampleRate(isRun);

                long fx_dd = (long) (fx * (1000 * 10) + 0.1); // 采样频率单位换算�?.1mHz

                long step =
                        (1000L * 1000 * 1000 * 1000 * 1000 * 10 * 10)
                                / fx_dd; // 周期，即两个采样的时间，单位0.1ps

                long t = t_sy * chaZhiNum[0] / step;

                if (t != 0) {
                    if (t > chaZhiNum[0]) t = t - chaZhiNum[0];
                    if (t > chaZhiNum[0]) t = chaZhiNum[0];
                }

                if (bPrintf) Logger.i("Chazhi setXiaoShu=" + t);
                disWavePlaceMainReg.setXiaoShu((int) t * 100 / chaZhiNum[0]);

            } else {
                disWavePlaceMainReg.setXiaoShu(0);
            }
        }
        sendCommand(disWavePlaceMainReg);
        sendCommand(disChaZhiReg);

        // 数学波形
        if (noDisp == 0) {
            int tm1;
            int tm2;
            // 数学波形取数计算:
            if (zoom) // 放大模式
            {
                tm1 = (int) (num2 * 100 + 0.1);
            } else {
                tm1 = (int) (num1 * 100 + 0.1);
            }

            // 计算每屏的数据量: 主视�?
            if (tm1 < 100) {
                // 小于1屏时�?屏处�?
                tm2 = (int) zunDepth;
            } else {
                tm2 = (int) (zunDepth * 100 * chaZhiNum[0] / tm1);
            }

            // 数学波形的抽样在点阵波形抽样的基础上进行再抽样
            tm2 /= disWavePlaceMainReg.getNumCouY();

            int cou = mathCouYang(tm2);

            disStaticWave.setCouY(cou);
            disStaticWave.setNeedCY(cou > 1 ? 1 : 0);

            // 数学波形是从点阵数据中抽�?
            disStaticWave.setLen((int)(dataLen / cou));
            //            disStaticWave.setWavePlace(disWavePlaceMainReg.getPlace());
            disStaticWave.setWavePlace((int)(
                    dataLen
                            / cou
                            / (disWavePlaceMainReg.getXEnd()
                                    - disWavePlaceMainReg.getXStart()
                                    + 1)));

            double fs = scope.getSampleRate(isRun);
            fs /= cou;
            MathChannel mathChannel;
            int maxIdx = ChannelFactory.getMaxMathIdx();
            for (int i = ChannelFactory.MATH1; i < maxIdx; i++) {
                mathChannel = ChannelFactory.getMathChannel(i);
                if (mathChannel != null) {
                    mathChannel.setSampleRate(fs, chaZhiNum[0]);
                    mathChannel.setWaveLen((int)(dataLen / cou));
                }
            }
        }
        sendCommand(disStaticWave);
        HorizontalAxis.getInstance().setStartX(disWavePlaceMainReg.getXStart());
        HorizontalAxis.getInstance().setEndX(disWavePlaceMainReg.getXEnd());
    }

    private int mathCouYang(int len) {
        int cou = 1;
        int []cnDataCyMath = MemDepthFactory.getMemDepth().getMathCouArray();
        int k = cnDataCyMath[0];
        if(len > k){
            cou = len / k;
            while ( k >= ScopeBase.getWidth()
                    && (len % k) != 0
                    || (k % ScopeBase.getWidth() != 0)) {
                cou++;
                k = len / cou;
            }
        }
        return cou;
    }

