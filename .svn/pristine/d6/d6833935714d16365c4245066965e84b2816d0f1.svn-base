    public void SendADData(int fpgaIdx, int adIdx, int addr, int val) {
        Log.d("MHO38V1",
                "SendADData() called with: fpgaIdx = ["
                        + fpgaIdx
                        + "], adIdx = ["
                        + adIdx
                        + "], addr = ["
                        + Integer.toHexString(addr)
                        + "], val = ["
                        + val
                        + "]");
        cmdDevice(0,100);
        FPGAReg_SPI_EXT reg = (FPGAReg_SPI_EXT) getFPGAReg(fpgaIdx, FPGAReg.FPGA_SPI_EXT);
        reg.setType(FPGAReg_SPI_EXT.SPI_EXT_AD);
        reg.setWriteAd(1 << adIdx);
        reg.setAdData(addr, val);
        reg.setDataLength(1);
        reg.setByteValid(0);
        sendCommand(reg);
    }

