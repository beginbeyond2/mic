    public int getFpgaStatus(){
        int v = 0;
        FPGAReg_STATUS regStatus = new FPGAReg_STATUS();
        for(int i=0;i<fpgaNums;i++) {
            regStatus.reset(true);
            regStatus.setFpgaIdx(i);
            recvCommand(regStatus, regStatus.getRecvReg());
            Log.d("123456789","" + Integer.toHexString(regStatus.getStatus()));
            v |= ((regStatus.getStatus()>>25) & 0x0F) << (i * 4);
        }
        return v;
    }

    public void probeProcess(int fpgaIdx) {
        boolean[] b = {false, false, false, false};
        boolean bAlive = false;
        ProbeFactory probeFactory = ProbeFactory.getInstance();
        FPGAReg_PROBE fpgaReg_probe = new FPGAReg_PROBE();
        fpgaReg_probe.setFpgaIdx(fpgaIdx);
        int beginIdx = beginChIdx(fpgaIdx);
        int endIdx = endChIdx(fpgaIdx);
        do {
            for (int i = 0; i < 3; i++) {
                fpgaReg_probe.reset(true);
                recvCommand(fpgaReg_probe, fpgaReg_probe.getRecvReg());
                if (fpgaReg_probe.getRecvReg().isHeaderValid()) {
                    break;
                }
            }

            if (fpgaReg_probe.getRecvReg().isHeaderValid()) {
                for (int i = beginIdx; i < endIdx; i++) {
                    int idx = i - beginIdx;
                    Channel channel = ChannelFactory.getDynamicChannel(i);
                    if (channel == null) continue;
                    b[idx] = bAlive = fpgaReg_probe.isProbeAlive(idx);
                    if (bAlive) {
                        int s = fpgaReg_probe.getProbeFifoSize(idx);

                        if (s > 0) {
                            s += 2;
                            FPGAReg_SPI_Read r = new FPGAReg_SPI_Read();
                            r.setType(FPGAReg_SPI_Read.SPI_EXT_UART);
                            r.setFpgaIdx(fpgaIdx);
                            r.setByteValid(0);
                            r.setDataLength(s);
                            r.setVal(8, 4, 1 << idx);
                            r.setCmdLength(s * 4);
                            ByteBuffer byteBuffer = ByteBuffer.allocate(256 /*s*4*/);
                            recvCommand(r, byteBuffer);
                            if ((byteBuffer.get(6) & 0xFF) == 0xAA
                                    && (byteBuffer.get(7) & 0xFF) == 0xAA) {
                                int len =
                                        byteBuffer.get(4) & 0xFF | (byteBuffer.get(5) & 0xFF << 8);
                                len /= 4;
                                len *= 4;
                                len = Math.min(len, byteBuffer.capacity() - 8);
                                probeFactory.Input(channel, byteBuffer, 8, len);
                                probeFactory.process(channel);
                            } else {
                                StringBuilder sb = new StringBuilder();
                                sb.append("ch:").append(i).append(",data:");
                                for (int j = 0; j < byteBuffer.capacity(); j++) {
                                    sb.append(",")
                                            .append(Integer.toHexString(byteBuffer.get(j) & 0xFF));
                                }
                                Log.e(TAG, "Probe 0xAAAA error," + sb.toString());
                            }
                        }
                        b[idx] = s > 0;
                    }
                    probeFactory.alive(channel, bAlive);
                }
            } else {
                Log.e(TAG, "Probe Header error:" + fpgaIdx);
            }
        } while (b[0] || b[1] || b[2] || b[3]);
    }

    public void readFpgaStatus(int fpgaIdx, FPGA_Status fpgaStatus) {
        int sIdx, eIdx;
        sIdx = beginChIdx(fpgaIdx);
        eIdx = endChIdx(fpgaIdx);
        FPGAReg_INTRPT regIntrpt = new FPGAReg_INTRPT();
        regIntrpt.setFpgaIdx(fpgaIdx);
        regIntrpt.reset(true);
        recvCommand(regIntrpt, regIntrpt.getRecvReg());
        regIntrpt.onRecv();
        if (regIntrpt.isAutoFinish()) {

            FPGAReg_STATUS_AUTO_V[] statusAutoV = new FPGAReg_STATUS_AUTO_V[4];
            FPGAReg_STATUS_AUTO_CYCLE[] statusAutoCycle = new FPGAReg_STATUS_AUTO_CYCLE[4];
            FPGA_Status.FpgaAuto a;

            for (int i = 0; i < statusAutoV.length; i++) {
                statusAutoV[i] = new FPGAReg_STATUS_AUTO_V(FPGAReg.FPGA_AUTO_V1 + i);
                statusAutoV[i].setFpgaIdx(fpgaIdx);
                recvCommand(statusAutoV[i], statusAutoV[i].getRecvReg());
                statusAutoV[i].onRecv();
            }

            for (int i = 0; i < statusAutoCycle.length; i++) {
                statusAutoCycle[i] =
                        new FPGAReg_STATUS_AUTO_CYCLE(FPGAReg.FPGA_STATUS_AUTO_CYCLE_1 + i);
                statusAutoCycle[i].setFpgaIdx(fpgaIdx);
                recvCommand(statusAutoCycle[i], statusAutoCycle[i].getRecvReg());
            }

            for (int i = sIdx; i < eIdx; i++) {
                a = fpgaStatus.getAuto(i);
                a.setVaild(true);

                a.setMinVal(statusAutoV[i - sIdx].getMinVal());
                a.setMaxVal(statusAutoV[i - sIdx].getMaxVal());
                a.setCycle(statusAutoCycle[i - sIdx].getRecvReg().getVal(0));

                if(a.getMinVal() == a.getMaxVal()
                        && a.getMinVal() == 0){
                    a.setVaild(false);
                }
            }


        }

        if (regIntrpt.isFre()) {
            FPGA_Status.FpgaFreq f = fpgaStatus.getFreq();
            FreqCounter freqCounter = FreqCounter.getInstance();
            if(freqCounter.isFreqCounterEnable()) {

                int idx = freqCounter.getChIdx()/4;
                if(idx == fpgaIdx) {
                    FPGAReg_STATUS_FREQ[] statusFreqs = new FPGAReg_STATUS_FREQ[2];
                    for (int i = 0; i < 2; i++) {
                        statusFreqs[i] = new FPGAReg_STATUS_FREQ(FPGAReg.FPGA_STATUS_CH_T + i);
                        statusFreqs[i].setFpgaIdx(fpgaIdx);
                        recvCommand(statusFreqs[i], statusFreqs[i].getRecvReg());
                        f.setVaild(true);
                        f.setTN(i, statusFreqs[i].getRecvReg().getVal(0));
                    }
                }
            }
        }
    }

