    public static boolean isFpgaChIdx(int fpgaIdx,int chIdx){
        return chIdx >=  beginChIdx(fpgaIdx) && chIdx < endChIdx(fpgaIdx);
    }

    public static int beginChIdx(int fpgaIdx) {
        return ChannelFactory.CH1 + fpgaIdx * ChannelFactory.CH_CNT / 2;
    }

    public static int endChIdx(int fpgaIdx) {
        return ChannelFactory.CH1 + (fpgaIdx + 1) * ChannelFactory.CH_CNT / 2;
    }

    public static int beginSerialIdx(int fpgaIdx) {
        return ChannelFactory.S1 + fpgaIdx * ChannelFactory.SERIAL_CNT / 2;
    }

    public static int endSerialIdx(int fpgaIdx) {
        return ChannelFactory.S1 + (fpgaIdx + 1) * ChannelFactory.SERIAL_CNT / 2;
    }

    public static int chIdxToFpgaIdx(int chIdx) {
        return (chIdx - ChannelFactory.CH1) / (ChannelFactory.CH_CNT / 2);
    }

    public static int serialIdxToFpgaIdx(int serialIdx) {
        return (serialIdx - ChannelFactory.S1) / (ChannelFactory.SERIAL_CNT / 2);
    }

    public void updateChCapacitance(int fpgaIdx) {

        CabteRegister cabteRegister = CabteRegister.getInstance();

        FPGAReg_CH_CAPACITANCE_16BIT regChCapacitance16BIT =
                (FPGAReg_CH_CAPACITANCE_16BIT)
                        getFPGAReg(fpgaIdx, FPGAReg.FPGA_CH_CAPACITANCE1_16BIT);
        FPGAReg_CH_CAPACITANCE reg =
                (FPGAReg_CH_CAPACITANCE) getFPGAReg(fpgaIdx, FPGAReg.FPGA_CH_CAPACITANCE1);

        FPGAReg_CH_CAP_DA regChCapDa = (FPGAReg_CH_CAP_DA)getFPGAReg(fpgaIdx,FPGAReg.FPGA_CH_CAP_DA12);

        Channel channel = null;
        int beginIdx = beginChIdx(fpgaIdx);
        int endIdx = endChIdx(fpgaIdx);
        int dwidx = 0;

        int [] daChMap = {1,3,2,0};
        for (int i = beginIdx; i < endIdx; i++) {
            channel = ChannelFactory.getDynamicChannel(i);
            if (channel != null) {

                dwidx = CabteRegister.getRatioIdx(channel.getResistanceType(),channel.getVScaleVal() / channel.getProbeRate());
                int xvv = cabteRegister.getChCapacitanceHigh(i,dwidx);
                regChCapacitance16BIT.setHigh(i-beginIdx, xvv);
                regChCapDa.setHigh(daChMap[i-beginIdx], xvv);
                reg.setHigh(i-beginIdx, xvv);
                reg.setTotal(i-beginIdx, 0xFF);
            }
        }
        sendCommand(regChCapDa);
        sendCommand(regChCapacitance16BIT);
        sendCommand(reg);
        updataReg(fpgaIdx);
    }

    public void resume() {
        Log.d("MHO68V2","resume" );
        Arrays.fill(vol2A_last, -1);
        Arrays.fill(vol2B_last, -1);
        Arrays.fill(vScaleLast, -1);
        coef_fpga_mho_bak[0] = null;
        coef_fpga_mho_bak[1] = null;
        coef_seach_mho_bak[0] = null;
        coef_seach_mho_bak[1] = null;
        Arrays.fill(Val0x31_last, -1);
        Arrays.fill(Val0x3A_last, -1);
        Arrays.fill(Val0x3B_last, -1);
        Arrays.fill(cnt_last, -1);
        Arrays.fill(sampleChState,false);
        for (int i = 0; i < fpgaNums; i++) {
            FPGAReg_DOT_MATRIX reg = (FPGAReg_DOT_MATRIX) getReg(i, FPGAReg.FPGA_DOT_MATRIX);
            reg.resetBak();
        }
    }

    public static void sendCmd(FPGAReg reg) {
        getInstance().sendCommand(reg);
    }

    public static FPGAReg getReg(int idx, int regIdx) {
        return getInstance().getFPGAReg(idx, regIdx);
    }

    public FPGAReg getFPGAReg(int idx, int regIdx) {
        if(fpgaRegs.length > idx && fpgaRegs[idx].length > regIdx) {
            return fpgaRegs[idx][regIdx];
        }
        return null;
    }

    public void runCommand(int idx, int regIdx) {
        FPGAReg reg = getFPGAReg(idx, regIdx);
        if (reg != null) {
            reg.onCommand();
            mHw.sendFpgaCmd(reg.getFpgaIdx(), reg.getCommand(), reg.getCommandLength());
        }
    }

    public void sendCommand(FPGAReg reg, int len) {
        if (reg != null) {
            mHw.sendFpgaCmd(reg.getFpgaIdx(), reg.getCommand(), len);
        }
    }

    public void sendCommand(FPGAReg reg) {
        sendCommand(reg, reg.getCommandLength());
    }

    public void recvCommand(FPGAReg w_reg, FPGAReg r_reg) {
        if (w_reg != null && r_reg != null) {
            mHw.recvFpgaCmd(
                    w_reg.getFpgaIdx(),
                    w_reg.getCommand(),
                    w_reg.getCommandLength(),
                    r_reg.getCommand());
        }
    }

    public void recvCommand(FPGAReg w_reg, ByteBuffer byteBuffer) {
        if (w_reg != null && byteBuffer != null) {
            mHw.recvFpgaCmd(
                    w_reg.getFpgaIdx(), w_reg.getCommand(), w_reg.getCommandLength(), byteBuffer);
        }
    }



    public void cmdSegment(int fpgaIdx) {
        runCommand(fpgaIdx, FPGAReg.FPGA_SEGMENT_START);
        runCommand(fpgaIdx, FPGAReg.FPGA_SEGMENT_NUMS);
    }

    boolean bClkOut = false;
    boolean bChPowerEnable = true;
    public void gntR_sampMode(int fpgaIdx) {
        runCommand(fpgaIdx, FPGAReg.FPGA_SAMPLE_MODE);
        runCommand(fpgaIdx, FPGAReg.FPGA_SEGMENT_FRAME);
        updateChCapacitance(fpgaIdx);

        int val = 0;
        Sample sample = Sample.getInstance();
        if(sample.isTriggerInOut()){
            val |= 1;
        }

        if(sample.isClkInOut()){
            val |= 2;
        }

        if(bClkOut != sample.isClkInOut()){
            bChPowerEnable = false;
            bClkOut = sample.isClkInOut();
        }

        SendClkInOut(fpgaIdx,val);
        mHw.setTriggerInOut(sample.isTriggerInOut());
        mHw.setClkInOut(sample.isClkInOut());
    }
    public void chPowerEnable(){
        if(adc.isChChangeReset()) {
            if (!bChPowerEnable) {
                Arrays.fill(sampleChState, false);
                SendAdc_ch_change(0);
                bChPowerEnable = true;
            }
        }
    }

    public void gntR_pinJ_baoL(int fpgaIdx) {
        runCommand(fpgaIdx, FPGAReg.FPGA_PJBL_TIMES);
    }

    public void gntR_zun_depth(int fpgaIdx) {
        runCommand(fpgaIdx, FPGAReg.FPGA_ZUN_DEPTH);
    }

    // 计算每次刷新多少列
    private int getColsPerRefresh_scollMode(int colsOneScreen) {
        Scope scope = Scope.getInstance();

        // 计算一屏的时间
        int t1 = (int) (scope.timeScale_mainBoard() * ScopeBase.getHorizonGridCnt() * 1000 + 0.1);
        // Logger.i(TAG, "one screeen time(ms)="+t1);
        if (t1 < 1) {
            t1 = 1;
        }

        int perT = 36;
//        if (HardwareProduct.isMHO())
        {
            perT = 20;
        }

        int cols = perT * colsOneScreen;
        if (cols % t1 != 0) cols = cols / t1 + 1;
        else cols = cols / t1;
        if (cols == 0) cols = 1;
        Logger.i(TAG, "每次刷新列数=" + cols + ", 时间=" + (cols * t1 / colsOneScreen));
        return cols;
    }

    public void gntR_samp_place(int fpgaIdx) {
        FPGAReg_PRE_SAMP preSampReg = (FPGAReg_PRE_SAMP) getFPGAReg(fpgaIdx, FPGAReg.FPGA_PRE_SAMP);
        FPGAReg_SCROLL_ROW scrollRowReg =
                (FPGAReg_SCROLL_ROW) getFPGAReg(fpgaIdx, FPGAReg.FPGA_SCROLL_ROW);
        FPGAReg_SLOW_SCALE_SET slowScaleSetReg =
                (FPGAReg_SLOW_SCALE_SET) getFPGAReg(fpgaIdx, FPGAReg.FPGA_SLOW_SCALE_SET);

        HorizontalAxis xAxis = HorizontalAxis.getInstance();
        Scope scope = Scope.getInstance();
        Sample sample = Sample.getInstance();
        int zunDepth = sample.getSampleMemDepth();
        int virSceenCols = ScopeBase.getWidth();

        // 计算屏数
        double screeNum = scope.screenNum_Main(scope.isRun(true)); // 最多只会有2位小�?

        int type;
        BigInteger t = BigInteger.valueOf(0);

        if (scope.isInScrollMode()) // 滚动模式
        {
            type = 0;
        } else {
            type = 1;
            // (触发位置时间*准存储深度)/(显示屏数*一屏的时间)
            try {
                long m = xAxis.getTimePosOfView(HorizontalAxis.WPI_STANDARD);

                t = BigInteger.valueOf(m);
                m = (long) zunDepth * 100; // 因为屏数可能为小数，所以放大100倍
                t = t.multiply(BigInteger.valueOf(m));

                m = (long) (screeNum * 100 + 0.1);
                BigInteger t2 = BigInteger.valueOf(m);
                m = scope.timeOneScreen_main();
                t2 = t2.multiply(BigInteger.valueOf(m));
                t = t.divide(t2);
            } catch (Exception e) {
                e.printStackTrace();
                Log.e(TAG, e.toString());
            }
        }

        if (type == 0) // 滚动模式
        {
            // 预采样深度计�?

            preSampReg.setPreVol(0);

            // 后采样时间计�?
            // =准存储深�?每次滚动的时间Tg/一屏的时间�?
            int x = virSceenCols;
            int cols = getColsPerRefresh_scollMode(x);
            if ((cols & 0x01) == 0x01) {
                cols++;
            }
            // 计算最后一次刷新时，超出屏幕部�?
            int n = x / cols;
            int rev = x % cols;
            if (rev != 0) {
                n += 1;
                rev = cols - rev;
            }
            scrollRowReg.setColsPerRefresh(cols);
            scrollRowReg.setLastInvalidCols(rev);

            slowScaleSetReg.setNumsReferesh(n);

            long c = zunDepth;

            c = cols * c / x;
            preSampReg.setPostVolL((int) (c & 0xFFFFFFFFL));
            preSampReg.setPostVolH((int) ((c >>> 32) & 0xFFFFFFFFL));

        } else {
            // 预采样深度计算
            // 延迟模式
            // =准存储深度/2-(触发位置时间*准存储深度)/(显示屏数*一屏的时间);
            // 非延迟模式
            // =准存储深度/2-(触发位置像素时间*准存储深度)/一屏的像素时间；
            long m = (long) zunDepth / 2;
            BigInteger c = BigInteger.valueOf(m);
            c = c.subtract(t);
            // 钳位处理
            m = (long) zunDepth;
            if (c.compareTo(BigInteger.valueOf(0)) < 0) {
                c = BigInteger.valueOf(0);
            } else if (c.compareTo(BigInteger.valueOf(m)) > 0) {
                c = BigInteger.valueOf(m);
            }
            int val = c.intValue();

            preSampReg.setPreVol(val);
            if (bPrintf) Logger.i("preSampVol=" + val);

            // 后采样时间计算
            // 延迟模式
            // =准存储深度/2+(触发位置时间*准存储深度)/(显示屏数*一屏的时间);
            // 非延迟模式
            // =准存储深度/2+(触发位置像素时间*准存储深度)/一屏的像素时间；
            m = (long) zunDepth / 2;
            c = BigInteger.valueOf(m);
            c = c.add(t);
            // 钳位处理
            if (c.compareTo(BigInteger.valueOf(0)) < 0) {
                c = BigInteger.valueOf(0);
            }
            long lval = c.longValue();
            if (bPrintf) Logger.i("PostVol=" + lval);
            preSampReg.setPostVolL((int) (lval & 0xFFFFFFFFL));
            preSampReg.setPostVolH((int) ((lval >>> 32) & 0xFFFFFFFFL));

            if (scope.isInSlowScaleMode()) { // 慢时基模式处理
                // 后采样时间计算
                // =准存储深度*每次滚动的时间Tg/一屏的时间;
                int x = virSceenCols;
                int cols = getColsPerRefresh_scollMode(x);
                if ((cols & 0x01) == 0x01) {
                    cols++;
                }

                // 前采样列数=预采样深度/每列多少组采样点
                double y = (double) zunDepth / x;
                slowScaleSetReg.setColsPreSamp((int) (preSampReg.getPreVol() / y + 0.5));
                slowScaleSetReg.setSampsPerLie((int) (y + 0.1));
                int temp = (int) (y * 100 + 0.5);
                temp = temp % 100;

                // 每列采样数有可能是小数
                switch (temp) {
                    case 25: // .25
                        slowScaleSetReg.setSampsPerLie_pt(1);
                        temp = 4;
                        break;
                    case 50: // .5
                        slowScaleSetReg.setSampsPerLie_pt(2);
                        temp = 2;
                        break;
                    case 75: // .75
                        slowScaleSetReg.setSampsPerLie_pt(3);
                        temp = 4;
                        break;
                    default:
                        slowScaleSetReg.setSampsPerLie_pt(0);
                        temp = 0;
                        break;
                }
                if (temp != 0) cols = cols + temp - cols % temp;
                scrollRowReg.setColsPerRefresh(cols);

                // 计算触发位置
                long z = (long) (lval / y + 0.01); // 后采样列数
                // 后采样时间必须是整数列，否者会产生误差
                lval = (long) (z * y + 0.01);
                int xx = 0; // 触发位置在屏幕内
                if (z > x) {
                    // 触发位置在屏幕外，左边
                    xx = (int) (z - x);
                }
                slowScaleSetReg.setColsTrigPlace(xx);

                // 计算后采样需要完成多少次刷新
                // 计算最后一次刷新时，超出屏幕部分
                int n = (int) (z / cols);
                int rev = (int) (z % cols);
                if (rev != 0) {
                    n += 1;
                    rev = cols - rev;
                }

                scrollRowReg.setLastInvalidCols(rev);
                slowScaleSetReg.setNumsReferesh(n);
                // long cc = zunDepth;
                // cc = cc * cols / virSceenCols;
                long cc = (long) (cols * y + 0.1);
                preSampReg.setPostVolL((int) (cc & 0xFFFFFFFFL));
                preSampReg.setPostVolH((int) ((cc >>> 32) & 0xFFFFFFFFL));

                preSampReg.setPreVol((int) (preSampReg.getPreVol() + y));

                // 计算第一次刷新时，需要多少数据
                long z1 = lval - zunDepth;
                FPGAReg_ZUN_DEPTH zun_depthReg =
                        (FPGAReg_ZUN_DEPTH) getFPGAReg(fpgaIdx, FPGAReg.FPGA_ZUN_DEPTH);
                if (z1 <= 0) {
                    zun_depthReg.Set_zunDepth((int) (cc - z1));
                } else {
                    zun_depthReg.Set_zunDepth((int) (cc - z1 % cc));
                }
                sendCommand(zun_depthReg);
            }
        }
        sendCommand(scrollRowReg);
        sendCommand(preSampReg);
        sendCommand(slowScaleSetReg);
        if (type == 0) {
            setDataFreq(fpgaIdx, 30, 5);
        }
    }

    public void gntR_CouY(int fpgaIdx) {
        Scope scope = Scope.getInstance();
        FPGAReg_NUM_CY12 couyReg = (FPGAReg_NUM_CY12) getFPGAReg(fpgaIdx, FPGAReg.FPGA_NUM_CY12);
        FPGAReg_CY_BUCONG couybcReg =
                (FPGAReg_CY_BUCONG) getFPGAReg(fpgaIdx, FPGAReg.FPGA_CY_BUCONG);

        // 始终以最高采样速率采样，然后抽�?
        int couY = 1;
        long a = scope.maxSampClk();
        a = a * 1000 * 1000 * 1000L; // 换算成mHz
        double fs = scope.getSampleRate(scope.isRun(true));

        long b = (long) (fs * 1000 + 0.1);

        int cy = (int) (a / b);
        if (a % b != 0) {
            Log.e(TAG, "samp: can not couY to " + b + "mHz");
        }
        couyReg.setVol12(cy);

        if (cy == 1) {
            couY = 0;
        }

        switch (scope.getChannelSampOnCnt(scope.isRun(true))) {
            case 2:
            case 4:
                cy = (int) Math.ceil((double) cy / 5.0);
                break;
            case 8:
            default:
                cy = (int) Math.ceil((double) cy / 2.5);
                break;
        }

        couyReg.setVol34(cy);

        sendCommand(couyReg);
        couybcReg.setCyType12(couY);
        couybcReg.setCyType34(couY);
        sendCommand(couybcReg);
    }

    public void gntR_serial_dec_depth(int fpgaIdx) {
        FPGAReg_SERIAL_DEC_DEPTH serialDecReg =
                (FPGAReg_SERIAL_DEC_DEPTH) getFPGAReg(fpgaIdx, FPGAReg.FPGA_SERIAL_DEC_DEPTH);
        Display display = Display.getInstance();
        Scope scope = Scope.getInstance();

        // 显示屏数*一屏的时间/40ns�?
        // 计算屏数
        double screeNum; // 最多只会有2位小�?
        long timeOneScreen;

        if (display.isZoom()) {
            screeNum = scope.screenNum_zoom(scope.isRun(true));
            timeOneScreen = scope.timeOneScreen_zoom();
        } else {
            screeNum = scope.screenNum_Main(scope.isRun(true));
            timeOneScreen = scope.timeOneScreen_main();
        }

        long x = (long) (screeNum * 100 + 0.1);
        x = x * timeOneScreen / (100 * 40 * 10000); // 0.1ps
        serialDecReg.setDecDepth((int) x);

        sendCommand(serialDecReg);
    }

    private double channelCoef(int chIdx, int idx) {
        double val = 0;
        Channel channel = ChannelFactory.getDynamicChannel(chIdx);
        if (channel != null) {
            CabteRegister cabteRegister = CabteRegister.getInstance();
            double vScaleVal =
                    VerticalAxis.clampMin(channel.getVScaleVal() / channel.getProbeRate(),channel.getResistanceType());
            if (isCalibrate()
                    && isZeroCalibrate()) {

                val =
                        cabteRegister.vol_ChannelCoef_defaultEx(channel.getChId(),
                                channel.getVScaleId(), pgaVal & 0xFF);
            } else {
                val = cabteRegister.calc_coefChannel(chIdx, vScaleVal, idx);
            }
        }
        Log.d("MHO38V1","ch" + chIdx + ":" + (-val) + "," + channel.getVScaleIdVal());
        return -val;
    }

    private synchronized double getChannelZero(int chIdx) {
        float val = 0;

        CabteRegister cabteRegister = CabteRegister.getInstance();
        int[] result = {pgaVal, 0, 0, 0,0};
        Channel channel = ChannelFactory.getDynamicChannel(chIdx);
        if (channel != null) {
            double vScaleVal =
                    VerticalAxis.clampMin(channel.getVScaleVal() / channel.getProbeRate(),channel.getResistanceType());
            int idx = CabteRegister.getRatioIdx(channel.getResistanceType(),vScaleVal);
            if (isCalibrate()
                    && isZeroCalibrate()) {
                val = cabteRegister.getChannelZero(chIdx, idx, pgaVal & 0xFF);
            } else {
                cabteRegister.calc_pga_fs_gain(channel.getChId(), vScaleVal, result);

                val = cabteRegister.getChannelZero(chIdx, idx, result[0] & 0xFF);

            }
        }

        return DoubleUtil.Float2Double(val);
    }

    private int getDA_Vol(Channel channel) {

        boolean bInvert = channel.isInvert();
        double chOffset = channel.getZero() + channel.getChOffset() * ScopeBase.getToFPGACoff();
        double offset,coef,zero;
        int vol;
        zero = getChannelZero(channel.getChId());

        if(!HardwareProduct.isMHO38V1()){
            int dang = CabteRegister.getRatioIdx(Channel.RESISTANCE_1M,channel.getVScaleVal()/channel.getProbeRate());
            if (channel.getResistanceType() == Channel.RESISTANCE_1M
                    && dang != HW.RATIO_DANG_1) {
                bInvert = !bInvert;
                chOffset = - chOffset;
            }
        }
        if (bInvert) {
            offset = (double) channel.getPos() - chOffset;
            offset /= channel.getYFactor();
            coef = channelCoef(channel.getChId(), offset >= 0 ? 0 : 1);
            vol = (int) Math.round(zero - coef * offset);

        }else{
            offset = (double) channel.getPos() + chOffset;
            offset /= channel.getYFactor();
            coef = channelCoef(channel.getChId(), offset >= 0 ? 0 : 1);
            vol = (int) Math.round(zero + coef * offset);
        }
        if (vol < 0) {
            vol = 0;
        } else if (vol > 65535){
            vol = 65535;
        }
        return vol;
    }

    private double getValueDifferentCoef(int chIdx) {
        return 1.0;
    }

    private double ADGear2PixBuf_fromVScale(int chIdx, int volScaleId) {
        return hwConfig.getAdValPerPix();
    }

    private static final int MAX_m = ((1 << 17) - 5);
    private static final int MIN_m = (-(1 << 17) + 5);

    public void gntR_ch_y_place(int fpgaIdx) {
        Scope scope = Scope.getInstance();
        if (!scope.isRun(true)) return;
        FPGAReg_CH_Y_PLACE chyplaceReg =
                (FPGAReg_CH_Y_PLACE) getFPGAReg(fpgaIdx, FPGAReg.FPGA_CH_Y_PLACE);
        FPGAReg_CH_Y_PLACE_BC chyplacebcReg =
                (FPGAReg_CH_Y_PLACE_BC) getFPGAReg(fpgaIdx, FPGAReg.FPGA_CH_Y_PLACE_BC);

        Display display = Display.getInstance();
        int[] m = {0, 0, 0, 0};
        int[] n = {0, 0, 0, 0};
        int[] place_bc = {0, 0, 0, 0};
        // int chIdx = 0;
        Channel channel;

        int beginIdx = beginChIdx(fpgaIdx);
        int endIdx = endChIdx(fpgaIdx);
        int j;
        boolean[] chSample = new boolean[ChannelFactory.CH_CNT];
        int chCnt = scope.getChannelSampOnCnt(scope.isRun(true), chSample);
        int halfHeight = ScopeBase.getHeight() / 2;
        for (int i = beginIdx; i < endIdx; i++) {
            j = i - beginIdx;
            if (!chSample[i]) continue;
            channel = ChannelFactory.getDynamicChannel(i);
            if (channel == null) {
                continue;
            }

            int dang = channel.getVScaleId();
            double pos = channel.getPos() / channel.getYFactor();
            double zero = getChannelZero(channel.getChId());
            double coef = channelCoef(channel.getChId(), pos >= 0 ? 0 : 1); // 取偏移量系数
            double iValue = zero + pos * coef;
            if (iValue < 0) {
                iValue = 0;
            } else if (iValue > 65535) {
                iValue = 65535;
            }else{
                Logger.d(TAG, "ch:" + channel.getChId() + ",zero:" + zero + ",pos:" + pos + ",coef:" + coef);
            }

            double z = (Math.round(iValue) - zero) / coef; // 计算通道指示器相对与中心的偏移（上负下正）

            // config.vPosOfZeroFix(true, chIdx) = z;
            channel.setPosFix(z * channel.getYFactor()); // 保存修正值，在静态波形、触发、查找表中会用到

            // 因档位不同，取不同的【AD值与屏幕像素的对应系数】
            double a = getValueDifferentCoef(channel.getChId());
            double k = ADGear2PixBuf_fromVScale(channel.getChId(), dang) * a;

            // printf("channel %d diffent vol=%f\n", i+1, a);
            // fAD2Pix[i] = k;
            channel.setAdPix(k);
            // 当通道偏移量移动到比较远时，可能导致m计算时溢出，这是进行相关处理
            if (z > 500) {
                place_bc[j] = (int) (-(z - 500));
                z = 500;

            } else if (z < -500) {
                place_bc[j] = (int) (-(z + 500));
                z = -500;
            }

            // iPlace_bc[i] = place_bc[i];
            channel.setPlaceVal(place_bc[j] * hwConfig.getPix2AdFactor());
            place_bc[j] = 0;

            // place_bc[i] = z1;

            double fx = z * hwConfig.getYPlaceFactor() / k ;

            if (fx > MAX_m) fx = MAX_m;
            else if (fx < MIN_m) fx = MIN_m;

            int vol_m = (int) (fx + (fx > 0 ? 0.5 : -0.5)); // 进行舍入
            int vol_n = (int) (k * 256 + 0.5);
            // if(bXYMode) vol_n = 1*256;
            if (display.isXYMode()
                    || (isCalibrate() && isChGainCalibrate())) {
                vol_n = 256;
                channel.setPlaceVal(0);
            }

            m[j] = -vol_m;
            n[j] = vol_n;

            channel.setM(m[j]);
            channel.setN(n[j]);

        }


        int xcnt = 0;
        int sIdx = 0;
        int s1 = 0;
        int sbit = 0;
        switch (chCnt) {
            case 2:
                xcnt = 4;
                break;
            case 4:
                xcnt = 2;
                break;
            case 8:
            default:
                xcnt = 1;
                break;
        }

        int idx = 0;
        for (int i = beginIdx; i < endIdx; i++) {
            idx = i - beginIdx;
            if (chSample[i]) {
                for (j = 0; j < xcnt; j++) {
                    chyplaceReg.setVolm(sIdx + j, m[idx]);
                    chyplaceReg.setVoln(sIdx + j, n[idx]);
                    chyplacebcReg.setVal(s1, sbit, 16, place_bc[idx]);
                    sbit += 16;
                    if (sbit >= 32) {
                        sbit = 0;
                        s1 += 1;
                    }
                }
                sIdx += xcnt;
                chCnt--;
            }
            if (chCnt == 0) break;
        }
        sendCommand(chyplaceReg);
        sendCommand(chyplacebcReg);
    }

    public void gntR_trigMode(int fpgaIdx) {
        Scope scope = Scope.getInstance();
        FPGAReg_TRIG_MODE reg = (FPGAReg_TRIG_MODE) getFPGAReg(fpgaIdx, FPGAReg.FPGA_TRIG_MODE);
        reg.setVal(0, 4, 0);
        reg.setVal(12, 15, 0xF);
        reg.setJiaoZhun(bCalibrate_ad_diffGain ? 1 : 0); // AD增益校准时需要设置为1;

        TriggerCommon triggerCommon = TriggerFactory.getInstance().getTriggerCommon();
        Trigger trigger = TriggerFactory.getInstance().getTrigger();
        int beginIdx = beginChIdx(fpgaIdx);
        int endIdx = endChIdx(fpgaIdx);
        boolean[] sel = new boolean[ChannelFactory.CH_CNT];
        int chCnt = scope.getChannelSampOnCnt(scope.isRun(true), sel);
        int selCh = trigger.getTriggerSource();

        if (selCh == 8) {//外部触发
            reg.setExternalTrigger(1);
        } else {
            reg.setExternalTrigger(0);
        }
//        chCnt /= adcNums;
        if(chCnt <= adcNums){
            selCh = (selCh / 4) * 4  + (selCh % 4) / 2;
        }
        reg.setTrigSource(selCh);
        reg.setNomalTrig(triggerCommon.getTriggerMode());
        reg.setForceTrig(0);
        int triggerType = triggerCommon.getTriggerType();
        switch (triggerType) {
            case Trigger.TRIG_TYPE_EDGE:
                {
                    TriggerEdge triggerEdge = (TriggerEdge) trigger;
                    reg.setTrigType(0);
                    reg.setTrigParam(triggerEdge.getTriggerEdge() & 0x07);
                }
                break;


            case Trigger.TRIG_TYPE_SERIAL1:
            case Trigger.TRIG_TYPE_SERIAL2:
            case Trigger.TRIG_TYPE_SERIAL3:
            case Trigger.TRIG_TYPE_SERIAL4:
                reg.setTrigType(4);
                reg.setTrigBus(triggerType - Trigger.TRIG_TYPE_SERIAL1);
                break;
            case Trigger.TRIG_TYPE_LOW_PULSE:
                {
                    TriggerRunt triggerRunt = (TriggerRunt) trigger;
                    reg.setTrigType(5);
                    reg.setTrigParam(triggerRunt.getCondition() | (triggerRunt.getPolarity() << 4));
                    int lowTime = (int) Trigger.triggerTime2FpgaUnit(triggerRunt.getTimeLow());
                    int highTime = (int) Trigger.triggerTime2FpgaUnit(triggerRunt.getTimeHigh());
                    if (triggerRunt.getCondition() == TriggerRunt.RUNT_RELATION_LESSER) {
                        reg.setTrigValL(highTime);
                        reg.setTrigValH(highTime);
                    } else {
                        reg.setTrigValL(lowTime);
                        reg.setTrigValH(highTime);
                    }
                    break;
                }
            case Trigger.TRIG_TYPE_PULSE:
                {
                    TriggerPulseWidth triggerPulseWidth = (TriggerPulseWidth) trigger;
                    reg.setTrigType(1);
                    if (triggerPulseWidth.getCondition() == TriggerPulseWidth.PW_RELATION_NOT_EQUAL) {
                        reg.setTrigParam(TriggerPulseWidth.PW_RELATION_EQUAL);
                    } else {
                        reg.setTrigParam(triggerPulseWidth.getCondition());
                    }
                    int x = triggerPulseWidth.getPolarity();
                    for (int i = beginIdx; i < endIdx; i++) {
                        reg.setTrigPolarityCh(i-beginIdx, x);
                    }

                    int vol = (int) Trigger.triggerTime2FpgaUnit(triggerPulseWidth.getPwTime());
                    int lowTime = (int) Trigger.triggerTime2FpgaUnit(triggerPulseWidth.getTimeLow());
                    int highTime = (int) Trigger.triggerTime2FpgaUnit(triggerPulseWidth.getTimeHigh());
                    switch (triggerPulseWidth.getCondition()) {
                        case TriggerPulseWidth.PW_RELATION_EQUAL:
                            reg.setTrigValL((int) Math.floor(1.0 * vol * 0.95 + 0.5));
                            reg.setTrigValH((int) Math.ceil(1.0 * vol * 1.05 + 0.5));
                            break;
                        case TriggerPulseWidth.PW_RELATION_LESSER://小于的时候 FPGA用最小值来判断的
                            reg.setTrigValL(highTime);
                            reg.setTrigValH(0);
                            break;
                        default:
                            reg.setTrigValL(lowTime);
                            reg.setTrigValH(highTime);
                            break;
                    }
                    break;
                }
            case Trigger.TRIG_TYPE_LOGIC:
                {
                    TriggerLogic triggerLogic = (TriggerLogic) trigger;
                    reg.setTrigType(2);
                    if (triggerLogic.getCondition() == TriggerLogic.LOGIC_RELATION_NOT_EQUAL) {
                        reg.setTrigParam(TriggerLogic.LOGIC_RELATION_EQUAL | ((triggerLogic.getLogic() << 3)));
                    } else {
                        reg.setTrigParam(triggerLogic.getCondition() | ((triggerLogic.getLogic() << 3)));
                    }

                    switch (chCnt) {
                        case 2:
                            {
                                for (int i = beginIdx; i < endIdx; i++) {
                                    if (sel[i]) {
                                        if (TriggerFactory.isTriggerSource(i)) {
                                            for (int j = 0; j < 4; j++) {
                                                reg.setTrigPolarityCh(
                                                        j, triggerLogic.getLogicValid(i));
                                            }
                                        }
                                        for (int j = 0; j < 4; j++) {
                                            reg.setLogicCh(
                                                    j,
                                                    triggerLogic.getLogicValid(i)
                                                                    == TriggerLogic.LOGIC_NONE
                                                            ? 1
                                                            : 0);
                                        }
                                    }
                                }
                                break;
                            }
                        case 4:
                            {
                                int it = 0;
                                for (int i = beginIdx; i < endIdx; i++) {
                                    if (sel[i]) {
                                        if (TriggerFactory.isTriggerSource(i)) {
                                            reg.setTrigPolarityCh(
                                                    it, triggerLogic.getLogicValid(i));
                                            reg.setTrigPolarityCh(
                                                    it + 1, triggerLogic.getLogicValid(i));
                                        }
                                        reg.setLogicCh(
                                                it,
                                                triggerLogic.getLogicValid(i)
                                                                == TriggerLogic.LOGIC_NONE
                                                        ? 1
                                                        : 0);
                                        reg.setLogicCh(
                                                it + 1,
                                                triggerLogic.getLogicValid(i)
                                                                == TriggerLogic.LOGIC_NONE
                                                        ? 1
                                                        : 0);
                                        it += 2;
                                    }
                                }
                                break;
                            }
                        case 8:
                        default:
                        {
                            for (int i = beginIdx; i < endIdx; i++) {
                                reg.setTrigPolarityCh(
                                        i - beginIdx, triggerLogic.getLogicValid(i));
                                reg.setLogicCh(
                                        i - beginIdx,
                                        triggerLogic.getLogicValid(i) == TriggerLogic.LOGIC_NONE
                                                ? 1
                                                : 0);
                            }
                            break;
                        }
                    }
                    long vol = Trigger.triggerTime2FpgaUnit(triggerLogic.getLogicTime());
                    int lowTime = (int) Trigger.triggerTime2FpgaUnit(triggerLogic.getTimeLow());
                    int highTime = (int) Trigger.triggerTime2FpgaUnit(triggerLogic.getTimeHigh());
                    switch (triggerLogic.getCondition()) {
                        case TriggerLogic.LOGIC_RELATION_EQUAL:
                            reg.setTrigValL((int) (vol * 95 / 100));
                            reg.setTrigValH((int) (vol * 105 / 100));
                            break;
                        case TriggerPulseWidth.PW_RELATION_LESSER://小于的时候 FPGA用最小值来判断的
                            reg.setTrigValL(highTime);
                            reg.setTrigValH(0);
                            break;
                        default:
                            reg.setTrigValL(lowTime);
                            reg.setTrigValH(highTime);
                            break;
                    }
                    break;
                }
            case Trigger.TRIG_TYPE_VIDEO:
                {
                    TriggerVideo triggerVideo = (TriggerVideo) trigger;
                    reg.setTrigType(3);
                    for (int i = beginIdx; i < endIdx; i++) {
                        reg.setTrigPolarityCh(i - beginIdx, triggerVideo.getPolarity());
                    }

                    reg.setTrigParam(
                            triggerVideo.getVideoTrigger()
                                    | (triggerVideo.getStandard() << 3)
                                    | (triggerVideo.getVideoFrequency() << 6)
                                    | (triggerVideo.getStandard()
                                                    >= TriggerVideo.VIDEO_STANDARD_720P
                                            ? (1 << 9)
                                            : 0));
                    reg.setTrigValL(triggerVideo.getLine());
                    reg.setTrigValH(triggerVideo.triggerVideoTimeFieldLine());
                    break;
                }
            case Trigger.TRIG_TYPE_TIMEOUT:
                {
                    TriggerTimeOut triggerTimeOut = (TriggerTimeOut) trigger;
                    reg.setTrigType(6);
                    reg.setTrigParam(triggerTimeOut.getPolarity());
                    reg.setTrigValL(
                            (int) Trigger.triggerTime2FpgaUnit(triggerTimeOut.getTimeOutTime()));

                    break;
                }
            case Trigger.TRIG_TYPE_SLOPE:
                {
                    TriggerSlope triggerSlope = (TriggerSlope) trigger;
                    reg.setTrigType(7);
                    reg.setTrigParam(triggerSlope.getCondition() | (triggerSlope.getEdge() << 4));
                    int lowTime = (int) Trigger.triggerTime2FpgaUnit(triggerSlope.getTimeLow());
                    int highTime = (int) Trigger.triggerTime2FpgaUnit(triggerSlope.getTimeHigh());
                    if (triggerSlope.getCondition() == TriggerSlope.SLOPE_RELATION_LESSER) {
                        reg.setTrigValL(highTime);
                        reg.setTrigValH(highTime);
                    } else {
                        reg.setTrigValL(lowTime);
                        reg.setTrigValH(highTime);
                    }
                    break;
                }
            case Trigger.TRIG_TYPE_NEDGE:
                {
                    TriggerNEdge triggerNEdge = (TriggerNEdge) trigger;
                    reg.setTrigType(8);
                    reg.setTrigParam(triggerNEdge.getSlope());
                    reg.setTrigValL((int) Trigger.triggerTime2FpgaUnit(triggerNEdge.getIdleTime()));
                    reg.setTrigValH(triggerNEdge.getEdge());
                    break;
                }
        }
        sendCommand(reg);
    }

    public void gntR_trigRestrainTime(int fpgaIdx) {
        FPGAReg_TRIG_RESTRAIN_TIME reg =
                (FPGAReg_TRIG_RESTRAIN_TIME) getFPGAReg(fpgaIdx, FPGAReg.FPGA_TRIG_RESTRAIN_TIME);
        long lx = TriggerFactory.getInstance().getTriggerCommon().getTriggerHoldOffTime();
        reg.setRestrainTime((int) TriggerCommon.trriggerHoldOffTime2FpgaUnit(lx));
        sendCommand(reg);
    }

    private int getTriggerEnterAutoTime() {
        long time =
                (long)
                        (scope.timeScale_mainBoard()
                                        * scope.screenNum_Main(scope.isRun(true))
                                        * ScopeBase.getHorizonGridCnt()
                                        * 1500
                                + 0.1);
        int type = TriggerFactory.getTriggerType();
        if (type == Trigger.TRIG_TYPE_NEDGE) {
            if (time < 1000) time = 1000;
            TriggerNEdge nEdge = (TriggerNEdge) TriggerFactory.getTriggerObj();

            long idleTime = nEdge.getIdleTime() * 8 * 2;
            if (time * 1e6 < idleTime) {
                time = (long) (idleTime / 1e6);
            }
        }
        if ((type == Trigger.TRIG_TYPE_SERIAL1)
                || (type == Trigger.TRIG_TYPE_SERIAL2)
                || (type == Trigger.TRIG_TYPE_SERIAL3)
                || (type == Trigger.TRIG_TYPE_SERIAL4)) {
            time = 1000;
        }
        // if(time < 1000) time = 1000;

        if (time < 200) time = 200;
        // lao yang rang da yu 5秒
        if (time > 5 * 1000) {
            time = 5 * 1000;
        }
        return (int) time;
    }

    public void gntR_trigAutoTime(int fpgaIdx) {
        FPGAReg_TRIG_AUTO_TRIG_TIME reg =
                (FPGAReg_TRIG_AUTO_TRIG_TIME) getFPGAReg(fpgaIdx, FPGAReg.FPGA_TRIG_AUTO_TRIG_TIME);
        if (isCalibrate()) reg.setTrigTime(1, 0);
        else {
            int ixx = 0;
            int ix = getTriggerEnterAutoTime();
            if (ix < 0 || ix > ((1 << 25) - 1)) ix = (1 << 25) - 1;
            int x = HorizontalAxis.getInstance().getTimeScaleIdOfView(HorizontalAxis.WPI_STANDARD);

            if (x <= HorizontalAxis.TSI_20mS) ix |= (3 << 30);
            else if (x == HorizontalAxis.TSI_10mS) ix |= (2 << 30);
            else if (x == HorizontalAxis.TSI_5mS) ix |= (1 << 30);

            if (x <= HorizontalAxis.TSI_20mS) {
                ixx = 100;
            } else if (x <= HorizontalAxis.TSI_10mS) {
                ixx = 50;
            } else if (x <= HorizontalAxis.TSI_5mS) {
                ixx = 20;
            } else {
                ixx = 9;
            }
            reg.setTrigTime(ix, ixx);
        }

        sendCommand(reg);
    }

    public void setTrigHuiCha(int[] x_rise_fall /*Integer x_rise,Integer x_fall*/) {

        // 注意：由于fpga使用触发电平时扩�?倍，所以回差值也是相对于AD值扩�?�?
        Channel channel;
        int tmp = 0;
        Scope scope = Scope.getInstance();
        Trigger trigger = TriggerFactory.getInstance().getTrigger();
        x_rise_fall[0] = 8;
        x_rise_fall[1] = 8;

        int trigSrcCnt = trigger.getTriggerSourceCnt();
        if (trigSrcCnt == 1) {
            channel = ChannelFactory.getDynamicChannel(trigger.getTriggerSource());
            if (channel == null) return;
            int y = channel.getVScaleId();
            // 触发源为静态变量，所以以何种触发类型去获取都一样，这里用边沿触�?

            switch (y) {
                case VerticalAxis.DANG_500uV:
                    x_rise_fall[0] = 50;
                    break;
                case VerticalAxis.DANG_1mV:
                    x_rise_fall[0] = 38;
                    break;
                case VerticalAxis.DANG_2mV:
                    x_rise_fall[0] = 20;
                    break;
                case VerticalAxis.DANG_5mV:
                    x_rise_fall[0] = 20;
                    break;
                case VerticalAxis.DANG_10mV:
                case VerticalAxis.DANG_20mV:
                case VerticalAxis.DANG_50mV:
                    x_rise_fall[0] = 10; // 4
                    break;
                default:
                    x_rise_fall[0] = 8;
                    break;
            }
            x_rise_fall[0] += 8;

            x_rise_fall[1] = x_rise_fall[0];

            switch (trigger.getTriggerType()) {
                case Trigger.TRIG_TYPE_LOGIC:
                    TriggerLogic triggerLogic = (TriggerLogic) trigger;
                    int logicCondition = triggerLogic.getCondition();
                    if (logicCondition == Trigger.TRIGGER_RELATION_TRUE) {
                        x_rise_fall[0] = 0;
                    } else if (logicCondition == Trigger.TRIGGER_RELATION_FALSE) {
                        x_rise_fall[1] = 0;
                    }
                    break;
                case Trigger.TRIG_TYPE_EDGE:
                    {
                        TriggerEdge triggerEdge = (TriggerEdge) trigger;
                        int tedge = triggerEdge.getTriggerEdge();
                        if (tedge == TriggerEdge.TET_ASC) // 上升�?
                        {
                            x_rise_fall[0] = 0;
                        } else if (tedge == TriggerEdge.TET_DSC) // 下降�?
                        {
                            x_rise_fall[1] = 0;
                        }
                        //                    else {
                        //                        //x_rise_fall[0] = 0;
                        //                        //x_rise_fall[1] = 0;
                        //                    }
                    }
                    break;
                case Trigger.TRIG_TYPE_LOW_PULSE: // 矮脉�?
                    {
                        TriggerRunt triggerRunt = (TriggerRunt) trigger;
                        int polarity = triggerRunt.getPolarity();
                        if (polarity == TriggerRunt.RUNT_POLARITY_POSITIVE) {
                            x_rise_fall[1] = 0;
                        } else if (polarity == TriggerRunt.RUNT_POLARITY_NEGATIVE) {
                            x_rise_fall[0] = 0;
                        }
                        break;
                    }
                case Trigger.TRIG_TYPE_PULSE: // 脉宽触发
                    {
                        TriggerPulseWidth triggerPulseWidth = (TriggerPulseWidth) trigger;
                        if (triggerPulseWidth.getPolarity()
                                == TriggerPulseWidth.PW_POLARITY_POSITIVE) {
                            x_rise_fall[1] = 0;
                        } else {
                            x_rise_fall[0] = 0;
                        }
                        break;
                    }
                case Trigger.TRIG_TYPE_TIMEOUT: // 超时触发
                    {
                        TriggerTimeOut triggerTimeOut = (TriggerTimeOut) trigger;
                        if (triggerTimeOut.getPolarity()
                                == TriggerTimeOut.TIMEOUT_POLARITY_POSITIVE) {
                            x_rise_fall[0] = 0;
                        } else {
                            x_rise_fall[1] = 0;
                        }
                        break;
                    }
                default:
                    break;
//                case Trigger.TRIG_TYPE_LOW_PULSE: // 矮脉�?
                case Trigger.TRIG_TYPE_SLOPE: // 斜率触发
                    x_rise_fall[0] = 0;
                    x_rise_fall[1] = 0;
                    break;
                case Trigger.TRIG_TYPE_NEDGE: // 第n边沿触发
                    {
                        TriggerNEdge triggerNEdge = (TriggerNEdge) trigger;
                        int edgeType = triggerNEdge.getSlope();
                        if (edgeType == TriggerNEdge.TET_ASC) {
                            x_rise_fall[0] = 0;
                        } else if (edgeType == TriggerNEdge.TET_DSC) {
                            x_rise_fall[1] = 0;
                        }
                        break;
                    }
            }
        }
        // Logger.d("x_rise = " + x_rise_fall[0] + ",x_fall = " + x_rise_fall[1]);
    }

    public void setTriggerLevelReg(
            int fpgaIdx, int value, int trigIdx, int riseHuiCha, int fallHuiCha) {

        if (!ChannelFactory.isDynamicCh(trigIdx)
                || !isFpgaChIdx(fpgaIdx,trigIdx)) // NONE触发源不用处�?
            return;
        Scope scope = Scope.getInstance();
        FPGAReg reg = getFPGAReg(fpgaIdx, FPGAReg.FPGA_TRIG_LEVEL);

        int x1 = value + 512 * 32 + riseHuiCha * 32;
        int x2 = value + 512 * 32 - fallHuiCha * 32;

        int bOF = 0;
        if (x1 > 32767 || x1 < 0) bOF = 1;
        if (x2 > 32767 || x2 < 0) bOF = 1;
        int cnt = 0;
        int beginIdx = beginChIdx(fpgaIdx);
        int endIdx = endChIdx(fpgaIdx);
        boolean[] sel = new boolean[ChannelFactory.CH_CNT];
        cnt = scope.getChannelSampOnCnt(scope.isRun(true), sel);
        int idx = 0;
        switch (cnt) {
            case 2:
                cnt = 4;
                idx = 0;
                break;
            case 4:
                for (int i = beginIdx; i < endIdx; i++) {
                    if (sel[i]) {
                        if (i == trigIdx) idx = 0;
                        else idx = 2;
                        break;
                    }
                }
                cnt = 2;
                break;
            case 8:
            default:
                idx = trigIdx-beginIdx;
                if(idx < 0) idx = 0;
                cnt = 1;
                break;
        }
        cnt = cnt + idx;
        for (int i = idx; i < cnt; i++) {
            reg.setVal(i, 0, 15, x1);
            reg.setVal(i, 15, 1, bOF);
            reg.setVal(i, 16, 15, x2);
            reg.setVal(i, 31, 1, bOF);
        }
    }

    public void setTriggerLevelReg_snd(int fpgaIdx, int value, int riseHuiCha, int fallHuiCha) {
        FPGAReg reg = getFPGAReg(fpgaIdx, FPGAReg.FPGA_TRIG_LEVEL);
        int x1 = value + 512 * 32 + riseHuiCha * 32;
        int x2 = value + 512 * 32 - fallHuiCha * 32;

        int bOF = 0; // 溢出标记 =1溢出
        if (x1 > 32767 || x1 < 0) bOF = 1;
        if (x2 > 32767 || x2 < 0) bOF = 1;

        reg.setVal(4, 0, 15, x1);
        reg.setVal(4, 15, 1, bOF);
        reg.setVal(4, 16, 15, x2);
        reg.setVal(4, 31, 1, bOF);
    }

    public double ADGear2PixBuf(int chIdx, boolean autoAdj) {

        int adGear = 0;
        Channel channel = ChannelFactory.getDynamicChannel(chIdx);
        if (channel != null) {
            adGear = channel.getVScaleId();
            if (!Scope.getInstance().isRun(true) && autoAdj) {
                VerticalAxis verticalAxis = ScopeFrozen.getInstance().getChVertical(chIdx);
                if (verticalAxis != null) {
                    adGear = verticalAxis.getScaleId();
                }
            }
        }

        return ADGear2PixBuf_fromVScale(chIdx, adGear);
    }

    public void gntR_trigLevel(int fpgaIdx) {

        FPGAReg reg = getFPGAReg(fpgaIdx, FPGAReg.FPGA_TRIG_LEVEL);
        int[] x_rise_fall = {0, 0};

        setTrigHuiCha(x_rise_fall);
        double sen = TriggerFactory.getInstance().getTriggerCommon().getTriggerSensitivity();
        if(sen < 0.1) sen = 0.1;
        else if(sen > 1) sen = 1;

        double r = hwConfig.getTriggerHuiChaFactor() * sen / 0.5;
        x_rise_fall[0] = (int)Math.round(r * x_rise_fall[0]);
        x_rise_fall[1] = (int)Math.round(r * x_rise_fall[1]);

        Trigger trigger = TriggerFactory.getInstance().getTrigger();
        switch (trigger.getTriggerType()) {
            case Trigger.TRIG_TYPE_EDGE: // 边沿触发
            case Trigger.TRIG_TYPE_PULSE: // 脉宽触发
            case Trigger.TRIG_TYPE_LOW_PULSE: // 矮脉冲
            case Trigger.TRIG_TYPE_SLOPE:
            case Trigger.TRIG_TYPE_NEDGE:
            case Trigger.TRIG_TYPE_TIMEOUT:
            case Trigger.TRIG_TYPE_LOGIC:
                {
                    for (int k = 0; k < trigger.getTriggerSourceCnt(); k++) {
                        int trigSouce = trigger.getTriggerSource(k);
                        Channel channel = ChannelFactory.getDynamicChannel(trigSouce);
                        if (channel != null) {
                            int cnt = trigger.getSrcTriggerLevelCnt();
                            for (int i = 0; i < cnt; i++) {
                                double level = trigger.getTriggerLevel(i, trigSouce).getPos();
                                level += channel.getPosFix();

                                double fx =
                                        level
                                                        * hwConfig.getTriggerLevelFactor()
                                                        / channel.getYFactor()
                                                        / ADGear2PixBuf(trigSouce, false)
                                                + (level > 0 ? 0.5 : -0.5);

                                if (i == 0)
                                    setTriggerLevelReg(
                                            fpgaIdx,
                                            (int) fx,
                                            trigSouce,
                                            x_rise_fall[0],
                                            x_rise_fall[1]);
                                else
                                    setTriggerLevelReg_snd(
                                            fpgaIdx, (int) fx, x_rise_fall[0], x_rise_fall[1]);
                            }
                        }
                    }
                }
            case Trigger.TRIG_TYPE_VIDEO: // 视频触发
            case Trigger.TRIG_TYPE_SERIAL1: // 串行触发
            case Trigger.TRIG_TYPE_SERIAL2: // 串行触发
            case Trigger.TRIG_TYPE_SERIAL3: // 串行触发
            case Trigger.TRIG_TYPE_SERIAL4: // 串行触发
            default:
                break;
        }

        sendCommand(reg);
    }

