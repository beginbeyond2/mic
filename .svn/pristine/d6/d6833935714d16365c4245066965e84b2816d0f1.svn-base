    private boolean bCalibrate_ad_diffGain = false; // AD增益校准时需要设置为1;

    public void setADdiffGainCalib(boolean bx) {
        bCalibrate_ad_diffGain = bx;
    }

    private FPGACommand() {

        mHw = Hardware.getInstance();
        scope = Scope.getInstance();
        hwConfig = HwConfig.getInstance();
        init();
    }

    public synchronized void setFlagCalibrate(boolean flag) {
        bCalibrate = flag;
    }

    public synchronized void setCalibrateType(int calibrateType) {
        this.CalibrateType = calibrateType;
    }
    public synchronized int getCalibrateType(){
        return this.CalibrateType;
    }
    public synchronized boolean isZeroCalibrate(){
        switch (this.CalibrateType){
            case CalibrateService.ZERO_CALIBRATE:
            case CalibrateService.CH_ZERO_CALIBRATE:
            case CalibrateService.AD_OFFSET_CALIBRATE:
                return true;
            default:
                return false;

        }
    }
    public synchronized boolean isChGainCalibrate(){
        return CalibrateType == CalibrateService.CHGAIN_CALIBRATE;
    }

    public synchronized void setPgaVal(int pgaVal) {
        this.pgaVal = pgaVal;
    }

    public synchronized int getPgaVal(){
        return this.pgaVal;
    }
    public synchronized boolean isCalibrate() {
        return bCalibrate;
    }

