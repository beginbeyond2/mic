        reg.setType(FPGAReg_SPI_EXT.SPI_EXT_CLKINOUT);
        reg.setDataLength(1);
        reg.setByteValid(0);
        reg.setVal(1,val);
        sendCommand(reg);
    }
    public void SendProbe(int chIdx, byte[] bytes) {
        int nums = bytes.length / 4;
        int fpgaIdx = chIdxToFpgaIdx(chIdx);
        FPGAReg_SPI_EXT reg = new FPGAReg_SPI_EXT(bytes.length + 4);
        reg.setFpgaIdx(fpgaIdx);
        reg.setType(FPGAReg_SPI_EXT.SPI_EXT_UART);
        reg.setDataLength(nums);
        reg.setByteValid(0);
        reg.setVal(8, 4, 1 << chIdx);
        for (int i = 0; i < nums; i++) {
            reg.setVal(
                    i + 1,
                    (bytes[i * 4] & 0xFF) << 24
                            | (bytes[i * 4 + 1] & 0xFF) << 16
                            | (bytes[i * 4 + 2] & 0xFF) << 8
                            | (bytes[i * 4 + 3] & 0xFF));
        }
        sendCommand(reg);
    }

    private void ms_sleep(long ms) {
        try {
            Thread.sleep(ms);
        } catch (InterruptedException e) {
            e.printStackTrace();
        }
    }

    public void gntR_ChOffsetDa(int fpgaIdx) {
        Channel channel;
        int[] chValue = {0, 0, 0, 0};
        int beginIdx = beginChIdx(fpgaIdx);
        int endIdx = endChIdx(fpgaIdx);
        for (int i = beginIdx; i < endIdx; i++) {
            channel = ChannelFactory.getDynamicChannel(i);
            if (channel != null) {
                chValue[i - beginIdx] = getDA_Vol(channel);
            }
        }
        gntR_ChOffsetDa(fpgaIdx, chValue[0], chValue[1], chValue[2], chValue[3]);
    }

    public void resetChOffset(int fpgaIdx){
        Channel channel;
        int[] chValue = {0, 0, 0, 0};
        int beginIdx = beginChIdx(fpgaIdx);
        int endIdx = endChIdx(fpgaIdx);
        for (int i = beginIdx; i < endIdx; i++) {
            channel = ChannelFactory.getDynamicChannel(i);
            if (channel != null) {
                chValue[i - beginIdx] = (int)Math.round(getChannelZero(channel.getChId()));
            }
        }
        gntR_ChOffsetDa(fpgaIdx, chValue[0], chValue[1], chValue[2], chValue[3]);
    }



    public void gntR_ChOffsetDa(int fpgaIdx, int ch1, int ch2, int ch3, int ch4) {
        Log.d(
                "MHO38V1",
                "gntR_ChOffsetDa() called with: fpgaIdx = ["
                        + fpgaIdx
                        + "], ch1 = ["
                        + ch1
                        + "], ch2 = ["
                        + ch2
                        + "], ch3 = ["
                        + ch3
                        + "], ch4 = ["
                        + ch4
                        + "]");
        FPGAReg_CH_OFFSET_DA12 reg =
                (FPGAReg_CH_OFFSET_DA12) getFPGAReg(fpgaIdx, FPGAReg.FPGA_CH_OFFSET_DA12);
        reg.setCh1(ch1);
        reg.setCh2(ch2);
        reg.setCh3(ch3);
        reg.setCh4(ch4);
        sendCommand(reg);
    }

    static final double x1_suolue = (double) ScopeBase.zoomYGrid_suolue() / ScopeBase.YGridWave();
    static final double x1_main = (double) ScopeBase.zoomYGrid_fangda() / ScopeBase.YGridWave();
    static final double y1_suolue =
            (double) (ScopeBase.YGridWave() - ScopeBase.zoomYGrid_suolue()) / 2;
    static final double y1_main =
            (double) (ScopeBase.zoomYGrid_fangda() - ScopeBase.YGridWave()) / 2;

    public void cmdFpgaDotMatrix(int chIdx) {
        int fpgaIdx = chIdxToFpgaIdx(chIdx);
        Scope scope = Scope.getInstance();
        if (!scope.isChannelInSample(chIdx, scope.isRun(true))) return;
        Channel channel = ChannelFactory.getDynamicChannel(chIdx);
        if (channel == null) return;
        double chPos = (double) channel.getPos();
        FPGAReg_DOT_MATRIX dotMatrixReg =
                (FPGAReg_DOT_MATRIX) getFPGAReg(fpgaIdx, FPGAReg.FPGA_DOT_MATRIX);
        dotMatrixReg.reset();
        dotMatrixReg.matrixParam.bChange = true;
        dotMatrixReg.matrixParam.x1 = 1.0d; // 放大镜引起的衰减
        dotMatrixReg.matrixParam.y1 = 0; // 放大镜引起的零点偏移
        dotMatrixReg.matrixParam.y0 = chPos; // 现在通道位置
        dotMatrixReg.matrixParam.k =
                ADGear2PixBuf(chIdx, true) * getValueDifferentCoef(chIdx); // AD与屏幕对应关�?
        // dotMatrixReg.matrixParam.y1 = chPos - dotMatrixReg.matrixParam.k *
        // Math.floor(chPos/dotMatrixReg.matrixParam.k);
        boolean[] chEn = new boolean[ChannelFactory.CH_CNT];
        int cnt = scope.getChannelSampOnCnt(scope.isRun(true), chEn);

        int beginIdx = beginChIdx(fpgaIdx);
        int endIdx = endChIdx(fpgaIdx);
        int idx = chIdx - beginIdx;
        switch (cnt) {
            case 2:
                for (int i = beginIdx; i < endIdx; i++) {
                    if (chEn[i]) {
                        if (i == chIdx) {
                            dotMatrixReg.setChannel(1);
                            break;
                        }
                    }
                }
                break;
            case 4: {
                int k = 0;
                for (int i = beginIdx; i < endIdx; i++) {
                    if (chEn[i]) {
                        if (i == chIdx) {
                            dotMatrixReg.setChannel(1 << k);
                            break;
                        }
                        k++;
                    }
                }
            }
                break;
            case 8:
            default:
                dotMatrixReg.setChannel(1 << idx);

                break;
        }

        if (scope.isRun(true)) {
            dotMatrixReg.matrixParam.x0 = 1.0d;
            dotMatrixReg.matrixParam.z = channel.getPosFix();
        } else {
            ScopeFrozen scopeFrozen = ScopeFrozen.getInstance();
            dotMatrixReg.matrixParam.x0 = (double) scope.zoomYScale(chIdx) / channel.getYFactor();
            dotMatrixReg.matrixParam.z =
                    scopeFrozen.getChPosFix(chIdx) / scopeFrozen.getYFactor(chIdx)
                            - channel.getZPos();
        }
        int len;

        if (scope.isZoom()) {

            dotMatrixReg.setUpDisSuolue(0);
            dotMatrixReg.matrixParam.y1 = y1_main;
            dotMatrixReg.matrixParam.x1 = x1_main;
            if (dotMatrixReg.judgeDotMatrixChange(dotMatrixReg.matrixParam, 0, chIdx)) {

                len =
                        dotMatrixReg.dotMatrixCal(
                                dotMatrixReg.matrixParam,
                                hwConfig.getAdMaxVal(),
                                0,
                                511 + ScopeBase.getHeight() / 2 - ScopeBase.zoomYGrid_suolue(),
                                0);
                dotMatrixReg.setCmdLength(len);
                sendCommand(dotMatrixReg, len + FPGAReg.FPGA_REG_HEADER_LEN);
            }

            dotMatrixReg.setUpDisSuolue(1);
            dotMatrixReg.matrixParam.y1 = y1_suolue;
            dotMatrixReg.matrixParam.x1 = x1_suolue;

            if (dotMatrixReg.judgeDotMatrixChange(dotMatrixReg.matrixParam, 1, chIdx)) {
                len =
                        dotMatrixReg.dotMatrixCal(
                                dotMatrixReg.matrixParam,
                                hwConfig.getAdMaxVal(),
                                0,
                                1023,
                                511 + ScopeBase.getHeight() / 2 - ScopeBase.zoomYGrid_suolue());
                dotMatrixReg.setCmdLength(len);
                sendCommand(dotMatrixReg, len + FPGAReg.FPGA_REG_HEADER_LEN);
            }
        } else {
            dotMatrixReg.setUpDisSuolue(0);
            if (dotMatrixReg.judgeDotMatrixChange(dotMatrixReg.matrixParam, 0, chIdx)) {
                len =
                        dotMatrixReg.dotMatrixCal(
                                dotMatrixReg.matrixParam, hwConfig.getAdMaxVal(), 0, 1023, 0);
                dotMatrixReg.setCmdLength(len);
                sendCommand(dotMatrixReg, len + FPGAReg.FPGA_REG_HEADER_LEN);
            }
        }
    }
    public void resetBak(int fpgaIdx){
        FPGAReg_DOT_MATRIX dotMatrixReg =
                (FPGAReg_DOT_MATRIX) getFPGAReg(fpgaIdx, FPGAReg.FPGA_DOT_MATRIX);
        int beginIdx = beginChIdx(fpgaIdx);
        int endIdx = endChIdx(fpgaIdx);
        for(int i=beginIdx;i<endIdx;i++) {
            dotMatrixReg.dotMatrixChange(i);
        }
    }

    public int update_v_Zoom(int fpgaIdx) {

        int n = hwConfig.getAdbits();
        int r, a, b, c, e = hwConfig.getAdMaxVal() + 1;
        double f = 1, f1, f2, bakPos;
        boolean bRun = scope.isRun(true);
        Channel channel;
        int[] vol = new int[8 * 3 + 1];
        Arrays.fill(vol, 0);
        double vScaleVal;
        int ret = 0;
        if (n < 12) return 0;
        double chPos;
        int beginIdx = beginChIdx(fpgaIdx);
        int endIdx = endChIdx(fpgaIdx);
        FPGAReg_DOT_MATRIX dotMatrixReg =
                (FPGAReg_DOT_MATRIX) getFPGAReg(fpgaIdx, FPGAReg.FPGA_DOT_MATRIX);
        double digitV = 1;
        for (int i = beginIdx; i < endIdx; i++) {
            channel = ChannelFactory.getDynamicChannel(i);
            if (channel == null) continue;
            vScaleVal = channel.getVScaleVal() / channel.getProbeRate();//档位
            f1 = channel.getYFactor();
            bakPos = channel.getZPos();
            digitV = HwConfig.getInstance().getDigitDang(channel.getResistanceType());
            if (bRun) {
                f = digitV / vScaleVal;
                chPos = 0;
                vScaleVal = 0;
                f2 = 1;
            } else {
                ScopeFrozen scopeFrozen = ScopeFrozen.getInstance();
                f1 = scopeFrozen.getYFactor(i);
                VerticalAxis verticalAxis = scopeFrozen.getChVertical(i);
                double v = verticalAxis.getScaleVal() / verticalAxis.getProbeRate();
                v *= f1;
                f = f2 = v / vScaleVal;

                vScaleVal = scopeFrozen.getChPosFix(i) / f1;
                chPos = channel.getPos();
            }

            if (f < 1) {
                f = 1;
            } else if (f > 4) {
                f = 4;
            }
            if (!bRun) {

                if(f <= 1){
                    channel.setZPos(0);
                    chPos = 0;
                }else {
                    r = e / 2;
                    r = (int) Math.round(r * f + r);
                    f2 /= f;
                    int z = (int) Math.round(chPos / f2 - vScaleVal * f);
                    if (z > r) {
                        z = r;
                    } else if (z < -r) {
                        z = -r;
                    }
                    channel.setZPos(vScaleVal - chPos / f2);
                    chPos = z;
                }
            }

            a = (int) (Math.pow(2, n - 1) + 0.1);

            b = (int) (e * f * Math.pow(2, 16 - n) + 0.1);
            c = (int) Math.round((double) e / 2 + chPos);
            vol[i - beginIdx + 1] = vol[i - beginIdx + 5] = a;
            vol[i - beginIdx + 9] = vol[i - beginIdx + 13] = b;
            vol[i - beginIdx + 17] = vol[i - beginIdx + 21] = c;
//            Log.d("1234","ch:" + channel.getChId() + ",f:" + f + ",a:" + a + ",b:" + b + ",c:" + c);
            channel.setYFactor(f);
            channel.setABC(a,b,c);

            if (!DoubleUtil.FuzzyCompare(channel.getYFactor(), f1)
                    || !DoubleUtil.FuzzyCompare(channel.getZPos(), bakPos)) {
                dotMatrixReg.dotMatrixChange(i);
                ret |= 1 << i;
            }
        }
        FPGAReg reg = new FPGAReg(FPGAReg.FPGA_V_ZOOM, vol.length * 4);
        reg.setFpgaIdx(fpgaIdx);
        reg.setVal(vol);
        sendCommand(reg);
        return ret;
    }

    static int[][] coef_fpga_mho_bak = {null, null};
    static int[][] coef_seach_mho_bak = {null, null};

    public void cmdFpgaReloadChazhiCoef_mho(int fpgaIdx) {
        Scope scope = Scope.getInstance();
        int[] coef_fpga;
        int[] coef_seach;
        FPGAReg_DISP_CHA dispChaReg =
                (FPGAReg_DISP_CHA) getFPGAReg(fpgaIdx, FPGAReg.FPGA_DISP_CHA1);
        if (!dispChaReg.isNeedChaZhi()) {
            return;
        }

        FPGAReg_CY_BUCONG cyBucongReg =
                (FPGAReg_CY_BUCONG) getFPGAReg(fpgaIdx, FPGAReg.FPGA_CY_BUCONG);
        if (cyBucongReg.getCyType12() > 0) { // 线性插值
            coef_fpga = CHAZHI_COEF.chazhiCoef_Line;
            coef_seach = coef_fpga;
        } else { // 升采样正弦滤波
            boolean[] sle = new boolean[ChannelFactory.CH_CNT];
            int cnt = scope.getChannelSampOnCnt(scope.isRun(true), sle);

            cnt /= adcNums;

            if(cnt > 1){
                coef_seach = CHAZHI_COEF.chazhiCoef_dub;
            }else{
                coef_seach = CHAZHI_COEF.chazhiCoef_sgl;
            }
            if (Display.getInstance().getDrawType() == Display.DRAWTYPE_DOTS)
                coef_fpga = CHAZHI_COEF.chazhiCoef_Line;
            else {
                coef_fpga = coef_seach;
            }
        }
        //
        if (coef_fpga != coef_fpga_mho_bak[fpgaIdx]) {
            coef_fpga_mho_bak[fpgaIdx] = coef_fpga;

            FPGAReg reg = new FPGAReg(FPGAReg.FPGA_CHAZHI_COEF, coef_fpga.length * 4);
            reg.setFpgaIdx(fpgaIdx);
            reg.setVal(coef_fpga);
            Log.d(TAG, "coef_fpga len:" + reg.getCommandLength());
            sendCommand(reg);
        }

        if (coef_seach != coef_seach_mho_bak[fpgaIdx]) {
            coef_seach_mho_bak[fpgaIdx] = coef_seach;

            FPGAReg reg = new FPGAReg(FPGAReg.FPGA_SEACH_COEF, coef_seach.length * 4);
            reg.setFpgaIdx(fpgaIdx);
            reg.setVal(coef_seach);
            Log.d(TAG, "coef_seach len:" + reg.getCommandLength());
            sendCommand(reg);
        }
    }

    public void cmdFpgaReloadChazhiCoef(int fpgaIdx) {
        cmdFpgaReloadChazhiCoef_mho(fpgaIdx);
    }

    private int[] FPGA_Command(int fpgaIdx, int param, int cmd) {
        return FPGA_Command(fpgaIdx, param, cmd, false);
    }

    private int[] FPGA_Command(int fpgaIdx, int param, int cmd, boolean bRecv) {
        // 因为在校准线程中直接调用了FPGA_Command 可能会与 命令线程中的 FPGA_Command 不同步
        int[] res = {-1, -1, -1};
        synchronized (this) {
            if (bAdCablition) {
                long t = SystemClock.elapsedRealtime() - adCablitionTs;
                t =  50 - t;
                if (t > 0) {
                    ms_sleep(t);
                }
                bAdCablition = false;
                adCablitionTs = 0;
            }
            FPGAReg_COMMAND reg = (FPGAReg_COMMAND) getFPGAReg(fpgaIdx, FPGAReg.FPGA_COMMAND);
            reg.setParam(param);
            reg.setCmd(cmd);
            reg.setCmdCntValid(1);
            reg.setCmdCnt(SyncHeader.getSyncHeader());
            if (bRecv) {
                recvCommand(reg, reg.getRecvReg());
                res[0] = reg.getSyncHeader();
                res[1] = reg.getColAddr();
                res[2] = reg.getFrameNums();
                return res;
            } else {
                sendCommand(reg);
            }
            return res;
        }
    }

    public void segmentTimestamp(int fpgaIdx) {
        if (scope.isSegmentEnable(scope.isRun(true))) {
            FPGAReg reg = new FPGAReg(FPGAReg.FPGA_SEGMENT_TS, 4);
            reg.setFpgaIdx(fpgaIdx);
            reg.setVal(0, 0x01);
            sendCommand(reg);
        }
    }

    public void forceTrigger(int fpgaIdx) {

        FPGAReg reg = new FPGAReg(FPGAReg.FPGA_FORCE_TRIGGER,4);
        reg.setFpgaIdx(fpgaIdx);
        reg.setVal(0,0x01);
        sendCommand(reg);
    }

    private boolean bAdCablition = false;
    private long adCablitionTs = 0;

    public void forceAdCablition(int fpgaIdx) {
        Log.d(TAG, "forceAdCablition() called with: fpgaIdx = [" + fpgaIdx + "]");
        if(HardwareProduct.isMHO38V1()){
            FPGAReg_SPI_EXT reg = (FPGAReg_SPI_EXT) getFPGAReg(fpgaIdx, FPGAReg.FPGA_SPI_EXT);
            reg.setType(FPGAReg_SPI_EXT.SPI_EXT_AD);
            reg.setCalibrationAd(0xF);
            reg.setDataLength(1);
            reg.setVal(1, 1);
            synchronized (this) {
                sendCommand(reg);
                bAdCablition = true;
                adCablitionTs = SystemClock.elapsedRealtime();
            }
        }
    }

    public void adSync(){
        Log.d(TAG, "adSync() called");
        FPGAReg_SPI_EXT reg = (FPGAReg_SPI_EXT) getFPGAReg(0, FPGAReg.FPGA_SPI_EXT);
        reg.setType(FPGAReg_SPI_EXT.SPI_EXT_AD);
        reg.adSync();
        reg.setDataLength(1);
        reg.setVal(1, 1);
        sendCommand(reg);
    }

