        regStatusId.setFpgaIdx(fpgaIdx);
        recvCommand(regStatusId, regStatusId.getRecvReg());
        Log.d(TAG, "fpga id = " + Integer.toHexString(regStatusId.getId()) + ",fpgaIdx:" + fpgaIdx);
