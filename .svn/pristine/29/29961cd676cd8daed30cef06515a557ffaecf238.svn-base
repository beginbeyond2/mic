<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@drawable/svg_semicircle_right_disable" android:state_enabled="false" />
    <item android:drawable="@drawable/svg_semicircle_right_select_ref" android:state_checked="true" />
    <item android:drawable="@drawable/svg_semicircle_right_select_ref" android:state_selected="true" />
    <item android:drawable="@drawable/svg_semicircle_right_select_ref" android:state_pressed="true" />
    <item android:drawable="@drawable/svg_semicircle_right" />
</selector>