public class SerialsDetailM1553bCsWord implements ISerialsDetail {
    private DataBean m1553bCsWordCsWord;
    private String m1553bCsWordCsWordTitle;

    public String getM1553bCsWordCsWordTitle() {
        return m1553bCsWordCsWordTitle;
    }

    public void setM1553bCsWordCsWordTitle(String m1553bCsWordCsWordTitle) {
        this.m1553bCsWordCsWordTitle = m1553bCsWordCsWordTitle;
    }

    public DataBean getM1553bCsWordCsWord() {
        return m1553bCsWordCsWord;
    }

    public void setM1553bCsWordCsWord(int digits, String value) {
        if (this.m1553bCsWordCsWord == null) {
            this.m1553bCsWordCsWord = new DataBean();
        }
        this.m1553bCsWordCsWord.setDigits(digits);
        this.m1553bCsWordCsWord.setValue(value);
    }

    @Override
    public String toString() {
        return "SerialsDetailM1553bCsWord{" +
                "m1553bCsWordCsWord='" + m1553bCsWordCsWord + '\'' +
                '}';
    }
}
