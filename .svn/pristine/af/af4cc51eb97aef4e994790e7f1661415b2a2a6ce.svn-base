        return byteBuffer.getShort(30) & 0xFFFF;
    }
    public int getMeasureEnd(){
        return byteBuffer.getShort(32) & 0xFFFF;
    }

    public int getPhaseRefChIdx() {
        return byteBuffer.get(20) & 0xFF;
    }
    public int getDelaySelfEdge() {
        return byteBuffer.getInt(21) & 0xFF;
    }
    public int getDelayRefChIdx() {
        return byteBuffer.getInt(22) & 0xFF;
    }
    public int getDelayRefChEdge() {
        return byteBuffer.getInt(23) & 0xFF;
    }




    public boolean isMeasureItemEnable(@MeasureType.MeasureItemType int measureType) {
        long val = byteBuffer.getLong(4);
        return ((val >>> measureType) & 0x01) != 0;
    }

    public void MeasureItemEnable(@MeasureType.MeasureItemType int measureType, boolean enable) {
        long mask = 1;
        long val = byteBuffer.getLong(4);
        mask = mask << measureType;
        val &= ~(mask);
        if (enable)
            val |= mask;
        byteBuffer.putLong(4, val);
    }

    public void setMeasureItemValid(@MeasureType.MeasureItemType int measureType, boolean bValid) {
        long mask = 1;
        long val = byteBuffer.getLong(12);
        mask = mask << measureType;
        val &= ~(mask);
        if (bValid)
            val |= mask;
        byteBuffer.putLong(12, val);
    }

    public boolean isMeasureItemValid(@MeasureType.MeasureItemType int measureType) {
        if(ChannelFactory.isMath_FFT_Ch(channel.getChId())){
            MathChannel mathChannel = (MathChannel)channel;
            switch (measureType){
                case MeasureType.MEASURE_CURSOR_X1:
                    return mathChannel.isCursorX1Valid();
                case MeasureType.MEASURE_CURSOR_X2:
                    return mathChannel.isCursorX2Valid();
            }
        }
        long val = byteBuffer.getLong(12);
        return ((val >>> measureType) & 0x01) == 1;
    }

    public void setMeasureItemVal(@MeasureType.MeasureItemType int measureType, double val) {
        floatBuffer.put(measureType, (float)val);
    }

    public float getMeasureItemVal(@MeasureType.MeasureItemType int measureType) {
        if(ChannelFactory.isMath_FFT_Ch(channel.getChId())){
            MathChannel mathChannel = (MathChannel)channel;
            switch (measureType){
                case MeasureType.MEASURE_CURSOR_X1:
                    return (float) mathChannel.getCursorX1Value();
                case MeasureType.MEASURE_CURSOR_X2:
                    return (float) mathChannel.getCursorX2Value();
            }
        }

        float val = floatBuffer.get(measureType);
        double tmpVal = 0;
        if(ChannelFactory.isDynamicCh(channel.getChId()) && !isCursorMeasureRange()){
            Channel ch = (Channel)channel;
            switch (measureType){
                case MeasureType.MEASURE_MAX:
                    tmpVal = ch.getMaxVal();
                    if(val < tmpVal){
                        val = (float)tmpVal;
                    }
                    break;
                case MeasureType.MEASURE_MIN:
                    tmpVal = ch.getMinVal();
                    if(val > tmpVal){
                        val = (float)tmpVal;
                    }
                    break;
                case MeasureType.MEASURE_PK_PK:
                    tmpVal = (ch.getPKPKVal());

                    if(val < tmpVal) {
                        val = (float) tmpVal;
                    }
                    break;
            }
        }



        return val;
    }

    //0 不小削波，1 正削，2 负削，3 双削，4 无波
    public int getClipping(){
        double val = getMeasureItemVal(MeasureType.MEASURE_CLIPPING);
        return (int)(val + 0.1);
    }

    public int getIndication(int measureType,int dir){

        int idx = measureType - MeasureType.MEASURE_FIRST;
        float val = floatBuffer.get(MeasureType.MEASURE_ITEM_MAX + idx * 4 + dir);
        val = Math.round(ScopeBase.changeAccuracy(val * ScopeBase.getToUICoff()));
        if(ChannelFactory.isDynamicCh(channel.getChId()) && !isCursorMeasureRange()){
            Channel ch = (Channel)channel;
            double maxVal = getMeasureItemVal(MeasureType.MEASURE_MAX);
            double minVal = getMeasureItemVal(MeasureType.MEASURE_MIN);
            WaveData dataBuffer = (WaveData) channel.obtain();
            if (dataBuffer==null){
                return Math.round(val);
            }
            double v = ch.getADVerticalPerPix() * dataBuffer.getProbeRate() / ch.getProbeRate();
            channel.recycle(dataBuffer);
            maxVal = ScopeBase.getNewHeight() / 2 - ch.getPosUI() - maxVal / v;
            minVal = ScopeBase.getNewHeight() / 2 - ch.getPosUI() - minVal / v;

            if(Scope.getInstance().isZoom()){
                maxVal = maxVal * ScopeBase.getZoomHeight()/ScopeBase.getHeight();
                minVal = minVal * ScopeBase.getZoomHeight()/ScopeBase.getHeight();
            }

            switch (measureType){
                case MeasureType.MEASURE_MAX:
                    if(dir == INDICATION_TOP) {
                        val = (float) maxVal;
                    }
                    break;
                case MeasureType.MEASURE_MIN:
                    if(dir == INDICATION_BOTTOM) {
                        val = (float) minVal;
                    }

                    break;
                case MeasureType.MEASURE_PK_PK:
                    if(dir == INDICATION_TOP) {
                        val = (float) maxVal;
                    }else if(dir == INDICATION_BOTTOM) {
                        val = (float) minVal;
                    }
                    break;
            }
        }
        return Math.round(val);
    }

    public void setIndication(int measureType,int dir,float val){
        int idx = measureType - MeasureType.MEASURE_FIRST;
        floatBuffer.put(MeasureType.MEASURE_ITEM_MAX + idx * 4 + dir,val);
    }

    private int waveX = 0;
    public boolean MeasureCalc() {
        boolean bMeasure = false;
        BaseChannel baseChannel = (BaseChannel)channel;
        if(baseChannel != null) {
            WaveData dataBuffer = (WaveData) channel.obtain();
            if (dataBuffer != null) {
                setChPos((int) Math.round(baseChannel.getPos()));
                setVRate((float) ((dataBuffer.getVScaleVal()/dataBuffer.getProbeRate())/(baseChannel.getFineScale()*baseChannel.getVScaleIdVal())));
                abs();
                WaveHeightRate(
                        Scope.getInstance().isZoom()
                                ?(float) ScopeBase.getZoomHeight()/ScopeBase.getHeight()
                                :1.0f
                );
                waveX = dataBuffer.getStartX();
                if(ChannelFactory.isRefCh(channel.getChId())){
                    RefChannel refChannel = (RefChannel) channel;
                    synchronized (refChannel.surfaceLock){
                        int startx = dataBuffer.getStartX();
                        int endx = dataBuffer.getEndX();
                        refChannel.calcXOffset(dataBuffer);
                        bMeasure = MeasureNative(dataBuffer.getByteBuffer(), byteBuffer);
                        dataBuffer.setStartX(startx);
                        dataBuffer.setEndX(endx);
                    }
                }else {
                    bMeasure = MeasureNative(dataBuffer.getByteBuffer(), byteBuffer);
                }
                channel.recycle(dataBuffer);
            }
        }
        return bMeasure;
    }

    public void calcStatics(){
        measureStatics.calcStatics();
    }
    public boolean MeasurePhase(Measure refMeasure) {

        if (this.isMeasureItemValid(MeasureType.MEASURE_FIRST_RISE_EDGE)
                && refMeasure.isMeasureItemValid(MeasureType.MEASURE_FIRST_RISE_EDGE)) {
            double val;
            double chFirstFallingEdge, refChFirstFallingEdge;
            double chPhase, refChPhase;
            double refTimePot,timePot;

            chFirstFallingEdge = getMeasureItemVal(MeasureType.MEASURE_FIRST_RISE_EDGE);
            refChFirstFallingEdge = refMeasure.getMeasureItemVal(MeasureType.MEASURE_FIRST_RISE_EDGE);
            timePot = getMeasureItemVal(MeasureType.MEASURE_TIME_POT);
            refTimePot = refMeasure.getMeasureItemVal(MeasureType.MEASURE_TIME_POT);

            if(isMeasureItemValid(MeasureType.MEASURE_PERIOD)){
                chPhase = getMeasureItemVal(MeasureType.MEASURE_PERIOD); //S
                val = (chFirstFallingEdge-refChFirstFallingEdge)*360.0*timePot/chPhase;
                while (val > 180) {
                    val -= 360;
                }
                while (val < -180) {
                    val += 360;
                }

                double v = getHorizontalRate();
                setIndication(MeasureType.MEASURE_PHASE,INDICATION_LEFT,Math.round(getStartX() + chFirstFallingEdge/v));
                setIndication(MeasureType.MEASURE_PHASE,INDICATION_RIGHT,Math.round(refMeasure.getStartX() + refChFirstFallingEdge/v));
                setMeasureItemVal(MeasureType.MEASURE_PHASE, -val);
                return true;
            }
        }

        return false;
    }

    public int getStartX(){
        int begin = getMeasureBegin();
        if(begin <= waveX){
            begin = waveX;
        }
        return begin;
    }

    public boolean MeasureDelay(Measure refMeasure) {

        boolean bRet = false;
        double pos1, pos2, timePot, refTimePot, val;
        int _selfEdge = getDelaySelfEdge();
        int relateEdge = getDelayRefChEdge();

        boolean selfEdge = false, selfEdgePos = false, refEdge = false, refEdgePos = false;
        switch (_selfEdge) {
            case RL_LAST_RISE_EDGE:
            case RL_FIRST_RISE_EDGE:
                selfEdge = false;//上升沿
                break;
            case RL_FIRST_FALL_EDGE:
            case RL_LAST_FALL_EDGE:
                selfEdge = true;//下降沿
                break;
        }
        switch (relateEdge) {
            case RL_LAST_RISE_EDGE:
            case RL_FIRST_RISE_EDGE:
                refEdge = false;//上升沿
                break;
            case RL_FIRST_FALL_EDGE:
            case RL_LAST_FALL_EDGE:
                refEdge = true;//下降沿
                break;
        }
        switch (_selfEdge) {
            case RL_LAST_RISE_EDGE:
            case RL_LAST_FALL_EDGE:
                selfEdgePos = true;//尾沿
                break;
            case RL_FIRST_RISE_EDGE:
            case RL_FIRST_FALL_EDGE:
                selfEdgePos = false;//首沿
                break;
        }

        switch (relateEdge) {
            case RL_LAST_RISE_EDGE:
            case RL_LAST_FALL_EDGE:
                refEdgePos = true;//尾沿
                break;
            case RL_FIRST_RISE_EDGE:
            case RL_FIRST_FALL_EDGE:
                refEdgePos = false;//首沿
                break;
        }


        //取待测点位置
        if (selfEdge) {
            if (selfEdgePos)
                pos1 = getMeasureItemVal(MeasureType.MEASURE_LAST_FALL_EDGE);
            else
                pos1 = getMeasureItemVal(MeasureType.MEASURE_FIRST_FALL_EDGE);
        } else {
            if (selfEdgePos) pos1 = getMeasureItemVal(MeasureType.MEASURE_LAST_RISE_EDGE);
            else pos1 = getMeasureItemVal(MeasureType.MEASURE_FIRST_RISE_EDGE);
        }

        //取参考点位置
        if (refEdge) {
            if (refEdgePos) pos2 = refMeasure.getMeasureItemVal(MeasureType.MEASURE_LAST_FALL_EDGE);
            else pos2 = refMeasure.getMeasureItemVal(MeasureType.MEASURE_FIRST_FALL_EDGE);
        } else {
            if (refEdgePos) pos2 = refMeasure.getMeasureItemVal(MeasureType.MEASURE_LAST_RISE_EDGE);
            else pos2 = refMeasure.getMeasureItemVal(MeasureType.MEASURE_FIRST_RISE_EDGE);
        }
        if (pos1 < 0 || pos2 < 0) {
            bRet = false;
        } else {
            timePot = getMeasureItemVal(MeasureType.MEASURE_TIME_POT);
            refTimePot = refMeasure.getMeasureItemVal(MeasureType.MEASURE_TIME_POT);

            val = pos1 * timePot - pos2 * refTimePot;

            double v = getHorizontalRate();

            setIndication(MeasureType.MEASURE_DELAY,INDICATION_LEFT,Math.round(getStartX() + pos1/v));
            setIndication(MeasureType.MEASURE_DELAY,INDICATION_RIGHT,Math.round(refMeasure.getStartX() + pos2/v));
            setMeasureItemVal(MeasureType.MEASURE_DELAY, val);
            bRet = true;
        }
        return bRet;
    }

    private boolean MeasureNative(ByteBuffer chBuffer, ByteBuffer measureItem) {
        boolean bMeasure = false;
        if (chBuffer.isDirect() && measureItem.isDirect()) {
            bMeasure = measure(chBuffer, measureItem);
        }
        return bMeasure;
    }


    private static native boolean measure(ByteBuffer chBuffer, ByteBuffer measureItem);
}
