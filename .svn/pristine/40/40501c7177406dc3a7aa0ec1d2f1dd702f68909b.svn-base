    public void Scale(int chIndex, double d, boolean isUpdateUI) {
        List<Double> axis = HorizontalAxis.getInstance().getxAxis();
        List<Double> newAxis=new ArrayList<>();
        for(int i=0;i<axis.size();i++){
            if ( ((extent-axis.get(i))>1E-15 || Double.compare(extent,axis.get(i))==0) && Double.compare(extent,d)>=0 ){
                newAxis.add(axis.get(i));
            }
        }

        //最大值的左边界
        if(newAxis.size()==0){
            d=extent;
        }
        //最小值的右边界
        if(newAxis.size()>0 && Double.compare(d, newAxis.get(newAxis.size()-1))<0){
            d=newAxis.get(newAxis.size()-1);
        }
        double finalD = d;
        int index= Tools.indexOf(axis, t->Double.compare(finalD,t)==0);
//        Logger.i(Command.TAG,"d:"+d+",extent:"+extent+",index:"+index);
//        Logger.i(Command.TAG, "list:"+Arrays.toString(newAxis.toArray()));
        if (index==-1)return;

        this.scale = d;
        if (isUpdateUI){
            CommandMsgToUI msgToUI = Command.get().getMsgToUI();
            msgToUI.setFlag(CommandMsgToUI.FLAG_TIMEBASE_ZOOM_SCALE);
            String param = String.valueOf(chIndex) + CommandMsgToUI.PARAM_SPLIT + String.valueOf(scale);
            msgToUI.setParam(param);
            RxBus.getInstance().post(RxEnum.COMMAND_TO_UI, msgToUI);
        }
    }
    public double ScaleQ(){
        return scale;
    }

    public String ListQ(){
        List<Double> axis= HorizontalAxis.getInstance().getxAxis();
        StringBuilder sb=new StringBuilder();
        for(int i=0;i<axis.size();i++){
            sb.append(axis.get(i).toString());
            if (i!= axis.size()-1) {
                sb.append(",");
            }
        }
//        Log.d("Tag.Debug", String.format("Command_Timebase.ListQ: %s ,len:%s",axis.size(),sb.toString().length() ));

        return sb.toString();
    }

