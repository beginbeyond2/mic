<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/bgChannelMaster"
    android:layout_width="112px"
    android:layout_height="160px">

    <ImageView
        android:id="@+id/background"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/ic_bg_s1s2" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center_horizontal">

        <TextView
            android:id="@+id/channelText"
            style="@style/textStyleMiddlebarRightMain"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="0px"
            android:visibility="gone"
            android:gravity="center"
            android:text="S1"
            android:textSize="28px" />

        <TextView
            android:id="@+id/serialsType"
            style="@style/textStyleMiddlebarRightMain"
            android:layout_width="match_parent"
            android:layout_height="25px"
            android:layout_marginTop="8px"
            android:layout_marginBottom="0px"
            android:text="SPI"
            android:textSize="20px" />

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/textLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@+id/channelText"
            android:gravity="center">

            <TextView
                android:id="@+id/text1"
                android:layout_width="match_parent"
                android:layout_height="20px"
                android:gravity="center"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="500.0mV"
                android:textSize="20px"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toTopOf="@+id/text2"
                app:layout_constraintVertical_chainStyle="packed"

                />


            <TextView
                android:id="@+id/text2"
                android:layout_width="match_parent"
                android:layout_height="20px"
                android:layout_below="@+id/text1"
                android:gravity="center"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="500.0mV"
                android:textSize="20px"
                app:layout_constraintBottom_toTopOf="@+id/text3"
                app:layout_constraintTop_toBottomOf="@id/text1"

                />

            <TextView
                android:id="@+id/text3"
                android:layout_width="match_parent"
                android:layout_height="20px"
                android:layout_below="@+id/text2"
                android:gravity="center"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="500.0mV"
                android:textSize="20px"
                app:layout_constraintBottom_toTopOf="@+id/text4"
                app:layout_constraintTop_toBottomOf="@id/text2"

                />

            <TextView
                android:id="@+id/text4"
                android:layout_width="match_parent"
                android:layout_height="20px"
                android:layout_below="@+id/text3"
                android:gravity="center"
                android:includeFontPadding="false"
                android:maxLines="1"
                android:text="500.0mV"
                android:textSize="20px"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintTop_toBottomOf="@id/text3" />
        </androidx.constraintlayout.widget.ConstraintLayout>

    </LinearLayout>

    <Button
        android:id="@+id/btnClick"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_centerInParent="true"
        android:background="@null" />

</RelativeLayout>