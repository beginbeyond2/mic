public class MainLayoutCenterTimeBase extends RelativeLayout {
    private static final String TAG = "MainLayoutCenterTimeBase";
    private Context context;
    private List<TimeBaseScale> list;
    private RelativeLayout recyclerLayout;
    private MainAdapterCenterTimeBase adapter;
    private OnClickItemListener onClickItemListener;
    private MTimeBaseSelector mTimeBaseSelector;

    private ViewGroup rootViewGroup;

    public interface OnClickItemListener {
        void onClickItem(TimeBaseScale scale);
    }

    public void setOnClickItemListener(OnClickItemListener onClickItemListener) {
        this.onClickItemListener = onClickItemListener;
    }

    public MainLayoutCenterTimeBase(Context context) {
        this(context, null);
    }

    public MainLayoutCenterTimeBase(Context context, @Nullable AttributeSet attrs) {
        this(context, attrs, 0);
    }

    public MainLayoutCenterTimeBase(Context context, @Nullable AttributeSet attrs, int defStyleAttr) {
        super(context, attrs, defStyleAttr);
        this.context = context;
        initView();
        EventFactory.addEventObserver(EventFactory.EVENT_TIME_SCALE_LIST, xAxis);
    }

    private void initView() {
        rootViewGroup= (ViewGroup) inflate(context, R.layout.layout_maincenter_timebase, this);

        findViewById(R.id.outView).setOnClickListener(new OnClickListener() {
            @Override
            public void onClick(View v) {
                hide();
            }
        });
        recyclerLayout = (RelativeLayout) findViewById(R.id.recyclerLayout);

        mTimeBaseSelector = new MTimeBaseSelector(context);
        mTimeBaseSelector.setOnClickEvent(onClickEvent);
        recyclerLayout.addView(mTimeBaseSelector);

//        RecyclerView recyclerView = (RecyclerView) findViewById(R.id.timeBaseRecyclerView);
//        RecyclerView.LayoutManager layoutManager = new GridLayoutManager(context, 9);
//        recyclerView.setLayoutManager(layoutManager);
        list = new ArrayList<TimeBaseScale>();
//        adapter = new MainAdapterCenterTimeBase(context, list);
//        adapter.setOnClickListener(onClickListener);
//        recyclerView.setAdapter(adapter);
        setList();
        generateChannelList();
        setViewLocation();
        hide();
    }

    private void setList() {
        if (list == null) return;
        List<String> sList = new ArrayList<>();
        for (int i = 0; i < list.size(); i++) {
            sList.add(list.get(i).getScale());
        }
        mTimeBaseSelector.initDataUI(sList);
    }

