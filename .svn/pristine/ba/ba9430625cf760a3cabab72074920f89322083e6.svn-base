    public void show() {

        setVisibility(VISIBLE);
        RxBus.getInstance().post(RxEnum.DIALOG_OPEN, MainViewGroup.DIALOG_CENTERTIMEBASE);
        Tools.PrintControlsLocation("MainLayoutCenterTimeBase",rootViewGroup);
    }

    public void show(String s) {
        mTimeBaseSelector.setSelectItems(s);
        setVisibility(VISIBLE);
        RxBus.getInstance().post(RxEnum.DIALOG_OPEN, MainViewGroup.DIALOG_CENTERTIMEBASE);
    }

    public void hide() {
        setVisibility(GONE);
        RxBus.getInstance().post(RxEnum.DIALOG_CLOSE, MainViewGroup.DIALOG_CENTERTIMEBASE);
    }

    private MTimeBaseSelector.OnClickEvent onClickEvent = new MTimeBaseSelector.OnClickEvent() {
        @Override
        public void onTouchDown(int index, String value) {
            if (onClickItemListener != null) {
                onClickItemListener.onClickItem(new TimeBaseScale(index, value));
            }
        }

        @Override
        public void onTouchUp(int index, String value) {
            hide();
        }

        @Override
        public void onItemChange(int index, String value) {
            if (onClickItemListener != null) {
                onClickItemListener.onClickItem(new TimeBaseScale(index, value));
            }
        }
    };
    private MainAdapterCenterTimeBase.OnClickListener onClickListener = new MainAdapterCenterTimeBase.OnClickListener() {
        @Override
        public void onClick(TimeBaseScale scale) {
            hide();
            if (onClickItemListener != null) {
                onClickItemListener.onClickItem(scale);
            }
        }
    };

    private Observer xAxis = new Observer() {
        @Override
        public void update(Observable observable, Object data) {
            EventBase eventBase = (EventBase) data;
            if (eventBase.getId() == EventFactory.EVENT_TIME_SCALE_LIST) {
                MainLayoutCenterTimeBase.this.post(new Runnable() {
                    @Override
                    public void run() {
                        CacheUtil.get().putMap(CacheUtil.MAIN_WAVE_TIMEBASE_MIN,String.valueOf(HorizontalAxis.getMinGear()));
                        CacheUtil.get().putMap(CacheUtil.MAIN_WAVE_TIMEBASE_MAX,String.valueOf(HorizontalAxis.getMaxGear()));
                        getList();
                    }
                });
            }
        }
    };
}
