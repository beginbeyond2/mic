    public List<TimeBaseScale> generateChannelList() {
        list.clear();
        List<Double> axis = HorizontalAxis.getInstance().getxAxis();
        for (int i = 0; i < axis.size(); i++) {
            String s = TBookUtil.getMFromDouble(axis.get(i));
            if (TextUtils.isEmpty(s)) continue;
            list.add(new TimeBaseScale(i, s + "s"));
        }
//        adapter.notifyDataSetChanged();
        setList();
        setViewLocation();
        return list;
    }

    public List<TimeBaseScale> generateMathFFTWaveList(int chIdx) {
        list.clear();
        HorizontalAxisMath horizontalAxisMath = ChannelFactory.getMathChannel(chIdx).getHorizontalAxisMathFFT();
        List<Double> xAxisList = horizontalAxisMath.getxAxis();

        String tail = "Hz";
        if (!xAxisList.isEmpty()) {
            for (int i = 0; i < xAxisList.size(); i++) {
                if (i < horizontalAxisMath.getMinScaleId()  || i > horizontalAxisMath.getMaxScaleId()) continue;
                String s = TBookUtil.getMFromDouble(xAxisList.get(i));
                if (TextUtils.isEmpty(s)) continue;
                list.add(new TimeBaseScale(i, s + tail));
            }
        }
//        adapter.notifyDataSetChanged();
        setList();
        setViewLocation();
        return list;
    }

    public List<TimeBaseScale> onlyGenerateChannelList() {
        List<TimeBaseScale> list = new ArrayList<TimeBaseScale>();
        List<Double> axis = HorizontalAxis.getInstance().getxAxis();
        for (int i = 0; i < axis.size(); i++) {
            String s = TBookUtil.getMFromDouble(axis.get(i));
            if (TextUtils.isEmpty(s)) continue;
            list.add(new TimeBaseScale(i, s + "s"));
        }
        return list;
    }


    public List<TimeBaseScale> onlyGenerateRefChannelList(RefChannel refChannel) {
        List<TimeBaseScale> list = new ArrayList<TimeBaseScale>();
        if (refChannel == null) {
            refChannel = (RefChannel) ChannelFactory.getInstance().getTopRefChannel();
        }
        HorizontalAxisRef horizontalAxisRef = refChannel.getHorizontalAxisRef();
        List<Double> xAxisList = horizontalAxisRef.getxAxis();
        String tail = "s";
        if (horizontalAxisRef.getRefType() == HorizontalAxisRef.REFTYPE_MATHFFT) {
            tail = "Hz";
        }
        if (!xAxisList.isEmpty()) {
            for (int i = 0; i < xAxisList.size(); i++) {
                String s = TBookUtil.getMFromDouble(xAxisList.get(i));
                if (TextUtils.isEmpty(s)) continue;
                list.add(new TimeBaseScale(i, s + tail));
            }
        }
        return list;
    }


    public List<TimeBaseScale> generateRefChannelList(RefChannel refChannel) {
        list.clear();
        if(refChannel == null){
            refChannel = (RefChannel) ChannelFactory.getInstance().getTopRefChannel();
        }
//        RefChannel refChannel = (RefChannel) ChannelFactory.getInstance().getTopRefChannel();
        HorizontalAxisRef horizontalAxisRef = refChannel.getHorizontalAxisRef();
        List<Double> xAxisList = horizontalAxisRef.getxAxis();
        String tail = "s";
        if (horizontalAxisRef.getRefType() == HorizontalAxisRef.REFTYPE_MATHFFT) {
            tail = "Hz";
        }
        if (!xAxisList.isEmpty()) {
            for (int i = 0; i < xAxisList.size(); i++) {
                String s = TBookUtil.getMFromDouble(xAxisList.get(i));
                if (TextUtils.isEmpty(s)) continue;
                list.add(new TimeBaseScale(i, s + tail));
            }
        }
//        adapter.notifyDataSetChanged();
        setList();
        setViewLocation();
        return list;
    }

    public List<TimeBaseScale> getList() {
        int chIdx = ChannelFactory.getChActivate();
        int timeBaseIndex = CacheUtil.get().getInt(CacheUtil.TOP_SLIP_USERSET_REF_TIMEBASE);
        if (timeBaseIndex == 0) {//跟随模拟通道
            if (ChannelFactory.isRefCh(chIdx)) {
                RefChannel refChannel = ChannelFactory.getRefChannel(chIdx);
                if (refChannel.getRefType() == WaveData.FFT_WAVE) {
                    return generateRefChannelList(refChannel);
                } else {
                    return generateChannelList();
                }
            }
            if (ChannelFactory.isMath_FFT_Ch(chIdx)) {
                return generateMathFFTWaveList(chIdx);
            } else {
                return generateChannelList();
            }
        } else {
            if (ChannelFactory.isRefCh(chIdx)) {
                return generateRefChannelList(null);
            } else if (ChannelFactory.isMath_FFT_Ch(chIdx)) {
                return generateMathFFTWaveList(chIdx);
            } else { //数学双波形的时基档位和基础通常是一样的
                return generateChannelList();
            }
        }
    }

    public List<TimeBaseScale> getList1(){
        return list;
    }

    public int getNormalIndex(String scale) {
        scale = scale.replace(" ","");
        scale = scale.replace( "u","μ");

        List<TimeBaseScale> scaleList = generateChannelList();
        for (int i = 0; i < scaleList.size(); i++) {
            String str = scaleList.get(i).getScale();
            str = str.replace(" ","");
            if (str.equals(scale)) {
                return i;
            }
        }
        return 0;
    }

    public int getMathFFTIndex(String scale) {
        int chIdx = ChannelFactory.getChActivate();
        if (ChannelFactory.isMath_FFT_Ch(chIdx)) {
            List<TimeBaseScale> scaleList = generateMathFFTWaveList(chIdx);
            for (int i = 0; i < scaleList.size(); i++) {
                if (scaleList.get(i).getScale().equals(scale)) {
                    return i;
                }
            }
        }
        return 0;
    }

    public int getRefIndex(RefChannel refChannel,String scale) {
        List<TimeBaseScale> scaleList = generateRefChannelList(refChannel);
        for (int i = 0; i < scaleList.size(); i++) {
            if (scaleList.get(i).getScale().equals(scale)) {
                return i;
            }
        }
        return 0;
    }


