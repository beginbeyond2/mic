public class RxBusRegister {
    public RxBusRegister() {
        initRegister();
        initMsg();
    }

    private void initRegister() {
        for(RxEnum bean: RxEnum.values()){
            RxBus.getInstance().register(bean);
        }
    }

    public void unRegister() {
        for(RxEnum bean: RxEnum.values()){
            RxBus.getInstance().unregister(bean);
        }
    }

