    public static MQEnum parseMqEnum(Object o){
        RxEnum rxEnum= ((MQBase)o).getRxType();
        MQEnum mqEnum= ((MQBase)o).getMqType();
        HashMap<MQEnum,Class> classList=msgClass.get(rxEnum);
        for(Map.Entry<MQEnum,Class> item:classList.entrySet() ){
            if (item.getKey()==mqEnum){
                return item.getKey();
            }
        }
        return MQEnum.NULL;
    }
    public static <T> T createMsg(RxEnum rxEnum,MQEnum mqEnum){
        HashMap<MQEnum,Class> classList=msgClass.get(rxEnum);
        for(Map.Entry<MQEnum,Class> item:classList.entrySet()){
            if (mqEnum==item.getKey()){
                try {
                    MQBase base= (MQBase) item.getValue().newInstance();
                    base.setMqType(mqEnum);
                    base.setRxType(rxEnum);
                    return (T)base;
                } catch (IllegalAccessException e) {
                    throw new RuntimeException(e);
                } catch (InstantiationException e) {
                    throw new RuntimeException(e);
                }
            }
        }
        return null;
    }

