    public static HashMap<Integer, Integer> getColorsIntMapForChannel(int chIndex) {
        int color = getAllBaseColorInt(chIndex);
        if (color != ColorsHashMap.getOrDefault(chIndex, getColorCommonInt())) {
            ColorsHashMap.put(chIndex, color);
        }
        return ColorsHashMap;
    }

