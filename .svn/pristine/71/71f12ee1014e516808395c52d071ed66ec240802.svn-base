    public static String getGenColor(int chIdx, String selColor) {

        chIdx = chIdx - TChan.Math1;

        int[] arrayColor = getMathRefColorInt();

        float [] selHsv = {0,0,0};
        float [] hsv = {0,0,0};
        Color.colorToHSV(Color.parseColor(selColor),selHsv);
        for (int i=0;i<arrayColor.length;i++ ) {
            if(chIdx != i) {
                Color.colorToHSV(arrayColor[i], hsv);
                if (Math.abs(selHsv[0] - hsv[0]) < 3
                        && Math.abs(selHsv[1] - hsv[1]) < 0.01
                        && Math.abs(selHsv[2] - hsv[2]) < 0.005) {
                    selHsv[2] -= 0.01;
                }
            }
        }
        return handleColor(Color.HSVToColor(selHsv));
    }
    public static int getHsv2Ch(float [] selHsv){

        int[] arrayColor = getMathRefColorInt();

        float [] hsv = {0,0,0};
        for (int i=0;i<arrayColor.length;i++ ) {
            Color.colorToHSV(arrayColor[i], hsv);
            if (Math.abs(selHsv[0] - hsv[0]) < 3
                    && Math.abs(selHsv[1] - hsv[1]) < 0.01
                    && Math.abs(selHsv[2] - hsv[2]) < 0.005) {
                if(ChannelFactory.isChOpen(ChannelFactory.MATH1 + i)) {
                    return i + TChan.Math1;
                }
            }
        }
        return -1;
    }


