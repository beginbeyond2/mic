package com.micsig.tbook.tbookscope.wavezone.trigger;

import static com.micsig.tbook.tbookscope.wavezone.trigger.VoltageLineManage.VoltageLineType_Value1;

/**
 * Created by liwb on 2018/7/11.
 */

public class DiscreetVoltageLineInfoBean {
    //图标的颜色
    public int ChannelId;
    public String VoltageLineName=VoltageLineType_Value1;
    public int ShowMode=ITriggerLine.ShowMode_One;
    /**
     * 电平触发索引，TWo的时候是高，低。其它时候为Normal
     *
     */
    public int VoltageLineChannelIndex=ITriggerLine.VoltageLine_Normal;

    @Override
    public String toString() {
        return "DiscreetVoltageLineInfoBean{" +
                "ChannelId=" + ChannelId +
                ", VoltageLineName='" + VoltageLineName + '\'' +
                ", ShowMode=" + ShowMode +
                ", VoltageLineChannelIndex=" + VoltageLineChannelIndex +
                '}';
    }
}
