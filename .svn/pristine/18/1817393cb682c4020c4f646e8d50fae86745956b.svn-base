<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_checked="true" android:state_enabled="false">
        <shape>
            <stroke android:width="1px" android:color="@color/bgNewRightViewDisable" />
            <corners android:radius="4px" />
            <solid android:color="@color/bgNewRightViewDisable" />
        </shape>
    </item>
    <item android:state_checked="true">
        <shape>
            <stroke android:width="1px" android:color="@color/bgNewRightViewDisable" />
            <corners android:radius="4px" />
            <solid android:color="@color/bgNewRightViewDisable" />
        </shape>
    </item>
    <item>
        <shape>
            <stroke android:width="1px" android:color="@color/bgNewRightViewDisable" />
            <corners android:radius="4px" />
            <solid android:color="@color/bgNewRightAllLayout" />
        </shape>
    </item>
</selector>