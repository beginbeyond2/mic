                    break;
                case MSG_BRIEF_DISPLAY_CH3_GONE:
                    briefDisplayCh3.setVisibility(View.GONE);
                    break;
                case MSG_BRIEF_DISPLAY_CH4:
                    briefDisplayCh4.setVisibility(View.GONE);
