<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <ImageView
        android:id="@+id/menu_channel_left"
        android:layout_width="18px"
        android:layout_height="32px"
        android:layout_marginEnd="33px"
        android:background="@drawable/measure_slide_l"
        android:visibility="gone" />

    <HorizontalScrollView
        android:id="@+id/main_menu_channel_scroll_view"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:overScrollMode="never"
        android:scrollbars="none" >

    </HorizontalScrollView>

    <ImageView
        android:id="@+id/menu_channel_right"
        android:layout_width="18px"
        android:layout_height="32px"
        android:layout_marginStart="33px"
        android:background="@drawable/measure_slide_r"
        android:visibility="gone" />

</LinearLayout>