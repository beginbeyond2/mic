    private void initControl() {
        RxBus.getInstance().getObservable(RxEnum.MAINRIGHT_CHANNELS).subscribe(consumerMainRightChannels);
        RxBus.getInstance().getObservable(RxEnum.MAINRIGHT_OTHERS).subscribe(consumerMainRightOthers);
        RxBus.getInstance().getObservable(RxEnum.RIGHTLAYOUT_REF).subscribe(consumerRightRef);
        RxBus.getInstance().getObservable(RxEnum.BOTTOMLAYOUT_ALLMEASURE).subscribe(consumerAllMeasure);
        RxBus.getInstance().getObservable(RxEnum.MAIN_LOAD_CACHE).subscribe(consumerLoadCache);
        RxBus.getInstance().getObservable(RxEnum.COMMANDMEASUREOPEN_TO_UI).subscribe(consumerCommandMeasureOpenToUI);
        RxBus.getInstance().getObservable(RxEnum.COMMANDMEASURECLOSE_TO_UI).subscribe(consumerCommandMeasureCloseToUI);
        RxBus.getInstance().getObservable(RxEnum.TOP_USER_SELFADJUST).subscribe(consumerUserSelfAdjust);
        RxBus.getInstance().getObservable(RxEnum.MQ_MSG_UPDATE_MEASURE_ITEM_POS).subscribe(consumerUpdateMeasureItemPos);
        RxBus.getInstance().getObservable(RxEnum.MQ_MSG_DELETE_MEASURE_ITEM_POS).subscribe(consumerDeleteMeasureItemPos);
        EventFactory.addEventObserver(EventFactory.EVENT_CH_MEASURE_UPDATE, eventUIObserver);
        EventFactory.addEventObserver(EventFactory.EVENT_MATH_MEASURE_UPDATE, eventUIObserver);
        EventFactory.addEventObserver(EventFactory.EVENT_REF_MEASURE_UPDATE, eventUIObserver);
        RxBus.getInstance().getObservable(RxEnum.MQ_MSG_CHANNEL_SELECT_COLOR).subscribe(consumerSelectColor);
        setChannelShow();
    }

    private void setCache() {
        //Cache中保存的channelId是从1�??始的，这是因为是从�?�择列表得的数据保存�??
        String channelStrings = CacheUtil.get().getString(CacheUtil.TOP_SLIP_MEASURE_SELECT_LIST_CHANNEL);
        String positionStrings = CacheUtil.get().getString(CacheUtil.TOP_SLIP_MEASURE_SELECT_LIST_INDEX);
        int channelSelect = CacheUtil.get().getInt(CacheUtil.TOP_SLIP_MEASURE_CHANNEL_SELECT);

        ArrayList<String> channelList = StrUtil.getListFromString(channelStrings, CacheUtil.MEASURE_SELECT_LIST_SLIP);
        ArrayList<String> indexList = StrUtil.getListFromString(positionStrings, CacheUtil.MEASURE_SELECT_LIST_SLIP);

        Logger.i("TopLayoutMeasureCommon channelList= " + channelList);
        Logger.i("TopLayoutMeasureCommon indexList= " + indexList);
        measureSelectList.clear();
        delAll();
        for (int i = 0; i < channelList.size(); i++) {
            int index = Integer.parseInt(indexList.get(i));
            int channel = Integer.parseInt(channelList.get(i));
            MeasureBean measureBean;
            if (index < 0) {
                measureBean = new MeasureBean(index, "", channel, 0);
            } else {
                measureBean = measureBeanList.get(index);
            }
            MeasureBean measureSelect = new MeasureBean(measureBean.getIndex(), measureBean.getName(), channel, measureBean.getDrawableResId());
//                measureSelectList.add(measureSelect);
//                addMeasureItem(measureSelect.getChannel(), measureSelect.getIndex(), measureSelect.getName(), MEASURE_DATA_INIT);

            String[] delays = CacheUtil.get().getString(CacheUtil.TOP_SLIP_MEASURE_DELAY_DATA + measureSelect.getChannel()).split(CacheUtil.DELAY_SLIP);
            delayDialog.setCache(Integer.parseInt(delays[0]), Integer.parseInt(delays[1]), Integer.parseInt(delays[2]));
            int phase = CacheUtil.get().getInt(CacheUtil.TOP_SLIP_MEASURE_PHASE_DATA + measureSelect.getChannel());
            phaseDialog.setCache(phase);
            String[] tvalue = CacheUtil.get().getString(CacheUtil.TOP_SLIP_MEASURE_TVALUE_DATA + measureSelect.getChannel()).split(CacheUtil.DELAY_SLIP);

            double vol=0; int edgeOccurence=1; int cursorIndex=0;
            try {
                vol = Double.parseDouble(tvalue[0]);
                edgeOccurence = Integer.parseInt(tvalue[1]);
                cursorIndex = Integer.parseInt(tvalue[2]);
            }catch (Exception e){
                e.printStackTrace();
            }
            tvalueDialog.setCache(vol,edgeOccurence,cursorIndex);

            if (measureBean.getIndex() == MEASURE_INDEX_DELAY) {
                if (selectListAdd(measureSelect, Integer.parseInt(delays[0]), Integer.parseInt(delays[1]), Integer.parseInt(delays[2]))) {
                    sendHardwareMsg(measureSelect.getChannel() - 1, MEASURE_INDEX_DELAY, true, new int[]{Integer.parseInt(delays[0]), Integer.parseInt(delays[1]), Integer.parseInt(delays[2])}, null);
                }
            } else if (measureBean.getIndex() == MEASURE_INDEX_PHASE) {
                if (selectListAdd(measureSelect, phase)) {
                    sendHardwareMsg(measureSelect.getChannel() - 1, MEASURE_INDEX_PHASE, true, null, new int[]{phase});
                }
            } else if (measureBean.getIndex() == MEASURE_INDEX_TVALUE) {
                if (selectListAdd(measureSelect, phase)) {
                    sendHardwareMsg(measureSelect.getChannel() - 1, MEASURE_INDEX_TVALUE, true,new int[]{edgeOccurence}, null, vol);
                }
                cursorTValueTrace(measureSelect,cursorIndex);
            }else {
                if (selectListAdd(measureSelect)) {
                    sendHardwareMsg(measureSelect.getChannel() - 1, measureBean.getIndex(), true, null, null);
                }
            }
        }
        measureSelectAdapter.notifyDataSetChanged();

        viewChannel.setChangeListener(null, null);
        viewChannel.setChecked(channelSelect);
        viewChannel.setChangeListener(onChannelItemClickListener, null);
        boolean ch1 = CacheUtil.get().getBoolean(CacheUtil.MAIN_CHANNEL_OPEN_STATE + TChan.Ch1);
        boolean ch2 = CacheUtil.get().getBoolean(CacheUtil.MAIN_CHANNEL_OPEN_STATE + TChan.Ch2);
        boolean ch3 = CacheUtil.get().getBoolean(CacheUtil.MAIN_CHANNEL_OPEN_STATE + TChan.Ch3);
        boolean ch4 = CacheUtil.get().getBoolean(CacheUtil.MAIN_CHANNEL_OPEN_STATE + TChan.Ch4);
        boolean ch5 = CacheUtil.get().getBoolean(CacheUtil.MAIN_CHANNEL_OPEN_STATE + TChan.Ch5);
        boolean ch6 = CacheUtil.get().getBoolean(CacheUtil.MAIN_CHANNEL_OPEN_STATE + TChan.Ch6);
        boolean ch7 = CacheUtil.get().getBoolean(CacheUtil.MAIN_CHANNEL_OPEN_STATE + TChan.Ch7);
        boolean ch8 = CacheUtil.get().getBoolean(CacheUtil.MAIN_CHANNEL_OPEN_STATE + TChan.Ch8);

        if (GlobalVar.get().getChannelsCount() == GlobalVar.CHANNEL_COUNT_2) {
            channelShow[0] = ch1;
            channelShow[1] = ch2;
        } else if (GlobalVar.get().getChannelsCount() == GlobalVar.CHANNEL_COUNT_4) {
            channelShow[0] = ch1;
            channelShow[1] = ch2;
            channelShow[2] = ch3;
            channelShow[3] = ch4;
        } else {
            channelShow[0] = ch1;
            channelShow[1] = ch2;
            channelShow[2] = ch3;
            channelShow[3] = ch4;
            channelShow[4] = ch5;
            channelShow[5] = ch6;
            channelShow[6] = ch7;
            channelShow[7] = ch8;
        }
        TChan.foreachCh1ToR8(chan -> {
            if (TChan.isMath(chan)) {
                boolean isCheck = CacheUtil.get().getBoolean(CacheUtil.MAIN_RIGHT_MATH + chan);
                boolean isAddByUser = CacheUtil.get().getBoolean(CacheUtil.RIGHT_SLIP_ADD_BY_USER_MATH + chan);
                channelShow[TChan.toFpgaChNo(chan)] = isCheck && isAddByUser;
            }
            if (TChan.isRef(chan)) {
                boolean isCheck = CacheUtil.get().getBoolean(CacheUtil.RIGHT_SLIP_REF_CHECK + chan);
                boolean isAddByUser = CacheUtil.get().getBoolean(CacheUtil.RIGHT_SLIP_ADD_BY_USER_REF + chan);
                channelShow[TChan.toFpgaChNo(chan)] = isCheck && isAddByUser;
            }
        });
        setChannelShow();
        RxBus.getInstance().post(RxEnum.CONTROLS_VISIBLE_CHANGED, MainViewGroup.VISIBLE_TOPMEASURE_SELECT);
        addEmptyMeasure();
    }

    private void addEmptyMeasure() {
        String channelStrings = CacheUtil.get().getString(CacheUtil.TOP_SLIP_MEASURE_SELECT_LIST_CHANNEL);
        String positionStrings = CacheUtil.get().getString(CacheUtil.TOP_SLIP_MEASURE_SELECT_LIST_INDEX);
        ArrayList<String> channelList = StrUtil.getListFromString(channelStrings, CacheUtil.MEASURE_SELECT_LIST_SLIP);
        ArrayList<String> indexList = StrUtil.getListFromString(positionStrings, CacheUtil.MEASURE_SELECT_LIST_SLIP);
        for (int i = 0; i < channelList.size() - 1; i++) {
            int channel = Integer.parseInt(channelList.get(i));
            int measureId = Integer.parseInt(indexList.get(i));
            if (channel < 0) {
                MeasureManage.MeasureItemStruct item = MeasureManage.getInstance().new MeasureItemStruct(channel, measureId, "", "");
                MeasureManage.getInstance().getMeasureItem().addEmptyMeasureItem(i, item);
            }
        }
        MeasureManage.getInstance().getMeasureItem().clearRowEmpty();//若一行都为空，则删除
    }

    private boolean selectListAdd(MeasureBean measureBean, int... param) {
        return selectListAdd(measureBean,0,param);
    }
    private boolean selectListAdd(MeasureBean measureBean, double a, int... param){

        Tools.PrintControlsLocation("TopLayoutMeasureCommon", rootView);
        //如果已选择列表中包含当前通道的延时相位，则界面上不做修改，只需返回true用以修改底层数据
        if ((param.length == 1 && measureBean.getIndex() == MEASURE_INDEX_PHASE)) {
            for (int i = measureSelectList.size() - 1; i >= 0; i--) {
                MeasureBean item = measureSelectList.get(i);
                if (item.getIndex() == MEASURE_INDEX_PHASE && item.getChannel() == measureBean.getChannel()) {
                    return true;
                }
            }
        } else if ((param.length == 3 && measureBean.getIndex() == MEASURE_INDEX_DELAY)) {
            for (int i = measureSelectList.size() - 1; i >= 0; i--) {
                MeasureBean item = measureSelectList.get(i);
                if (item.getIndex() == MEASURE_INDEX_DELAY && item.getChannel() == measureBean.getChannel()) {
                    return true;
                }
            }
        }

        if (measureSelectList.size() < measureSelectMaxNum) {
            for (MeasureBean item : measureSelectList) {
                if (item.equals(measureBean)) {
                    return item.getIndex() == MEASURE_INDEX_TVALUE
                            && item.getChannel() == measureBean.getChannel();
                }
            }
            measureSelectList.add(measureBean);
            measureSelectAdapter.notifyDataSetChanged();
            // 添加
            addMeasureItem(measureBean.getChannel(), measureBean.getIndex(), measureBean.getName(), MEASURE_DATA_INIT);
            saveMeasureSelect();
            setStaticsItemEnable(measureBean.getChannel()-1,measureBean.getIndex(),true);
            if (param.length == 0 ) {
                Command.get().getMeasure().Open(measureBean.getIndex(), measureBean.getChannel() - 1, 0, 0, 0, false);
            } else if (param.length == 1
                    && measureBean.getIndex() == MEASURE_INDEX_PHASE) { //相位
                Command.get().getMeasure().Open(measureBean.getIndex(), measureBean.getChannel() - 1, param[0], 0, 0, false);
            } else if (param.length == 3
                    && measureBean.getIndex() == MEASURE_INDEX_DELAY) { //延时
                Command.get().getMeasure().Open(measureBean.getIndex(), measureBean.getChannel() - 1, param[0], param[1], param[2], false);
            } else if (param.length == 1
                    && measureBean.getIndex() == MEASURE_INDEX_TVALUE){
                Command.get().getMeasure().Open(measureBean.getIndex(), measureBean.getChannel() - 1, param[0], 0, 0, a, false);
            }
            return true;
        }
        return false;
    }

    private void saveMeasureSelect() {
        ArrayList<String> listIndex = new ArrayList<>();
        ArrayList<String> listChannel = new ArrayList<>();
//        for (MeasureBean item : measureSelectList) {
//            listIndex.add(String.valueOf(item.getIndex()));
//            listChannel.add(String.valueOf(item.getChannel()));
//        }

        List<MeasureManage.MeasureItemStruct> list = MeasureManage.getInstance().getMeasureItem().getMeasureList();
        for (MeasureManage.MeasureItemStruct itemStruct : list) {
            listIndex.add(String.valueOf(itemStruct.getMeasureId()));
            listChannel.add(String.valueOf(itemStruct.getChannelId()));
        }
        CacheUtil.get().putMap(CacheUtil.TOP_SLIP_MEASURE_SELECT_LIST_INDEX, StrUtil.getStringFromList(listIndex, CacheUtil.MEASURE_SELECT_LIST_SLIP));
        CacheUtil.get().putMap(CacheUtil.TOP_SLIP_MEASURE_SELECT_LIST_CHANNEL, StrUtil.getStringFromList(listChannel, CacheUtil.MEASURE_SELECT_LIST_SLIP));
        RxBus.getInstance().post(RxEnum.CONTROLS_VISIBLE_CHANGED, MainViewGroup.VISIBLE_TOPMEASURE_SELECT);
        updateMeasureBeanState();
    }


    private void updateMeasureBeanState() {
        ArrayList<String> listIndex = new ArrayList<>();
        ArrayList<String> listChannel = new ArrayList<>();
//        for (MeasureBean item : measureSelectList) {
//            listIndex.add(String.valueOf(item.getIndex()));
//            listChannel.add(String.valueOf(item.getChannel()));
//        }

        List<MeasureManage.MeasureItemStruct> list = MeasureManage.getInstance().getMeasureItem().getMeasureList();
        for (MeasureManage.MeasureItemStruct itemStruct : list) {
            listIndex.add(String.valueOf(itemStruct.getMeasureId()));
            listChannel.add(String.valueOf(itemStruct.getChannelId()));
        }

        for (int i = 0; i < measureBeanList.size(); i++) {
            measureBeanList.get(i).setSelect(false);
            measureBeanList.get(i).setChannel(viewChannel.getSelectChannel() + 1);
        }
        for (int i= 0; i< listChannel.size(); i++) {
            if (Integer.parseInt(listChannel.get(i)) < 0) continue;
            if(Integer.parseInt(listChannel.get(i)) == TChan.toUiChNo(viewChannel.getSelectChannel())
                    && ChannelFactory.isChOpen(viewChannel.getSelectChannel())) {
                measureBeanList.get(Integer.parseInt(listIndex.get(i))).setSelect(true);
            }
        }
        measureAdapter.notifyDataSetChanged();
    }


    private void setChannelShow() {
        viewChannel.setItemVisible(channelShow,true);
        RxBus.getInstance().post(RxEnum.CONTROLS_VISIBLE_CHANGED, MainViewGroup.VISIBLE_TOPMEASURE_CHANNEL);
        updateMeasureBeanState();
    }

