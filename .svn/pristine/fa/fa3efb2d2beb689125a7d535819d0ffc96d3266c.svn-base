    private void initMeasureSelectView(View view) {
        RecyclerView rvMeasureSelectList = (RecyclerView) view.findViewById(R.id.measureSelectList);
        rvMeasureSelectList.setLayoutManager(new GridLayoutManager(context, measureSelectSpanCount));
        measureSelectList.clear();
