    private Consumer<Command_Measure.MeasureInfo> consumerCommandMeasureOpenToUI = new Consumer<Command_Measure.MeasureInfo>() {
        @Override
        public void accept(Command_Measure.MeasureInfo measureInfo) throws Exception {
//            Logger.i(TAG,"measure.type:"+measureInfo.measureType);
            // 26为所有测量项
            checkAndUpdateSelectList();
            if (measureInfo.measureType >= 0 && measureInfo.measureType < allMeasureNums) {
                addUIMeasureItem(measureInfo);
            } else {
                addHideMeasureItem(measureInfo);
            }

        }
    };

    private void addUIMeasureItem(Command_Measure.MeasureInfo measureInfo) {
        MeasureBean measureBean = measureBeanList.get(measureInfo.measureType);
        MeasureBean measureBean2 = new MeasureBean(measureBean.getIndex(), measureBean.getName(), measureInfo.measureChannel + 1, measureBean.getDrawableResId());
        if (measureSelectList.size() < GlobalVar.get().getMeasureItemCount()) {
            for (MeasureBean item : measureSelectList) {
                if (item.equals(measureBean2)) {
                    if(measureInfo.measureType == MeasureManage.IMeasure.MeasureId_TVALUE){
                        int[] param = {measureInfo.param1};
                        sendHardwareMsg(item.getChannel() - 1, item.getIndex(), true, param, null,measureInfo.dparam1);

                        cursorTValueTrace(measureBean2,measureInfo.param2);
                    }
                    return;
                }
            }
//            measureSelectList.add(measureBean2);
            // 添加
            addMeasureItem(measureBean2.getChannel(), measureBean2.getIndex(), measureBean2.getName(), MEASURE_DATA_INIT);
            setStaticsItemEnable(measureBean2.getChannel()-1, measureBean2.getIndex(),true);
//            Logger.i(TAG,"type:"+measureInfo.measureType);
            switch (measureInfo.measureType) {
                case 4: {
                    int selfPosition=measureInfo.param2;
                    int otherChannel=measureInfo.param1;
                    int otherPosition=measureInfo.param3;
                    CacheUtil.get().putMap(CacheUtil.TOP_SLIP_MEASURE_DELAY_DATA + measureBean2.getChannel(), selfPosition + CacheUtil.DELAY_SLIP + otherChannel + CacheUtil.DELAY_SLIP + otherPosition);
                    if (selectListAdd(measureBean2, selfPosition, otherChannel, otherPosition)) {
                        int[] param = {measureInfo.param2, measureInfo.param1, measureInfo.param3};
                        sendHardwareMsg(measureBean2.getChannel() - 1, measureBean2.getIndex(), true, param, null);
                    }
                }
                break;
                case 12: {
                    CacheUtil.get().putMap(CacheUtil.TOP_SLIP_MEASURE_PHASE_DATA + measureBean2.getChannel(), String.valueOf(measureInfo.param1));
                    if (selectListAdd(measureBean2, measureInfo.param1)) {
                        int[] param = {measureInfo.param1};
                        sendHardwareMsg(measureBean2.getChannel() - 1, measureBean2.getIndex(), true, null, param);
                    }
                }
                break;
                case MeasureManage.IMeasure.MeasureId_TVALUE:{
                    Log.d(TAG,"MeasureId_TVALUE:" + measureInfo.param2);
                    int cursoridx = measureInfo.param2;

                    CacheUtil.get().putMap(CacheUtil.TOP_SLIP_MEASURE_TVALUE_DATA + measureBean2.getChannel(), measureInfo.dparam1 + CacheUtil.DELAY_SLIP + measureInfo.param1 + CacheUtil.DELAY_SLIP + cursoridx);
                    if(selectListAdd(measureBean2,measureInfo.dparam1,measureInfo.param1)) {
                        int[] param = {measureInfo.param1};
                        sendHardwareMsg(measureBean2.getChannel() - 1, measureBean2.getIndex(), true, param, null, measureInfo.dparam1);
                    }
                    cursorTValueTrace(measureBean2,cursoridx);

                }
                break;


                default: {
                    if (selectListAdd(measureBean2, new int[0])) {
                        sendHardwareMsg(measureBean2.getChannel() - 1, measureBean2.getIndex(), true, null, null);
                    }
                }
                break;
            }
            measureSelectAdapter.notifyDataSetChanged();
            saveMeasureSelect();
        }
    }

    private void addHideMeasureItem(Command_Measure.MeasureInfo measureInfo) {
        switch (measureInfo.measureType) {
            case MeasureManage.IMeasure.MeasureId_ColValQ: {
                MeasureBean bean = new MeasureBean(measureInfo.measureType, "", measureInfo.measureChannel, 0);
                hideMeasureBeanList.add(bean);
                int[] param = {measureInfo.param1};
                sendHardwareMsg(measureInfo.measureChannel, measureInfo.measureType, true, null, param);
//                Logger.i(TAG, "23 add");
            }

        }
    }

    private Consumer<Command_Measure.MeasureInfo> consumerCommandMeasureCloseToUI = new Consumer<Command_Measure.MeasureInfo>() {
        @Override
        public void accept(Command_Measure.MeasureInfo measureInfo) throws Exception {
            if (measureInfo.flag == Command_Measure.MeasureInfo.FLAG_ClearAll) {
                measureSelectList.clear();
                measureSelectAdapter.notifyDataSetChanged();
                hideMeasureBeanList.clear();
//                MeasureManage.getInstance().getMeasureItem().delAllMeasureItem();
                delAll();
                saveMeasureSelect();
//                Logger.i(TAG,"clear all!");
            } else {
                if (measureInfo != null) {
//                    Log.d(TAG,"measureInfo.measureChannel:" + measureInfo.measureChannel
//                            + ",measureInfo.measureType:" + measureInfo.measureType);

                    MeasureManage.getInstance().getMeasureItem().delMeasureItem(measureInfo.measureChannel+1, measureInfo.measureType);

                    try {
                        int index = Tools.indexOf(measureSelectList, s -> s.getChannel() == measureInfo.measureChannel+1 && s.getIndex() == measureInfo.measureType);
                        if(index >= 0) {
                            measureSelectList.remove(index);
                        }
                        measureSelectAdapter.notifyDataSetChanged();
                        index = Tools.indexOf(hideMeasureBeanList, s -> s.getChannel() == measureInfo.measureChannel && s.getIndex() == measureInfo.measureType);
                        if(index >= 0) {
                            hideMeasureBeanList.remove(index);
                        }
                    }catch (Exception e){

                    }

                    if(!isMeasureAll(measureInfo.measureChannel+1,measureInfo.measureType)
                            || measureInfo.measureType == MEASURE_INDEX_COLVAL) {

//                        Log.d(TAG,"close ch:" + measureInfo.measureChannel + ",type:" + measureInfo.measureType);

                        sendHardwareMsg(measureInfo.measureChannel, measureInfo.measureType, false, null, null);
                    }


                    saveMeasureSelect();
                    //hideMeasureBeanList.remove(new MeasureBean(measureInfo.measureType, "", measureInfo.measureChannel , 0));
//                    Logger.i(TAG,"clear item type:"+measureInfo.measureType);
                }
            }
        }
    };

