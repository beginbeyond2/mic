    private TopDialogMeasureTValue.OnSureListener onTValueSureListener = new TopDialogMeasureTValue.OnSureListener() {
        @Override
        public void onSure(MeasureBean measureBean, double vol, int edgeOccurence, int cursorIndex) {
            PlaySound.getInstance().playButton();

            CacheUtil.get().putMap(CacheUtil.TOP_SLIP_MEASURE_TVALUE_DATA + TChan.toUiChNo(viewChannel.getSelectChannel()), vol + CacheUtil.DELAY_SLIP + edgeOccurence + CacheUtil.DELAY_SLIP + cursorIndex);
