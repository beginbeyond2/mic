    private void initMeasureView(View view) {
        RecyclerView rvMeasureList = (RecyclerView) view.findViewById(R.id.measureList);
        rvMeasureList.setLayoutManager(new GridLayoutManager(context, measureSpanCount));
        String[] measures = getResources().getStringArray(R.array.measures);
        allMeasureNums = measures.length;
        for (int i = 0; i < measures.length; i++) {
            measureBeanList.add(new MeasureBean(i, measures[i], viewChannel.getSelectChannel() + 1, getMeasureDrawable()[i], false));
        }
        measureAdapter = new MeasureAdapter(context, measureBeanList);
        measureAdapter.setItemClickListener(onMeasureItemClickListener);
        rvMeasureList.setAdapter(measureAdapter);
    }

