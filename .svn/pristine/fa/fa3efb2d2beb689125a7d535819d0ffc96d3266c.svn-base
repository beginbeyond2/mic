    private void cursorTValueTrace(MeasureBean measureBean, int cursorIndex){

        boolean bCursor = false;
        int chIdx = measureBean.getChannel() - 1;
        int X1 = CacheUtil.get().getInt(CacheUtil.TOP_SLIP_MEASURE_TVALUE_X1);
        int X2 = CacheUtil.get().getInt(CacheUtil.TOP_SLIP_MEASURE_TVALUE_X2);

        Log.d(TAG,"chIdx:" + chIdx + ",cursorIndex:" + cursorIndex + ",X1:" + X1 + ",X2:" + X2);

        switch (cursorIndex){
            case 1:
                X1 = chIdx;
                if(X2 == chIdx){
                    X2 = -1;
                }
                bCursor = true;
                break;
            case 2:
                X2 = chIdx;
                if(X1 == chIdx){
                    X1 = -1;
                }
                bCursor = true;
                break;
            default:
                if(X1 == chIdx){
                    X1 = -1;
                }
                if(X2 == chIdx){
                    X2 = -1;
                }
                break;
        }

//        if(X1 == X2){
//            new Throwable().printStackTrace();
//        }

        CacheUtil.get().putMap(CacheUtil.TOP_SLIP_MEASURE_TVALUE_X1,String.valueOf(X1));
        CacheUtil.get().putMap(CacheUtil.TOP_SLIP_MEASURE_TVALUE_X2,String.valueOf(X2));


        if(bCursor){
            CursorManage cursorManage = CursorManage.getInstance();
            if(!cursorManage.getColVisible()){
                RxBus.getInstance().post(RxEnum.EXTERNALKEYS_CURSOR, new ExternalKeysMsgCursor(false, ExternalKeysMsgCursor.TYPE_OPEN));
            }
            if(cursorManage.isCursorTrace()) {
//                cursorManage.setCursorTrace(false);
                Command.get().getCursor().Trace(false,true);
            }

            if(MeasureService.isCursorRang()){
                Command.get().getMeasure_setting().Range(0, true);
            }

        }
        //这里将光标追踪按钮置灰
        RxBus.getInstance().post(RxEnum.MSG_TVALUE_ENABLE, true);
    }

    private void resetTValueCurSorCache(int chId) {

        String[] tValues = CacheUtil.get().getString(CacheUtil.TOP_SLIP_MEASURE_TVALUE_DATA + (chId + 1)).split(CacheUtil.DELAY_SLIP);
        int cursorIndex = Integer.parseInt(tValues[2]);
        int X1 = CacheUtil.get().getInt(CacheUtil.TOP_SLIP_MEASURE_TVALUE_X1);
        int X2 = CacheUtil.get().getInt(CacheUtil.TOP_SLIP_MEASURE_TVALUE_X2);
        Log.d(TAG,"cursorIndex:" + cursorIndex + ",X1:" + X1 + ",X2:" + X2 + ",chId:" + chId);
        switch (cursorIndex) {
            case 1:
                if (X1 == chId) {
                    CacheUtil.get().putMap(CacheUtil.TOP_SLIP_MEASURE_TVALUE_X1, String.valueOf("-1"));
                }
                break;
            case 2:
                if (X2 == chId) {
                    CacheUtil.get().putMap(CacheUtil.TOP_SLIP_MEASURE_TVALUE_X2, String.valueOf("-1"));
                }
                break;
            default:
//                CacheUtil.get().putMap(CacheUtil.TOP_SLIP_MEASURE_TVALUE_X1, String.valueOf("-1"));
//                CacheUtil.get().putMap(CacheUtil.TOP_SLIP_MEASURE_TVALUE_X2, String.valueOf("-1"));
                break;
        }
        RxBus.getInstance().post(RxEnum.MSG_TVALUE_ENABLE, true);
    }


