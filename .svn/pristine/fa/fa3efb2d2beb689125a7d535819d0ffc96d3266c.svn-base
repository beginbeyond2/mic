    private void checkAndUpdateSelectList() {
        List<MeasureManage.MeasureItemStruct> validList = MeasureManage.getInstance().getMeasureItem().getValidMeasureList();
        if (measureSelectList.size() != validList.size()) {
            updateSelectMeasureList();
        }
    }

    private void updateSelectMeasureList() { //
        ArrayList<MeasureBean> tempList = new ArrayList<>();
        List<MeasureManage.MeasureItemStruct> list = MeasureManage.getInstance().getMeasureItem().getValidMeasureList();
        for (MeasureManage.MeasureItemStruct itemStruct : list) {
            for (MeasureBean measureBean : measureSelectList) {
                if (itemStruct.getChannelId() == measureBean.getChannel() && itemStruct.getMeasureId() == measureBean.getIndex()) {
                    tempList.add(measureBean);
                    break;
                }
            }
        }
        measureSelectList.clear();
        measureSelectList.addAll(tempList);
    }

    private Consumer<String> consumerDeleteMeasureItemPos = new Consumer<String>() {
        @Override
        public void accept(String deleteItemInfo) throws Throwable {
            if (StrUtil.isEmpty(deleteItemInfo)) return;
            Logger.i("TopLayoutMeasureCommon deleteItemInfo= " + deleteItemInfo);
            String[] strs = deleteItemInfo.split(" ");
            int channelId = Integer.parseInt(strs[0]);
            int measureId = Integer.parseInt(strs[1]);
            measureSelectList.removeIf(bean -> bean.getChannel() < 0);
            MeasureBean temp = null;
            for (MeasureBean bean : measureSelectList) {
                if (bean.getChannel() == channelId && bean.getIndex() == measureId) {
                    temp = bean;
                    break;
                }
            }
            if (temp == null) return;
            int i = measureSelectList.indexOf(temp);
            measureSelectList.remove(temp);
            measureSelectAdapter.notifyDataSetChanged();
            //删除
            delMeasureItem(temp.getChannel(), temp.getIndex(), i);
            saveMeasureSelect();
            setStaticsItemEnable(temp.getChannel() - 1, temp.getIndex(), false);
            if (!isMeasureAll(temp.getChannel(), temp.getIndex())) {
                sendHardwareMsg(temp.getChannel() - 1, temp.getIndex(), false, null, null);
            }
        }
    };


