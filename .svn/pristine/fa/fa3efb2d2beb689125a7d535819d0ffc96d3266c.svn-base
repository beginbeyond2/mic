    private MeasureAdapter.OnItemClickListener onMeasureItemClickListener = new MeasureAdapter.OnItemClickListener() {
        @Override
        public void onClick(MeasureAdapter adapter, MeasureBean measureBean) {
            PlaySound.getInstance().playButton();
            checkAndUpdateSelectList();
            String[] measureStrings = context.getResources().getStringArray(R.array.measures);
            RadioButton radioButton = viewChannel.getSelectedRadioButton();
            if (adapter.hashCode() == measureAdapter.hashCode()) {
                if (measureBean.isSelect()) {
                    measureSelectAdapter.getItemClickListener().onClick(measureSelectAdapter, measureBean);
                } else {
                    int chIdx = viewChannel.getSelectChannel();
                    if (!channelShow[chIdx]) return;
                    measureBean.setChannel(chIdx);
                    if (measureStrings[MEASURE_INDEX_DELAY].equals(measureBean.getName())) {//延时
                        if (ChannelFactory.isRefCh(chIdx)) return;
                        String[] delays = CacheUtil.get().getString(CacheUtil.TOP_SLIP_MEASURE_DELAY_DATA + (chIdx + 1)).split(CacheUtil.DELAY_SLIP);
                        delayDialog.setCache(Integer.parseInt(delays[0]), Integer.parseInt(delays[1]), Integer.parseInt(delays[2]));
                        delayDialog.setData(radioButton.getText().toString(), measureBean, onDelaySureListener);
                    } else if (measureStrings[MEASURE_INDEX_PHASE].equals(measureBean.getName())) {//相位
                        if (ChannelFactory.isRefCh(chIdx)) return;
                        String phase = CacheUtil.get().getString(CacheUtil.TOP_SLIP_MEASURE_PHASE_DATA + (chIdx + 1));
                        phaseDialog.setCache(Integer.parseInt(phase));
                        phaseDialog.setData(radioButton.getText().toString(), measureBean, onPhaseSureListener);
                    } else if (measureStrings[MEASURE_INDEX_TVALUE].equals(measureBean.getName())) {//TValue
                        String[] tValues = CacheUtil.get().getString(CacheUtil.TOP_SLIP_MEASURE_TVALUE_DATA + (chIdx + 1)).split(CacheUtil.DELAY_SLIP);
                        tvalueDialog.setCache(Double.parseDouble(tValues[0]), Integer.parseInt(tValues[1]), Integer.parseInt(tValues[2]));
                        tvalueDialog.setData(radioButton.getText().toString(), measureBean, onTValueSureListener);
                    } else {
                        MeasureBean measureBean2 = new MeasureBean(measureBean.getIndex(), measureBean.getName(), chIdx + 1, measureBean.getDrawableResId());
                        if (selectListAdd(measureBean2)) {
                            sendHardwareMsg(chIdx, measureBean.getIndex(), true, null, null);
                        }
                    }
                }
            } else if (adapter.hashCode() == measureSelectAdapter.hashCode()) {
                int i = measureSelectList.indexOf(measureBean);
                measureSelectList.remove(measureBean);
                measureSelectAdapter.notifyDataSetChanged();
                //删除
                delMeasureItem(measureBean.getChannel(), measureBean.getIndex(), i);
                saveMeasureSelect();
                setStaticsItemEnable(measureBean.getChannel() - 1, measureBean.getIndex(), false);
//                Command.get().getMeasure().Clear(i, false);
                if(!isMeasureAll(measureBean.getChannel(),measureBean.getIndex())) {
                    sendHardwareMsg(measureBean.getChannel() - 1, measureBean.getIndex(), false, null, null);
                }
            }
        }
    };
    private void sendHardwareMsg(int chId, int measureId, boolean isOpen, int[] delay, int[] phase){
        sendHardwareMsg(chId,measureId,isOpen,delay,phase,0);
    }
    private void sendHardwareMsg(int chId, int measureId, boolean isOpen, int[] delay, int[] phase,double v) {
        Log.d(TAG, "sendHardwareMsg() called with: chId = [" + chId + "], measureId = [" + measureId + "], isOpen = [" + isOpen + "], delay = [" + delay + "], phase = [" + phase + "], v = [" + v + "]");
        Measure measure = getHardwareMeasure(chId);
//        Logger.i(TAG," measure: " + (measure!=null?"true":"false")+",measureId:"+measureId+",chId:"+chId);
        if (measure != null) {
            if (measureId == MEASURE_INDEX_DELAY) {
                if (isOpen) {
                    if (delay != null) {
                        measure.MeasureDelay(delay[0], delay[1], delay[2]);
                        measure.MeasureDelayEnable(true);
                    }
                } else {
                    measure.MeasureDelayEnable(false);
                }
            } else if (measureId == MEASURE_INDEX_PHASE) {
                if (isOpen) {
                    if (phase != null) {
                        measure.MeasurePhase(phase[0]);
                        measure.MeasurePhaseEnable(true);
                    }
                } else {
                    measure.MeasurePhaseEnable(false);
                }
            } else if (measureId == MEASURE_INDEX_COLVAL) {
                if (isOpen) {
                    if (phase != null) {
                        measure.MeasureCol(phase[0]);
                    }
                }
            }else if(measureId == MEASURE_INDEX_TVALUE){
                if (isOpen) {
                    if (delay != null) {
                        measure.setTValue(v,delay[0]);
                    }
                } else {
                    resetTValueCurSorCache(chId);
                }
            }
            measure.MeasureItemEnable(measureId + Measure.MeasureType.MEASURE_FIRST, isOpen);
            if (ChannelFactory.isDynamicCh(chId)) {
                MeasureService.forceChMeasureRefresh();
            } else if (ChannelFactory.isMathCh(chId)) {
                MeasureService.forceMathMeasureRefresh();
            } else if (ChannelFactory.isRefCh(chId)) {
                MeasureService.forceRefMeasureRefresh();
            }
        }
    }

    private Measure getHardwareMeasure(int chId) {
        BaseChannel baseChannel = null;
        if (ChannelFactory.isDynamicCh(chId)) {
            baseChannel = ChannelFactory.getDynamicChannel(chId);
        } else if (ChannelFactory.isMathCh(chId)) {
            baseChannel = ChannelFactory.getMathChannel(chId);
        } else if (ChannelFactory.isRefCh(chId)) {
            baseChannel = ChannelFactory.getRefChannel(chId);
        }
        if (baseChannel != null) {
            return baseChannel.getMeasure();
        }
        return null;
    }

    private void setStaticsItemEnable(int chIdx,int measureId,boolean bEnable){

        Measure measure = getHardwareMeasure(chIdx);
        if(measure != null){
            measure.setStaticsItemEnable(measureId + Measure.MeasureType.MEASURE_PERIOD,bEnable);
        }
    }

    private void addMeasureItem(int channelId, int measureId, String measureName, String data) {
        MeasureManage.MeasureItemStruct item = MeasureManage.getInstance().new MeasureItemStruct(channelId, measureId, measureName, data);
        MeasureManage.getInstance().getMeasureItem().addMeasureItem(item);

    }

    void updateMeasureItem(int channelId, int measureId, String measureName, String data) {
        MeasureManage.MeasureItemStruct item = MeasureManage.getInstance().new MeasureItemStruct(channelId, measureId, measureName, data);
        MeasureManage.getInstance().getMeasureItem().updateMeasureItem(item);
    }

    void updateMeasureIndication(){
        int chIdx = 0;
        int idx = 0;
        Measure measure=null;
        MeasureManage.MeasureIndication measureIndication = MeasureManage.getInstance().getMeasureIndication();

        for (int i = 0; i < measureSelectList.size(); i++) {//更新SelectMeasure
            MeasureBean bean = measureSelectList.get(i);
            measure = getHardwareMeasure(bean.getChannel() - 1);
            idx = bean.getIndex() + Measure.MeasureType.MEASURE_FIRST;
            chIdx = bean.getChannel()-1;
            if(measureIndication.getChIdx() == chIdx
                    && measureIndication.getMeasureId() == idx) {
                break;
            }
        }
        if(com.micsig.tbook.scope.Display.Display.getInstance().isXYMode()){
            measure = null;
        }
        if(measure != null
                && ChannelFactory.isChOpen(chIdx)
                && measure.isMeasureItemValid(idx)){
            for (int j = 0; j < MeasureManage.MeasureIndication.MEASURE_INDICATION_MAX; j++) {
                int v = measure.getIndication(idx, j);
                measureIndication.setVisiable(j, v >= 0);
                measureIndication.setPos(j, v);
            }
        }else{
            measureIndication.setVisiable(false);
        }

    }

    private void delMeasureItem(int channelId, int measureId, int index) {
        MeasureManage.MeasureItem measureItem = MeasureManage.getInstance().getMeasureItem();
        if(measureItem == null || channelId < 0 || measureId < 0) return;
//        List<MeasureManage.MeasureItemStruct> measureStructList = measureItem.getMeasureList();
//        for (int i= 0; i< measureStructList.size(); i++) {
//            MeasureManage.MeasureItemStruct measureItemStruct = measureStructList.get(i);
//            if(measureItemStruct.getChannelId() == channelId && measureItemStruct.getMeasureId() == measureId) {
//                measureItem.delMeasureItem(channelId, measureId);
//                break;
//            }
//        }
        measureItem.delMeasureItem(channelId, measureId);
        MeasureManage.MeasureItemStruct measureItemStruct = measureItem.getMeasureItemStruct(channelId, measureId);


//        int effectiveCount = 0;//有效测量项的个数
//        int newIndex = 0;//最终需要删除index
//        MeasureManage.MeasureItemStruct measureItemStruct = null;
//        for (int i = 0; i < measureStructList.size(); i++) {
//            measureItemStruct = measureItem.getMeasureList().get(i);
//            newIndex = i;
//            if (measureItemStruct.getChannelId() >= 0) {
//                effectiveCount++;
//                if (effectiveCount == index + 1) {
//                    break;
//                }
//            }
//        }
//        measureItem.delMeasureItem(newIndex);
        MeasureManage.MeasureIndication measureIndication = MeasureManage.getInstance().getMeasureIndication();
        if(measureIndication != null){
            measureIndication.setVisiable(false);
            if(measureItemStruct != null && measureIndication.getChIdx() == (measureItemStruct.getChannelId() - 1)
                && measureIndication.getMeasureId() == (measureItemStruct.getMeasureId() + Measure.MeasureType.MEASURE_FIRST)){
                measureIndication.setMeasureIndication(-1,-1);
            }
        }
        Command.get().getMeasure().Clear(index, false);
    }

    private void delAll() {

        ChannelFactory.forEachCh(channel -> {
            Measure measure = getHardwareMeasure(channel.getChId());
            if(measure != null){
                measure.getMeasureStatics().clear();
            }
        });
        MeasureManage.getInstance().getMeasureItem().delAllMeasureItem();
        Command.get().getMeasure().ClearAllItem(false);
        MeasureManage.getInstance().getMeasureIndication().setVisiable(false);
        MeasureManage.getInstance().getMeasureIndication().setMeasureIndication(-1,-1);
    }


    private EventUIObserver eventUIObserver = new EventUIObserver() {
        @Override
        public void update(Object data) {
            EventBase eventBase = (EventBase) data;
            int id = eventBase.getId();

            if (id == EventFactory.EVENT_CH_MEASURE_UPDATE
                    || id == EventFactory.EVENT_MATH_MEASURE_UPDATE
                    || id == EventFactory.EVENT_REF_MEASURE_UPDATE) {

                int chidx = -1;


                CursorManage cursorManage = CursorManage.getInstance();
                WorkModeManage workModeManage = WorkModeManage.getInstance();
                int X1 = CacheUtil.get().getInt(CacheUtil.TOP_SLIP_MEASURE_TVALUE_X1);
                int X2 = CacheUtil.get().getInt(CacheUtil.TOP_SLIP_MEASURE_TVALUE_X2);

//                Log.d(TAG,"X1:" + X1 + ",X2:" + X2);

                for (int i = 0; i < measureSelectList.size(); i++) {//更新SelectMeasure
                    MeasureBean bean = measureSelectList.get(i);
                    chidx = bean.getChannel() - 1;
                    long curTimeX = 0;
                    double timeEvery = 0;
//                    int chIdx = TChan.toFpgaChNo(chidx);
                    if (ChannelFactory.isDynamicCh(chidx)
                            || ChannelFactory.isMathCh(chidx)
                            || ChannelFactory.isSerialCh(chidx)) {
                        if (ChannelFactory.isMath_FFT_Ch(chidx)) {
                            HorizontalAxisMath horizontalAxisMath = ChannelFactory.getMathChannel(chidx).getHorizontalAxisMathFFT();
                            curTimeX = ScopeBase.getWidth() / 2 - horizontalAxisMath.getXPosOfView();
                            timeEvery = horizontalAxisMath.fftXScaleIdVal() / ScopeBase.getHorizonPerGridPixels();
                        } else {
                            curTimeX = ScopeBase.getWidth() / 2 - HorizontalAxis.getInstance().getTimePoseOfViewPix();
                            timeEvery = HorizontalAxis.getInstance().getTimesPrePix();
                        }
                    } else if (ChannelFactory.isRefCh(chidx)) {
                        RefChannel refChannel = ChannelFactory.getRefChannel(chidx);
                        curTimeX = ScopeBase.getWidth() / 2 - refChannel.getTimePoseOfViewPix();
                        timeEvery = refChannel.getRefTimePerPix();
                    }

                    Measure measure = getHardwareMeasure(chidx);
                    int idx = bean.getIndex() + Measure.MeasureType.MEASURE_FIRST;

                    if (ChannelFactory.isChOpen(chidx) && measure != null
                            && measure.isMeasureItemValid(idx)) {

                        if((ChannelFactory.isDynamicCh(chidx) && id != EventFactory.EVENT_CH_MEASURE_UPDATE)
                                || (ChannelFactory.isMathCh(chidx) && id != EventFactory.EVENT_MATH_MEASURE_UPDATE)
                                || (ChannelFactory.isRefCh(chidx) && id != EventFactory.EVENT_REF_MEASURE_UPDATE)
                        ){
                            continue;
                        }

                        float itemVal = measure.getMeasureItemVal(idx);
                        if(idx == Measure.MeasureType.MEASURE_TVALUE){
//                            if(!cursorManage.isCursorTrace()
//                                    && cursorManage.getColVisible()
//                                    && (workModeManage.getmWorkMode() == IWorkMode.WorkMode_YT
//                                    || workModeManage.getmWorkMode() == IWorkMode.WorkMode_YTZOOM
//                            )
//                                ){
//                                Log.d(TAG,"X1:" + X1 + ",chidx:" + chidx +",X2:" + X2 + ",itemVal:" + itemVal);
                                if(X1 == chidx){

                                    cursorManage.setCursor(TChan.Cursor_col_1, itemVal);
                                }
                                if(X2 == chidx){
                                    cursorManage.setCursor(TChan.Cursor_col_2, itemVal);
                                }
//                            }

                            itemVal = (float) ((itemVal - curTimeX) * timeEvery);

//                            Log.d(TAG,"---itemVal:" + itemVal);
                        }


                        Command.get().getMeasure().setListMeasureValue(bean.getChannel(), bean.getIndex(), itemVal, true);
                        updateMeasureItem(bean.getChannel(), bean.getIndex(), bean.getName(),
                                clippingProcess(addUnit(chidx, bean.getIndex(), itemVal),
                                        idx, measure.getClipping()));
                    } else {
                        Command.get().getMeasure().setListMeasureValue(bean.getChannel(), bean.getIndex(), 0,false);
                        updateMeasureItem(bean.getChannel(), bean.getIndex(), bean.getName(), MEASURE_DATA_INIT);
                    }
                }
                if(measureSelectList.size() > 0) {
                    updateMeasureIndication();
                }
//                Logger.i(TAG," hidemeasurebeanlist size:"+hideMeasureBeanList.size());


                for (int i = 0; i < hideMeasureBeanList.size(); i++) {
                    int ch = hideMeasureBeanList.get(i).getChannel();
                    int idx = hideMeasureBeanList.get(i).getIndex() + Measure.MeasureType.MEASURE_PERIOD;
                    Measure measure = getHardwareMeasure(ch);
//                    Logger.i(TAG,"ch:"+ch+",measure:"+(measure!=null?"true":"false")+",valid:"+measure.isMeasureItemValid(idx));
                    if (ChannelFactory.isChOpen(ch) && measure != null
                            && measure.isMeasureItemValid(idx)) {
                        if((ChannelFactory.isDynamicCh(chidx) && id != EventFactory.EVENT_CH_MEASURE_UPDATE)
                                || (ChannelFactory.isMathCh(chidx) && id != EventFactory.EVENT_MATH_MEASURE_UPDATE)
                                || (ChannelFactory.isRefCh(chidx) && id != EventFactory.EVENT_REF_MEASURE_UPDATE)
                        ){
                            continue;
                        }
                        if(measure.isMeasureItemValid(idx)){
                            float itemVal = measure.getMeasureItemVal(idx);

                            Command.get().getMeasure().setListMeasureValueEx(ch, idx - Measure.MeasureType.MEASURE_PERIOD, itemVal,true);
                        }else{
                            Command.get().getMeasure().setListMeasureValueEx(ch, idx - Measure.MeasureType.MEASURE_PERIOD, 0,false);
                        }
                    }
                }
                setAllMeasureData();
            }
        }
    };

    private void setAllMeasureData(){
        if (MeasureManage.getInstance().getAllMeasure().isVisible()) {//更新AllMeasure
            List<String> values = new ArrayList<>();
            int ch = CacheUtil.get().getInt(CacheUtil.MAIN_CENTER_CHANNELS_SELECT);
            Measure measure = getHardwareMeasure(ch);
            for (MeasureBean bean : measureBeanList) {
                if (bean.getIndex() == MEASURE_INDEX_DELAY
                        || bean.getIndex() == MEASURE_INDEX_PHASE
                        || bean.getIndex() == MEASURE_INDEX_TVALUE) {//延时、相位没有AllMeasure�???
                    continue;
                }
                if (measure != null && measure.isMeasureItemValid(bean.getIndex() + Measure.MeasureType.MEASURE_PERIOD)) {
                    float itemVal = measure.getMeasureItemVal(bean.getIndex() + Measure.MeasureType.MEASURE_PERIOD);
                    values.add(clippingProcess(addUnit(ch, bean.getIndex(), itemVal),
                            bean.getIndex() + Measure.MeasureType.MEASURE_PERIOD,
                            measure.getClipping()));
                } else {
                    values.add(MEASURE_DATA_INIT);
                }
            }
            MeasureManage.getInstance().getAllMeasure().setMeasureData(values);
        }
    }

    private String addUnit(int ch, int measureType, float val) {
        switch (measureType) {
            case MeasureManage.IMeasure.MeasureId_Freq:
                return TBookUtil.getFourFromD_(val) + "Hz";
            case MeasureManage.IMeasure.MeasureId_DutyAdd:
            case MeasureManage.IMeasure.MeasureId_DutySub:
            case MeasureManage.IMeasure.MeasureId_ROV:
            case MeasureManage.IMeasure.MeasureId_FOV:
                //%不显示m、k、M等前缀，保留2位小数
                return TBookUtil.getPoint2FromD_noscale(val * 100) + "%";
            case MeasureManage.IMeasure.MeasureId_Phase:
                String d = TBookUtil.getFourFromD_(val);
                if ("-0 f".equals(d) || "0 f".equals(d)) {
                    d = "0";
                }
                return d + "°";
            case MeasureManage.IMeasure.MeasureId_Period:
            case MeasureManage.IMeasure.MeasureId_RiseTime:
            case MeasureManage.IMeasure.MeasureId_FallTime:
            case MeasureManage.IMeasure.MeasureId_Delay:
            case MeasureManage.IMeasure.MeasureId_WidthAdd:
            case MeasureManage.IMeasure.MeasureId_WidthSub:
            case MeasureManage.IMeasure.MeasureId_BurstW:
            case MeasureManage.IMeasure.MeasureId_TVALUE:
                return TBookUtil.getFourFromD_(val) + "s";
            case MeasureManage.IMeasure.MeasureId_PKPK:
            case MeasureManage.IMeasure.MeasureId_Amp:
            case MeasureManage.IMeasure.MeasureId_High:
            case MeasureManage.IMeasure.MeasureId_Low:
            case MeasureManage.IMeasure.MeasureId_Max:
            case MeasureManage.IMeasure.MeasureId_Min:
            case MeasureManage.IMeasure.MeasureId_RMS:
            case MeasureManage.IMeasure.MeasureId_CRMS:
            case MeasureManage.IMeasure.MeasureId_Mean:
            case MeasureManage.IMeasure.MeasureId_CMean:
            case MeasureManage.IMeasure.MeasureId_ACRMS:
                return TBookUtil.getFourFromD_(val) + ChannelFactory.getProbeType(ch);
            case MeasureManage.IMeasure.MeasureId_PostitiveRate:
            case MeasureManage.IMeasure.MeasureId_NegativeRate:
                return TBookUtil.getFourFromD_(val) + ChannelFactory.getProbeType(ch) + "/s";
        }
        return "";
    }

    private String clippingProcess(String sData, int itemId, int clipping) {
        switch (clipping) {
            case 1://正削
                switch (itemId) {
                    case Measure.MeasureType.MEASURE_NEGATIVE_OVERSHOOT:
                    case Measure.MeasureType.MEASURE_LOW:
                    case Measure.MeasureType.MEASURE_MIN:
                        break;
                    default:
                        if (!sData.equals(MEASURE_DATA_INIT)) sData += "?";
                        break;
                }
                break;
            case 2://负削
                switch (itemId) {
                    case Measure.MeasureType.MEASURE_POSITIVE_OVERSHOOT:
                    case Measure.MeasureType.MEASURE_HIGH:
                    case Measure.MeasureType.MEASURE_MAX:
                        break;
                    default:
                        if (!sData.equals(MEASURE_DATA_INIT)) sData += "?";
                        break;
                }
                break;
            case 3://双削
                if (!sData.equals(MEASURE_DATA_INIT)) sData += "?";
                break;
            case 4://无波
                if (!sData.equals(MEASURE_DATA_INIT)) sData += "?";
                break;
            case 0://正常
            default:
                break;
        }
        return sData;
    }

    private Consumer<String> consumerSelectColor = new Consumer<String>() {
        @Override
        public void accept(String colorInfo) throws Throwable {
            if (colorInfo.isEmpty()) return;
            Logger.i(TAG, "selectColorInfo= " + colorInfo);
            String[] info = colorInfo.split(";");
            int chIndex = Integer.parseInt(info[0]);
            String colorStr = info[1];
            viewChannel.setChannelColor(chIndex, colorStr);
            measureAdapter.updateColors();
            measureSelectAdapter.updateColors();
        }
    };

}