    private float [][][] ad_fs_a = new float[ChannelFactory.CH_CNT][6][2];
    private float [][] ad_fs_d = new float[ChannelFactory.CH_CNT][6];

    private static final float DA_CH_OFFSET_ZERO = 32768f;
