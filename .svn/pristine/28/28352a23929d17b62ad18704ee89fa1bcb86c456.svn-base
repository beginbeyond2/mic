    private float [][][]chZero_50 = new float[ChannelFactory.CH_CNT][MHO68V2_RATIO_DANG_CNT][33];//通道零点
    private float [] ch_pga_stepdb = new float[ChannelFactory.CH_CNT];
    private float [][][]coefChannel = new float[ChannelFactory.CH_CNT][MHO68V2_RATIO_DANG_CNT][2];//偏移量系数
    private float [][][]chZero = new float[ChannelFactory.CH_CNT][MHO68V2_RATIO_DANG_CNT][33];//通道零点
    private int [] chCapacitanceHigh = new int[ChannelFactory.CH_CNT * MHO68V2_RATIO_DANG_CNT] ;

    // 0: 1M 1,1: 1M 16,2: 1M 64,3: 1M 256,4: 50 2, 5: 50 20

