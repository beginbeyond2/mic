    private Consumer<CommandMsgToUI> consumerCommandToUI = new Consumer<CommandMsgToUI>() {
        @Override
        public void accept(CommandMsgToUI commandMsgToUI) throws Exception {
            switch (commandMsgToUI.getFlag()) {
                case CommandMsgToUI.FLAG_MENU_TRIGGER:
                case CommandMsgToUI.FLAG_MENU_MEASURE:{
                    openSlip(TOPSLIP);
                }break;
                case CommandMsgToUI.FLAG_MENU_Main:{
                    boolean isOpen=Boolean.parseBoolean(commandMsgToUI.getParam());
                    slipOption(isOpen,TOPSLIP);
                }break;
                case CommandMsgToUI.FLAG_MENU_QuickBottom:{
                    boolean isOpen=Boolean.parseBoolean(commandMsgToUI.getParam());
                    slipOption(isOpen,BOTTOMSLIP);
                }break;
                case CommandMsgToUI.FLAG_MENU_CHANNEL:{
                    String[] params= commandMsgToUI.getParam().split(CommandMsgToUI.PARAM_SPLIT);
                    int ch=Integer.parseInt(params[0]);
                    boolean isOpen=Boolean.parseBoolean(params[1]);
                    ch= TChan.toUiChNo(ch);
                    switch (ch)
                    {
                        case TChan.Ch1:slipOption(isOpen,RIGHTSLIP_CH1);break;
                        case TChan.Ch2:slipOption(isOpen,RIGHTSLIP_CH2);break;
                        case TChan.Ch3:slipOption(isOpen,RIGHTSLIP_CH3);break;
                        case TChan.Ch4:slipOption(isOpen,RIGHTSLIP_CH4);break;
                        case TChan.Ch5:slipOption(isOpen,RIGHTSLIP_CH5);break;
                        case TChan.Ch6:slipOption(isOpen,RIGHTSLIP_CH6);break;
                        case TChan.Ch7:slipOption(isOpen,RIGHTSLIP_CH7);break;
                        case TChan.Ch8:slipOption(isOpen,RIGHTSLIP_CH8);break;
                        case TChan.Math1:slipOption(isOpen,RIGHTSLIP_MATH1);break;
                        case TChan.Math2:slipOption(isOpen,RIGHTSLIP_MATH2);break;
                        case TChan.Math3:slipOption(isOpen,RIGHTSLIP_MATH3);break;
                        case TChan.Math4:slipOption(isOpen,RIGHTSLIP_MATH4);break;
                        case TChan.Math5:slipOption(isOpen,RIGHTSLIP_MATH5);break;
                        case TChan.Math6:slipOption(isOpen,RIGHTSLIP_MATH6);break;
                        case TChan.Math7:slipOption(isOpen,RIGHTSLIP_MATH7);break;
                        case TChan.Math8:slipOption(isOpen,RIGHTSLIP_MATH8);break;
                        case TChan.R1:slipOption(isOpen,RIGHTSLIP_REF1);break;
                        case TChan.R2:slipOption(isOpen,RIGHTSLIP_REF2);break;
                        case TChan.R3:slipOption(isOpen,RIGHTSLIP_REF3);break;
                        case TChan.R4:slipOption(isOpen,RIGHTSLIP_REF4);break;
                        case TChan.R5:slipOption(isOpen,RIGHTSLIP_REF5);break;
                        case TChan.R6:slipOption(isOpen,RIGHTSLIP_REF6);break;
                        case TChan.R7:slipOption(isOpen,RIGHTSLIP_REF7);break;
                        case TChan.R8: slipOption(isOpen,RIGHTSLIP_REF8);break;
                        case TChan.S1:slipOption(isOpen,RIGHTSLIP_S1);break;
                        case TChan.S2:slipOption(isOpen,RIGHTSLIP_S2);break;
                        case TChan.S3:slipOption(isOpen,RIGHTSLIP_S3);break;
                        case TChan.S4:slipOption(isOpen,RIGHTSLIP_S4);break;

                    }
                }break;
            }
        }
    };

    private void slipOption(boolean isOpen,@Slip int slip){
        if (isOpen){
            openSlip(slip);
        }else {
            hideSlip(slip);
        }
    }

