    private Consumer<String> consumerSelectColor = new Consumer<String>() {
        @Override
        public void accept(String colorInfo) throws Throwable {
            if (colorInfo.isEmpty()) return;
            Logger.i(TAG, "selectColorInfo= " + colorInfo);
            String[] info = colorInfo.split(";");
            int chIndex = Integer.parseInt(info[0]);
            String colorStr = info[1];
            handleChannelColorChange(chIndex, colorStr);
        }
    };

    private void handleChannelColorChange(int chIndex, String colorStr) {
        WaveManage.get().changeChannelColor(chIndex, colorStr);//通道指示器
        ((MainActivity) context).changeColor(chIndex);//波形
        changeItemMasterColor(chIndex, colorStr);//通道按钮中文案颜色
        channelsLayout.changeColor();// CHX
    }

    private void changeItemMasterColor(int chIndex, String colorStr) {
        if (TChan.isRef(chIndex)) {
            refMasters.get(TChan.toRefNumber(chIndex) - 1).setContentColor(TChan.toFpgaChNo(chIndex));
        }
        if (TChan.isMath(chIndex)) {
            mathMasters.get(TChan.toMathNumber(chIndex) - 1).setContentColor(TChan.toFpgaChNo(chIndex));
        }
    }

}
