            // 串型文本打开与关闭，是通过分段存储消息过来的
            boolean isSerialsTxt = CacheUtil.get().getBoolean(CacheUtil.MAIN_BOTTOM_SLIP_SERIALBUSTXT);
            sliderZone_bottom.setEnableSlip(!isSerialsTxt);
        }
