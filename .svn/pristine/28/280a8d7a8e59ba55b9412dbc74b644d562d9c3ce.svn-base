    public void hideAllSlip() {
        hideAllDialogsButDialogOkCancel();
        for (int i = 0; i < sliderZoneList.size(); i++) {
            hideSliderZone(sliderZoneList.get(i), -1, -1);
        }
        hideFileSelectDialog();

    }

    public void hideSlip(@Slip int slip) {
