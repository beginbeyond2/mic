    }

    /*

     */
    public void hideAllMenu() {
        for (SliderZone s : sliderZoneList) {
            s.setEnable(false);
            s.setCurrShowState(false);
            ViewGroup parentViewGroup = (ViewGroup) s.getSliderViewGroup().getParent();
            switch (s.getSliderDir()) {
                case SliderZone.SliderDir_BottomToTop:
                    s.getSliderViewGroup().layout(s.getSliderViewGroup().getLeft(), parentViewGroup.getHeight(),
                            s.getSliderViewGroup().getRight(), parentViewGroup.getHeight() + s.getSliderViewGroup().getHeight());
                    break;
                case SliderZone.SliderDir_TopToBottom:
                    s.getSliderViewGroup().layout(s.getSliderViewGroup().getLeft(), 0 - s.getSliderViewGroup().getHeight(),
                            s.getSliderViewGroup().getRight(), 0);
                    break;
                case SliderZone.SliderDir_LeftToRight:
                    s.getSliderViewGroup().layout(0 - s.getSliderViewGroup().getWidth(), s.getSliderViewGroup().getTop(),
                            0, s.getSliderViewGroup().getBottom());
                    break;
                case SliderZone.SliderDir_RightToLeft:
                    s.getSliderViewGroup().layout(parentViewGroup.getWidth(), s.getSliderViewGroup().getTop(),
                            parentViewGroup.getWidth() + s.getSliderViewGroup().getWidth(), s.getSliderViewGroup().getBottom());
                    break;
                default:
                    break;
            }

        }
    }

    private Consumer<MainMsgSlip> consumerMainSlipFromOther = new Consumer<MainMsgSlip>() {
        @Override
        public void accept(MainMsgSlip msgSlip) throws Exception {
            if (msgSlip.isOpen()) {
                openSlip(msgSlip.getSlip());
                changeSlipStyle(msgSlip, 0);//改变slide Math/Ref/Serials显示样式
            } else {
                hideSlip(msgSlip.getSlip());
            }
        }
    };

    private void changeSlipStyle(MainMsgSlip msgSlip, int slipNumber) {
        int channelNumber = -1;
        int slipIndex = null == msgSlip ? slipNumber : msgSlip.getSlip();
        boolean isNormal = null == msgSlip || msgSlip.isNormal();
        switch (slipIndex) {
            case RIGHTSLIP_MATH1: channelNumber = TChan.Math1;break;
            case RIGHTSLIP_MATH2: channelNumber = TChan.Math2;break;
            case RIGHTSLIP_MATH3: channelNumber = TChan.Math3;break;
            case RIGHTSLIP_MATH4: channelNumber = TChan.Math4;break;
            case RIGHTSLIP_MATH5: channelNumber = TChan.Math5;break;
            case RIGHTSLIP_MATH6: channelNumber = TChan.Math6;break;
            case RIGHTSLIP_MATH7: channelNumber = TChan.Math7;break;
            case RIGHTSLIP_MATH8: channelNumber = TChan.Math8;break;
            case RIGHTSLIP_REF1: channelNumber = TChan.R1;break;
            case RIGHTSLIP_REF2: channelNumber = TChan.R2;break;
            case RIGHTSLIP_REF3: channelNumber = TChan.R3;break;
            case RIGHTSLIP_REF4: channelNumber = TChan.R4;break;
            case RIGHTSLIP_REF5: channelNumber = TChan.R5;break;
            case RIGHTSLIP_REF6: channelNumber = TChan.R6;break;
            case RIGHTSLIP_REF7: channelNumber = TChan.R7;break;
            case RIGHTSLIP_REF8: channelNumber = TChan.R8;break;
            case RIGHTSLIP_S1: channelNumber = TChan.S1;break;
            case RIGHTSLIP_S2: channelNumber = TChan.S2;break;
            case RIGHTSLIP_S3: channelNumber = TChan.S3;break;
            case RIGHTSLIP_S4: channelNumber = TChan.S4;break;
        }
        if(channelNumber > 0) {
            RxBus.getInstance().post(RxEnum.MQ_MSG_SHOW_NORMAL_STATE, String.valueOf(channelNumber) + CommandMsgToUI.PARAM_SPLIT + String.valueOf(isNormal));
        }
    }

