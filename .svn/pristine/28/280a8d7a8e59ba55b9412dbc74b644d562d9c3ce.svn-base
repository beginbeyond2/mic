    @Retention(RetentionPolicy.SOURCE)
    public @interface Dialog {
    }

    public boolean isDialogShow(@Dialog int dialog) {

        switch (dialog) {
            case DIALOG_MEASUREDELAY:
                return dialogMeasureDelay.getVisibility() == View.VISIBLE;
            case DIALOG_MEASUREPHASE:
                return dialogMeasurePhase.getVisibility() == View.VISIBLE;
            case DIALOG_MEASURE_TVALUE:
                return dialogMeasureTValue.getVisibility() == View.VISIBLE;
            case DIALOG_TOPCOUNT:
                return dialogTopCount.getVisibility() == View.VISIBLE;
            case DIALOG_TOPSCALE:
                return dialogTopScale.getVisibility() == View.VISIBLE;
            case DIALOG_TEXTKEYBOARD:
                return dialogTextKeyBoard.getVisibility() == View.VISIBLE;
            case DIALOG_NUMBERKEYBOARD:
                return dialogNumberKeyBoard.getVisibility() == View.VISIBLE;
            case DIALOG_FLOATKEYBOARD:
                return dialogFloatKeyBoard.getVisibility() == View.VISIBLE;
            case DIALOG_FORMULAKEYBOARD:
                return dialogFormulaKeyBoard.getVisibility() == View.VISIBLE;
            case DIALOG_NUMBERPICKER:
                return dialogNumberPicker.getVisibility() == View.VISIBLE;
            case DIALOG_BAUDRATE:
                return dialogBaudRate.getVisibility() == View.VISIBLE;
            case DIALOG_BANDWIDTH:
                return dialogBandWidth.getVisibility() == View.VISIBLE;
            case DIALOG_PROBEMULTIPLE:
                return dialogProbeMultiple.getVisibility() == View.VISIBLE;
            case DIALOG_REFRECALL:
                return dialogRefRecall.getVisibility() == View.VISIBLE;
            case DIALOG_AFTERGLOW:
                return dialogAfterGlow.getVisibility() == View.VISIBLE;
            case DIALOG_FFT_AFTERGLOW:
                return dialogFftAfterGlow.getVisibility() == View.VISIBLE;
            case DIALOG_CENTERTIMEBASE:
                return dialogCenterTimeBase.getVisibility() == View.VISIBLE;
            case DIALOG_OKCANCEL:
                return dialogOkCancel.getVisibility() == VISIBLE;
            case DIALOG_OK:
                return dialogOk.getVisibility() == VISIBLE;
            case DIALOG_MENUHALF:
                return dialogMenuHalf.getVisibility() == VISIBLE;
            case DIALOG_CHANNELLABEL:
                return dialogChannelLabel.getVisibility() == VISIBLE;
            case DIALOG_BANDWIDTHHZ:
                return dialogBandWidthHz.getVisibility() == View.VISIBLE;
            case DIALOG_MATH_FFT_PERSIST:
                return dialogMathFFTPersist.getVisibility()==View.VISIBLE;
            case DIALOG_PROBE_INTERFACE:
                return dialogProbeInterface.getVisibility() == View.VISIBLE;
            case DIALOG_LOAF_REF_CSV:
                return dialogLoadRefCsvWave.getVisibility() == View.VISIBLE;
            case DIALOG_SELECT_COLOR:
                return dialogSelectColor.getVisibility() == View.VISIBLE;
            case DIALOG_SET_CHANNEL_INFO:
                return dialogSetChannelInfo.getVisibility() == View.VISIBLE;
            case DIALOG_FULL_FLOAT_KEYBOARD:
                return dialogFullFloatKeyBoard.getVisibility() == View.VISIBLE;
        }
        return false;
    }

    public ViewGroup getDialog(@Dialog int dialog) {
        switch (dialog) {
            case DIALOG_MEASUREDELAY:
                return dialogMeasureDelay;
            case DIALOG_MEASUREPHASE:
