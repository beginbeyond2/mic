    private void OnChanActiveChange(Object obj) {
        MQEnum mqEnum= RxBusRegister.parseMqEnum(obj);
        if (mqEnum != MQEnum.CH_ACTIVE) return;
        IChan chan = ((MsgChActiveChange) obj).getChan();

        if (IChan.isCh1ToCh8(chan))  {
            if (!isRightLayout()) {
//                RxBus.getInstance().post(RxEnum.SLIPRIGHTMENU, MainHolderBottom.SLIPRIGHTMENU_CHANNELS);
            }
        } else if (IChan.isMathToS4(chan) ) {
            if (isRightLayout()) {
//                RxBus.getInstance().post(RxEnum.SLIPRIGHTMENU, MainHolderBottom.SLIPRIGHTMENU_OTHERS);
            }
        }
        if (isRightSlipShow()) {
            int slipNumber = -1;
            switch (chan) {
                case CH1:
                    if (!isSlipShow(RIGHTSLIP_CH1)) slipNumber = RIGHTSLIP_CH1;
                    break;
                case CH2:
                    if (!isSlipShow(RIGHTSLIP_CH2)) slipNumber = RIGHTSLIP_CH2;
                    break;
                case CH3:
                    if (!isSlipShow(RIGHTSLIP_CH3)) slipNumber = RIGHTSLIP_CH3;
                    break;
                case CH4:
                    if (!isSlipShow(RIGHTSLIP_CH4)) slipNumber = RIGHTSLIP_CH4;
                    break;
                case CH5:
                    if (!isSlipShow(RIGHTSLIP_CH5)) slipNumber = RIGHTSLIP_CH5;
                    break;
                case CH6:
                    if (!isSlipShow(RIGHTSLIP_CH6)) slipNumber = RIGHTSLIP_CH6;
                    break;
                case CH7:
                    if (!isSlipShow(RIGHTSLIP_CH7)) slipNumber = RIGHTSLIP_CH7;
                    break;
                case CH8:
                    if (!isSlipShow(RIGHTSLIP_CH8)) slipNumber = RIGHTSLIP_CH8;
                    break;
                case Math1:
                    if (!isSlipShow(RIGHTSLIP_MATH1)) slipNumber = RIGHTSLIP_MATH1;
                    break;
                case Math2:
                    if (!isSlipShow(RIGHTSLIP_MATH2)) slipNumber = RIGHTSLIP_MATH2;
                    break;
                case Math3:
                    if (!isSlipShow(RIGHTSLIP_MATH3)) slipNumber = RIGHTSLIP_MATH3;
                    break;
                case Math4:
                    if (!isSlipShow(RIGHTSLIP_MATH4)) slipNumber = RIGHTSLIP_MATH4;
                    break;
                case Math5:
                    if (!isSlipShow(RIGHTSLIP_MATH5)) slipNumber = RIGHTSLIP_MATH5;
                    break;
                case Math6:
                    if (!isSlipShow(RIGHTSLIP_MATH6)) slipNumber = RIGHTSLIP_MATH6;
                    break;
                case Math7:
                    if (!isSlipShow(RIGHTSLIP_MATH7)) slipNumber = RIGHTSLIP_MATH7;
                    break;
                case Math8:
                    if (!isSlipShow(RIGHTSLIP_MATH8)) slipNumber = RIGHTSLIP_MATH8;
                    break;
                case R1:
                    if (!isSlipShow(RIGHTSLIP_REF1)) slipNumber = RIGHTSLIP_REF1;
                    break;
                case R2:
                    if (!isSlipShow(RIGHTSLIP_REF2)) slipNumber = RIGHTSLIP_REF2;
                    break;
                case R3:
                    if (!isSlipShow(RIGHTSLIP_REF3)) slipNumber = RIGHTSLIP_REF3;
                    break;
                case R4:
                    if (!isSlipShow(RIGHTSLIP_REF4)) slipNumber = RIGHTSLIP_REF4;
                    break;
                case R5:
                    if (!isSlipShow(RIGHTSLIP_REF5)) slipNumber = RIGHTSLIP_REF5;
                    break;
                case R6:
                    if (!isSlipShow(RIGHTSLIP_REF6)) slipNumber = RIGHTSLIP_REF6;
                    break;
                case R7:
                    if (!isSlipShow(RIGHTSLIP_REF7)) slipNumber = RIGHTSLIP_REF7;
                    break;
                case R8:
                    if (!isSlipShow(RIGHTSLIP_REF8)) slipNumber = RIGHTSLIP_REF8;
                    break;
                case S1:
                    if (!isSlipShow(RIGHTSLIP_S1)) slipNumber = RIGHTSLIP_S1;
                    break;
                case S2:
                    if (!isSlipShow(RIGHTSLIP_S2)) slipNumber = RIGHTSLIP_S2;
                    break;
                case S3:
                    if (!isSlipShow(RIGHTSLIP_S3)) slipNumber = RIGHTSLIP_S3;
                    break;
                case S4:
                    if (!isSlipShow(RIGHTSLIP_S4)) slipNumber = RIGHTSLIP_S4;
                    break;
            }
            if (slipNumber > 0) {
                openSlip(slipNumber);
                changeSlipStyle(null, slipNumber);//改变slide Math/Ref/Serials显示样式
            }
        }
    }

    private Consumer<TopMsgDisplay> consumerDisplay = new Consumer<TopMsgDisplay>() {
