            case DIALOG_SET_CHANNEL_INFO:
                return dialogSetChannelInfo;
            case DIALOG_FULL_FLOAT_KEYBOARD:
                return dialogFullFloatKeyBoard;
        }
        return null;
    }

    /**
     * 设置指定dialog隐藏
     *
     * @return 返回true，则表示该dialog正在显示并成功关闭了它
     */
    public boolean hideDialog(@Dialog int dialog) {
        switch (dialog) {
            case DIALOG_MEASUREDELAY:
                if (isDialogShow(dialog)) {
                    dialogMeasureDelay.hide();
                    return true;
                }
                break;
            case DIALOG_MEASUREPHASE:
                if (isDialogShow(dialog)) {
                    dialogMeasurePhase.hide();
                    return true;
                }
                break;
            case DIALOG_MEASURE_TVALUE:
                if (isDialogShow(dialog)) {
                    dialogMeasureTValue.hide();
                    return true;
                }
                break;
            case DIALOG_TOPCOUNT:
                if (isDialogShow(dialog)) {
                    dialogTopCount.hide();
                    return true;
                }
                break;
            case DIALOG_TOPSCALE:
                if (isDialogShow(dialog)) {
                    dialogTopScale.hide();
                    return true;
                }
                break;
            case DIALOG_TEXTKEYBOARD:
                if (isDialogShow(dialog)) {
                    dialogTextKeyBoard.hide();
                    return true;
                }
                break;
            case DIALOG_NUMBERKEYBOARD:
                if (isDialogShow(dialog)) {
                    dialogNumberKeyBoard.hide();
                    return true;
                }
                break;
            case DIALOG_FLOATKEYBOARD:
                if (isDialogShow(dialog)) {
                    dialogFloatKeyBoard.hide();
                    return true;
                }
                break;
            case DIALOG_FORMULAKEYBOARD:
                if (isDialogShow(dialog)) {
                    dialogFormulaKeyBoard.hide();
                    return true;
                }
                break;
            case DIALOG_NUMBERPICKER:
                if (isDialogShow(dialog)) {
                    dialogNumberPicker.hide();
                    return true;
                }
                break;
            case DIALOG_BAUDRATE:
                if (isDialogShow(dialog)) {
                    dialogBaudRate.hide();
                    return true;
                }
                break;
            case DIALOG_BANDWIDTH:
                if (isDialogShow(dialog)) {
                    dialogBandWidth.hide();
                    return true;
                }
                break;
            case DIALOG_PROBEMULTIPLE:
                if (isDialogShow(dialog)) {
                    dialogProbeMultiple.hide();
                    return true;
                }
                break;
            case DIALOG_REFRECALL:
                if (isDialogShow(dialog)) {
                    dialogRefRecall.hide();
                    return true;
                }
                break;
            case DIALOG_AFTERGLOW:
                if (isDialogShow(dialog)) {
                    dialogAfterGlow.hide();
                    return true;
                }
                break;
            case DIALOG_FFT_AFTERGLOW:
                if (isDialogShow(dialog)) {
                    dialogFftAfterGlow.hide();
                    return true;
                }
                break;
            case DIALOG_CENTERTIMEBASE:
                if (isDialogShow(dialog)) {
                    dialogCenterTimeBase.hide();
                    return true;
                }
                break;
            case DIALOG_OKCANCEL:
                if (isDialogShow(dialog)) {
                    dialogOkCancel.hide();
                    return true;
                }
                break;
            case DIALOG_OK:
                if (isDialogShow(dialog)) {
                    dialogOk.hide();
                    return true;
                }
                break;
            case DIALOG_MENUHALF:
                if (isDialogShow(dialog)) {
                    dialogMenuHalf.hide();
                    return true;
                }
                break;
            case DIALOG_CHANNELLABEL:
                if (isDialogShow(dialog)) {
                    dialogChannelLabel.hide();
                    return true;
                }
                break;
            case DIALOG_BANDWIDTHHZ:
                if (isDialogShow(dialog)) {
                    dialogBandWidthHz.hide();
                    return true;
                }
                break;
            case DIALOG_MATH_FFT_PERSIST:
                if (isDialogShow(dialog)){
                    dialogMathFFTPersist.hide();
                    return true;
                }
            case DIALOG_PROBE_INTERFACE:
                if (isDialogShow(dialog)){
                    dialogProbeInterface.hide();
                    return true;
                }
            case DIALOG_LOAF_REF_CSV:
                if (isDialogShow(dialog)) {
                    dialogLoadRefCsvWave.hide();
                    return true;
                }
            case DIALOG_SELECT_COLOR:
                if (isDialogShow(dialog)) {
                    dialogSelectColor.hide();
                    return true;
                }
            case DIALOG_SET_CHANNEL_INFO:
                if (isDialogShow(dialog)) {
                    dialogSetChannelInfo.hide();
                    return true;
                }
            case DIALOG_FULL_FLOAT_KEYBOARD:
                if (isDialogShow(dialog)) {
                    dialogFullFloatKeyBoard.hide();
                    return true;
                }
        }
        return false;
    }

    /**
     * 确定取消双按钮的dialog或者单按钮确定的dialog，是否显示
     */
    public boolean isDialogOkVisible() {
        return isDialogShow(DIALOG_OKCANCEL) || isDialogShow(DIALOG_OK);
    }

    /**
     * @return 关闭所有当前正在显示的dialog(除了dialogOkCancel)，有dialog在显示且成功关闭则返回true
     */
    public boolean hideAllDialogsButDialogOkCancel() {
        boolean b1 = hideDialog(DIALOG_MEASUREDELAY);
        boolean b2 = hideDialog(DIALOG_MEASUREPHASE);
        boolean b3 = hideDialog(DIALOG_TOPCOUNT);
        boolean b4 = hideDialog(DIALOG_TOPSCALE);
        boolean b5 = hideDialog(DIALOG_TEXTKEYBOARD);
        boolean b6 = hideDialog(DIALOG_NUMBERKEYBOARD);
        boolean b7 = hideDialog(DIALOG_FLOATKEYBOARD);
        boolean b8 = hideDialog(DIALOG_FORMULAKEYBOARD);
        boolean b9 = hideDialog(DIALOG_NUMBERPICKER);
        boolean b10 = hideDialog(DIALOG_BAUDRATE);
        boolean b11 = hideDialog(DIALOG_BANDWIDTH);
        boolean b12 = hideDialog(DIALOG_PROBEMULTIPLE);
        boolean b13 = hideDialog(DIALOG_REFRECALL);
        boolean b14 = hideDialog(DIALOG_AFTERGLOW);
        boolean b15 = hideDialog(DIALOG_CENTERTIMEBASE);
        boolean b16 = hideDialog(DIALOG_MENUHALF);
        boolean b17 = hideDialog(DIALOG_CHANNELLABEL);
        boolean b18 = hideDialog(DIALOG_BANDWIDTHHZ);
        boolean b19 =hideDialog(DIALOG_MATH_FFT_PERSIST);
        boolean b20 = hideDialog(DIALOG_PROBE_INTERFACE);
        boolean b21 = hideDialog(DIALOG_FFT_AFTERGLOW);
        boolean b22 = hideDialog(DIALOG_LOAF_REF_CSV);
        boolean b23 = hideDialog(DIALOG_SELECT_COLOR);
        boolean b24 = hideDialog(DIALOG_SET_CHANNEL_INFO);
        boolean b25 = hideDialog(DIALOG_MEASURE_TVALUE);
//        boolean b15 = hideDialog(DIALOG_OK);
        return b1 || b2 || b3 || b4 || b5 || b6 || b7 || b8
                || b9 || b10 || b11 || b12 || b13 || b14 || b15
                || b16 || b17 || b18 || b19 || b20 || b21 || b22
                || b23 || b24 || b25;
    }

