    public MainViewGroup(Context context, AttributeSet attrs, int defStyleAttr) {
        super(context, attrs, defStyleAttr);
        this.context = context;
        View view = inflate(context, R.layout.activity_main2, this);

        setBackgroundResource(R.color.bg_main_outside);
        LinearLayout.LayoutParams lp = new LinearLayout.LayoutParams(
                LayoutParams.MATCH_PARENT, LayoutParams.MATCH_PARENT);
        this.setLayoutParams(lp);

//        mMiddlebar_right = (ConstraintLayout) view.findViewById(R.id.menu_right2);
        channelsLayout = (MainLayoutCenterChannel) view.findViewById(R.id.mainLayoutCenterChannels);
        test = (MainLayoutCenterTest)view.findViewById(R.id.mainLayoutCenterTests);
        centerMenuLayout = (MainLayoutCenterMenu) view.findViewById(R.id.mainLayoutCenterMenu);
        centerSegmentedLayout = (MainLayoutCenterSegmented) view.findViewById(R.id.mainLayoutCenterSegmented);
        triggerLevel = (MTriggerLevel) view.findViewById(R.id.triggerLevel);
        levelSwipeLeft = (View) view.findViewById(R.id.levelSwipeLeft);
        tvToast = (TextView) view.findViewById(R.id.toast);
        mainChannelVerticalScale = view.findViewById(R.id.main_chan_vertical_scale);
        triggerLevel.setChannelCount(channelCount);
        maxVelocity = ViewConfiguration.get(context).getScaledMaximumFlingVelocity();
        mainRightChannelLayoutEight = view.findViewById(R.id.mainRightChannelLayoutEight);
        if (channelCount == GlobalVar.CHANNEL_COUNT_2) {
            findViewById(R.id.mainRightDoubleChannelLayout).setVisibility(VISIBLE);
            findViewById(R.id.mainRightChannelLayout).setVisibility(GONE);
            mainRightChannelLayoutEight.setVisibility(GONE);
        } else if (channelCount == GlobalVar.CHANNEL_COUNT_4) {
            findViewById(R.id.mainRightDoubleChannelLayout).setVisibility(GONE);
            findViewById(R.id.mainRightChannelLayout).setVisibility(VISIBLE);
            mainRightChannelLayoutEight.setVisibility(GONE);
        } else {
            findViewById(R.id.mainRightDoubleChannelLayout).setVisibility(GONE);
            findViewById(R.id.mainRightChannelLayout).setVisibility(GONE);
            mainRightChannelLayoutEight.setVisibility(VISIBLE);
        }
        mainSlipOutView = findViewById(R.id.mainSlipOutView);
        mainTopLayoutLeft=findViewById(R.id.mainTopLayoutLeft);
        mainTopLayoutLeft.setMainViewGroup(this);
        rlListView = view.findViewById(R.id.rlListView);
        textureView = view.findViewById(R.id.textureView);
        viewSpace = view.findViewById(R.id.viewSpace);
        nullView = view.findViewById(R.id.nullView);
        mainBottomMeasureItem = view.findViewById(R.id.bottom_measure_item);
        clTriggerLevel = view.findViewById(R.id.cl_triggerLevel);

        if (channelCount == GlobalVar.CHANNEL_COUNT_4) {
            briefDisplayCh1 = findViewById(R.id.briefDisplayTextFourCh1);
            briefDisplayCh2 = findViewById(R.id.briefDisplayTextFourCh2);
            briefDisplayCh3 = findViewById(R.id.briefDisplayTextFourCh3);
            briefDisplayCh4 = findViewById(R.id.briefDisplayTextFourCh4);
        } else {
            briefDisplayCh1 = findViewById(R.id.briefDisplayTextDoubleCh1);
            briefDisplayCh2 = findViewById(R.id.briefDisplayTextDoubleCh2);
        }
        mathMasters.add(findViewById(R.id.math1Master));
        mathMasters.add(findViewById(R.id.math2Master));
        mathMasters.add(findViewById(R.id.math3Master));
        mathMasters.add(findViewById(R.id.math4Master));
        mathMasters.add(findViewById(R.id.math5Master));
        mathMasters.add(findViewById(R.id.math6Master));
        mathMasters.add(findViewById(R.id.math7Master));
        mathMasters.add(findViewById(R.id.math8Master));
        refMasters.add(findViewById(R.id.ref1Master));
        refMasters.add(findViewById(R.id.ref2Master));
        refMasters.add(findViewById(R.id.ref3Master));
        refMasters.add(findViewById(R.id.ref4Master));
        refMasters.add(findViewById(R.id.ref5Master));
        refMasters.add(findViewById(R.id.ref6Master));
        refMasters.add(findViewById(R.id.ref7Master));
        refMasters.add(findViewById(R.id.ref8Master));
        busMasters.add(findViewById(R.id.rightS1Master));
        busMasters.add(findViewById(R.id.rightS2Master));
        busMasters.add(findViewById(R.id.rightS3Master));
        busMasters.add(findViewById(R.id.rightS4Master));

        setEnableWaveOption(true);
        initFindDialog(view);
        initControl();
        setRightScroll();
        setLevelMenu();

        findViewById(R.id.waveXYOutView).setOnClickListener(new OnClickListener() {
            @Override
            public void onClick(View v) {
                hideAllDialogsButDialogOkCancel();
            }
        });

        Command.get().getMenu().initMainViewGroup(this);

        nullView.setOnClickListener((v) -> {
            //0011279 用一个空View放在前头 什么都不处理
            Logger.i(TAG, "click nullView");
        });

        measureMenu=findViewById(R.id.mainTopMeasureMenu);
        measureMenu.setOnClickListener((v)->{
            OnBtnMeasureClick();
        });

        mainTopRight=findViewById(R.id.mainTopRight);
        mainTopRight.OnClickEvent=(v)->{
            if (topMenu==null) {
                topMenu = (TopLayoutPopWindow) findViewById(R.id.topSlipMenuBar_Quick);
            }
            if (isSlipShow(TOPSLIP)==false || topMenu.isShowLayoutTrigger()==false) {
                topMenu.showLayoutTrigger();
                openSlip(TOPSLIP);
            } else {
                hideSlip(TOPSLIP);

            }
        };

        statusBar=findViewById(R.id.statusBar);
        statusBar.setOnClickListener((v)->{
            MainMsgCenterMenuCommand command= new MainMsgCenterMenuCommand(MainMsgCenterMenuCommand.CommandReturnHome);
            RxBus.getInstance().post(RxEnum.MainLeft_To_Menu_Command,command);
        });

        mainTopLayoutCenter=findViewById(R.id.mainTopLayoutCenter);
        mainTopLayoutCenter.OnClickEvent = ((isDoubleClick) -> {
            if (topMenu==null) {
                topMenu = (TopLayoutPopWindow) findViewById(R.id.topSlipMenuBar_Quick);
            }
            Logger.d(TAG, "isDoubleClick= " + isDoubleClick);
            if (isDoubleClick) {
//                topMenu.showLayoutDisplay();
//                topMenu.getLayoutDisPlay().showLayoutCommon();
                hideSlip(TOPSLIP);
                RxBus.getInstance().post(RxEnum.MQ_MSG_MOUSE_CLICK_POSITION, ChannelFactory.getChActivate() + ";" + 4);
            } else {
                if (isSlipShow(TOPSLIP) == false || topMenu.isShowLayoutSample() == false) {
                    topMenu.showLayoutSample();
                    openSlip(TOPSLIP);
                } else {
                    hideSlip(TOPSLIP);
                }
            }
        });

//        String positionStrings = CacheUtil.get().getString(CacheUtil.TOP_SLIP_MEASURE_SELECT_LIST_INDEX);
//        ArrayList<String> indexList = StrUtil.getListFromString(positionStrings, CacheUtil.MEASURE_SELECT_LIST_SLIP);
//        int indexSize = indexList.size();
//        String measureStr = "";
//        if (indexSize == 0) {
//            measureStr = "false" + CommandMsgToUI.PARAM_SPLIT + indexSize;
//        } else if (indexSize <= 10) {
//            measureStr = "true" + CommandMsgToUI.PARAM_SPLIT + "1";
//        } else {
//            measureStr = "true" + CommandMsgToUI.PARAM_SPLIT + "11";
//        }
//        try {
//            consumerCommandMeasureOpenToUI.accept(measureStr);
//        } catch (Throwable e) {
//            e.printStackTrace();
//        }

        btnStopAutoSave = findViewById(R.id.stopAutoSave);
    }

    public void OnBtnMeasureClick(){
        if (topMenu==null) {
            topMenu = (TopLayoutPopWindow) findViewById(R.id.topSlipMenuBar_Quick);
        }
        if (isSlipShow(TOPSLIP)==false || topMenu.isShowLayoutMeasureCommon()==false) {
            topMenu.showLayoutMeasure();
            openSlip(TOPSLIP);
        } else {
            hideSlip(TOPSLIP);

        }
    }

