    private void initFindDialog(View view) {
        dialogTextKeyBoard = (TopDialogTextKeyBoard) findViewById(R.id.dialogTextKeyBoard);
        dialogMeasureDelay = (TopDialogMeasureDelay) findViewById(R.id.dialogMeasureDelay);
        dialogMeasurePhase = (TopDialogMeasurePhase) findViewById(R.id.dialogMeasurePhase);
        dialogMeasureTValue = (TopDialogMeasureTValue) findViewById(R.id.dialogMeasureTValue);

        dialogTopCount = (TopDialogCount) findViewById(R.id.dialogTopCount);
        dialogTopScale = (TopDialogScale) findViewById(R.id.dialogTopScale);
        dialogBaudRate = (DialogBaudRate) findViewById(R.id.dialogBaudRate);
