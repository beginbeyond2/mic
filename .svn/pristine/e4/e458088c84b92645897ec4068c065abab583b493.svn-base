package com.micsig.tbook.tbookscope.struct;

/**
 * Created by liwb on 2018/1/3.
 */

public class ExternalKeysMsg_ToMCU {
    public static final String TYPE_CH = "TYPE_CH";

    public static final String TYPE_MATH = "TYPE_MATH";
    public static final String TYPE_RUNSTOP = "TYPE_RUNSTOP";
    public static final String TYPE_AUTO = "TYPE_AUTO";
    public static final String TYPE_SEQ = "TYPE_SEQ";
    public static final String TYPE_FINE = "TYPE_FINE";
    public static final String TYPE_ZOOM = "TYPE_ZOOM";
    public static final String TYPE_SEARCH = "TYPE_SEARCH";
    public static final String TYPE_REF = "TYPE_REF";
    public static final String TYPE_SERIAL = "TYPE_SERIAL";
    public static final String TYPE_DIGITAL = "TYPE_DIGITAL";
    public static final String TYPE_WAVEFORM = "TYPE_WAVEFORM";
    public static final String TYPE_POWER = "TYPE_POWER";
    public static final String TYPE_TOUCH_OFF = "TYPE_TOUCH_OFF";

    public static final String TYPE_S1 = "TYPE_S1";
    public static final String TYPE_S2 = "TYPE_S2";
    public static final String TYPE_S3 = "TYPE_S3";
    public static final String TYPE_S4 = "TYPE_S4";

    public static final String TYPE_VCURSOR = "TYPE_VCURSOR";
    public static final String TYPE_HCURSOR = "TYPE_HCURSOR";
    public static final String TYPE_ALL = "TYPE_ALL";

    public static final String STATE_LED_RED = "STATE_LED_RED";
    public static final String STATE_LED_GREEN = "STATE_LED_GREEN";
    public static final String STATE_LED_ON = "STATE_LED_ON";
    public static final String STATE_LED_OFF = "STATE_LED_OFF";

    /**
     * LED类型
     */
    private String ledType;
    /**
     * LED状态
     */
    private String ledState;

    public String getLedType() {
        return ledType;
    }

    public void setLedType(String ledType) {
        this.ledType = ledType;
    }

    public String getLedState() {
        return ledState;
    }

    public void setLedState(String ledState) {
        this.ledState = ledState;
    }

    public ExternalKeysMsg_ToMCU(String ledType, String ledState) {
        this.ledType = ledType;
        this.ledState = ledState;
    }

    @Override
    public String toString() {
        return "ExternalKeysMsg_ToMCU{" +
                "ledType=" + ledType +
                ", ledState=" + ledState +
                '}';
    }
}
