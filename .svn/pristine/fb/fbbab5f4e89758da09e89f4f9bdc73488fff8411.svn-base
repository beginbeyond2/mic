    <Button
        android:id="@+id/btnLeftMenuHalf"
        android:layout_width="match_parent"
        android:layout_height="50px"
        android:button="@null"
        android:background="@drawable/ic_left_50_selector"
        android:visibility="gone"
        ui:layout_constraintLeft_toLeftOf="parent"
        ui:layout_constraintRight_toRightOf="parent"
        ui:layout_constraintTop_toTopOf="parent"
        ui:layout_constraintBottom_toTopOf="@+id/btnLeftScreen" />
    <Button
        android:id="@+id/btnLeftScreen"
        android:layout_width="match_parent"
        android:layout_height="50px"
        android:button="@null"
        android:background="@drawable/ic_capture_selector"
        android:visibility="gone"
        ui:layout_constraintLeft_toLeftOf="parent"
        ui:layout_constraintRight_toRightOf="parent"
        ui:layout_constraintTop_toBottomOf="@id/btnLeftMenuHalf"
        ui:layout_constraintBottom_toTopOf="@+id/btnLeftZoom" />
    <CheckBox
        android:id="@+id/btnLeftZoom"
        android:layout_width="match_parent"
        android:layout_height="50px"
        android:button="@null"
        android:background="@drawable/ic_zoom_selector"
        android:visibility="gone"
        ui:layout_constraintLeft_toLeftOf="parent"
        ui:layout_constraintRight_toRightOf="parent"
        ui:layout_constraintTop_toBottomOf="@id/btnLeftScreen"
        ui:layout_constraintBottom_toBottomOf="parent" />

    <com.micsig.tbook.ui.main.LeftPositionView
        android:id="@+id/leftPositionView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/color_Backcolor_MainMenu3"
        />

</androidx.constraintlayout.widget.ConstraintLayout>