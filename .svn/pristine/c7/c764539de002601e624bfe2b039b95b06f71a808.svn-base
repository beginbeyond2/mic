    <item android:state_checked="true"
        android:drawable="@drawable/bg_topslip_btn_74_44_select">
    </item>
    <item android:state_pressed="true"
        android:drawable="@drawable/bg_topslip_btn_74_44_select">
    </item>
    <item
        android:drawable="@drawable/bg_topslip_btn_74_44_normal">
    </item>
</selector>