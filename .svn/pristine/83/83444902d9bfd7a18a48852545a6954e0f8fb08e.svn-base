package com.micsig.tbook.tbookscope.top.layout.userset;



/**
 * Created by yangj on 2017/4/27.
 */

public class SaveRecovery  {
    private int index;
    private String name;

    public SaveRecovery(int index, String name) {
        this.index = index;
        this.name = name;
    }

    public int getIndex() {
        return index;
    }

    public void setIndex(int index) {
        this.index = index;
    }

    public String getName() {
        return name;
    }

    public void setName(String name) {
        this.name = name;
    }

    @Override
    public String toString() {
        return "SaveRecovery{" +
                "index=" + index +
                ", name='" + name + '\'' +
                '}';
    }
}
