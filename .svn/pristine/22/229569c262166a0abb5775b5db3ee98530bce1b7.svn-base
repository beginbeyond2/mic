package com.micsig.tbook.tbookscope.top.layout.trigger.serials.bean;

import com.micsig.tbook.ui.top.view.channel.TopBeanChannel;

/**
 * Created by yangj on 2017/5/17.
 */

public class SerialsDetailUart1Data implements ISerialsDetail {
    private TopBeanChannel uart1DataCondition;
    private DataBean uart1DataEdit;
    private String uart1DataConditionTitle;
    private String uart1DataEditTitle;

    public String getUart1DataConditionTitle() {
        return uart1DataConditionTitle;
    }

    public void setUart1DataConditionTitle(String uart1DataConditionTitle) {
        this.uart1DataConditionTitle = uart1DataConditionTitle;
    }

    public String getUart1DataEditTitle() {
        return uart1DataEditTitle;
    }

    public void setUart1DataEditTitle(String uart1DataEditTitle) {
        this.uart1DataEditTitle = uart1DataEditTitle;
    }

    public TopBeanChannel getUart1DataCondition() {
        return uart1DataCondition;
    }

    public void setUart1DataCondition(TopBeanChannel uart1DataCondition) {
        this.uart1DataCondition = uart1DataCondition;
    }

    public DataBean getUart1DataEdit() {
        return uart1DataEdit;
    }

    public void setUart1DataEdit(int digits, String value) {
        if (this.uart1DataEdit == null) {
            this.uart1DataEdit = new DataBean();
        }
        this.uart1DataEdit.setDigits(digits);
        this.uart1DataEdit.setValue(value);
    }

    @Override
    public String toString() {
        return "SerialsDetailUart1Data{" +
                "uart1DataCondition=" + uart1DataCondition +
                ", uart1DataEdit='" + uart1DataEdit + '\'' +
                '}';
    }
}
