<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <RelativeLayout
        android:id="@+id/clkLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/clkHead"
            style="@style/rightHeadText"
            android:layout_width="wrap_content"
            android:layout_height="54px"
            android:layout_marginVertical="7px"
            android:layout_marginStart="0px"
            android:gravity="center_vertical"
            android:text="@string/serialsSpiSource" />

        <com.micsig.tbook.ui.rightslipmenu.RightViewSelect
            android:id="@+id/clk"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@+id/clkHead"
            android:layout_alignParentEnd="true"
            app:array="@array/channelsNameEight"
            app:arrayOrientation="horizontalEachRow4"
            app:itemHeight="54px"
            app:itemMargin="7px"
            app:itemWidth="108px" />

        <com.micsig.tbook.ui.rightslipmenu.RightViewSelect
            android:id="@+id/clkCheck"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignTop="@+id/clkHead"
            android:layout_alignEnd="@id/clk"
            android:layout_alignBottom="@+id/clkHead"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="7px"
            app:array="@array/serialsSpiRF"
            app:arrayOrientation="horizontalEachRow2"
            app:itemHalfCornerEach="each_108_54"
            app:itemHeight="54px"
            app:itemStartAndEndBgHalfCorner="true"
            app:itemWidth="108px" />

    </RelativeLayout>

    <View
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="2px"
        android:layout_marginVertical="7px"
        android:layout_marginEnd="7px"
        android:background="@drawable/bg_right_layout_divider" />

    <RelativeLayout
        android:id="@+id/dataLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/dataHead"
            style="@style/rightHeadText"
            android:layout_width="wrap_content"
            android:layout_height="54px"
            android:layout_marginVertical="7px"
            android:layout_marginStart="0px"
            android:gravity="center_vertical"
            android:text="@string/serialsSpiData" />

        <com.micsig.tbook.ui.rightslipmenu.RightViewSelect
            android:id="@+id/data"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/dataHead"
            android:layout_alignParentEnd="true"
            app:array="@array/channelsNameEight"
            app:arrayOrientation="horizontalEachRow4"
            app:itemHeight="54px"
            app:itemMargin="7px"
            app:itemWidth="108px" />

        <com.micsig.tbook.ui.rightslipmenu.RightViewSelect
            android:id="@+id/dataCheck"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignTop="@+id/dataHead"
            android:layout_alignBottom="@+id/dataHead"
            android:layout_alignParentEnd="true"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="7px"
            app:array="@array/serialsSpiHL"
            app:arrayOrientation="horizontalEachRow2"
            app:itemHalfCornerEach="each_120_60"
            app:itemHeight="54px"
            app:itemStartAndEndBgHalfCorner="true"
            app:itemWidth="108px" />

    </RelativeLayout>

    <View
        android:id="@+id/divider2"
        android:layout_width="match_parent"
        android:layout_height="2px"
        android:layout_marginVertical="7px"
        android:layout_marginEnd="7px"
        android:background="@drawable/bg_right_layout_divider" />

    <RelativeLayout
        android:id="@+id/csLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/csHead"
            style="@style/rightHeadText"
            android:layout_width="wrap_content"
            android:layout_height="54px"
            android:layout_marginVertical="7px"
            android:layout_marginStart="0px"
            android:gravity="center_vertical"
            android:text="@string/serialsSpiCS" />

        <com.micsig.tbook.ui.rightslipmenu.RightViewSelect
            android:id="@+id/cs"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@id/csHead"
            android:layout_alignParentEnd="true"
            app:array="@array/channelsNameEight"
            app:arrayOrientation="horizontalEachRow4"
            app:itemHeight="54px"
            app:itemMargin="7px"
            app:itemWidth="108px" />

        <com.micsig.tbook.ui.rightslipmenu.RightViewSelect
            android:id="@+id/csCheck"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignTop="@+id/csHead"
            android:layout_alignBottom="@+id/csHead"
            android:layout_alignParentEnd="true"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="7px"
            app:array="@array/serialsSpiHL"
            app:arrayOrientation="horizontalEachRow2"
            app:itemHalfCornerEach="each_108_54"
            app:itemHeight="54px"
            app:itemStartAndEndBgHalfCorner="true"
            app:itemWidth="108px" />

        <com.micsig.tbook.ui.MSwitchBox
            android:id="@+id/csSwith"
            android:layout_width="72px"
            android:layout_height="wrap_content"
            android:layout_alignTop="@id/csHead"
            android:layout_alignBottom="@id/csHead"
            android:layout_marginStart="70px"
            android:layout_toEndOf="@+id/csHead" />
    </RelativeLayout>

    <View
        android:id="@+id/divider3"
        android:layout_width="match_parent"
        android:layout_height="2px"
        android:layout_marginVertical="7px"
        android:layout_marginEnd="7px"
        android:background="@drawable/bg_right_layout_divider" />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/bitHead"
            style="@style/rightHeadText"
            android:layout_width="wrap_content"
            android:layout_height="54px"
            android:layout_marginStart="0px"
            android:layout_marginTop="7px"
            android:gravity="center_vertical"
            android:text="@string/serialsSpiBits" />

        <com.micsig.tbook.ui.rightslipmenu.RightViewSelect
            android:id="@+id/bit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            app:array="@array/serialsSpiBits"
            app:arrayOrientation="horizontalEachRow4"
            app:firstShowCount="1"
            app:itemHeight="54px"
            app:itemMargin="7px"
            app:itemWidth="108px" />
    </RelativeLayout>
</LinearLayout>