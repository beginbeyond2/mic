package com.micsig.tbook.tbookscope.wavezone.display;

public class MsgCursorVisible {
    private boolean isYt;
    private boolean isShu;
    private boolean visible;

    public MsgCursorVisible(boolean isYt, boolean isShu, boolean visible) {
        this.isYt = isYt;
        this.isShu = isShu;
        this.visible = visible;
    }

    public boolean isYt() {
        return isYt;
    }

    public void setYt(boolean yt) {
        isYt = yt;
    }

    public boolean isShu() {
        return isShu;
    }

    public void setShu(boolean shu) {
        isShu = shu;
    }

    public boolean isVisible() {
        return visible;
    }

    public void setVisible(boolean visible) {
        this.visible = visible;
    }

    @Override
    public String toString() {
        return "CursorVisibleMsg{" +
                "isYt=" + isYt +
                ", isShu=" + isShu +
                ", visible=" + visible +
                '}';
    }
}
