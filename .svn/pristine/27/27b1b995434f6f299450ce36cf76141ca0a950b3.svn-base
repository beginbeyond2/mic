    @Override
    public void calcGain(int flag){

        for(int i=0;i<ChannelFactory.CH_CNT;i++){

            if((flag & (1<<i)) != 0) {
                ch_pga_stepdb[i] = (float) (20 * Math.log10(0.257 * gain_pga_stepdb_a40_8[i] / 0.0408 / gain_pga_stepdb_a257[i]) / 8);
                ch_lghg[i] = (float) (0.257 * gain_pga_lghg_a25_7[i] / 0.0257 / gain_pga_stepdb_a257[i]);

                for(int k=0;k<3;k++) {
                    ch_fs_d[i][RATIO_DANG_1][k] = (float) (0.0102 * 8 * getMaxAdVal() / FULL_VV / gain_fs_a10_2[i][k]);
                    ch_fs_d[i][RATIO_DANG_2][k] = (float) (0.0408 * 8 * getMaxAdVal() / FULL_VV / gain_fs_a40_8[i][k]);
                    ch_fs_d[i][RATIO_DANG_3][k] = (float) (0.510 * 8 * getMaxAdVal() / FULL_VV / gain_fs_a510[i][k]);
                    ch_fs_d[i][RATIO_DANG_4][k] = ch_fs_d[i][RATIO_DANG_3][k] * ch_fs_d[i][RATIO_DANG_2][k] / ch_fs_d[i][RATIO_DANG_1][k];

                    ch_fs_a[i][RATIO_DANG_1][k] = (float) (getAdFsDefault()/2 / (0.0112 * 8 * getMaxAdVal() / FULL_VV / gain_fs_a11_2[i][k] - ch_fs_d[i][RATIO_DANG_1][k]));
                    ch_fs_a[i][RATIO_DANG_2][k] = (float) (getAdFsDefault()/2  / (0.0448 * 8 * getMaxAdVal() / FULL_VV / gain_fs_a44_8[i][k] - ch_fs_d[i][RATIO_DANG_2][k]));
                    ch_fs_a[i][RATIO_DANG_3][k] = (float) (getAdFsDefault()/2  / (0.560 * 8 * getMaxAdVal() / FULL_VV / gain_fs_a560[i][k] - ch_fs_d[i][RATIO_DANG_3][k]));
                    ch_fs_a[i][RATIO_DANG_4][k] = ch_fs_a[i][RATIO_DANG_3][k] * ch_fs_a[i][RATIO_DANG_2][k] / ch_fs_a[i][RATIO_DANG_1][k];
                }
            }
        }
    }

