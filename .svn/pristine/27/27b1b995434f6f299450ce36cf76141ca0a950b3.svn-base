    @Override
    protected void defaultVal() {

        defaultVal_AdFullscale();
        defaultVal_coefChannel();
        defaultVal_chZero();
        defaultVal_ChCapacitance();
    }

    public void defaultVal_AdFullscale(){
        for(int i=0;i<ch_pga_stepdb.length;i++){
            ch_pga_stepdb[i] = pga_stepdb;
            ch_lghg[i] = pga_lghg;
            for(int j=0;j<4;j++) {
                for(int k=0;k<3;k++) {
                    ch_fs_a[i][j][k] = fullscale_a[j];
                    ch_fs_d[i][j][k] = fullscale_d[j];
                }
            }
        }

    }
    private void defaultVal_coefChannel(){

        HwConfig hwConfig = HwConfig.getInstance();
        for(int i=0;i<ChannelFactory.CH_CNT;i++){
            for(int j=0;j<4;j++){
                coefChannel[i][j][0] = hwConfig.getChCoefDefault()[getRatioIdx2Dang(Channel.RESISTANCE_1M,j)];
                coefChannel[i][j][1] = hwConfig.getChCoefDefault()[getRatioIdx2Dang(Channel.RESISTANCE_1M,j)];
            }
        }

    }

    private void defaultVal_chZero(){
        for(int i = 0; i< 30; i++){
            for(int j=0; j<ChannelFactory.CH_CNT; j++){
                chZero[j][0][i] = DA_CH_OFFSET_ZERO;
                chZero[j][1][i] = DA_CH_OFFSET_ZERO;
                chZero[j][2][i] = DA_CH_OFFSET_ZERO;
                chZero[j][3][i] = DA_CH_OFFSET_ZERO;
            }
        }
    }

    private void defaultVal_ChCapacitance(){
        int val = 0xFFFF;
        val /= 2;
        Arrays.fill(chCapacitanceHigh, val);
    }

    public void defaultVal_coefChannel(int ch,int dang,int resistanceType){
        coefChannel[ch][dang][1] = coefChannel[ch][dang][0] = (float) vol_ChannelCoef_default(Channel.RESISTANCE_1M, dang);
    }

    private static double getLMH6518(int pgaval){
        double val = 10;
        if((pgaval & 0x10) != 0){
            val = 30;
        }
        val += 8.86 + (pgaval & 0xF) * (-2);
        return Math.pow(10,val/20);
    }


    public double vol_ChannelCoef_defaultEx(int chIdx,int dangwei,int pgaVal){
        double v = 1;
        int dang = getRatioIdx(Channel.RESISTANCE_1M,VerticalAxis.getScaleIdValById(dangwei));
        switch (dang){
            default:
            case RATIO_DANG_1:
            case RATIO_DANG_3:
                v = 1;
                break;
            case RATIO_DANG_2:
            case RATIO_DANG_4:
                v = 0.25;
                break;
        }
        v = v * getLMH6518(pgaVal);
        return (HwConfig.getInstance().getAdFSR() * 65536) /( 2.5 * 2 * v * 1024);
    }

    public double vol_ChannelCoef_default(int resistanceType,int dang){
        float [] chCoef = HwConfig.getInstance().getChCoefDefault();
        if(dang < chCoef.length) {
            return chCoef[dang];
        }
        Log.e(TAG,"dangwei error:" + dang);
        return 0;
    }
    public int getRatioIdx(int resistanceType,double v){
        int i = 0;
        for(i=0;i<RATIO_DANG_VAL.length;i++){
            if(v <= RATIO_DANG_VAL[i]){
                break;
            }
        }
        if(i >= RATIO_DANG_VAL.length){
            i = RATIO_DANG_VAL.length - 1;
        }
        return i;
    }

    @Override
    public int getRatioIdx2Dang(int resistanceType,int idx){
        switch (idx){
            default:
            case RATIO_DANG_1:
                return  VerticalAxis.DANG_10mV;
            case RATIO_DANG_2:
                return  VerticalAxis.DANG_100mV;
            case RATIO_DANG_3:
                return  VerticalAxis.DANG_500mV;
            case RATIO_DANG_4:
                return  VerticalAxis.DANG_5V;
        }
    }
    @Override
    public double getVerticalRange(int resistanceType,int dang){
        double vRange = 2.5;
        switch (dang){
            case RATIO_DANG_1:
            case RATIO_DANG_2:
                vRange = 2.5;
                break;
            default:
            case RATIO_DANG_3:
            case RATIO_DANG_4:
                vRange =  125;
                break;
        }
        return vRange;
    }

