    public double calc_coefChannel(int chIdx,double scaleVal,int idx){
        int resistanceType = Channel.RESISTANCE_1M;
        int refScaleId = getRatioIdx(resistanceType,scaleVal);
        double v = VerticalAxis.getScaleIdValById(getRatioIdx2Dang(resistanceType,refScaleId));
        v = (coefChannel[chIdx][refScaleId][idx] * scaleVal / v);
        return v;
    }

    @Override
    public void calc_pga_fs_gain(int chIdx,double scaleVal,int []result){
        calc_pga_gain(0,chIdx,Channel.RESISTANCE_1M, scaleVal, result);
        //result[1] = result[2] = result[3] = 16384;
    }
    @Override
    public void calc_pga_gain(int cnt,int chIdx,int resistanceType,double scaleVal,int []result){

        scaleVal = VerticalAxis.clampMin(scaleVal,resistanceType);

        int pga = 0;
        int dang = getRatioIdx(resistanceType,scaleVal);

        float a = ch_fs_a[chIdx][dang][0];
        float d = ch_fs_d[chIdx][dang][0];

        int y = (int) (1 - Math.round(20 * Math.log10(d / scaleVal) / ch_pga_stepdb[chIdx]));

        if (y > 10) {
            y = 10;
        }

        double k;
        if (y >= 0 && y <= 10) {
            pga = 0x400 + y;
            k = Math.pow(10, (1 - y) * ch_pga_stepdb[chIdx] / 20);
        } else {
            y = (int) (1 - Math.round(20 * Math.log10(d / ch_lghg[chIdx] / scaleVal) / ch_pga_stepdb[chIdx]));
            if (y > 10) {
                y = 10;
            } else if (y < 0) {
                y = 0;
            }
            pga = 0x410 + y;
            k = Math.pow(10, (1 - y) * ch_pga_stepdb[chIdx] / 20) * ch_lghg[chIdx];
        }
        result[0] = pga;
        for (int i = 0; i < 3; i++) {
            a = ch_fs_a[chIdx][dang][i];
            d = ch_fs_d[chIdx][dang][i];

            int yy = (int) Math.round(getAdFsDefault() + (scaleVal * k - d) * a);


            if (yy > 488) {

            } else if (yy < 64) {

            } else {

            }

            if(yy < 0) {
                yy = 0;
            }else if(yy > 0x7FFF){
                yy = 0x7FFF;
            }
            result[i + 1] = yy;
        }
    }

    private int getAdFsDefault(){
        return 16384;
    }
    private int getMaxAdVal(){
        return 1023;
    }


