    public HW_MHO38V1(int fpgaNums){
        super(fpgaNums);
        addItemAll(Arrays.asList("零点校准","通道增益校准(需要信号)","偏移量校准(需要信号)","电容校准(需要信号)"));
    }

    @Override
    public void setChPga() {
        Channel channel;
        CabteRegister cabteRegister = CabteRegister.getInstance();
        final int [] vol = new int[ChannelFactory.CH_CNT];
        int [] result = {0,0,0,0,0};
        int maxIdx = ChannelFactory.getMaxChIdx();
        for(int i=0;i<maxIdx;i++) {
            channel = ChannelFactory.getDynamicChannel(i);
            double vScaleVal = channel.getVScaleVal()/channel.getProbeRate();
            cabteRegister.calc_pga_fs_gain(channel.getChId(), vScaleVal,result);
            vol[i] = result[0] & 0xFFFF;
        }
        setChPgaGain(vol);
    }

    @Override
    public void setAdGain(int fpgaIdx) {
        boolean[] sle = new boolean[ChannelFactory.CH_CNT];
        Scope scope = Scope.getInstance();
        int cnt = scope.getChannelSampOnCnt(scope.isRun(true), sle);
        int[] fullscale_i = {0, 0, 0, 0};
        int[] fullscale_q = {0, 0, 0, 0};
        int[] result = {0, 0, 0, 0,0};
        CabteRegister pCabReg = CabteRegister.getInstance();
        FPGACommand fpgaCommand = FPGACommand.getInstance();
        Channel channel;
        float[] gain_bc = {1, 1, 1, 1};
        int adcMaxChNums = HwConfig.getInstance().getAdcMaxChNums();
        int beginIdx = FPGACommand.beginChIdx(fpgaIdx);
        int endIdx = FPGACommand.endChIdx(fpgaIdx);
        switch (cnt) {
            case 4:
                for (int i = beginIdx; i < endIdx; i += 2) {
                    channel = ChannelFactory.getDynamicChannel(i);
                    int idx = (i - beginIdx) / 2;
                    if (sle[i] && sle[i + 1]) {
                        pCabReg.calc_pga_fs_gain(channel.getChId(),channel.getVScaleVal()/channel.getProbeRate(), result);
                        fullscale_i[idx] = result[1];

                        channel = ChannelFactory.getDynamicChannel(i + 1);
                        pCabReg.calc_pga_fs_gain(channel.getChId(),channel.getVScaleVal()/channel.getProbeRate(), result);
                        fullscale_q[idx] = result[1];

                    } else {
                        if (sle[i]) {
                            pCabReg.calc_pga_fs_gain(channel.getChId(),channel.getVScaleVal()/channel.getProbeRate(), result);
                            fullscale_i[idx] = result[2];
                            fullscale_q[idx] = result[3];
                        } else {
                            channel = ChannelFactory.getDynamicChannel(i + 1);
                            pCabReg.calc_pga_fs_gain(channel.getChId(),channel.getVScaleVal()/channel.getProbeRate(), result);
                            fullscale_i[idx] = result[2];
                            fullscale_q[idx] = result[3];
                        }
                    }


                }
                break;
            default:
                for (int i = beginIdx; i < endIdx; i += 2) {
                    channel = ChannelFactory.getDynamicChannel(i);
                    int idx = (i - beginIdx)/2;
                    pCabReg.calc_pga_fs_gain(channel.getChId(),channel.getVScaleVal()/channel.getProbeRate(), result);
                    fullscale_i[idx] = result[1];

                    channel = ChannelFactory.getDynamicChannel(i + 1);
                    pCabReg.calc_pga_fs_gain(channel.getChId(),channel.getVScaleVal()/channel.getProbeRate(), result);
                    fullscale_q[idx] = result[1];
                }
                break;
        }

        for (int i = beginIdx; i < endIdx; i += 2) {
            int idx = (i - beginIdx) / 2;
            fpgaCommand.writeAD_gain(fpgaIdx,idx, 0, fullscale_i[idx]);
            fpgaCommand.writeAD_gain(fpgaIdx,idx , 1, fullscale_q[idx]);
            fpgaCommand.sendFpga_gain_bc(fpgaIdx,gain_bc);
            fpgaCommand.cmdDevice(50);
        }

    }



    @Override
    public void changeChVolScale() {

        long marsk= SHIFTREG_INIT_VAL;
        Scope scope = Scope.getInstance();

        Channel channel;
        int dang = 0;
        int idx = 0;
        int chMax = scope.getChNum();
        for(int i=0;i<chMax;i++)
        {
            idx = i;
            channel = ChannelFactory.getDynamicChannel(i);

            dang = CabteRegister.getRatioIdx(channel.getResistanceType(),channel.getVScaleVal()/channel.getProbeRate());

            idx = ChannelFactory.CH8 - idx;

            switch (dang){
                default:
                case HW.RATIO_DANG_1:
                    marsk &= ~(1L << (idx * 8 + 7));
                    marsk &= ~(1L << (idx * 8 + 2));
                    break;
                case HW.RATIO_DANG_2:

                    marsk &= ~(1L << (idx * 8 + 7));
                    marsk &= ~(1L << (idx * 8 + 3));
                    break;
                case HW.RATIO_DANG_3:
                    marsk &= ~(1L << (idx * 8 + 6));
                    marsk &= ~(1L << (idx * 8 + 2));
                    break;
                case HW.RATIO_DANG_4:
                    marsk &= ~(1L << (idx * 8 + 6));
                    marsk &= ~(1L << (idx * 8 + 3));
                    break;
            }
        }
        long temp=ChVolScaleShiftRegister();
        sendShiftRegister((temp & marsk));
        usleep(2400);
        sendShiftRegister(temp);
    }


    private long ChVolScaleShiftRegister(){
        long iTmpValue = SHIFTREG_INIT_VAL;

        Scope scope = Scope.getInstance();
        int dang = 0;
        int chMax = scope.getChNum();
        int idx = 0;
        for(int i=0;i<chMax;i++){
            idx =  i;

            Channel channel = ChannelFactory.getDynamicChannel(i);
            if(!scope.isChannelInSample(i)
                    || channel.getCoupleType() == Channel.COUPLE_TYPE_AC){
                idx = ChannelFactory.CH8 - idx;
                iTmpValue &= ~(1L << (idx * 8 + 0));
            }
        }
        return iTmpValue;
    }




