    public HorizontalAxis() {
        horizontalAxisAction = new HorizontalAxisAction(this);
        EventFactory.addEventObserver(EventFactory.EVENT_CHANNEL_OPEN, this);
        EventFactory.addEventObserver(EventFactory.EVENT_CHANNEL_CLOSE, this);
        EventFactory.addEventObserver(EventFactory.EVENT_DISPLAY_ZOOM, this);
        EventFactory.addEventObserver(EventFactory.EVENT_MEM_DEPTH, this);
        EventFactory.addEventObserver(EventFactory.EVENT_SCOPE_STATE, this);
        EventFactory.addEventObserver(EventFactory.EVENT_FORCE_MEM_DEPTH, this);
        EventFactory.addEventObserver(EventFactory.EVENT_CHANGE_CH_TIMEBASE, this);
        InitStdXAxis();
    }
    public static boolean isValidScaleId(int timeScaleId){
        return minGear <=  timeScaleId && maxGear >= timeScaleId;
    }
    public static boolean isRoolScale(int timeScale) {
        return timeScale <= TSI_100mS;
    }

    public static boolean isRoolScale() {
        return HorizontalAxis.getInstance().timeScaleIdMain <= TSI_100mS;
    }

    private static int minGear = TSI_MIN;
    private static int maxGear = TSI_MAX;

    public static int getMinGear() {
        return minGear;
    }

    public static void setMinGear(int gear) {
        minGear = gear;
    }

    public static int getMaxGear() {
        return maxGear;
    }

    public static void setMaxGear(int gear) {
        maxGear = gear;
    }

    public void InitStdXAxis() {
        xAxis.clear();
        for (int i = minGear; i <= maxGear; i++) {
            xAxis.add(stdTimeScaleIdVal(i));
        }
    }

    public void initXAxis() {
        boolean bChange = false;
        synchronized (this) {
            int l = xAxis.size();
            xAxis.clear();
            for (int i = minGear; i <= maxGear; i++) {
                xAxis.add(timeScaleIdVal(i));
            }
            if( l != xAxis.size()){
                bChange = true;
            }
        }
        if(bChange) {
            EventFactory.sendEvent(EventFactory.EVENT_TIME_SCALE_LIST);
        }
    }

    public int timeValtoTimeScaleId(double val) {
        synchronized (this) {
            for (int i = maxGear; i > minGear; i--) {
                if (i < xAxis.size()) {
                    if (val < ((xAxis.get(i) + xAxis.get(i - 1)) / 2))
                        return i;
                }
            }
        }
        return minGear;
    }

    private double timeScaleIdVal(int timeScaleId) {

        IMemDepth memDepth = MemDepthFactory.getMemDepth();
        double val = stdTimeScaleIdVal(timeScaleId);

        if (memDepth.isSpecialTimeScale()) {
            int stdTimeScaleId;
            Scope scope = Scope.getInstance();
            double timeScaleRatio = memDepth.getTimeScaleRatio(timeScaleId);
            val *= timeScaleRatio;

            if (scope.isRun()) {
                if (!scope.isZoom()) {
                    return val;
                }
                stdTimeScaleId = getTimeScaleIdOfView(WPI_STANDARD);
            } else {
                stdTimeScaleId = ScopeFrozen.getInstance().getTimeScaleId();
            }

            //小于等于标准时基档时，上述计算的肯定正确，只有展开时才可能会修改时基档
            if (timeScaleId <= stdTimeScaleId)
                return val;

            //zoom且时基大于缩略图、静态，只有这两种情况才有可能需要对时基特殊处理
            //注意，对于参考波形，时基不用特殊处理
            double timeScaleStd = stdTimeScaleIdVal(stdTimeScaleId) * memDepth.getTimeScaleRatio(stdTimeScaleId);
            double timeScaleNow = stdTimeScaleIdVal(timeScaleId) * timeScaleRatio;
            double iScreenNum = timeScaleStd / timeScaleNow;//屏数计算
            double iLieNum = (float) (iScreenNum * ScopeBase.getWidth());//总列数
            double tmp = iLieNum / scope.zunMemDepth();//插值倍数

            if (tmp > 1.01) {//插值
                if ((tmp > 62.5 - 0.01 && tmp < 62.5 + 0.01)//temp == 62.5
                        || (tmp > 31.25 - 0.01 && tmp < 31.25 + 0.01))//temp == 31.25
                {
                    val = val * 5.0 / 4;
                } else if ((tmp > 1.6 - 0.01 && tmp < 1.6 + 0.01)) {
                    val = val * 4 / 5;
                }
            } else {//抽样
                tmp = 500 / tmp;//500列对应多少数据
                int x = (int) (tmp + 0.1);
                if (x % 500 != 0) {//每列个数为小数
                    if (x % 100 == 0) {//每列个数乘以5为整数（如1.6，3.2）
                        val = val * 5.0 / 4;
                    }
                }
            }
        }

        return val;
    }

    public static double stdTimeScaleIdVal(int timeScaleId) {
        double ret = 1e-9d;
        switch (timeScaleId) {
            case TSI_1KS:
                ret = 1000;
                break;
            case TSI_500S:
                ret = 500;
                break;
            case TSI_200S:
                ret = 200;
                break;
            case TSI_100S:
                ret = 100;
                break;
            case TSI_50S:
                ret = 50;
                break;
            case TSI_20S:
                ret = 20;
                break;
            case TSI_10S:
                ret = 10;
                break;
            case TSI_5S:
                ret = 5;
                break;
            case TSI_2S:
                ret = 2;
                break;
            case TSI_1S:
                ret = 1;
                break;
            case TSI_500mS:
                ret = 0.5;
                break;
            case TSI_200mS:
                ret = 0.2;
                break;
            case TSI_100mS:
                ret = 0.1;
                break;
            case TSI_50mS:
                ret = 0.05;
                break;
            case TSI_20mS:
                ret = 0.02;
                break;
            case TSI_10mS:
                ret = 0.01;
                break;
            case TSI_5mS:
                ret = 0.005;
                break;
            case TSI_2mS:
                ret = 0.002;
                break;
            case TSI_1mS:
                ret = 0.001;
                break;
            case TSI_500uS:
                ret = 500e-6;
                break;
            case TSI_200uS:
                ret = 200e-6;
                break;
            case TSI_100uS:
                ret = 100e-6;
                break;
            case TSI_50uS:
                ret = 50e-6;
                break;
            case TSI_20uS:
                ret = 20e-6;
                break;
            case TSI_10uS:
                ret = 10e-6;
                break;
            case TSI_5uS:
                ret = 5e-6;
                break;
            case TSI_2uS:
                ret = 2e-6;
                break;
            case TSI_1uS:
                ret = 1e-6;
                break;
            case TSI_500nS:
                ret = 500e-9;
                break;
            case TSI_200nS:
                ret = 200e-9;
                break;
            case TSI_100nS:
                ret = 100e-9;
                break;
            case TSI_50nS:
                ret = 50e-9;
                break;
            case TSI_20nS:
                ret = 20e-9;
                break;
            case TSI_10nS:
                ret = 10e-9;
                break;
            case TSI_5nS:
                ret = 5e-9;
                break;
            case TSI_2nS:
                ret = 2e-9;
                break;
            case TSI_1nS:
                ret = 1e-9;
                break;
            case TSI_500pS:
                ret = 500e-12;
                break;
            case TSI_250pS:
            default:
                ret = 250e-12;
                break;
        }
        return ret;
    }

    public List<Double> getxAxis() {
        synchronized (this) {
            return new ArrayList<>(xAxis);
        }
    }

    public int getWPIId() {
        int id = WPI_STANDARD;
        if (Display.getInstance().isZoom())
            id = WPI_LARGE;
        return id;
    }

    public double getTimeScaleIdVal() {
        return getTimeScaleIdVal(getTimeScaleIdOfView());
    }

    public double getTimeScaleIdVal(int timeScaleId) {

        double val = 0;
        synchronized (this) {
            if (timeScaleId >= minGear && timeScaleId <= maxGear) {
                int idx = timeScaleId - minGear;
                if(idx < xAxis.size()) {
                    val = xAxis.get(idx);
                }
            } else {
                throw new IllegalArgumentException();
            }
        }

        return val;
    }

    public int getTimeScaleIdOfView() {
        return getTimeScaleIdOfView(getWPIId());
    }

    public void setTimeScaleIdOfView(int timeScaleId) {
        setTimeScaleIdOfView(getWPIId(), timeScaleId);
    }

    public void setTimeScaleIdOfView(int WPIId, int timeScaleId) {
        if (WPIId == WPI_LARGE) {
            timeScaleIdZoom = timeScaleId;
            horizontalAxisAction.timeScaleIdChange();
        } else {
            timeScaleIdMain = timeScaleId;
            horizontalAxisAction.timeScaleIdChange();
        }

    }

    public int getTimeScaleIdOfView(int WPIId) {
        if (WPIId == WPI_LARGE) return timeScaleIdZoom;
        return timeScaleIdMain;
    }

    public long getTimePosOfView() {
        return getTimePosOfView(getWPIId());
    }

    public void setTimePosOfView(long timePos) {
        setTimePosOfView(getWPIId(), timePos);
    }

    public long getTimePosOfView(int WPIId) {
        if (WPIId == WPI_LARGE) return timePoseZoom;
        return timePoseMain;
    }

    public void setTimePosOfView(int WPIId, long timePos) {
        if (WPIId == WPI_LARGE) {
            timePoseZoom = timePos;
            horizontalAxisAction.timePosChange();
        } else {
            timePoseMain = timePos;
            horizontalAxisAction.timePosChange();
        }
    }

    public boolean isGreater100ms() {
        return (timeScaleIdMain <= TSI_100mS);
    }

    //根据档位，触发时间 计算 触发时刻在屏幕对应像素
    public long getTimePoseOfGrid(double timeScale, long timePos) {
        long offset;
        timeScale = (double) ScopeBase.getHorizonPerGridPixels() * timePos / (timeScale * 1e13);
//        if (timeScale < 0)
//            offset = (long) (timeScale - 0.5);
//        else
//            offset = (long) (timeScale + 0.5);

        return Math.round(timeScale);
    }

    public static long TimebaseToPix(int WPIId,double val) {
        Scope scope = Scope.getInstance();
        double timeScale;
        if (WPIId == WPI_STANDARD) {
            timeScale = scope.timeScale_mainBoard()/ScopeBase.getHorizonPerGridPixels();
        } else {
            timeScale = scope.timeScale_zoomBoard()/ScopeBase.getHorizonPerGridPixels();
        }

        return (long)(val>0?val/timeScale + 0.5:val/timeScale-0.5);
    }
    public static double PixToTimebase(int WPIId, long pix){
        Scope scope = Scope.getInstance();
        double timeScale;
        if (WPIId == WPI_STANDARD) {
            timeScale = scope.timeScale_mainBoard()/ScopeBase.getHorizonPerGridPixels();
        } else {
            timeScale = scope.timeScale_zoomBoard()/ScopeBase.getHorizonPerGridPixels();
        }
        return pix*timeScale;
    }
    //获得触发时刻屏幕位置
    public long getTimePoseOfGrid(int WPIId) {
        Scope scope = Scope.getInstance();
        double timeScale;
        if (WPIId == WPI_STANDARD) {
            timeScale = scope.timeScale_mainBoard();
        } else {
            timeScale = scope.timeScale_zoomBoard();
        }
        return getTimePoseOfGrid(timeScale, getTimePosOfView(WPIId));
    }

    //修改触发时刻负数
    public void correctTimePose() {
        long pos = getTimePosOfView(WPI_STANDARD);
        long pos1 = correctTimePose(pos);
        if (pos != pos1)
            setTimePosOfView(WPI_STANDARD, pos1);
    }

    public long correctTimePose(long pos) {
        Scope scope = Scope.getInstance();
        if (scope.isZoom())
            return pos;
        if (scope.isUsersetReset()){
            return pos;
        }

        long timeScreen_n = -(long) (scope.timeOneScreen_main() * scope.screenNum_Main() + 0.1);
//        Logger.i(TAG, "correctTimePose() ==>[0]"
//                +" pos:"+pos+"["+(pos/1e13)+"]"
//                +" timeOneScreen_main:"+(scope.timeOneScreen_main()/1e13)
//                +" screenNum_Main:"+scope.screenNum_Main()
//                +" timeScreen_n:"+(timeScreen_n/1e13)
//        + "run:" + scope.isRun());
        if (scope.isRun()) {
            if (pos < timeScreen_n) {
                pos = timeScreen_n;
            }
        } else {

            long half_timeScreen_n = timeScreen_n/2;
            long xpos = ScopeFrozen.getInstance().getTimePosOfView();
            if (pos < 0) {
                if(xpos < half_timeScreen_n) {
                    if(pos < timeScreen_n) {
                        pos = timeScreen_n;
                    }
                } else {
                    half_timeScreen_n += xpos;
                    if (pos < half_timeScreen_n) {
                        pos = half_timeScreen_n;
                    }
                }
            } else {
                if(xpos > -half_timeScreen_n) {
                    if(pos < xpos+half_timeScreen_n) {
                        pos = xpos+half_timeScreen_n;
                    }
                    if(pos > xpos-half_timeScreen_n) {
                        pos = xpos-half_timeScreen_n;
                    }
                } else if(xpos < half_timeScreen_n) {
                    if(pos > 0) {
                        pos = 0;
                    }
                } else {
                    half_timeScreen_n -= xpos;
                    if (pos > -half_timeScreen_n) {
                        pos = -half_timeScreen_n;
                    }
                }
            }
        }
        return pos;
    }

    //根据档位，屏幕像素位置放回时间
    public long getTimePose(double timeScale, long pos) {
        timeScale = timeScale * 1e13 * pos / ScopeBase.getHorizonPerGridPixels();
        long offset;
        if (timeScale < 0)
            offset = (long) (timeScale - 0.5);
        else
            offset = (long) (timeScale + 0.5);
        return offset;
    }

    //当触发时刻左右移动时，进行极限限定
    public void correctTimePose_poseMove() {
        Scope scope = Scope.getInstance();
        boolean zoom = scope.isZoom();

        long posMain = getTimePosOfView(WPI_STANDARD);
        long pos = getTimePosOfView();
        long halfTime = scope.timeOneScreen_main() / 2;
        if (zoom) {
            long lx1 = halfTime - posMain;
            long lx2 = halfTime + posMain;
            if (-pos > lx1) {//判断数据头是否在屏幕中心偏右
                setTimePosOfView(-lx1);
            } else if (pos > lx2) {//判断数据尾是否在屏幕中心偏左
                setTimePosOfView(lx2);
            }
        }
    }
