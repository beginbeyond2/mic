    //根据档位，屏幕像素位置放回时间
    public long getTimePose(int WPIId, long pos) {
        Scope scope = Scope.getInstance();
        double timeScale;
        if (WPIId == WPI_STANDARD) {
            timeScale = scope.timeScale_mainBoard();
        } else {
            timeScale = scope.timeScale_zoomBoard();
        }
        return getTimePose(timeScale, pos);
    }

    //根据档位，屏幕像素位置放回时间
    public long getTimePose(long pos) {
        return getTimePose(getWPIId(), pos);
    }

    public static final long TIME_FS_100 = 10_000_000_000_000L;
    private static final long MAX_TIME_POS = (long) ScopeBase.getHorizonGridCnt() * 1000 * 1000 * 1000 * 1000 * 1000 * 10;

    //档位，触发时间，偏移像素，返回新触发时间
    public long timePoseOfViewChangeEx(double timeScale, long timePos, long offset) {

        long gridTime = (long) (timeScale * 1e13 + 0.1);//0.1ps
        gridTime /= ScopeBase.getHorizonPerGridPixels();
        offset = timePos / gridTime - offset;
        long pos = offset * gridTime;
        if (pos > MAX_TIME_POS)
            pos = MAX_TIME_POS;
        timePos = pos;
        return timePos;
    }

    public long getTimePoseOfViewPix() {
        return getTimePoseOfGrid(getWPIId());
    }

    //移动触发位置触发位置
    public void setTimePoseOfViewPix(long pos) {

        pos = getTimePose(pos);
//        Logger.i(TAG, "setTimePoseOfViewPix() ==>"+" [2]pos:"+pos+" - "+(1.0*pos/1e13));
        if (pos > MAX_TIME_POS) {
            pos = MAX_TIME_POS;
        }
        pos = correctTimePose(pos);
//        Logger.i(TAG, "setTimePoseOfViewPix() ==>"+" [3]pos:"+pos+" - "+(1.0*pos/1e13));
        setTimePosOfView(pos);
    }

    //秒为单位
    public double getTimesPrePix() {
        double timeScale = getTimeScaleIdVal();
        timeScale /= ScopeBase.getHorizonPerGridPixels();
        return timeScale;
    }

    //秒转100飞秒，0.1ps
    public static long Sto100FS(double s) {
        return (long) (s * 1000 * 1000 * 1000 * 1000 * 10 + 0.01);
    }

    //100飞秒单位
    public long getTimesPrePixExt() {
        return Sto100FS(getTimesPrePix());
    }

    public synchronized int getStartX() {
        return startX;
    }

    public synchronized void setStartX(int startX) {
        this.startX = startX;
    }

    public synchronized int getEndX() {
        return endX;
    }

    public synchronized void setEndX(int endX) {
        this.endX = endX;
    }


    @Override
    public void update(Observable observable, Object data) {
        EventBase eventBase = (EventBase) data;
        if (eventBase != null) {
            switch (eventBase.getId()) {
                case EventFactory.EVENT_CHANNEL_OPEN:
                case EventFactory.EVENT_CHANNEL_CLOSE:
                case EventFactory.EVENT_DISPLAY_ZOOM:
                case EventFactory.EVENT_MEM_DEPTH:
                case EventFactory.EVENT_SCOPE_STATE:
                case EventFactory.EVENT_FORCE_MEM_DEPTH:
                    initXAxis();
                    break;
                case EventFactory.EVENT_CHANGE_CH_TIMEBASE:
                    double timeBase = (double) eventBase.getData();
                    Logger.i(TAG, " timeBase= " + timeBase + " ,scaleFollowingCh= " + scaleFollowingCh);
                    int chIdx = eventBase.getChannelIndex();
                    if (scaleFollowingCh) {
                        changeScaleByRef(timeBase);
                        //调整完时基之后，进行触发位置同步
                        if (ChannelFactory.isRefCh(chIdx)) {
                            RefChannel refChannel = ChannelFactory.getRefChannel(chIdx);
                            if (refChannel != null && refChannel.getRefType() != WaveData.FFT_WAVE) {
                                EventFactory.sendEvent(new EventBase(EventFactory.EVENT_SET_CH_TIMEPOS, refChannel.getRefXPos_original() * 1E-13));
                            }
                        }
                    }
                    break;
            }
        }
    }

    private void changeScaleByRef(double timeBase) {
        Logger.d(TAG, "changeScaleByRef timeBase= " + timeBase);
        int scaleIsd = -1;
        for (int i = 0; i < xAxis.size(); i++) {
            if (xAxis.get(i) == timeBase) {
                scaleIsd = i;
                break;
            }
        }
        if (scaleIsd >= 0) {
            setTimeScaleIdOfView(scaleIsd);
        }
    }

    public static int BaudrateToTimeScale(int baudrate) {
        if (baudrate <= 0) {
            return TSI_50mS;
        }
        double tsis[] = {1000, 500, 200, 100, 50, 20, 10, 5, 2, 1,
                0.5, 0.2, 0.1, 0.05, 0.02, 0.01, 0.005, 0.002, 0.001,
                500e-6, 200e-6, 100e-6, 50e-6, 20e-6, 10e-6, 5e-6, 2e-6, 1e-6,
                500e-9, 200e-9, 100e-9, 50e-9, 20e-9, 10e-9, 5e-9, 2e-9, 1e-9};
        double ctsi = 9.6 / baudrate;
        int ret = TSI_50mS;
        int max = tsis.length;
        for (int i = 0; i < max - 1; i++) {
            if (tsis[i] > ctsi && ctsi >= tsis[i + 1]) {
                ctsi = tsis[i + 1];
                if ((i + 1) > max) i = 18;
                ret = (i + 1);
                break;
            }
        }
        return ret;
    }


    /**
     * scpi调用该方法，查询给定触发时刻的时间值对应在屏幕上的位置信息
     *
     * @param timePosVal 给定触发时刻的时间值
     * @return 对应屏幕上的位置信息，中间为0，范围从[-350 ~ 349]
     */
    public long SCPIQueryPixInScreenFromTImePosVal(double timePosVal) {
        double pix = timePosVal * ScopeBase.getHorizonPerGridPixels() / getTimeScaleIdVal();
//        if (pix < -350) pix = -350;
//        if(pix > 349) pix = 349;
        return Math.round(pix);
    }

    public void setScaleFollowingCh(boolean followingCh) {
        this.scaleFollowingCh = followingCh;
    }

    public boolean getScaleFollowingCh() {
        return this.scaleFollowingCh;
    }


}
