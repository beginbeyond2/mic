    private long timePoseMain = 0;//主窗口或放大模式缩略窗口：中心点相对触发位置的偏移量。单位0.1ps
    private long timePoseZoom = 0;//放大模式放大窗口：屏幕中心点相对触发位置的偏移量。单位0.1ps
    private int timeScaleIdMain = TSI_5mS;
    private int timeScaleIdZoom = TSI_5mS;
