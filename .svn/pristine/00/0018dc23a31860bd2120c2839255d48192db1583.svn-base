package com.micsig.tbook.ui.bean;

/**
 * Created by yangj on 2017/5/22.
 */

public class RxIntWithSelect extends RxMsgSelect {
    private int value;

    public int getValue() {
        return value;
    }

    public void setValue(int value) {
        this.value = value;
    }

    public RxIntWithSelect(int value) {
        this.value = value;
    }

    @Override
    public String toString() {
        return "RxIntWithSelect{" +
                "value=" + value +
                "rxMsgSelect=" + rxMsgSelect +
                '}';
    }
}
