                isUp ? new ExternalKeysMsgLevel(ExternalKeysMsgLevel.TYPE_TRIGGER_MOVEUP, count)
                        : new ExternalKeysMsgLevel(ExternalKeysMsgLevel.TYPE_TRIGGER_MOVEDOMN, count));
