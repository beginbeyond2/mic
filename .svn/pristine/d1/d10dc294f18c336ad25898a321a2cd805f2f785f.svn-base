public class RefChannel extends BaseChannel implements Observer {
    private static final String TAG = "RefChannel";
    private FilterThread refThread;
    private ImageParam refParam = new ImageParam();
    private SurfaceNative surfaceNative = null;
    private RefChannelAction refChannelAction;
    private HorizontalAxisRef horizontalAxisRef;

    private int refType;
    private long refXPos = 0; //相对于原始触发时刻的位置移动了多少当前档位的像素
    private long refXPos_original;//原始触发时刻
    private long refDelayPos;
    private int refXStart;
    private int refXEnd;
    private double refYPos;
    private double refTimeScaleVal_original;//原始触发档位
    private double refTimeScaleVal;//当前触发档位
    private double refVScaleVal;
    private double refFineVal = 1.0;
    private int refProbeType;
    private String refProbeStr;
    private double refProbeRate;
    private double refSampleRate;
    private int refWaveLength;

    public RefChannel(int chIdx) {
        super(chIdx,"REF" + (chIdx - ChannelFactory.REF1 + 1));
        refChannelAction = new RefChannelAction(this);
        refThread = new FilterThread(TAG);
        refThread.setRunnable(new Runnable() {
            @Override
            public void run() {
                drawRef();
            }
        });
        InitRefParam();
        EventFactory.addEventObserver(EventFactory.EVENT_SURFACE_CREATED,this);
        EventFactory.addEventObserver(EventFactory.EVENT_SURFACE_DESTROYED,this);

        horizontalAxisRef = new HorizontalAxisRef();
        setBuffer(DataFactory.allocateBufferQueue(true));
    }

    private void InitRefParam(){

        refParam.setPerPixelByte(4);
        refParam.setBackgroundColor(0);
        refParam.setForegroundColor(0xFFE17D7D);
        refParam.setWidth(ScopeBase.getWidth());
        refParam.setHeight(ScopeBase.getHeight());
        refParam.setXOffset(0);
        refParam.setYOffset((int) Math.round(this.getPos()));
    }

    public void setForegroundColor(int colorValue) {
        colorValue = (colorValue & 0xFF000000)
                | ((colorValue & 0xFF) << 16)
                | ((colorValue & 0xFF00))
                | ((colorValue & 0xFF0000) >> 16);
        refParam.setForegroundColor(colorValue);
        drawRef();
    }
    @Override
    public void open() {
        setOpen(true);
        ScopeMessage.getInstance().sendUiMsg(UiMessage.UI_MESSAGE_DEPTH_SAMPFRE);
        sendEvent(EventFactory.EVENT_CHANNEL_OPEN, true);
    }

    @Override
    public void close() {
        setOpen(false);
        ScopeMessage.getInstance().sendUiMsg(UiMessage.UI_MESSAGE_DEPTH_SAMPFRE);
        sendEvent(EventFactory.EVENT_CHANNEL_CLOSE);
    }

    @Override
    public void activate() {
        sendEvent(EventFactory.EVENT_CHANNEL_ACTIVE,true);
        sendEvent(EventFactory.EVENT_CHANNEL_VSCALE,true);
        if (isOpen()) {
            ScopeMessage.getInstance().sendUiMsg(UiMessage.UI_MESSAGE_DEPTH_SAMPFRE);
            ScopeMessage.getInstance().sendUiMsg(UiMessage.UI_MESSAGE_SIMPLE_WIN_DIS);
        }
    }

    @Override
    public double getVerticalPerPix() {
        double val = refVScaleVal * refFineVal;
        double h = ScopeBase.getVerticalPerGridPixels() * ScopeBase.getToUICoff();
        if (Scope.getInstance().isZoom()) {
            h = ScopeBase.getZoomVerticalPerGridPixels() * ScopeBase.getToUICoff();
        }
        return val / h;
    }

    @Override
    public double getADVerticalPerPix() {
        double val = refVScaleVal * refFineVal;
        double h = ScopeBase.getVerticalPerGridPixels() * ScopeBase.getToUICoff();
        return val / h;
    }

    @Override
    public double getSampleRate() {
        double fs = 1.0;
        WaveData dataBuffer = (WaveData)obtain();
        if(dataBuffer != null){
            fs = dataBuffer.getSampRate();
            recycle(dataBuffer);
        }
        return fs;
    }

    @Override
    public double getSampleRate2display() {
        double fs = 1.0;
        WaveData dataBuffer = (WaveData) obtain();
        if (dataBuffer != null) {
            fs = dataBuffer.getSampRate2display();
            recycle(dataBuffer);
        }
        return fs;
    }

    public int getRefType(){
        return refType;
    }
    public double getRefProbeRate(){
        return refProbeRate;
    }
    public int getVScaleId() {
        int VScaleId = 0;
        switch (refType) {
            default:
            case 0://dynamic ch
            {
                double val = refVScaleVal / refProbeRate;
                VScaleId = ChannelFactory.getDynamicChannel(ChannelFactory.CH1).getVScaleId(val);
                break;
            }
            case 1://Math ch:Dual
                VScaleId = VerticalAxisMathDual.getScaleIdByValue(refVScaleVal);
                break;
            case 2://Math ch:FFT
                VScaleId = refProbeType == VerticalAxis.PROBE_TYPE_DB ?
                        VerticalAxisMathFft.getScaleIdInDb(refVScaleVal) :
                        VerticalAxisMathFft.getScaleIdInRms(refVScaleVal);
                break;
        }
        return VScaleId;
    }

    public int getVScaleIdMax() {
        int VScaleIdMax = VerticalAxis.getMaxGear();
        switch (refType) {
            case 0:
                VScaleIdMax = VerticalAxis.getMaxGear();
                break;
            case 1:
                VScaleIdMax =VerticalAxisMathDual.DANG_DUAL_MAX;
                break;
            case 2:
                VScaleIdMax = refProbeType == VerticalAxis.PROBE_TYPE_DB ?
                        VerticalAxisMathFft.DANG_DBV_MAX :
                        VerticalAxisMathFft.DANG_RMS_MAX;
                break;
        }
        return VScaleIdMax;
    }

    public int getVScaleIdMin() {
        int VScaleIdMin = VerticalAxis.getMinGear();
        switch (refType) {
            case 0:
                VScaleIdMin = VerticalAxis.getMinGear();
                break;
            case 1:
                VScaleIdMin =VerticalAxisMathDual.DANG_DUAL_MIN;
                break;
            case 2:
                VScaleIdMin = refProbeType == VerticalAxis.PROBE_TYPE_DB ?
                        VerticalAxisMathFft.DANG_DBV_MIN :
                        VerticalAxisMathFft.DANG_RMS_MIN;
                break;
        }
        return VScaleIdMin;
    }

    public void setVScaleId(int scaleId) {
        switch (refType) {
            case 0:
                refFineVal = 1.0;
                refVScaleVal = ChannelFactory.getDynamicChannel(ChannelFactory.CH1).getVScaleIdVal(scaleId);
                refVScaleVal *= refProbeRate;
                break;
            case 1:
                refFineVal = 1.0;
                refVScaleVal = VerticalAxisMathDual.getScaleIdValById(scaleId);
                break;
            case 2:
                refFineVal = 1.0;
                refVScaleVal = refProbeType == VerticalAxis.PROBE_TYPE_DB ?
                        VerticalAxisMathFft.dbvIdToValue(scaleId) :
                        VerticalAxisMathFft.rmsIdToValue(scaleId);

                break;
        }
        drawRef();
        super.setVScaleId(scaleId);
        sendEvent(EventFactory.EVENT_CHANNEL_VSCALE,true);
    }
    public int calcVScaleId(int val){
        int scaleId = getVScaleId();
        double fineVal = refFineVal;
        if(val > 0){
            if(fineVal >= 1.0){
                scaleId += val;
            }
        }else if(val < 0){
            if(fineVal <= 1.0){
                scaleId += val;
            }
        }
        return scaleId;
    }
    public void setVScaleVal(double vScaleVal){

        vScaleVal /= refProbeRate;
        int scaleId = -1;
        switch (refType){
            case 0: {
                double v;
                scaleId = VerticalAxis.getMinGear();
                v = VerticalAxis.getScaleIdValById(scaleId);
                for (int i = VerticalAxis.getMinGear(); i <= VerticalAxis.getMaxGear(); i++) {
                    scaleId = i;
                    v = VerticalAxis.getScaleIdValById(scaleId);
                    if (vScaleVal <= v || DoubleUtil.FuzzyCompare(vScaleVal, v)) {
                        break;
                    }
                }
                refFineVal = vScaleVal / v;
                refVScaleVal = v * refProbeRate;
            }

            break;
            case 1: {
                    double v;
                    scaleId = VerticalAxisMathDual.DANG_DUAL_MIN;
                    v = VerticalAxisMathDual.getScaleIdValById(scaleId);
                    int i = scaleId;
                    int m = VerticalAxisMathDual.DANG_DUAL_MAX;
                    for (; i <= m; i++) {
                        scaleId = i;
                        v = VerticalAxisMathDual.getScaleIdValById(scaleId);
                        if (vScaleVal <= v || DoubleUtil.FuzzyCompare(vScaleVal, v)) {
                            break;
                        }
                    }
                    refFineVal = vScaleVal / v;
                    refVScaleVal = v * refProbeRate;
            }
                break;
            case 2: {

                double v;
                int i,m;
                if(refProbeType == VerticalAxis.PROBE_TYPE_DB){
                    scaleId = VerticalAxisMathFft.DANG_DBV_MIN;
                    m = VerticalAxisMathFft.DANG_DBV_MAX;
                    v = VerticalAxisMathFft.dbvIdToValue(scaleId);
                }else{
                    scaleId = VerticalAxisMathFft.DANG_RMS_MIN;
                    m = VerticalAxisMathFft.DANG_RMS_MAX;
                    v = VerticalAxisMathFft.rmsIdToValue(scaleId);
                }
                i = scaleId;
                for (; i <= m; i++) {
                    scaleId = i;
                    v = refProbeType == VerticalAxis.PROBE_TYPE_DB ?
                            VerticalAxisMathFft.dbvIdToValue(scaleId) :
                            VerticalAxisMathFft.rmsIdToValue(scaleId);
                    if (vScaleVal <= v || DoubleUtil.FuzzyCompare(vScaleVal, v)) {
                        break;
                    }
                }
                refFineVal = vScaleVal / v;
                refVScaleVal = v * refProbeRate;
            }
            break;
        }
        drawRef();
        if(scaleId > 0) {
            super.setVScaleId(scaleId);
        }
        sendEvent(EventFactory.EVENT_CHANNEL_VSCALE,true);
    }

    @Override
    public boolean isVScaleIdValid(int vScaleId) {
        return false;
    }

    public double getVScaleVal() {
        return refVScaleVal * refFineVal;
    }
    public double getFineScale(){
        return refFineVal * 1/ refProbeRate;
    }
    public double getVScaleIdVal() {
        return getVScaleVal();
    }
    public int getProbeType() {
        return refProbeType;
    }
    public String getProbeStr(){
        return refProbeStr;
    }
    //采用绝对坐标的ID
    public int getRefTimeScaleId() {
        return horizontalAxisRef.timeScaleId(refTimeScaleVal,refType);
    }
    //采用相对坐标（界面index）的ID
    public int getRefTimeScaleId_ui() {
        return horizontalAxisRef.timeScaleId_ui(refTimeScaleVal_original,refTimeScaleVal,refType);
    }
    public double getRefTimeScaleVal() {//获取Ref时基
        return refTimeScaleVal;
    }
    public double getRefTimePerPix(){
        if (HorizontalAxis.getInstance().getScaleFollowingCh()) {
            return HorizontalAxis.getInstance().getTimesPrePix();
        } else {
            return refTimeScaleVal/ScopeBase.getHorizonPerGridPixels();
        }
    }

    @Override
    public void setPos(double pos) {
        pos = pos * ScopeBase.getToFPGACoff();
        super.setPos(pos);
        drawRef();
        sendEvent(EventFactory.EVENT_REF_VPOS,true);
    }

