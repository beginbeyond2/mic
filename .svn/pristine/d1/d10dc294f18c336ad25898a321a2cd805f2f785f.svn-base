    public void sendEvent(int eventId){
        EventFactory.sendEvent(new EventBase(eventId, getChId()), false);
    }
    public void sendEvent(int eventId,boolean async){
        EventFactory.sendEvent(new EventBase(eventId, getChId()), async);
    }

    public void setXPosOfViewPix(long pos){
        long pos1 = HorizontalAxis.getInstance().getTimePoseOfGrid(refTimeScaleVal, refXPos_original);
        refXPos = pos1-pos;
        Logger.i("RefChannel= ", getName() + " ,ref now pix=" + pos + ", original pix=" + pos1 + ", mov pix=" + refXPos);
        drawRef();
        ScopeMessage.getInstance().sendUiMsg(UiMessage.UI_MESSAGE_SIMPLE_WIN_DIS);
    }

    public long getTimeDelayOfViewPix() {
        return HorizontalAxis.getInstance().getTimePoseOfGrid(refTimeScaleVal, refDelayPos);
    }

    public long getTimePoseOfViewPix(long timePos) {//返回像素
        return HorizontalAxis.getInstance().getTimePoseOfGrid(refTimeScaleVal, timePos);
    }

    public long getTimePoseOfViewPix(){//返回像素
        return HorizontalAxis.getInstance().getTimePoseOfGrid(refTimeScaleVal, refXPos_original) - refXPos;
    }

    public long getTimePoseOfViewPix_original_originalScale(){
        return HorizontalAxis.getInstance().getTimePoseOfGrid(refTimeScaleVal_original, refXPos_original);
    }

    public long getTimePoseOfViewPix_original_nowScale(){
        return HorizontalAxis.getInstance().getTimePoseOfGrid(refTimeScaleVal, refXPos_original);
    }

    public long getTimePosOfView(){ //返回时间
        return refXPos_original-HorizontalAxis.getInstance().getTimePose(refTimeScaleVal, refXPos);
    }

    public long getTimePosOfView(int posPix) {
        return HorizontalAxis.getInstance().getTimePose(refTimeScaleVal, posPix);
    }

    public  long getRefMovPix(){
        return refXPos;
    }


    public void correctTimePose(){
        double radio=refTimeScaleVal_original/refTimeScaleVal;
        if(refXPos < 0){
            //左移
            int leftMosPix=refXEnd-ScopeBase.getWidth()/2;
            leftMosPix *= radio;
            if(-refXPos > leftMosPix){
                refXPos = -leftMosPix;
            }
        }
        else{
            //右移
            int rightMosPix=ScopeBase.getWidth()/2-refXStart;
            rightMosPix *= radio;
            if(rightMosPix > 0) {
                if (refXPos > rightMosPix) {
                    refXPos = rightMosPix;
                }
            }
        }
    }

    public long getXPos_pix_original(){
        return HorizontalAxis.getInstance().getTimePoseOfGrid(refTimeScaleVal_original, refXPos_original);
    }

    public int getWaveLen(){
        int len=0;
        WaveData dataBuffer = (WaveData)obtain();
        if(dataBuffer != null){
            len = dataBuffer.getWaveLength();
            recycle(dataBuffer);
        }
        return len;
    }

    public HorizontalAxisRef getHorizontalAxisRef() {
        return horizontalAxisRef;
    }


    public double getScreenNum(){
        return (double)(refTimeScaleVal_original/refTimeScaleVal);
    }

    public void setRefTimeScale(double timeScale) {
        setRefTimeScale(timeScale,0);
    }

    public void setRefTimeScale(double timeScale, int pos) {
        refXPos *= refTimeScaleVal / timeScale;
        refXPos += pos;
        double tempScaleVal = refTimeScaleVal;
        refTimeScaleVal = timeScale;
        long temp = getTimePoseOfViewPix_original_nowScale();
        boolean needFix = Math.abs(temp) < 1000 && Math.abs(refXPos - temp) <= 1;
        if (pos == 0 && temp != 0 && (Math.abs(refXPos - temp) * 1.0 / Math.abs(temp) <= 1E-3 || needFix) && tempScaleVal != timeScale) {
            refXPos = temp;
        }
        drawRef();
        ScopeMessage.getInstance().sendUiMsg(UiMessage.UI_MESSAGE_SIMPLE_WIN_DIS);
    }

    public boolean loadWave(FileChannel fileChannel){
        boolean bret = false;
        IDataBuffer dataBuffer = obtain();
        if(dataBuffer != null){
            bret = dataBuffer.load(fileChannel);
            recycle(dataBuffer);
        }
        if(bret){
            loadWave();
        }
        return bret;
    }
    public void loadWave(){
        Log.d(TAG, "loadWave() called");
        refChannelAction.loadWave();
        LoadRefConfig();
        drawRef();
    }

    public boolean loadWave(String pathName){
        Log.d(TAG, "loadWave() called with: pathName = [" + pathName + "]");

//        if(LoadCsv.onTest()){
//            return true;
//        }

        boolean bret = false;
        File file = new File(pathName);
        if(!file.exists()) {
            return bret;
        }
        IDataBuffer dataBuffer = obtain();
        if(dataBuffer != null){
            bret = dataBuffer.load(pathName);
            recycle(dataBuffer);
        }
        if(bret){
            loadWave();
        }
        return bret;
    }

    public void LoadRefConfig(){
        WaveData dataBuffer = (WaveData)obtain();
        if(dataBuffer != null){
            refType = dataBuffer.getWaveType();
            refXPos_original = dataBuffer.getXPos();
            refXPos = 0;
            refXStart = dataBuffer.getStartX();
            refXEnd = dataBuffer.getEndX();
            refYPos = dataBuffer.getYPosition();
            Log.d("LoadRefConfig", "channel= " + getName() + " ,refXStart:" + refXStart + ",refXEnd:" + refXEnd + ",refXPos_original:" + refXPos_original + " ,refYPos= " + refYPos);
            refVScaleVal = dataBuffer.getVScaleVal();
            refProbeType = dataBuffer.getProbeType();
            refProbeStr = dataBuffer.getProbeStr();
            Logger.i("LoadRefConfig channel= " + getName() + " ,refProbeType= " + refProbeType + " ,refProbeStr= " + refProbeStr + " ,label= " + dataBuffer.getLabel());
            refProbeRate = dataBuffer.getProbeRate();
            refSampleRate = dataBuffer.getSampRate2display();
            refWaveLength = dataBuffer.getWaveLength();
            int memDepthSet = dataBuffer.getMemDepthSet();
            int memDepthItemIdx = dataBuffer.getMemDepthItemIdx();
            super.setLabel(dataBuffer.getLabel());
            recycle(dataBuffer);
            setPos(refYPos);//目的：将RefChannel中的位置 同步到 MathRefWave中
            super.setPos(refYPos);
            horizontalAxisRef.setRefType(refType);
            horizontalAxisRef.setMemDepthSet(memDepthSet);
            horizontalAxisRef.setMemDepthItemIdx(memDepthItemIdx);
            horizontalAxisRef.setSampleRate(refSampleRate);
            horizontalAxisRef.setWaveLength(refWaveLength);

            refTimeScaleVal_original = dataBuffer.getTimeScaleVal();
            horizontalAxisRef.generateHorizontalAxis(refTimeScaleVal_original);//生成Ref的时基列表
            if(refType == 2) {//默认
                refTimeScaleVal = horizontalAxisRef.getxAxis().get(0);
            }
            else
                refTimeScaleVal = refTimeScaleVal_original;
            refFineVal = 1.0;
            if(refType > 0){
                refProbeRate = 1.0;
            }
            Log.d(TAG, "LoadRefConfig() called refVScaleVal:" + refVScaleVal
                    + ",refType:" + refType
                    + ",refProbeRate:" + refProbeRate);
            setVScaleVal(refVScaleVal);
            setDelay(0);
            refChannelAction.changeChTimeBase();
        }
    }

    public void calcXOffset(WaveData waveData){

        int w = ScopeBase.getWidth()/2;
        int s = refXStart;
        int e = refXEnd;
        double r = refTimeScaleVal_original/refTimeScaleVal;

        s = (int)Math.floor(w - (w - s) * r + refXPos);
        e = (int)Math.floor(w + (e - w) * r + refXPos);

        waveData.setStartX(s);
        waveData.setEndX(e);
    }


    public void drawRef(){
//        Logger.d("limh", "drawRef channel= " + getName() + " ,isOPen= " + isOpen());
        if(!isOpen()) {
            return;
        }

        //Logger.i(Log.getStackTraceString(new Throwable()));
        if(refThread.isSelfThread()) {
            WaveData dataBuffer = (WaveData)obtain();
            if (dataBuffer != null) {
                refChannelAction.loadWave();
                refParam.setTimeScaleVal(refTimeScaleVal);
                double v = refVScaleVal * refFineVal/(ScopeBase.getVerticalPerGridPixels());

                if(refType == 2
                        && refProbeType == VerticalAxis.PROBE_TYPE_DB) {
                    v *= dataBuffer.getVScaleVal()*1e4;
                }
                refParam.setVerticalPerPix(v);


                // horizontal
                if (refType != WaveData.FFT_WAVE) {
                    refParam.setXOffset((int) (refXPos + getTimeDelayOfViewPix()));
                } else {
                    refParam.setXOffset((int) refXPos);
                }
                Logger.i(TAG, "refXPos= " + refXPos + " ,delayPos= " + getTimeDelayOfViewPix() + " ,delay= " + delay);
                //calcXOffset(dataBuffer);
                // vertical
                if(Scope.getInstance().isZoom()) {
                    refParam.setYOffset((int) Math.round(this.getPos() * ScopeBase.getZoomHeight() / ScopeBase.getHeight()));
                    refParam.setHeight(ScopeBase.getZoomHeight());
                } else {
                    refParam.setYOffset((int) Math.round(this.getPos()));
                    refParam.setHeight(ScopeBase.getHeight());
                }
                //Logger.i("RefChannel---drawRef", super.getChId()+"xoffset="+refXPos+", yoffset="+this.getPos());
                synchronized (surfaceLock) {
                    if (surfaceNative != null) {
                        refParam.setStartX(refXStart);
                        refParam.setEndX(refXEnd);
                        surfaceNative.drawSurface(dataBuffer.getByteBuffer(), refParam.getDirectBuffer());
                    }
                }
                recycle(dataBuffer);
            }
        }else
        {
            refThread.run();
        }
    }

    public final Object surfaceLock = new Object();
    @Override
    public void update(Observable observable, Object data) {
        EventBase eventBase = (EventBase)data;
        if(eventBase != null){
            if(eventBase.getId() == EventFactory.EVENT_SURFACE_CREATED){
                SurfaceDataRecv surface = (SurfaceDataRecv)eventBase.getData();
                if(surface != null){
                    synchronized (surfaceLock) {
                        surfaceNative = surface.getSurfaceNative(SurfacePreview.LAYER_REF1 + getChId() - ChannelFactory.REF1);
                        surfaceNative.acquireSurface(ScopeBase.getWidth(), ScopeBase.getHeight());
                        surfaceNative.clearSurface();
                    }
                }
            }else if(eventBase.getId() == EventFactory.EVENT_SURFACE_DESTROYED){
                SurfaceDataRecv surface = (SurfaceDataRecv)eventBase.getData();
                if(surface != null) {
                    synchronized (surfaceLock) {
                        if(surfaceNative != null) {
                            surfaceNative.releaseSurface();
                            surfaceNative = null;
                        }
                    }
                }
            }
        }
    }

    public double getRefTimeScaleVal_original() {
        return refTimeScaleVal_original;
    }

    public long getRefXPos_original() {
        return refXPos_original;
    }

    private double delay = 0;

    public void setDelay(double delay) {
        this.delay = delay;
        this.refDelayPos = (long) (delay / 1e-13);
        drawRef();
    }

    public double getDelay() {
        return this.delay;
    }

}
