    public int FftPersist_ModeQ() {
        return this.fftPersistMode;
    }

    /**
     * 设置余辉普通显示模式下余辉时间
     * index: 是数值，不是索引
     */
    public void Persist_Adjust(int index, boolean isUpdateUI) {
//        if (persistAdjust == index) return;
        if ( Tools.indexOf(ToolsSCPI.displayPersistAdjust, s->index==s)==-1 ) return;
        this.persistAdjust = index;
        if (isUpdateUI) {
            CommandMsgToUI msgToUI = Command.get().getMsgToUI();
            msgToUI.setFlag(CommandMsgToUI.FLAG_DISPLAY_PERSISTADJUST);
            msgToUI.setParam(String.valueOf(index));
            RxBus.getInstance().post(RxEnum.COMMAND_TO_UI, msgToUI);
        }
    }

    /**
     * 查询余辉普通显示模式下余辉时间
     */
    public int Persist_AdjustQ() {
        return this.persistAdjust;
    }

    /**
     * 设置FFT余辉普通显示模式下余辉时间
     * index: 是数值，不是索引
     */
    public void FftPersist_Adjust(int index, boolean isUpdateUI) {
        if ( Tools.indexOf(ToolsSCPI.displayFftPersistAdjust, s->index==s)==-1 ) return;
        this.fftPersistAdjust = index;
        if (isUpdateUI) {
            CommandMsgToUI msgToUI = Command.get().getMsgToUI();
            msgToUI.setFlag(CommandMsgToUI.FLAG_DISPLAY_FFT_PERSISTADJUST);
            msgToUI.setParam(String.valueOf(index));
            RxBus.getInstance().post(RxEnum.COMMAND_TO_UI, msgToUI);
        }
    }

    /**
     * 查询FFT余辉普通显示模式下余辉时间
     */
    public int FftPersist_AdjustQ() {
        return this.fftPersistAdjust;
    }


    /**
     * 清除余辉显示
     */
    public void Persist_Clear(boolean isUpdateUI) {
        if (isUpdateUI) {//由于是个btn，不需要修改UI
            CommandMsgToUI msgToUI = Command.get().getMsgToUI();
            msgToUI.setFlag(CommandMsgToUI.FLAG_DISPLAY_PERSIST_CLEAR);
            RxBus.getInstance().post(RxEnum.COMMAND_TO_UI, msgToUI);
        }
    }

    /**
     * 清除FFT余辉显示
     */
    public void FftPersist_Clear(boolean isUpdateUI) {
        if (isUpdateUI) {//由于是个btn，不需要修改UI
            CommandMsgToUI msgToUI = Command.get().getMsgToUI();
            msgToUI.setFlag(CommandMsgToUI.FLAG_DISPLAY_FFT_PERSIST_CLEAR);
            RxBus.getInstance().post(RxEnum.COMMAND_TO_UI, msgToUI);
        }
    }

    /**
     * 打开或关闭高刷新
