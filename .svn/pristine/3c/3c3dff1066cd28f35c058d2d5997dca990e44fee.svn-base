    /**
     * 查询余辉显示模式
     */
    public int Persist_ModeQ() {
        return this.persistMode;
    }

    /**
     * 设置FFT余辉显示模式
     */
    public void FftPersist_Mode(int index, boolean isUpdateUI) {
        if (this.fftPersistMode == index) return;
        this.fftPersistMode = index;
        if (isUpdateUI) {
            CommandMsgToUI msgToUI = Command.get().getMsgToUI();
            msgToUI.setFlag(CommandMsgToUI.FLAG_DISPLAY_FFT_PERSISTMODE);
