        this.isHigh = isHigh;
        if (isUpdateUI) {
            CommandMsgToUI msgToUI = Command.get().getMsgToUI();
            msgToUI.setFlag(CommandMsgToUI.FLAG_DISPLAY_HIGHREFRESH);
            msgToUI.setParam(String.valueOf(isHigh));
