    /**
     * 常规   routineTimebaseMode()    时基模式  （YT，XY）
     */
    public void setRoutineTimeBaseMode(int index, boolean isUpdateUI) {
        if (routineTimebaseMode == index) return;
        this.routineTimebaseMode = index;
        if (isUpdateUI) {
            CommandMsgToUI msgToUI=Command.get().getMsgToUI();
            msgToUI.setFlag(CommandMsgToUI.FLAG_DISPLAY_TIMEBASE);
            msgToUI.setParam(String.valueOf(this.routineTimebaseMode));
            RxBus.getInstance().post(RxEnum.COMMAND_TO_UI,msgToUI);
        }
    }

