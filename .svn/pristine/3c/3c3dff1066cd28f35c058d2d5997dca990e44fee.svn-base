    public static final int RoutineTimeBaseMode_YT = 0;
    public static final int RoutineTimeBaseMode_XY = 1;

    //时基模式
    private int routineTimebaseMode = 0;
    //滚屏
    private int routineRollingScreen = 0;

    private int waveForm;
    private int brightness;
    private int graticule;
    private int intensity;
    private int persistMode, fftPersistMode;
    private int persistAdjust, fftPersistAdjust;
    private boolean isHigh;
    //时基参考
    private int horRef;
    private boolean cct;
    private boolean isZoom;

    /**
     * 设置屏幕中波形的显示方式 点 线
     */
    public void WaveForm(int index, boolean isUpdateUI) {
        if (waveForm == index) return;
        this.waveForm = index;
        if (isUpdateUI) {
            CommandMsgToUI msgToUI = Command.get().getMsgToUI();
            msgToUI.setFlag(CommandMsgToUI.FLAG_DISPLAY_WAVEFORM);
            msgToUI.setParam(String.valueOf(index));
            RxBus.getInstance().post(RxEnum.COMMAND_TO_UI, msgToUI);
        }
    }

    /**
     * 查询屏幕中波形的显示方式
     */
    public int WaveFormQ() {
        return this.waveForm;
    }

    /**
     * 设置屏幕中波形显示的亮度
     */
    public void Brightness(int brightness, boolean isUpdateUI) {
        if (this.brightness == brightness) return;
        this.brightness = brightness;
        if (isUpdateUI) {
            CommandMsgToUI msgToUI = Command.get().getMsgToUI();
            msgToUI.setFlag(CommandMsgToUI.FLAG_DISPLAY_BRIGHTNESS);
            msgToUI.setParam(String.valueOf(brightness));
            RxBus.getInstance().post(RxEnum.COMMAND_TO_UI, msgToUI);
        }
    }

    /**
     * 查询屏幕中波形显示的亮度
     */
    public int BrightnessQ() {
        return this.brightness;
    }

    /**
     * 设置屏幕显示的网格类型
     */
    public void Graticule(int graticule, boolean isUpdateUI) {
        if (this.graticule == graticule) return;
        this.graticule = graticule;
        if (isUpdateUI) {
            CommandMsgToUI msgToUI = Command.get().getMsgToUI();
            msgToUI.setFlag(CommandMsgToUI.FLAG_DISPLAY_GRATICULE);
            msgToUI.setParam(String.valueOf(graticule));
            RxBus.getInstance().post(RxEnum.COMMAND_TO_UI, msgToUI);
        }
    }

    /**
     * 查询屏幕显示的网格类型
     */
    public int GraticuleQ() {
        return this.graticule;
    }

    /**
     * 设置屏幕中网格显示的亮度
     */
    public void Intensity(int intensity, boolean isUpdateUI) {
        if (this.intensity == intensity) return;
        this.intensity = intensity;
        if (isUpdateUI) {
            CommandMsgToUI msgToUI = Command.get().getMsgToUI();
            msgToUI.setFlag(CommandMsgToUI.FLAG_DISPLAY_INTENSITY);
            msgToUI.setParam(String.valueOf(intensity));
            RxBus.getInstance().post(RxEnum.COMMAND_TO_UI, msgToUI);
        }
    }

    /**
     * 查询屏幕中网格显示的亮度
     */
    public int IntensityQ() {
        return this.intensity;
    }

    /**
     * 设置余辉显示模式
