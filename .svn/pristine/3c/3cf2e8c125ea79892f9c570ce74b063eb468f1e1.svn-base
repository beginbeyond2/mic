package com.micsig.tbook.tbookscope.top.layout.trigger.serials.bean;

/**
 * Created by yangj on 2017/5/17.
 */

public class SerialsDetailI2cFrame1 implements ISerialsDetail {
    private DataBean i2cFrame1Addr;
    private DataBean i2cFrame1Data;
    private String i2cFrame1AddrTitle;
    private String i2cFrame1DataTitle;

    public String getI2cFrame1AddrTitle() {
        return i2cFrame1AddrTitle;
    }

    public void setI2cFrame1AddrTitle(String i2cFrame1AddrTitle) {
        this.i2cFrame1AddrTitle = i2cFrame1AddrTitle;
    }

    public String getI2cFrame1DataTitle() {
        return i2cFrame1DataTitle;
    }

    public void setI2cFrame1DataTitle(String i2cFrame1DataTitle) {
        this.i2cFrame1DataTitle = i2cFrame1DataTitle;
    }

    public DataBean getI2cFrame1Addr() {
        return i2cFrame1Addr;
    }

    public void setI2cFrame1Addr(int digits, String value) {
        if (this.i2cFrame1Addr == null) {
            this.i2cFrame1Addr = new DataBean();
        }
        this.i2cFrame1Addr.setDigits(digits);
        this.i2cFrame1Addr.setValue(value);
    }

    public DataBean getI2cFrame1Data() {
        return i2cFrame1Data;
    }

    public void setI2cFrame1Data(int digits, String value) {
        if (this.i2cFrame1Data == null) {
            this.i2cFrame1Data = new DataBean();
        }
        this.i2cFrame1Data.setDigits(digits);
        this.i2cFrame1Data.setValue(value);
    }

    @Override
    public String toString() {
        return "SerialsDetailI2cFrame1{" +
                "i2cFrame1Addr='" + i2cFrame1Addr + '\'' +
                ", i2cFrame1Data='" + i2cFrame1Data + '\'' +
                '}';
    }
}
