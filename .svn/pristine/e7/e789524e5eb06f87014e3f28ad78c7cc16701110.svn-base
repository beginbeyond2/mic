package com.micsig.tbook.scope.Calibrate;

import java.util.Arrays;

public class ADC_EV12AQ60x extends ADC {
    public ADC_EV12AQ60x() {

    }

    @Override
    public void Init() {
    }

    @Override
    public void setOffset(int fpgaIdx, int adIdx, int i0_q1, int vol) {
        final int[] addr = {0x0124, 0x0324, 0x0524, 0x0724};
        if (i0_q1 >= 0 && i0_q1 < addr.length) {
            SendADData(fpgaIdx, 0, addr[i0_q1], vol);
        }
    }

    @Override
    public void setGain(int fpgaIdx, int adIdx, int i0_q1, int vol) {
        final int[] addr = {0x0122, 0x0322, 0x0522, 0x0722};
        if (i0_q1 >= 0 && i0_q1 < addr.length) {
            SendADData(fpgaIdx, 0, addr[i0_q1], vol);
        }
    }
    /*
     * 四通道
     * 0: CH1,CH5 => IN3 => D => 3
     * 1: CH2,CH6 => IN0 => A => 0
     * 2: CH3,CH7 => IN2 => C => 2
     * 3: CH4,CH8 => IN1 => B => 1
     * 双通道
     * 0: CH1,CH5 => IN3 => A,B => 0,1
     * 1: CH2,CH6 => IN0 => C,D => 2,3
     * 单通道
     * 0: CH1,CH5 => IN3 => A,B,C,D => 0,1,2,3
     * 1: CH2,CH6 => IN0 => A,B,C,D => 0,1,2,3
     */
    @Override
    public void setChannel(int cnt, boolean[] sel) {

        switch (cnt) {
            case 2:
                // 通道选择
                SendADData(0, 0, 0x000B , sel[1] ? 0 : 1);
                SendADData(1, 0, 0x000B , sel[5] ? 0 : 1);
                // 时钟模式
                SendADData(0, 0, 0x000A , 0);
                SendADData(1, 0, 0x000A , 0);
                break;
            case 4:
                // 通道选择
                SendADData(0, 0, 0x000B , 3);
                SendADData(1, 0, 0x000B , 3);
                // 时钟模式
                SendADData(0, 0, 0x000A , 2);
                SendADData(1, 0, 0x000A , 2);
                break;
            case 8:
            default:
                // 通道选择
                SendADData(0, 0, 0x000B , 4);
                SendADData(1, 0, 0x000B , 4);
                // 时钟模式
                SendADData(0, 0, 0x000A , 3);
                SendADData(1, 0, 0x000A , 3);
                break;
        }
        if(fpgaCommand != null){
            fpgaCommand.adSync();
        }
    }

    @Override
    protected void SendADData(int fpgaIdx, int adIdx, int addr, int val) {
        super.SendADData(fpgaIdx, adIdx, addr| 0x8000, val);
    }


    @Override
    public int getSampleChannel(boolean[] sel) {
        int nums = 0;
        // 0,1,2,3,4,5,6,7

        if (sel[2] || sel[3] || sel[6] || sel[7]) {
            // 2, 3, 6, 7 任意通道开启 进入8通道模式
            Arrays.fill(sel, true);
            nums = 8;

        } else if ((sel[0] && sel[1]) || (sel[4] && sel[5])) {
            // {0, 1}, {4, 5} 两组有一组开启 就将进入到 4通道模式，一个AD 管理两个通道
            sel[0] = sel[1] = sel[4] = sel[5] = true;
            nums = 4;
        } else {
            if (sel[0]) {
                if (!sel[4] && !sel[5]) {
                    sel[4] = true;
                }
            } else if (sel[1]) {
                if (!sel[4] && !sel[5]) {
                    sel[5] = true;
                }
            } else if (sel[4]) {
                sel[0] = true;
            } else if (sel[5]) {
                sel[1] = true;
            }
            nums = 2;
        }
        return nums;
    }

    @Override
    public int getMaxAdInClk() {
        return 6000;
    }

    @Override
    public int getMaxChNums() {
        return 4;
    }


}
