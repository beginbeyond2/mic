<?xml version="1.0" encoding="utf-8"?>
<AbsoluteLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <View
        android:id="@+id/outView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <RelativeLayout
        android:layout_width="818px"
        android:layout_height="170px"
        android:layout_x="491px"
        android:layout_y="600px"
        android:background="@drawable/shape_frame_bg_black"
        android:clickable="true"
        android:padding="17px">

        <TextView
            android:id="@+id/title"
            style="@style/textStyle"
            android:layout_width="120px"
            android:layout_height="60px"
            android:gravity="center"
            android:text="@string/dialogcount_title" />

        <TextView
            android:id="@+id/show"
            style="@style/editTextStyleRight"
            android:layout_width="120px"
            android:layout_height="60px"
            android:layout_marginStart="264px"
            android:textColor="@color/textColorNewRightViewEnable" />

        <RadioButton
            android:id="@+id/x100"
            style="@style/buttonStyleTop"
            android:layout_width="120px"
            android:layout_height="60px"
            android:layout_alignParentEnd="true"
            android:button="@null"
            android:gravity="center"
            android:text="@string/dialogcount_x100" />

        <RadioButton
            android:id="@+id/x1"
            style="@style/buttonStyleTop"
            android:layout_width="120px"
            android:layout_height="60px"
            android:layout_marginEnd="16px"
            android:layout_toStartOf="@id/x100"
            android:button="@null"
            android:checked="true"
            android:gravity="center"
            android:text="@string/dialogcount_x1" />

        <Button
            android:id="@+id/subtract"
            style="@style/buttonStyleTop"
            android:layout_width="120px"
            android:layout_height="60px"
            android:layout_below="@id/title"
            android:layout_marginTop="16px"
            android:includeFontPadding="false"
            android:gravity="center"
            android:text="@string/dialogcount_subtract"
            android:textSize="30px" />

        <Button
            android:id="@+id/add"
            style="@style/buttonStyleTop"
            android:layout_width="120px"
            android:layout_height="60px"
            android:layout_alignStart="@id/x1"
            android:layout_below="@id/title"
            android:layout_marginTop="16px"
            android:includeFontPadding="false"
            android:gravity="center"
            android:text="@string/dialogcount_add"
            android:textSize="30px" />

        <SeekBar
            android:id="@+id/progress"
            android:layout_width="360px"
            android:layout_height="60px"
            android:layout_alignTop="@id/subtract"
            android:layout_toEndOf="@id/subtract"
            android:layout_marginStart="24px"
            android:progress="50"
            android:paddingStart="0px"
            android:paddingEnd="0px"
            android:maxHeight="53px"
            android:minHeight="53px"
            android:background="@null"
            android:layout_gravity="center_vertical"
            android:thumb="@drawable/svg_seekbar_chute_slider"
            android:thumbOffset="0px"
            android:progressDrawable="@drawable/layer_seekbar_chute"
            android:splitTrack="false" />
    </RelativeLayout>
</AbsoluteLayout>