<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:ignore="MissingDefaultResource">

    <View
        android:id="@+id/outView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:id="@+id/ll_content"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/shape_frame_bg_black"
        android:clickable="true"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent">


        <View
            android:id="@+id/driver1"
            android:layout_width="match_parent"
            android:layout_height="2px"
            android:layout_gravity="center_horizontal"
            android:layout_marginStart="7px"
            android:layout_marginTop="14px"
            android:layout_marginEnd="7px"
            android:layout_marginBottom="7px"
            android:background="@drawable/bg_right_layout_divider" />

        <View
            android:id="@+id/driver2"
            android:layout_width="match_parent"
            android:layout_height="2px"
            android:layout_gravity="center_horizontal"
            android:layout_marginStart="7px"
            android:layout_marginTop="14px"
            android:layout_marginEnd="7px"
            android:layout_marginBottom="7px"
            android:background="@drawable/bg_right_layout_divider" />

        <Button
            android:id="@+id/btnOK"
            style="@style/buttonStyle"
            android:layout_width="155px"
            android:layout_height="60px"
            android:layout_gravity="center"
            android:layout_marginVertical="20px"
            android:text="@string/dialog_ok" />


    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>