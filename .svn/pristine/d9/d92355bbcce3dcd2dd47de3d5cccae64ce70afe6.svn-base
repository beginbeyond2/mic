package com.micsig.tbook.tbookscope.top.layout.trigger.serials.bean;

/**
 * Created by yangj on 2017/5/17.
 */

public class SerialsDetailM1553bDataWord implements ISerialsDetail {
    private DataBean m1553bDataWordData;
    private String m1553bDataWordDataTitle;

    public String getM1553bDataWordDataTitle() {
        return m1553bDataWordDataTitle;
    }

    public void setM1553bDataWordDataTitle(String m1553bDataWordDataTitle) {
        this.m1553bDataWordDataTitle = m1553bDataWordDataTitle;
    }

    public DataBean getM1553bDataWordData() {
        return m1553bDataWordData;
    }

    public void setM1553bDataWordData(int digits, String value) {
        if (this.m1553bDataWordData == null) {
            this.m1553bDataWordData = new DataBean();
        }
        this.m1553bDataWordData.setDigits(digits);
        this.m1553bDataWordData.setValue(value);
    }

    @Override
    public String toString() {
        return "SerialsDetailM1553bDataWord{" +
                "m1553bDataWordData='" + m1553bDataWordData + '\'' +
                '}';
    }
}
