    //ps 为单位
    //public static final int MAX_DELAY_PS = 100*1000;//100ns
    public static final int MAX_DELAY_PS = 500*1000;//100ns
    public void setDelay(int delay){
        if(-MAX_DELAY_PS <= delay && delay <= MAX_DELAY_PS) {
            this.delay = delay;
            channelAction.changeDelay();
        }else{
