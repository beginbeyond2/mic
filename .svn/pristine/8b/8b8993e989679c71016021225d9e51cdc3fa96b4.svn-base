    public  void setMaxMinVal(double maxVal,double minVal,boolean bRun) {
        double v = 0;
        if(bRun){
            v = getADVerticalPerPix() * ScopeBase.getToFPGACoff();
        }else{
            v = ScopeFrozen.getInstance().getChVertical(getChId()).getScaleVal()/(ScopeBase.getVerticalPerGridPixels());
        }
        synchronized (this) {
            maxVal = (maxVal * 256 + m) * n / 65536 + placeVal;
            minVal = (minVal * 256 + m) * n / 65536 + placeVal;

            if (bRun) {
                maxVal_bak = maxVal;
                minVal_bak = minVal;
            } else {

                if (maxVal > maxVal_bak) maxVal = maxVal_bak;
                if (minVal < minVal_bak) minVal = minVal_bak;
            }

            this.maxVal = maxVal * v;
            this.minVal = minVal * v;
            this.pkpkVal = this.maxVal - this.minVal;
        }

    }

    double maxVal_bak = Double.MIN_VALUE;
    double minVal_bak = Double.MAX_VALUE;
    public  void setMaxMinVal16Bit(double maxVal, double minVal,boolean bRun) {
        double v = 0;
        synchronized (this) {
            maxVal += 512 - c;
            minVal += 512 - c;
        }

        if(bRun){
            v = getVScaleVal()/ScopeBase.getVerticalPerGridPixels();
            maxVal = maxVal / getYFactor() - getPos();
            minVal = minVal / getYFactor() - getPos();
        }else{
            ScopeFrozen scopeFrozen = ScopeFrozen.getInstance();
            v = scopeFrozen.getChVertical(getChId()).getScaleVal()/(ScopeBase.getVerticalPerGridPixels());
            maxVal = maxVal / getYFactor() - scopeFrozen.getChPos(getChId());
            minVal = minVal / getYFactor() - scopeFrozen.getChPos(getChId());
        }

        synchronized (this) {
            this.maxVal = maxVal * v;
            this.minVal = minVal * v;
            this.pkpkVal = this.maxVal - this.minVal;
        }
    }

    public double getHalfWaveAmpInPix() {
        //notice: this value not contain ChannelZero
        waitWave();
        return (getMaxVal() + getMinVal()) / 2 / getADVerticalPerPix();
    }

    private volatile boolean needWave = true;
    public void setNeedWave(boolean needWave){
        this.needWave = needWave;
        if(!needWave){
            super.setWaveValid(false);
        }
    }

    @Override
    public IDataBuffer obtain() {
        if(isWaveValid()) {
            return super.obtain();
        }
        return null;
    }

    public boolean isNeedWave(){
        return this.needWave || getMeasure().isEnable();
    }

    @Override
    public void setWaveValid(boolean bWaveValid) {

        if(bWaitWave){
            Logger.d(TAG,"setWaveValid :" + bWaveValid);
            synchronized (this) {
                this.notify();
            }
        }
        super.setWaveValid(bWaveValid);
    }

    volatile boolean bWaitWave = false;
    public void waitWave(){
        if(!isNeedWave()) {
            synchronized (this) {
                bWaitWave = true;
                boolean needWave_bak = this.needWave;
                this.needWave = true;
                channelAction.getWave();
                Logger.d(TAG,"getwave,needWave_bak:" + needWave_bak);
                try {
                    this.wait(2000);
                } catch (InterruptedException e) {
                    e.printStackTrace();
                }
                bWaitWave = false;
                needWave = needWave_bak;
            }
        }
    }

    @Override
    public boolean save(String pathName) {
        this.waitWave();
        return super.save(pathName);
    }

    @Override
    public boolean saveCSV(String pathName) {
        this.waitWave();
        return super.saveCSV(pathName);
    }


