    public int getBandWidthType(int BandWidthType){
        int bwType = BandWidthType;
        if(BandWidthType == BANDWIDTH_TYPE_FULL) {
            double bw = getBandWidth(BANDWIDTH_TYPE_FULL);
            for(int i=0;i<BANDWIDTH_TYPE_20M;i++){
                if(bw > (BandWidth[i] - 10)){
                    bwType = i;
                    break;
                }
            }
        }
        return bwType;
    }

    public void bandWidthTypeChange(){
        channelAction.BandWidthTypeChange();
    }
    public void setBandWidthType(int bandWidthType,double bandWidth) {
        if(bandWidthType == BANDWIDTH_TYPE_FULL){
            if(bandWidth < getMaxBandWidth()){
                bandWidthType = BANDWIDTH_TYPE_LOWPASS;
            }
        }
        if(bandWidthType == BANDWIDTH_TYPE_FULL){
            bandWidth = maxBandWidth;
        }
        BandWidthType = bandWidthType;
        BandWidth[BandWidthType] = bandWidth;
        channelAction.BandWidthTypeChange();
    }

    public double getBandWidth(int BandWidthType){
        double bw = BandWidth[BandWidthType];
        if(bw > maxBandWidth){
            bw = maxBandWidth;
        }
        return bw;
    }
    public double getBandWidth() {
        return getBandWidth(BandWidthType);
    }

