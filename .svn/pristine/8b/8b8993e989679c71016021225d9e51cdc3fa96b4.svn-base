    public void setSample(boolean bSample) {
        if (bSample) {
            if (!isSample()) {
                channelAction.openSample();
            }
        } else {
            if (isSample()) {
                channelAction.closeSample();
            }
        }
        this.bSample = bSample;
        // Logger.d("Channel","Ch" + (getChId()+1) + ", Sample = " + bSample);
    }

