    private void setVScaleId(int scaleId,double fine,boolean bUser, boolean initScaleBak){
        if (VerticalAxis.isValidScaleId(scaleId)
                && isVScaleIdValid(scaleId)) {

            if(getResistanceType() == RESISTANCE_50
                    && isEnable_50O_700mV()){
                if(scaleId >= VerticalAxis.DANG_1V){
                    scaleId = VerticalAxis.DANG_1V;
                    if(fine >= 0.7){
                        fine = 0.7;
                    }
                }
            }

            verticalAxis.setFineScale(fine);
            verticalAxis.setScaleId(scaleId);
            channelAction.vScaleIdChange();
            super.setVScaleId(scaleId);
            if (initScaleBak && isValidScaleIdExt(verticalAxis.getScaleId())) {
                scaleIdBak = -1;
            }
            if(bUser){
                channelAction.vScaleIdUserChange();
            }

            if(isAutoProbe()){
                BaseProbe baseProbe = getProbe();
                if(baseProbe != null){
                    baseProbe.setVScaleVal(getVScaleVal());
                }
            }
        }
    }

    public void setVScaleId(int scaleId,double fine,boolean bUser){
