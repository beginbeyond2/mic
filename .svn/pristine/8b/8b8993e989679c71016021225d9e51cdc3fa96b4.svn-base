    public void setProbe(BaseProbe baseProbe){
        if (null==baseProbe && verticalAxis.getProbe()!=null){
            EventFactory.sendEvent(new EventBase(EventFactory.EVENT_PROBE_UNPLUG,getChId()),true);
        }else if (null!=baseProbe && verticalAxis.getProbe()==null) {
            EventFactory.sendEvent(new EventBase(EventFactory.EVENT_PROBE_PLUG,getChId()), true);
        }
        verticalAxis.setProbe(baseProbe);
        channelAction.probeChange();
    }

    public BaseProbe getProbe(){
        return verticalAxis.getProbe();
    }

    public Channel(int idx) {
        super(idx,"CH" + (idx + 1));
        verticalAxis = new VerticalAxis();
        channelAction = new ChannelAction(this);
        for(int i=TriggerLevel.TRIGGER_LEVEL_NORMAL;i<TriggerLevel.TRIGGER_LEVEL_MAX;i++){
            triggerLevels[i] = new TriggerLevel(i);
        }
        for (int i=0;i<channelZeroPos.length;i++){
            channelZeroPos[i] = 0;
        }
        setBuffer(DataFactory.allocateBufferQueue(false));
    }

    public TriggerLevel getTriggerLevel(int triggerLevelType){
        if(TriggerLevel.isTriggerLevelVaild(triggerLevelType))
            return triggerLevels[triggerLevelType];
        return null;
    }

