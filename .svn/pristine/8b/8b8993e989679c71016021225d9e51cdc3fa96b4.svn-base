    private boolean isValidScaleIdExt(int vScaleId){
        return (vScaleId >= getMinGear() && vScaleId <= getMaxGear());
    }

    @Override
    public boolean isVScaleIdValid(int vScaleId) {
        if(VerticalAxis.isValidScaleIdExt(vScaleId) && isValidScaleIdExt(vScaleId)){
            if(getVerticalMode() == VERTICAL_MODE_SCREEN_CENTER){
                double vScaleVal = getVScaleIdVal(vScaleId) * getFineScale();
                double val = centerVal / vScaleVal;
                int max = Scope.vSpanOfView(getResistanceType(),vScaleVal);
                return (val <= max) && (val >= -max);
            }else{
                return true;
            }
        }
        return false;
    }



    //输入任意档位自动转换精细档位
    public void setVScaleVal(double scaleVal){
        scaleVal /= verticalAxis.getProbeRate();

        int scaleId = VerticalAxis.getMinGear();
        double val = VerticalAxis.getScaleIdValById(scaleId);
        if(scaleVal < val){
            scaleVal = val;
        }

        for(int i=VerticalAxis.getMinGear();i<=VerticalAxis.getMaxGear();i++){
            val= VerticalAxis.getScaleIdValById(i);
            scaleId = i;
            if(scaleVal <= val || DoubleUtil.FuzzyCompare(scaleVal,val)){
                break;
            }
        }
        if(scaleId == VerticalAxis.getMaxGear()
                && scaleVal > VerticalAxis.getScaleIdValById(VerticalAxis.getMaxGear()) ){
            scaleVal = val;
        }

        setVScaleId(scaleId,scaleVal/val);
    }

    public int calcVScaleId(int dang,int val){
        int i = 0;
        for(i=VerticalAxis.getMinGear();i<=VerticalAxis.getMaxGear();i++){
            if(i >= dang){
                i += val;
                if(i < 0){
                    i = 0;
                }else if(i >= VerticalAxis.getMaxGear()){
                    i = VerticalAxis.getMaxGear();
                }
                break;
            }
        }
        return i;
    }

    public int calcVScaleId(int val){
        int scaleId = getVScaleId();
        double vScaleVal = getVScaleVal()/getProbeRate();
        if(val > 0){
            vScaleVal += vScaleVal * 0.01;
            int i = VerticalAxis.getMinGear();
            for(i=VerticalAxis.getMinGear();i<=VerticalAxis.getMaxGear();i++){
                if(VerticalAxis.getScaleIdValById(i) > vScaleVal){
                    scaleId = i;
                    break;
                }
            }
            if(i >= VerticalAxis.getMaxGear()){
                scaleId = VerticalAxis.getMaxGear();
            }
        }else{
            vScaleVal -= vScaleVal * 0.01;
            int i=VerticalAxis.getMaxGear();
            for(i=VerticalAxis.getMaxGear();i>=VerticalAxis.getMinGear();i--){
                if(VerticalAxis.getScaleIdValById(i) < vScaleVal){
                    scaleId = i;
                    break;
                }
            }
            if(i <= VerticalAxis.getMinGear()){
                scaleId = VerticalAxis.getMinGear();
            }
        }

        return scaleId;
    }

