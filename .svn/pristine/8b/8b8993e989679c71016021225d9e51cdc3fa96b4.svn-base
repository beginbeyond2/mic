    int scaleIdBak = -1;
    private volatile long  resistanceTS = 0;
    public long getResistanceTS(){
        return resistanceTS;
    }
    public void setResistanceType(int resistanceType) {
        if(resistanceType == RESISTANCE_50){
            resistanceTS = SystemClock.elapsedRealtime();
        }else{
            resistanceTS = 0;
        }
        synchronized (this) {
            this.resistanceType = resistanceType;
        }
        channelAction.ResistanceTypeChange();
        if(!isValidScaleIdExt(verticalAxis.getScaleId())){
            scaleIdBak = verticalAxis.getScaleId();
//            setVScaleId(VerticalAxis.DANG_1V, 1.0,true, false);
            if(isEnable_50O_700mV()){
                setVScaleId(VerticalAxis.DANG_1V, 0.7,true, false);
            }else{
                setVScaleId(
                        HardwareProduct.isMHO68V1() ? VerticalAxis.DANG_500mV : VerticalAxis.DANG_1V
                        , 1.0,true, false);
            }
        }else{
            if(resistanceType == RESISTANCE_1M && scaleIdBak != verticalAxis.getScaleId()){
                setVScaleId(scaleIdBak, 1.0,true, true);
            }
        }
    }

