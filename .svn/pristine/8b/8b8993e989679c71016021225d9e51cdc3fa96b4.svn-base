    private int [] channelZeroPos = new int[VerticalAxis.DANG_CNT];

    private volatile double chOffsetVal = 0;
    public void setChOffsetVal(double val){
        double v = getChOffset(val/getProbeRate());//计算出设置的偏移量 等于 多少个像素
        this.chOffsetVal = v * getADVerticalPerPix()/getProbeRate();//根据像素个数、档位、探针倍数 计算出实际的偏移值
        Log.d(TAG, "setChOffsetVal() called with: val = [" + val + "]" + " ,Pix= " + v + " ,chOffsetVal= " + chOffsetVal);
        channelAction.pos((int) Math.round(getPos()),false);
        channelAction.offsetChange();
    }

    private double getChOffset(double val){ //实际对应的偏移像素
        double v = val * getProbeRate() / getADVerticalPerPix() * ScopeBase.getToFPGACoff();
        if(v < vMin){
            v = vMin;
        }else if(v > vMax){
            v = vMax;
        }
        return v * ScopeBase.getToUICoff();
    }

    public double getChOffset(){//偏移量 实际的偏移像素
        return getChOffset(this.chOffsetVal);
    }

    public double getChOffsetVal(){// 偏移的幅值
        return getChOffset() * getADVerticalPerPix();
    }


