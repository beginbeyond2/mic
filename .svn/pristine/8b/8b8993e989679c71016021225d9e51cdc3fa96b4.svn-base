//    public void setPos(double pos) {
//        setPos(pos,false);
//    }

    public void setPos(double pos, boolean delay) {//这里传递过来的是 正负偏移量的像素值
        pos = pos * ScopeBase.getToFPGACoff();//转换成1000对应的偏移量
        double v = getZero() + getChOffset() * ScopeBase.getToFPGACoff() + pos;
        if (v >= vMin && v <= vMax) {
            super.setPos(pos);
        }
        channelAction.pos((int) Math.round(getPos()), delay);
    }

    public void setPos(double pos){
        pos = pos * ScopeBase.getToFPGACoff();
        double zero = getZero() + getChOffset() * ScopeBase.getToFPGACoff();
        if(pos + zero < vMin){
            pos = vMin - zero;
        }else if(pos + zero > vMax){
            pos = vMax - zero;
        }
        super.setPos(pos);
        channelAction.pos((int) Math.round(getPos()),false);
    }

    public double getMoveZeroVal(){
        return  (double)getZero()/ScopeBase.getVerticalPerGridPixels();
    }

    public void setZero(int pos){
        if (DoubleUtil.FuzzyCompare(getFineScale(),1.0)) {
            if (Math.abs(pos) <= ScopeBase.getHeight() / 2) {
                boolean bMoveZero = false;
                synchronized (this) {
                    int vScaleId = this.getVScaleId();
                    if(channelZeroPos[vScaleId]  != pos) {
                        channelZeroPos[this.getVScaleId()] = pos;
                        bMoveZero = true;
                    }
                }
                if(bMoveZero) {
                    channelAction.movezero();
                }
            }
        }
    }

    public synchronized void setZero(int vDang,int pos){

        channelZeroPos[vDang] = pos;
    }
    public boolean isFineExtent(){
        return !DoubleUtil.FuzzyCompare(getFineScale(),1.0);
    }
    public synchronized int getZero(){
        if (DoubleUtil.FuzzyCompare(getFineScale(),1.0)) {
            return channelZeroPos[this.getVScaleId()];
        }else{
            return 0;
        }
    }



