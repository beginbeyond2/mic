    public void forceRefresh() {
        sendEvent(EventFactory.EVENT_MATH_REFRESH);
    }

    public void setMaxVal(double val) {
        int id = getMathExprWave().maxVal2VScaleId(val / (ScopeBase.getVerticalGridCnt() / 2 - 1));
        if (isVScaleIdValid(id)) {
            setVScaleId(id);
        } else {
            Logger.d(TAG, "isVScaleIdValid id" + id + ",");
        }
    }

    public boolean isDifferential() {
        boolean bRet = false;
        if (getMathType() == MathWave.MATH_EXPR) {
            String exprString = getMathExprWave().getExprString();
            for (int i = 0; i < ChannelFactory.getChNums(); i++) {
                if (exprString.contains("diff(ch" + (i + 1) + ")")) {
                    bRet = true;
                    break;
                }
            }
        }
        return bRet;
    }

    public int getMathChIdx(){
        return getChId() - ChannelFactory.MATH1;
    }


    private double x1Val,x2Val;
    private boolean bX1Valid = false;
    private boolean bX2Valid = false;

    public synchronized void setCursorValue(double x1Val,double x2Val){
        this.x1Val = x1Val;
        this.x2Val = x2Val;
    }
    public synchronized void setCursorValid(boolean bX1Valid,boolean bX2Valid){
        this.bX1Valid = bX1Valid;
        this.bX2Valid = bX2Valid;
    }
    public synchronized double getCursorX1Value(){
        return x1Val;
    }
    public synchronized double getCursorX2Value(){
        return x2Val;
    }
    public synchronized boolean isCursorX1Valid(){
        return bX1Valid;
    }
    public synchronized boolean isCursorX2Valid(){
        return bX2Valid;
    }
