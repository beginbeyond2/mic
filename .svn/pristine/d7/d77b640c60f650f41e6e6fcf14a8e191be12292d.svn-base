<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <View
        android:id="@+id/outView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />


    <View
        android:layout_width="819px"
        android:layout_height="907px"
        android:layout_marginEnd="120px"
        android:layout_marginBottom="76px"
        android:background="@color/color_Enable"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <RelativeLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="120px"
        android:layout_marginBottom="76px"
        android:background="@drawable/shape_frame_bg_black"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="7px"
        android:paddingVertical="7px"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.micsig.tbook.ui.rightslipmenu.RightViewSelect
            android:id="@+id/baudRate"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:array="@array/serialsUartBaudRate"
            app:arrayOrientation="horizontalEachRow4"
            app:itemHeight="54px"
            app:itemMargin="7px"
            app:itemWidth="108px" />

        <com.micsig.tbook.ui.rightslipmenu.RightViewUserDefineEdit
            android:id="@+id/defineEdit"
            android:layout_width="230px"
            android:layout_height="54px"
            android:layout_alignEnd="@+id/baudRate"
            android:layout_alignBottom="@+id/baudRate"
            android:layout_marginEnd="7px"
            android:layout_marginBottom="7px" />
    </RelativeLayout>

</androidx.constraintlayout.widget.ConstraintLayout>