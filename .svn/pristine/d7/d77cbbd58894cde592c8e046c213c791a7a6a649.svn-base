<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_selected="true">
        <shape>
            <corners android:radius="8dp" />
            <stroke android:width="1px" android:color="@color/dividerNewTopView" />
            <solid android:color="@color/bgNewTopViewSelect" />
        </shape>
    </item>
    <item android:state_enabled="false">
        <shape>
            <corners android:radius="8dp" />
            <stroke android:width="1px" android:color="@color/textColorNewTopViewDisable" />
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>
    <item>
        <shape>
            <corners android:radius="8dp" />
            <stroke android:width="1px" android:color="@color/dividerNewTopView" />
            <solid android:color="@android:color/transparent" />
        </shape>
    </item>
</selector>