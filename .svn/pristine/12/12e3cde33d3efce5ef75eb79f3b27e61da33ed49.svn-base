package com.micsig.tbook.scope.fpga;

/**
 * Created by zhuzh on 2018-7-11.
 */

public class FPGAReg_INTRPT extends FPGAReg {
    private FPGAReg recvReg;
    private int val = 0;
    public FPGAReg_INTRPT() {
        super(FPGA_INTRPT, 4,true);
        recvReg = new FPGAReg(FPGA_INTRPT,4);
    }
    public FPGAReg getRecvReg(){
        return recvReg;
    }

    public void onRecv(){
        val = recvReg.getVal(0);
    }
    public boolean isDevFinish(){
        return (val & (1<<2)) != 0;
    }
    public boolean isAutoFinish(){
        return (val & (1<<3)) != 0;
    }
    public boolean isRefrsh(){
        return (val & (1<<4)) != 0;
    }
    public boolean isVideoTrig(){
        return (val & (1<<5)) != 0;
    }
    public boolean isFpgaIO(){
        return (val & (1<<7)) != 0;
    }
    public boolean isFre(){
        return (val & (1<<8)) != 0;
    }

}
