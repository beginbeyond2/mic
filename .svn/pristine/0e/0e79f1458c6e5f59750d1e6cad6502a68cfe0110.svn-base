<?xml version="1.0" encoding="utf-8"?>
<AbsoluteLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:ui="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <com.micsig.tbook.ui.MButton_CheckBox_ThreeClick
        android:id="@+id/nameUnCheck"
        android:layout_width="56px"
        android:layout_height="35px"
        android:layout_y="42px"
        android:text=""
        android:textColor="@color/color_Text_white"
        android:textSize="13px"
        ui:checkedBitmap="@drawable/l_math"
        ui:textCenterX="true"
        ui:text_y="8px"
        ui:unCheckedBitmap="@drawable/l_unclick" />

    <LinearLayout
        android:id="@+id/leftLayout"
        android:layout_width="56px"
        android:layout_height="52px"
        android:layout_y="45px"
        android:orientation="vertical"
        android:visibility="visible">

        <TextView
            android:id="@+id/nameCheck"
            style="@style/textStyleMiddlebarRightMain"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="-3px"
            android:lineSpacingMultiplier="0.8"
            android:text="MATH"
            android:textSize="14px" />

        <TextView
            android:id="@+id/vertical"
            style="@style/textStyleMiddlebarRight"
            android:layout_width="match_parent"
            android:layout_height="19px"
            android:layout_marginTop="-6px"
            android:text="50V"
            android:textSize="14px"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/timebase"
            style="@style/textStyleMiddlebarRight"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2px"
            android:text="200mA" />
    </LinearLayout>

    <AbsoluteLayout
        android:id="@+id/mathRefRightLayout"
        android:layout_width="39px"
        android:layout_height="121px"
        android:layout_x="57px">

        <com.micsig.tbook.ui.MButton
            android:id="@+id/btnmV"
            android:layout_width="39px"
            android:layout_height="62px"
            android:layout_y="0px"
            ui:touchDownBitmap="@drawable/math_mv_1"
            ui:touchUpBitmap="@drawable/math_mv" />

        <com.micsig.tbook.ui.MButton
            android:id="@+id/btnV"
            android:layout_width="39px"
            android:layout_height="62px"
            android:layout_y="59px"
            ui:touchDownBitmap="@drawable/math_v_1"
            ui:touchUpBitmap="@drawable/math_v" />
    </AbsoluteLayout>

    <LinearLayout
        android:id="@+id/serialsRightLayout"
        android:layout_width="39px"
        android:layout_height="120px"
        android:layout_x="57px"
        android:background="@color/color_S1"
        android:padding="1px"
        android:visibility="invisible">

        <LinearLayout
            android:id="@+id/serialsRightBgMainLayout"
            android:layout_width="39px"
            android:layout_height="120px"
            android:background="@color/bg_main_outside"
            android:gravity="center"
            android:orientation="vertical">

            <TextView
                android:id="@+id/text1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:textSize="10px" />

            <TextView
                android:id="@+id/text2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:textSize="10px" />

            <TextView
                android:id="@+id/text3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:textSize="10px" />

            <TextView
                android:id="@+id/text4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"
                android:textSize="10px" />
        </LinearLayout>
    </LinearLayout>
</AbsoluteLayout>