public class FPGAReg_STATUS_AUTO_CYCLE extends FPGAReg{
    private FPGAReg recvReg;
    public FPGAReg_STATUS_AUTO_CYCLE(int addr) {
        super(addr, 4, true);
        recvReg = new FPGAReg(addr,4);
    }
    public FPGAReg getRecvReg(){
        return recvReg;
    }
}
