    @Override
    public void setSelectCursor(int chNO) {
        switch (WorkModeManage.getInstance().getmWorkMode()) {
            case IWorkMode.WorkMode_XY:
                waveManage_xy.setSelectCursor(chNO);
                waveManage_yt.setSelectCursor(chNO);
                break;
            case IWorkMode.WorkMode_YT:
            case IWorkMode.WorkMode_YTZOOM:
                if (chNO==this.getCurCh()) {
                    CursorManage.getInstance().setCursorTrace(true);
                }
                SerialBusManage.getInstance().setSelectCursor(chNO);
                waveManage_yt.setSelectCursor(chNO);
                CursorManage.getInstance().setCursorTrace(false);
                break;
        }
    }

    @Override
    public int selectCursor(int x, int y) {
        switch (WorkModeManage.getInstance().getmWorkMode()) {
            case IWorkMode.WorkMode_XY:
                return waveManage_xy.selectCursor(x, y);

            case IWorkMode.WorkMode_YT:
            case IWorkMode.WorkMode_YTZOOM: {

                int curCh = getCurCh();
                int chNo = SerialBusManage.getInstance().selectCursor(x, y);
                if (chNo < 0) {
                    CursorManage.getInstance().setCursorTrace(false);
                    chNo = waveManage_yt.selectCursor(x, y,curCh);
                    if (chNo < 0) {
                        CursorManage.getInstance().setCursorTrace(true);
                        setSelectCursor(curCh);
                        chNo = curCh;
                    }
                } else {
                    if (curCh==chNo){
                        CursorManage.getInstance().setCursorTrace(true);
                    }
                    waveManage_yt.setSelectCursor(chNo);
                }
//                CursorManage.setCursorByScaleTrace();
                CursorManage.getInstance().setCursorTrace(false);
                //Logger.i(TAG, "chNo:" + chNo+",curChNo:"+getCurCh());
                return chNo;
            }

        }
        return -1;
    }

    @Override
    public void movePix(int px) {
        switch (WorkModeManage.getInstance().getmWorkMode()) {
            case IWorkMode.WorkMode_XY:
                waveManage_xy.movePix(px);
                break;
            case IWorkMode.WorkMode_YT:
            case IWorkMode.WorkMode_YTZOOM: {
                int curCh = waveManage_yt.getCurCh();
                if (curCh < 0) {
                    SerialBusManage.getInstance().movePix(px);
                } else {
                    waveManage_yt.movePix(px);
                }

                break;
            }
        }
    }

    @Override
    public int getCurCh() {
        switch (WorkModeManage.getInstance().getmWorkMode()) {
            case IWorkMode.WorkMode_XY:
                return waveManage_xy.getCurCh();
            case IWorkMode.WorkMode_YT:
            case IWorkMode.WorkMode_YTZOOM: {
                int curCh = waveManage_yt.getCurCh();
                if (curCh < 0) {
                    curCh = SerialBusManage.getInstance().isSelected();
                }
                return curCh;
            }
        }
        return -1;
    }

    public boolean isLabelContains(int x , int y) {
        switch (WorkModeManage.getInstance().getmWorkMode()) {
            case IWorkMode.WorkMode_XY:
                return false;
            case IWorkMode.WorkMode_YT:
            case IWorkMode.WorkMode_YTZOOM:
            default:
                return waveManage_yt.isLabelContains(x, y);

        }
    }

