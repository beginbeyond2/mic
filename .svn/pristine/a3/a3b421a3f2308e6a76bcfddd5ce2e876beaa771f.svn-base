    public void setRefOffset(int chIndex) {
        RefChannel refChannel = (RefChannel) ChannelFactory.getRefChannel(TChan.toFpgaChNo(chIndex));
        if (refChannel==null) return;
        double leftPos = Tools.getChannelPositionUI(chIndex); //541 实际像素位置
        int zoomHeight = (int) (ScopeBase.getNewHeight() * 0.75);
        double pos = (Tools.isZoom() ? zoomHeight : 1.0 * ScopeBase.getNewHeight()) / 2 - leftPos;//-1
        String unit = ChannelFactory.getProbeType(TChan.toFpgaChNo(chIndex));;
        int startPos = ScopeBase.getHeight() - zoomHeight;
        leftPos = Tools.isZoom() ? (leftPos + startPos) : leftPos;
        startPos = Tools.isZoom() ? startPos : 0;
        String number = TBookUtil.getFourFromD_Trim0(pos * refChannel.getVerticalPerPix());
        switch (chIndex) {
            case TChan.R1:
                if (ref1Master == null) {
                    ref1Master = (MainRightLayoutItemChannelMaster) mainViewGroup.findViewById(R.id.ref1Master);
                }
                ref1Master.setLeftPosition(number + unit);
                break;
            case TChan.R2:
                if (ref2Master == null) {
                    ref2Master = (MainRightLayoutItemChannelMaster) mainViewGroup.findViewById(R.id.ref2Master);
                }
                ref2Master.setLeftPosition(number + unit);
                break;
            case TChan.R3:
                if (ref3Master == null) {
                    ref3Master = (MainRightLayoutItemChannelMaster) mainViewGroup.findViewById(R.id.ref3Master);
                }
                ref3Master.setLeftPosition(number + unit);
                break;
            case TChan.R4:
                if (ref4Master == null) {
                    ref4Master = (MainRightLayoutItemChannelMaster) mainViewGroup.findViewById(R.id.ref4Master);
                }
                ref4Master.setLeftPosition(number + unit);
                break;
            case TChan.R5:
                if (ref5Master == null) {
                    ref5Master = (MainRightLayoutItemChannelMaster) mainViewGroup.findViewById(R.id.ref5Master);
                }
                ref5Master.setLeftPosition(number + unit);
                break;
            case TChan.R6:
                if (ref6Master == null) {
                    ref6Master = (MainRightLayoutItemChannelMaster) mainViewGroup.findViewById(R.id.ref6Master);
                }
                ref6Master.setLeftPosition(number + unit);
                break;
            case TChan.R7:
                if (ref7Master == null) {
                    ref7Master = (MainRightLayoutItemChannelMaster) mainViewGroup.findViewById(R.id.ref7Master);
                }
                ref7Master.setLeftPosition(number + unit);
                break;
            case TChan.R8:
                if (ref8Master == null) {
                    ref8Master = (MainRightLayoutItemChannelMaster) mainViewGroup.findViewById(R.id.ref8Master);
                }
                ref8Master.setLeftPosition(number + unit);
                break;
        }
    }

    public void setOffset(int chIndex) {
        Channel channel = ChannelFactory.getDynamicChannel(chIndex - 1);
        if (channel==null) return;
        double leftPos = Tools.getChannelPositionUI(chIndex); //541 实际像素位置
        int zoomHeight = (int) (ScopeBase.getNewHeight() * 0.75);
        double pos = (Tools.isZoom() ? zoomHeight : 1.0 * ScopeBase.getNewHeight()) / 2 - leftPos;//-1
        String unit = CacheUtil.get().getInt(CacheUtil.RIGHT_SLIP_CH_PROBE_TYPE + chIndex) == 0 ? "V" : "A";
//        layoutBranch.setOffset(TBookUtil.getFourFromD_Trim0(pos * channel.getVerticalPerPix()) + unit);
        int startPos = ScopeBase.getHeight() - zoomHeight;
        leftPos = Tools.isZoom() ? (leftPos + startPos) : leftPos;
        startPos = Tools.isZoom() ? startPos : 0;
        String number = TBookUtil.getFourFromD_Trim0(pos * channel.getVerticalPerPix());
//        RxBus.getInstance().post(RxEnum.MSG_CHANNEL_SLIP_POSITION,number+unit+";"+chIndex);
        leftPositionView.setData(chIndex - 1, leftPos
                , number
                , unit, startPos);
        if (GlobalVar.get().getChannelsCount()==GlobalVar.CHANNEL_COUNT_8){
            if (ch1Master == null || ch2Master == null || ch3Master == null || ch4Master == null
                    || ch5Master == null || ch6Master == null || ch7Master == null || ch8Master == null) {
                ch1Master = (MainRightLayoutItemChannelMaster) mainViewGroup.findViewById(R.id.rightCh1MasterEight);
                ch2Master = (MainRightLayoutItemChannelMaster) mainViewGroup.findViewById(R.id.rightCh2MasterEight);
                ch3Master = (MainRightLayoutItemChannelMaster) mainViewGroup.findViewById(R.id.rightCh3MasterEight);
                ch4Master = (MainRightLayoutItemChannelMaster) mainViewGroup.findViewById(R.id.rightCh4MasterEight);
                ch5Master = (MainRightLayoutItemChannelMaster) mainViewGroup.findViewById(R.id.rightCh5MasterEight);
                ch6Master = (MainRightLayoutItemChannelMaster) mainViewGroup.findViewById(R.id.rightCh6MasterEight);
                ch7Master = (MainRightLayoutItemChannelMaster) mainViewGroup.findViewById(R.id.rightCh7MasterEight);
                ch8Master = (MainRightLayoutItemChannelMaster) mainViewGroup.findViewById(R.id.rightCh8MasterEight);
            }
            switch (chIndex){
                case TChan.Ch1:ch1Master.setLeftPosition(number+unit); break;
                case TChan.Ch2:ch2Master.setLeftPosition(number+unit); break;
                case TChan.Ch3:ch3Master.setLeftPosition(number+unit); break;
                case TChan.Ch4:ch4Master.setLeftPosition(number+unit); break;
                case TChan.Ch5:ch5Master.setLeftPosition(number+unit); break;
                case TChan.Ch6:ch6Master.setLeftPosition(number+unit); break;
                case TChan.Ch7:ch7Master.setLeftPosition(number+unit); break;
                case TChan.Ch8:ch8Master.setLeftPosition(number+unit); break;
            }
        }else if (GlobalVar.get().getChannelsCount() == GlobalVar.CHANNEL_COUNT_4) {
            if (ch1Master == null || ch2Master == null || ch3Master == null || ch4Master == null) {
                ch1Master = (MainRightLayoutItemChannelMaster) mainViewGroup.findViewById(R.id.rightCh1Master);
                ch2Master = (MainRightLayoutItemChannelMaster) mainViewGroup.findViewById(R.id.rightCh2Master);
                ch3Master = (MainRightLayoutItemChannelMaster) mainViewGroup.findViewById(R.id.rightCh3Master);
                ch4Master = (MainRightLayoutItemChannelMaster) mainViewGroup.findViewById(R.id.rightCh4Master);
            }
            if (chIndex == TChan.Ch1) {
                ch1Master.setLeftPosition(number + unit);
            } else if (chIndex == TChan.Ch2) {
                ch2Master.setLeftPosition(number + unit);
            } else if (chIndex == TChan.Ch3) {
                ch3Master.setLeftPosition(number + unit);
            } else if (chIndex == TChan.Ch4) {
                ch4Master.setLeftPosition(number + unit);
            }
        } else {
            if (ch1Master == null || ch2Master == null) {
                ch1Master = (MainRightLayoutItemChannelMaster) mainViewGroup.findViewById(R.id.rightCh1MasterDouble);
                ch2Master = (MainRightLayoutItemChannelMaster) mainViewGroup.findViewById(R.id.rightCh2MasterDouble);
            }
            if (chIndex == TChan.Ch1) {
                ch1Master.setLeftPosition(number + unit);
            } else if (chIndex == TChan.Ch2) {
                ch2Master.setLeftPosition(number + unit);
            }
        }
    }

    public void setMathOffset(int mathIndex) {
        if (!ChannelFactory.isMathCh(TChan.toFpgaChNo(mathIndex))) return;
        MathChannel mathChannel = ChannelFactory.getMathChannel(TChan.toFpgaChNo(mathIndex));
        double pos;
        switch (CacheUtil.get().getInt(CacheUtil.RIGHT_SLIP_MATH_TYPE + mathIndex)) {
            case CacheUtil.MATHTYPE_DW:
                pos = CacheUtil.get().getDouble(CacheUtil.MAIN_WAVE_MATH_DW_Y_POSITION + mathIndex);
                break;
            case CacheUtil.MATHTYPE_FFT:
                if (CacheUtil.get().getInt(CacheUtil.RIGHT_SLIP_MATH_FFT_TYPE_ID + mathIndex) == 0) {
                    pos = CacheUtil.get().getDouble(CacheUtil.MAIN_WAVE_MATH_FFT_RMS_Y_POSITION + mathIndex);
                } else {
                    pos = CacheUtil.get().getDouble(CacheUtil.MAIN_WAVE_MATH_FFT_DB_Y_POSITION + mathIndex);
                }
                break;
            case CacheUtil.MATHTYPE_AXB:
                pos = CacheUtil.get().getDouble(CacheUtil.MAIN_WAVE_MATH_AXB_Y_POSITION + mathIndex);
                break;
            default:
                pos = CacheUtil.get().getDouble(CacheUtil.MAIN_WAVE_MATH_AM_Y_POSITION + mathIndex);
                break;
        }
        pos = GlobalVar.get().getMainWave().y / 2 - pos;
        String unit = ChannelFactory.getProbeType(TChan.toFpgaChNo(mathIndex));
        String number = TBookUtil.getFourFromD_Trim0(pos * mathChannel.getADVerticalPerPix());

        switch (mathIndex) {
            case TChan.Math1:
                if (math1Master == null) {
                    math1Master = (MainRightLayoutItemChannelMaster) mainViewGroup.findViewById(R.id.math1Master);
                }
                math1Master.setLeftPosition(number + unit);
                break;
            case TChan.Math2:
                if (math2Master == null) {
                    math2Master = (MainRightLayoutItemChannelMaster) mainViewGroup.findViewById(R.id.math2Master);
                }
                math2Master.setLeftPosition(number + unit);
                break;
            case TChan.Math3:
                if (math3Master == null) {
                    math3Master = (MainRightLayoutItemChannelMaster) mainViewGroup.findViewById(R.id.math3Master);
                }
                math3Master.setLeftPosition(number + unit);
                break;
            case TChan.Math4:
                if (math4Master == null) {
                    math4Master = (MainRightLayoutItemChannelMaster) mainViewGroup.findViewById(R.id.math4Master);
                }
                math4Master.setLeftPosition(number + unit);
                break;
            case TChan.Math5:
                if (math5Master == null) {
                    math5Master = (MainRightLayoutItemChannelMaster) mainViewGroup.findViewById(R.id.math5Master);
                }
                math5Master.setLeftPosition(number + unit);
                break;
            case TChan.Math6:
                if (math6Master == null) {
                    math6Master = (MainRightLayoutItemChannelMaster) mainViewGroup.findViewById(R.id.math6Master);
                }
                math6Master.setLeftPosition(number + unit);
                break;
            case TChan.Math7:
                if (math7Master == null) {
                    math7Master = (MainRightLayoutItemChannelMaster) mainViewGroup.findViewById(R.id.math7Master);
                }
                math7Master.setLeftPosition(number + unit);
                break;
            case TChan.Math8:
                if (math8Master == null) {
                    math8Master = (MainRightLayoutItemChannelMaster) mainViewGroup.findViewById(R.id.math8Master);
                }
                math8Master.setLeftPosition(number + unit);
                break;
        }
    }

    private void setRefOffset(MainRightLayoutItemChannelBranch layoutBranch, int refIndex) {
        Log.d(Tag.Debug, String.format("WaveManage.setRefOffset: %d",refIndex ));
        RefChannel channel = ChannelFactory.getRefChannel(refIndex);
        double pos = CacheUtil.get().getDouble(CacheUtil.MAIN_WAVE_REF_Y_POSITION + (TChan.toUiChNo(refIndex) ));
        pos = GlobalVar.get().getMainWave().y / 2 - pos;
        String unit = ChannelFactory.getProbeType(refIndex);
        layoutBranch.setMathRefOffset(TBookUtil.getFourFromD_Trim0(pos * channel.getVerticalPerPix()) + unit);
    }

    private void changeSerialTrigVol_channel(int chIdx) { //这里chIdx=IWave.ch1~ch4
        if (isCurChannelEquals(CacheUtil.S1, chIdx)) {
            if (ChannelFactory.isChOpen(ChannelFactory.S1)) {
                CacheUtil.get().setValueLevelSerials(CacheUtil.S1);
            } else {
                return;
            }
        } else if (isCurChannelEquals(CacheUtil.S2, chIdx)) {
            if (ChannelFactory.isChOpen(ChannelFactory.S2)) {
                CacheUtil.get().setValueLevelSerials(CacheUtil.S2);
            } else {
                return;
            }
        } else if (isCurChannelEquals(CacheUtil.S3, chIdx)) {
            if (ChannelFactory.isChOpen(ChannelFactory.S3)) {
                CacheUtil.get().setValueLevelSerials(CacheUtil.S3);
            } else {
                return;
            }
        } else if (isCurChannelEquals(CacheUtil.S4, chIdx)) {
            if (ChannelFactory.isChOpen(ChannelFactory.S4)) {
                CacheUtil.get().setValueLevelSerials(CacheUtil.S4);
            } else {
                return;
            }
        }
        int src = TChan.toFpgaChNo(chIdx);
        Channel channel = ChannelFactory.getDynamicChannel(src);
        if (channel != null) {
            double vol1 = Tools.getYTLevelCache(CacheUtil.VALUE_CHANNEL + chIdx);
            if (isM429(chIdx)) {
                channel.setBusSecondaryLevel(vol1);
            } else {
                channel.setBusPrimaryLevel(vol1);
            }
//            Logger.i(TAG, "bus: ch" + (src - ChannelFactory.CH1 + 1) + "=" + vol1);
            double vol2 = Tools.getYTLevelCache(CacheUtil.VALUE_CHANNEL_H + chIdx);
            if (isM429(chIdx)) {
                channel.setBusPrimaryLevel(vol2);
            } else {
                channel.setBusSecondaryLevel(vol2);
            }
//            Logger.i(TAG, "bus: ch" + (src - ChannelFactory.CH1 + 1) + " second=" + vol2);
        }
        CacheUtil.get().setValueLevelSerials(0);
    }

    private boolean isM429(int chIdx) {//这里chIdx=IWave.ch1~ch4
        return (CacheUtil.get().getInt(CacheUtil.RIGHT_SLIP_SERIALS + CacheUtil.S1) == RightLayoutSerials.SERIALS_M429
                && CacheUtil.get().getInt(CacheUtil.RIGHT_SLIP_SERIALS_M429_SOURCE + CacheUtil.S1) == chIdx - 1)
                ||
                (CacheUtil.get().getInt(CacheUtil.RIGHT_SLIP_SERIALS + CacheUtil.S2) == RightLayoutSerials.SERIALS_M429
                        && CacheUtil.get().getInt(CacheUtil.RIGHT_SLIP_SERIALS_M429_SOURCE + CacheUtil.S2) == chIdx - 1)
                ||
                (CacheUtil.get().getInt(CacheUtil.RIGHT_SLIP_SERIALS + CacheUtil.S3) == RightLayoutSerials.SERIALS_M429
                        && CacheUtil.get().getInt(CacheUtil.RIGHT_SLIP_SERIALS_M429_SOURCE + CacheUtil.S3) == chIdx - 1)
                ||
                (CacheUtil.get().getInt(CacheUtil.RIGHT_SLIP_SERIALS + CacheUtil.S4) == RightLayoutSerials.SERIALS_M429
                        && CacheUtil.get().getInt(CacheUtil.RIGHT_SLIP_SERIALS_M429_SOURCE + CacheUtil.S4) == chIdx - 1)
                ;
    }

    private boolean isCurChannelEquals(int serialsNumber, int tCh) {
        int busType = CacheUtil.get().getInt(CacheUtil.RIGHT_SLIP_SERIALS + serialsNumber);
        switch (busType) {
            case CacheUtil.UART: {
                int ch = CacheUtil.get().getInt(CacheUtil.RIGHT_SLIP_SERIALS_UART_RX + serialsNumber);
                return ch == tCh;
            }
            case CacheUtil.LIN: {
                int ch = CacheUtil.get().getInt(CacheUtil.RIGHT_SLIP_SERIALS_LIN_SOURCE + serialsNumber);
                return ch == tCh;
            }
            case CacheUtil.CAN: {
                int ch = CacheUtil.get().getInt(CacheUtil.RIGHT_SLIP_SERIALS_CAN_SOURCE + serialsNumber);
                return ch == tCh;
            }
            case CacheUtil.SPI: {
                int chClk = CacheUtil.get().getInt(CacheUtil.RIGHT_SLIP_SERIALS_SPI_CLK + serialsNumber);
                int chData = CacheUtil.get().getInt(CacheUtil.RIGHT_SLIP_SERIALS_SPI_DATA + serialsNumber);
                int chCs = CacheUtil.get().getInt(CacheUtil.RIGHT_SLIP_SERIALS_SPI_CS + serialsNumber);
                boolean csSwitch = CacheUtil.get().getBoolean(CacheUtil.RIGHT_SLIP_SERIALS_SPI_CSSWITCH + serialsNumber);
                return tCh == chClk || tCh == chData || (csSwitch && tCh == chCs);
            }
            case CacheUtil.I2C: {
                int chSda = CacheUtil.get().getInt(CacheUtil.RIGHT_SLIP_SERIALS_I2C_SDA + serialsNumber);
                int chScl = CacheUtil.get().getInt(CacheUtil.RIGHT_SLIP_SERIALS_I2C_SCL + serialsNumber);
                return tCh == chSda || tCh == chScl;
            }
            case CacheUtil.M429: {
                int ch = CacheUtil.get().getInt(CacheUtil.RIGHT_SLIP_SERIALS_M429_SOURCE + serialsNumber);
                return ch == tCh;
            }
            case CacheUtil.M1553B: {
                int ch = CacheUtil.get().getInt(CacheUtil.RIGHT_SLIP_SERIALS_M1553B_SOURCE + serialsNumber);
                return ch == tCh;
            }
        }
        return false;
    }

    MsgWaveToLevel msgWaveToLevel = new MsgWaveToLevel(MsgWaveToLevel.LEVELTYPE_TRIGGER, TChan.Ch1);

    private void sendMsgWaveToLevel(int levelType, int ch) {
        msgWaveToLevel.setLevelType(levelType);
        msgWaveToLevel.setCurCh(ch);
        RxBus.getInstance().post(RxEnum.WAVE_TO_LEVEL, msgWaveToLevel);
    }

