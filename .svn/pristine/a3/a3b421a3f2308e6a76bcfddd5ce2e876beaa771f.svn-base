public class WaveManage implements IWorkMode, IWaveManage {
    private static final String TAG = "WaveManage";

    //region 单例
    private static final class WaveManageHolder {
        public static final WaveManage instance = new WaveManage();
    }

    public static WaveManage get() {
        return WaveManageHolder.instance;
    }
    //endregion

    private WaveManage_XY waveManage_xy;
    private WaveManage_YT waveManage_yt;
    private MainViewGroup mainViewGroup;

    private WaveManage() {
        waveManage_xy = new WaveManage_XY(onMovingWaveEvent, onSelectChangeEvent);
        waveManage_yt = new WaveManage_YT(onMovingWaveEvent, onSelectChangeEvent);
        RxBus.getInstance().getObservable(RxEnum.MAIN_LOAD_CACHE).subscribe(consumerLoadCache);
        RxBus.getInstance().getObservable(RxEnum.MAIN_LOAD_CACHE_EX).subscribe(consumerLoadCacheEx);
        RxBus.getInstance().getObservable(RxEnum.WAVEZONE_WORKMODE_CHANGE).subscribe(consumerWorkModeChange);
        RxBus.getInstance().getObservable(RxEnum.RIGHTLAYOUT_SERIALS).subscribe(consumerRightSerials);
        EventFactory.addEventObserver(EventFactory.EVENT_CHANNEL_POS, eventUIObserver);
        EventFactory.addEventObserver(EventFactory.EVENT_MATH_VPOS, eventUIObserver);
        EventFactory.addEventObserver(EventFactory.EVENT_REF_VPOS, eventUIObserver);
        EventFactory.addEventObserver(EventFactory.EVENT_WAVE_LABEL_SELECT,eventUIObserver);
        EventFactory.addEventObserver(EventFactory.EVENT_WAVE_LABEL_MOVE, eventUIObserver);

    }

    private Consumer<RightMsgSerials> consumerRightSerials = new Consumer<RightMsgSerials>() {

        @Override
        public void accept(RightMsgSerials rightMsgSerials) throws Exception {
            if(!rightMsgSerials.isFromEventBus()) {
                ChannelFactory.forEachCh(channel -> {
                    changeSerialTrigVol_channel(channel.getChId());
                });
            }
        }
    };

    public void setWaveTextureView(PreviewTextureView waveTextureView) {
        waveManage_yt.setWaveTextureView(waveTextureView);
    }

    /**
     * 设置点选功能使能
     */
    public void setClickSelectEnable(boolean clickSelectEnable) {
        waveManage_yt.setClickSelectEnable(clickSelectEnable);
    }

    public void setWaveChange(int height) {
        WaveMaskLayer_YTZoom.getInstance().changeZoomH(height >> 2);
        waveManage_yt.setWaveChange(height);
//        waveManage_xy.setWaveChange(height);
        TChan.foreachChan(this::setOffset);
        TChan.foreachRef(this::setRefOffset);
        TChan.foreachMath(this::setMathOffset);

    }

    public void changeChannelColor(int chIndex, String colorStr) {
        waveManage_yt.changeColor(chIndex, colorStr);

    }

    public void init(MainViewGroup mainViewGroup) {
        this.mainViewGroup = mainViewGroup;
    }

    private Consumer<LoadCache> consumerLoadCache = new Consumer<LoadCache>() {
        @Override
        public void accept(LoadCache loadCache) throws Exception {
            setCache();
            CacheUtil.get().setLoadMenuState(CacheUtil.LOAD_WaveManage, true);
        }
    };

    private Consumer<LoadCache> consumerLoadCacheEx = new Consumer<LoadCache>() {
        @Override
        public void accept(LoadCache loadCache) throws Exception {
            setCache();
            TChan.foreachChan(chan -> {
                setOffset(chan);
            });
            TChan.foreachRef(refChan -> {
                setRefOffset(refChan);
            });
            TChan.foreachMath(mathChan -> {
                setMathOffset(mathChan);
            });
        }
    };

    private void setCache() {

        int curWorkMode = WorkModeManage.getInstance().getmWorkMode();
        if(curWorkMode != IWorkMode.WorkMode_XY) {
            TChan.foreachChan((chNo)->{
                Channel ch = ChannelFactory.getDynamicChannel(TChan.toFpgaChNo(chNo));
                if (ch != null) {
                    int val = Scope.vSpanOfView(ch.getResistanceType(),ch.getVScaleVal() / ch.getProbeRate());
                    ch.setVRange(-val, val);
                }

            });
            TChan.foreachRef((chan)->{
                setPositionY(chan, Tools.getYTChannelPositionUI(chan));
            });
            TChan.foreachChan((chNo)->{
                Channel ch = ChannelFactory.getDynamicChannel(TChan.toFpgaChNo(chNo));
                if (ch!=null){
                    ch.setPos(Tools.getYTChannelPosition(chNo));
                }
                setPositionY(chNo,Tools.getYTChannelPositionUI(chNo));
            });
            TChan.foreachMath((mathNo)->{
                MathChannel math = ChannelFactory.getMathChannel(TChan.toFpgaChNo(mathNo));
                if (math!=null && math.getPosUI()!=Tools.getYTChannelPosition(mathNo)){
                    math.setPos(Tools.getYTChannelPosition(mathNo));
                }
                setPositionY(mathNo,Tools.getYTChannelPositionUI(mathNo));
            });
            TChan.foreachRef((refNo)->{
                RefChannel ref = ChannelFactory.getRefChannel(TChan.toFpgaChNo(refNo));
                if (ref!=null){
                    ref.setPos(Tools.getYTChannelPosition(refNo));
                }
            });
        }

        WorkModeManage.getInstance().setWorkModeOnlyChangeData(WorkMode_XY);
        waveManage_xy.setPositionY(TChan.Ch1, CacheUtil.get().getDouble(CacheUtil.MAIN_WAVE_CH_XY_POSITION + TChan.Ch1));
        DisplayXYService.getInstance().setX(ScopeBase.getXYWidth() / 2 - (int) waveManage_xy.getPositionY(TChan.Ch1));
        waveManage_xy.setPositionY(TChan.Ch2, CacheUtil.get().getDouble(CacheUtil.MAIN_WAVE_CH_XY_POSITION + TChan.Ch2));
        DisplayXYService.getInstance().setY(ScopeBase.getXYWidth() / 2 - (int) waveManage_xy.getPositionY(TChan.Ch2));
        WorkModeManage.getInstance().setWorkModeOnlyChangeData(curWorkMode);
    }

    private void setMathWaveVScaleId(int mathChan) {
        int mathType = CacheUtil.get().getInt(CacheUtil.RIGHT_SLIP_MATH_TYPE + mathChan);
        MathChannel mathChannel = ChannelFactory.getMathChannel(TChan.toFpgaChNo(mathChan));
        if (mathChannel == null) return;
        if (mathType == CacheUtil.MATHTYPE_AXB) {
            MathExprWave exprWave = mathChannel.getMathExprWave();
            exprWave.setVScaleId(CacheUtil.get().getInt(CacheUtil.MAIN_RIGHT_MATH_AXB_VSCALE_ID + mathChan));
        } else if (mathType == CacheUtil.MATHTYPE_DW) {
            MathDualWave dualWave = mathChannel.getMathDualWave();
            dualWave.setVScaleId(CacheUtil.get().getInt(CacheUtil.MAIN_RIGHT_MATH_DW_VSCALE_ID + mathChan));
        } else if (mathType == CacheUtil.MATHTYPE_AM) {
            MathExprWave exprWave = mathChannel.getMathExprWave();
            exprWave.setVScaleId(CacheUtil.get().getInt(CacheUtil.MAIN_RIGHT_MATH_AM_VSCALE_ID + mathChan));
        } else {
            if (CacheUtil.get().getInt(CacheUtil.RIGHT_SLIP_MATH_FFT_TYPE_ID + mathChan) == 1) {
                MathFFTWave mathFFTWave = mathChannel.getMathFFTWave();
                mathFFTWave.setVScaleId(CacheUtil.get().getInt(CacheUtil.MAIN_RIGHT_MATH_FFT_DB_VSCALE_ID + mathChan));
            } else {
                MathFFTWave mathFFTWave = mathChannel.getMathFFTWave();
                mathFFTWave.setVScaleId(CacheUtil.get().getInt(CacheUtil.MAIN_RIGHT_MATH_FFT_RMS_VSCALE_ID + mathChan));
            }
        }
    }

    private Consumer<WorkModeBean> consumerWorkModeChange = new Consumer<WorkModeBean>() {
        @Override
        public void accept(WorkModeBean workModeBean) throws Exception {
            switch (workModeBean.getNextWorkMode()) {
                case IWorkMode.WorkMode_YT:
                case IWorkMode.WorkMode_YTZOOM:
                    waveManage_yt.refresh();
                    WaveGridManage.getInstance().refresh();
                    TChan.foreachChan(chan -> setOffset(chan));
                    TChan.foreachRef(refChan -> setRefOffset(refChan));
                    TChan.foreachMath(mathChan -> setMathOffset(mathChan));
                    break;
            }
        }
    };

    private boolean isSelectLabel = false;
    private int labelSelectChan = -1;
    private int isLabelTouchX = -1;//Label点击位置
    private int labelTouchLeft;//开始点击时的Label左边界

    private EventUIObserver eventUIObserver = new EventUIObserver() {
        @Override
        public void update(Object data) {
            EventBase eventBase = (EventBase) data;
            int id = eventBase.getId();
            if (id == EventFactory.EVENT_CHANNEL_POS) {
                for (int i = ChannelFactory.CH1; i < ChannelFactory.CH_CNT; i++) {
//                    if (!ChannelFactory.isChOpen(i)) continue;
                    Channel channel = ChannelFactory.getDynamicChannel(i);
                    if (channel == null) continue;
                    double y = ScopeBase.getNewHeight() / 2.0 - channel.getPosUI();
                    y = Tools.YT2Zoom(y);
//                    Log.d(Tag.Debug, String.format("WaveManage.update CHAN newHeight:%s,PosUI:%s,y:%s,channel:%s", ScopeBase.getNewHeight(), channel.getPosUI(), y, channel.getName()));
//                    Log.d(Tag.Debug, String.format("WaveManage.update: %s,%s",y,getPositionY(TChan.toUiChNo(i)) ));
                    if (y != getPositionY(TChan.toUiChNo(i))) {
                        setPositionYFromEventBus(TChan.toUiChNo(i), y);
                    }
                }
            } else if (id == EventFactory.EVENT_MATH_VPOS) {
//                int chIdx = (int) eventBase.getData();
//                if (ChannelFactory.isChOpen(chIdx)) {
                TChan.foreachMath(mathCh -> {
                    MathChannel mathChannel = ChannelFactory.getMathChannel(TChan.toFpgaChNo(mathCh));
                    if (mathChannel != null) {
                        double y = ScopeBase.getNewHeight() / 2.0 - mathChannel.getPosUI();
                        y = Tools.YT2Zoom(y);
//                        Log.d(Tag.Debug, String.format("WaveManage.update newHeight:%s,PosUI:%s,y:%s,channel:%s\"", ScopeBase.getNewHeight(), mathChannel.getPosUI(), y, mathChannel.getName()));
                        if (y != getPositionY(mathCh)) {
                            setPositionYFromEventBus(mathCh, y);
                        }
                    }
                });
//                }
            } else if (id == EventFactory.EVENT_REF_VPOS) {
                TChan.foreachRef((ref)->{
                    int fpgaRef=TChan.toFpgaChNo(ref);
//                    if (ChannelFactory.isChOpen(fpgaRef)) {
                        double y = ScopeBase.getNewHeight() / 2.0 - ChannelFactory.getRefChannel(fpgaRef).getPosUI();
                        y = Tools.YT2Zoom(y);
                        if (y != getPositionY(ref)) {
                            setPositionYFromEventBus(ref, y);
                        }
//                    }
                });
            } else if (id == EventFactory.EVENT_WAVE_LABEL_SELECT) {//点击选中label
                String point = (String) eventBase.getData();
                String[] temp = point.split(";");
                isSelectLabel = waveManage_yt.isLabelContains(Integer.parseInt(temp[0]), Integer.parseInt(temp[1]));
                labelSelectChan = waveManage_yt.getLabelSelectChan();
                isLabelTouchX = Integer.parseInt(temp[0]);
                labelTouchLeft = waveManage_yt.getLabelRect(labelSelectChan).left;
                Logger.i("WaveManage touch x= " + Integer.parseInt(temp[0]) + " ,y= " + Integer.parseInt(temp[1]) + " ,isLabelContains= " + isSelectLabel);
            } else if (id == EventFactory.EVENT_WAVE_LABEL_MOVE) {//左右滑动label
                String point = (String) eventBase.getData();
                String[] temp = point.split(";");
                if (isSelectLabel && isLabelTouchX != Integer.parseInt(temp[0])) {
                    Logger.i("WaveManage move deltaX= " + (Integer.parseInt(temp[0]) - isLabelTouchX) + " ,labelRect.left= " + labelTouchLeft + " ,isLabelTouchX= " + isLabelTouchX);
                    waveManage_yt.changeLabelPos(labelSelectChan, labelTouchLeft + Integer.parseInt(temp[0]) - isLabelTouchX);
                }
            }
        }
    };

    MainRightLayoutItemChannelBranch ch1Branch, ch2Branch, ch3Branch, ch4Branch, mathBranch, refBranch, s1Branch, s2Branch;
    MainRightLayoutItemChannelMaster ch1Master, ch2Master, ch3Master, ch4Master,ch5Master,ch6Master,ch7Master,ch8Master;
    MainRightLayoutItemChannelMaster ref1Master, ref2Master, ref3Master, ref4Master, ref5Master, ref6Master, ref7Master, ref8Master;
    MainRightLayoutItemChannelMaster math1Master, math2Master, math3Master, math4Master, math5Master, math6Master, math7Master, math8Master;

    LeftPositionView leftPositionView;

    private IWave.OnMovingWaveEvent onMovingWaveEvent = new IWave.OnMovingWaveEvent() {
        @Override
        public void OnMovingWave(IWave iWave, long x, double y, boolean isSwitchWorkMode, boolean isFromEventBus) {

            switch (WorkModeManage.getInstance().getmWorkMode()) {
                case IWorkMode.WorkMode_XY: {
                    switch (iWave.getLineNameID()) {
                        case TChan.Ch1:
                        case TChan.Ch3:
                        case TChan.Ch5:
                        case TChan.Ch7:
                            if (!isFromEventBus) {
                                DisplayXYService.getInstance().setX(ScopeBase.getXYWidth() / 2 - (int) x);
                            }
                            CacheUtil.get().putMap(CacheUtil.MAIN_WAVE_CH_XY_POSITION + iWave.getLineNameID(), String.valueOf(x));
                            break;
                        case TChan.Ch2:
                        case TChan.Ch4:
                        case TChan.Ch6:
                        case TChan.Ch8:
                            if (!isFromEventBus) {
                                DisplayXYService.getInstance().setY(ScopeBase.getXYHeight() / 2 - (int) Math.round(y));
                            }
                            CacheUtil.get().putMap(CacheUtil.MAIN_WAVE_CH_XY_POSITION + iWave.getLineNameID(), String.valueOf(y));
                            break;
//                        case IWave.Ch3:
//                            if (!isFromEventBus) {
//                                DisplayXYService.getInstance().setX(ScopeBase.getXYWidth() / 2 - (int) x);
//                            }
//                            CacheUtil.get().putMap(CacheUtil.MAIN_WAVE_CH_XY_POSITION + iWave.getLineNameID(), String.valueOf(x));
//                            break;
//                        case IWave.Ch4:
//                            if (!isFromEventBus) {
//                                DisplayXYService.getInstance().setY(ScopeBase.getXYHeight() / 2 - y);
//                            }
//                            CacheUtil.get().putMap(CacheUtil.MAIN_WAVE_CH_XY_POSITION + iWave.getLineNameID(), String.valueOf(y));
//                            break;
                    }
                    if (!isSwitchWorkMode) {
                        CursorManage.getInstance().curChannelMove();
                    }
                }
                break;
                case IWorkMode.WorkMode_YT:
                case IWorkMode.WorkMode_YTZOOM:
                    if (leftPositionView == null) {
                        leftPositionView = (LeftPositionView) mainViewGroup.findViewById(R.id.leftPositionView);
                    }
                    int chIdx = iWave.getLineNameID();
                    Command.get().getChannel().setPosition(chIdx - 1, y);
                    Tools.putChannelPosition(chIdx, y);//这里是保存的像素位置
                    y = Tools.getYTChannelPosition(chIdx);//转换为正负偏移量
                    int idx = chIdx -1;
                    if(ChannelFactory.isDynamicCh(idx)){
                        if (!isFromEventBus) {
                            Channel channel = ChannelFactory.getDynamicChannel(idx);
                            if (channel != null) {
                                channel.setPos(y, true);
                            }
                        }
                        setOffset(chIdx);
                    }else if(ChannelFactory.isMathCh(idx)){
                        if (!isFromEventBus) {
                            MathChannel mathChannel = ChannelFactory.getMathChannel(idx);
                            if(mathChannel != null){
                                if (mathChannel.getPosUI() != y) {
                                    mathChannel.setPos(y);
                                }
                            }
                        }
//                        if (mathBranch == null) {
//                            mathBranch = (MainRightLayoutItemChannelBranch) mainViewGroup.findViewById(R.id.rightMathBranch);
//                        }
                        setMathOffset(TChan.toUiChNo(idx));
                    }else if(ChannelFactory.isRefCh(idx)){
                        if (!isFromEventBus) {
                            RefChannel refChannel = ChannelFactory.getRefChannel(idx);
                            if (refChannel != null && refChannel.getPosUI() != y) {
                                refChannel.setPos(y);
                            }
                        }
//                        if (refBranch == null) {
//                            refBranch = (MainRightLayoutItemChannelBranch) mainViewGroup.findViewById(R.id.rightRefBranch);
//                        }
//                        setRefOffset(refBranch, idx);
                        setRefOffset(TChan.toUiChNo(idx));
                    }




                    ITriggerLine triggerLine = VoltageLineManage.getInstance().getVoltageLine(VoltageLineManage.VoltageLineType_Trigger);
                    int curCh = iWave.getLineNameID();//1~4

                    if (ChannelFactory.isChActivate(TChan.toFpgaChNo(curCh)) && !isSwitchWorkMode)
                        CursorManage.getInstance().curChannelMove();

                    if (!TChan.isChan(curCh)) return;

                    double triggerChannelTempH = Tools.getLevelCache(CacheUtil.TRIGGER_CHANNEL_TEMP_H + curCh);
                    double triggerChannelTemp = Tools.getLevelCache(CacheUtil.TRIGGER_CHANNEL_TEMP + curCh);


                    if (triggerLine.getShowMode() == ITriggerLine.ShowMode_Two) {
                        if (iWave.getLineNameID() == triggerLine.getChannelId()) {
                            triggerLine.setOtherY(ITriggerLine.VoltageLine_High, getPositionY(curCh) - triggerChannelTempH);
                            triggerLine.setOtherY(ITriggerLine.VoltageLine_Low, getPositionY(curCh) - triggerChannelTemp);
                            Tools.putLevelCache(CacheUtil.TRIGGER_CHANNEL_H + curCh,
                                    getPositionY(curCh) - triggerLine.getOtherY(ITriggerLine.VoltageLine_High));
                            Tools.putLevelCache(CacheUtil.TRIGGER_CHANNEL + curCh,
                                   getPositionY(curCh) - triggerLine.getOtherY(ITriggerLine.VoltageLine_Low));
                            sendMsgWaveToLevel(MsgWaveToLevel.LEVELTYPE_TRIGGER, curCh);
                            Trigger trigger = TriggerFactory.getInstance().getTrigger();
                            if (trigger.isTriggerSource( TChan.toFpgaChNo(curCh))) {
                                trigger.getTriggerLevel(TriggerLevel.TRIGGER_LEVEL_LOW, TChan.toFpgaChNo(curCh))
                                        .setPos(Tools.getYTLevelCache(CacheUtil.TRIGGER_CHANNEL + curCh));
                                trigger.getTriggerLevel(TriggerLevel.TRIGGER_LEVEL_HIGH, TChan.toFpgaChNo(curCh))
                                        .setPos(Tools.getYTLevelCache(CacheUtil.TRIGGER_CHANNEL_H + curCh));
                            }
                        }
                    } else {
                        triggerLine.setOtherY(curCh, getPositionY(curCh) - triggerChannelTemp);

                        Tools.putLevelCache(CacheUtil.TRIGGER_CHANNEL + curCh, getPositionY(curCh) - triggerLine.getOtherY(curCh));
                        sendMsgWaveToLevel(MsgWaveToLevel.LEVELTYPE_TRIGGER, curCh);
                        Trigger trigger = TriggerFactory.getInstance().getTrigger();
                        if (trigger.isTriggerSource(TChan.toFpgaChNo(curCh))) {
                            if(!isFromEventBus) {
                                trigger.getTriggerLevel(TriggerLevel.TRIGGER_LEVEL_LOW, TChan.toFpgaChNo(curCh))
                                        .setPos(Tools.getYTLevelCache(CacheUtil.TRIGGER_CHANNEL + curCh));
                            }
                        }
                    }
                    int serials = 0;
                    boolean s1 = CacheUtil.get().getBoolean(CacheUtil.MAIN_RIGHT_SERIAL + CacheUtil.S1);
                    boolean s2 = CacheUtil.get().getBoolean(CacheUtil.MAIN_RIGHT_SERIAL + CacheUtil.S2);
                    boolean s3 = CacheUtil.get().getBoolean(CacheUtil.MAIN_RIGHT_SERIAL + CacheUtil.S3);
                    boolean s4 = CacheUtil.get().getBoolean(CacheUtil.MAIN_RIGHT_SERIAL + CacheUtil.S4);
                    if (s1 || s2 || s3 || s4) {
                        SerialChannel serialChannel;
                        int maxIdx = ChannelFactory.getMaxSerialIdx();
                        for (int i = ChannelFactory.S1; i < maxIdx; i++) {
                            serialChannel = ChannelFactory.getSerialChannel(i);
                            if (serialChannel != null && serialChannel.isOpen()) {
                                IBus bus = serialChannel.getBus();
                                if (bus != null && bus.isChInSample(TChan.toFpgaChNo(curCh))) {
                                    serials = CacheUtil.S1 + (i - ChannelFactory.S1);
                                    break;
                                }
                            }
                        }
                    }
//                    Logger.e("limh", "serials= " + serials);
                    if(serials == 0) break;
                    if (serials == CacheUtil.S1) {
                        CacheUtil.get().setValueLevelSerials(CacheUtil.S1);
                        double valueChannelTempH = Tools.getLevelCache(CacheUtil.VALUE_CHANNEL_TEMP_H + curCh);
                        double valueChannelTemp = Tools.getLevelCache(CacheUtil.VALUE_CHANNEL_TEMP + curCh);
                        int i = 0;
                        ITriggerLine valueLine = VoltageLineManage.getInstance().getVoltageLine(VoltageLineManage.VoltageLineType_Value1);
                        ITriggerLine valueLine2 = VoltageLineManage.getInstance().getVoltageLine(VoltageLineManage.VoltageLineType_Value2);
                        ITriggerLine valueLine3 = VoltageLineManage.getInstance().getVoltageLine(VoltageLineManage.VoltageLineType_Value3);
                        ITriggerLine valueLine4 = VoltageLineManage.getInstance().getVoltageLine(VoltageLineManage.VoltageLineType_Value4);
                        boolean s2M429 = CacheUtil.get().getInt(CacheUtil.RIGHT_SLIP_SERIALS + CacheUtil.S2) == CacheUtil.M429;
                        boolean s3M429 = CacheUtil.get().getInt(CacheUtil.RIGHT_SLIP_SERIALS + CacheUtil.S3) == CacheUtil.M429;
                        boolean s4M429 = CacheUtil.get().getInt(CacheUtil.RIGHT_SLIP_SERIALS + CacheUtil.S4) == CacheUtil.M429;
                        int levelType = MsgWaveToLevel.LEVELTYPE_VALUE1;
                        if (CacheUtil.get().getInt(CacheUtil.RIGHT_SLIP_SERIALS + CacheUtil.S1) == CacheUtil.M429) {
                            valueLine.setShowMode(ITriggerLine.ShowMode_Two);
                            if (s2M429) {
                                valueLine2.setShowMode(ITriggerLine.ShowMode_Two);
                            } else {
                                valueLine2.setShowMode(ITriggerLine.ShowMode_One);
                            }
                            if (s3M429) {
                                valueLine3.setShowMode(ITriggerLine.ShowMode_Two);
                            } else {
                                valueLine3.setShowMode(ITriggerLine.ShowMode_One);
                            }
                            if (s4M429) {
                                valueLine4.setShowMode(ITriggerLine.ShowMode_Two);
                            } else {
                                valueLine4.setShowMode(ITriggerLine.ShowMode_One);
                            }
                            if (iWave.getLineNameID() == valueLine.getChannelId()) {
                                if (s2M429) {
                                    if(valueLine2.getChannelId() == curCh) {
