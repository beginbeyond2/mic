    @Override
    public void draw(ICanvasGL canvas) {
        switch (WorkModeManage.getInstance().getmWorkMode()) {
            case IWorkMode.WorkMode_XY:
                waveManage_xy.draw(canvas);
                break;
            case IWorkMode.WorkMode_YT:
            case IWorkMode.WorkMode_YTZOOM:
                waveManage_yt.draw(canvas);
                break;
        }
    }

    @Override
    public void setVisible(int ChNo, boolean visible) {
        switch (WorkModeManage.getInstance().getmWorkMode()) {
            case IWorkMode.WorkMode_XY:
                waveManage_xy.setVisible(ChNo, visible);
                waveManage_yt.setVisible(ChNo, visible);
                break;
            case IWorkMode.WorkMode_YT:
            case IWorkMode.WorkMode_YTZOOM:
                if (TChan.isSerial(ChNo)) {
                    SerialBusManage.getInstance().setVisible(ChNo, visible);
                } else {
                    waveManage_yt.setVisible(ChNo, visible);
                }

                break;
        }
    }

