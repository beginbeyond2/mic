    private static final int MSG_TRIGGERLINE_VISIABLE = 1;
    private static final int MSG_TRIGGERLINE_GONE = 2;
    private static final int MSG_VALUELINE1_VISIABLE = 3;
    private static final int MSG_VALUELINE1_GONE = 4;
    private static final int MSG_VALUELINE2_VISIABLE = 5;
    private static final int MSG_VALUELINE2_GONE = 6;
    private Handler handler = new Handler() {
        @Override
        public void handleMessage(Message msg) {
            super.handleMessage(msg);
            switch (msg.what) {
                case MSG_TRIGGERLINE_VISIABLE:
                    if (handler.hasMessages(MSG_TRIGGERLINE_GONE)) {
                        handler.removeMessages(MSG_TRIGGERLINE_GONE);
                    }
                    handler.sendEmptyMessageDelayed(MSG_TRIGGERLINE_GONE, 100);
                    break;
                case MSG_TRIGGERLINE_GONE:
                    VoltageLineManage.getInstance().getVoltageLine(VoltageLineManage.VoltageLineType_Trigger).setVisibleLine(false);
                    break;
                case MSG_VALUELINE1_VISIABLE:
                    if (handler.hasMessages(MSG_VALUELINE1_GONE)) {
                        handler.removeMessages(MSG_VALUELINE1_GONE);
                    }
                    handler.sendEmptyMessageDelayed(MSG_VALUELINE1_GONE, 100);
                    break;
                case MSG_VALUELINE1_GONE:
                    VoltageLineManage.getInstance().getVoltageLine(VoltageLineManage.VoltageLineType_Value1).setVisibleLine(false);
                    break;
                case MSG_VALUELINE2_VISIABLE:
                    if (handler.hasMessages(MSG_VALUELINE2_GONE)) {
                        handler.removeMessages(MSG_VALUELINE2_GONE);
                    }
                    handler.sendEmptyMessageDelayed(MSG_VALUELINE2_GONE, 100);
                    break;
                case MSG_VALUELINE2_GONE:
                    VoltageLineManage.getInstance().getVoltageLine(VoltageLineManage.VoltageLineType_Value2).setVisibleLine(false);
                    break;
            }
        }
    };

    //region interface IWorkMode
    @Override
    public void switchWorkMode(@WorkMode int workMode) {
        switch (workMode) {
            case IWorkMode.WorkMode_XY:
                waveManage_xy.switchWorkMode(workMode);
                break;
            case IWorkMode.WorkMode_YT:
            case IWorkMode.WorkMode_YTZOOM:
                waveManage_yt.switchWorkMode(workMode);
                break;
        }
    }

