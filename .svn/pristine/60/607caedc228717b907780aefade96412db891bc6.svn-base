package com.micsig.tbook.scope.fpga;

public class FPGAReg_SPI_Read  extends FPGAReg{

    public FPGAReg_SPI_Read() {
        super(FPGA_SPI_R, 4);
    }
    public final static int SPI_EXT_PLL = (1<<0);
    public final static int SPI_EXT_AD = (1<<1);
    public final static int SPI_EXT_CHCTRL = (1<<2);
    public final static int SPI_EXT_CHGAIN = (1<<3);
    public final static int SPI_EXT_UART = (1<<4);


    public void setType(int t){
        setVal(0,0);
        setVal(0,0,8,t);
    }

    public void setDataLength(int len){
        setVal(0,24,6,len);
    }
    public void setByteValid(int n){
        setVal(0,30,2,n);
    }


}
