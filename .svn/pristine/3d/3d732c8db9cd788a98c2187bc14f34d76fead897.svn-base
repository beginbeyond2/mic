<?xml version="1.0" encoding="utf-8"?>
<AbsoluteLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    >

    <View
        android:id="@+id/outView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <View
        android:layout_width="@dimen/rightChannelDialogWidth"
        android:layout_height="@dimen/rightDialogHeight"
        android:layout_x="@dimen/rightChannelDialogX"
        android:layout_y="@dimen/newRightDialogY"
        android:background="@color/color_Enable"
        />
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="@dimen/rightChannelDialogWidth"
        android:layout_height="wrap_content"
        android:layout_x="@dimen/rightChannelDialogX"
        android:layout_y="@dimen/newRightDialogY"
        android:background="@drawable/shape_frame_bg_black"
        android:paddingTop="7px"
        android:paddingBottom="20px"
        android:paddingStart="5px"
        android:paddingEnd="5px">
        <View
            android:id="@+id/backgroundView"
            android:layout_width="0dp"
            android:layout_height="48px"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintLeft_toLeftOf="@id/divider2"
            app:layout_constraintRight_toRightOf="@id/divider2"
            android:layout_marginTop="5px"
            android:layout_marginBottom="5px"
            android:background="@drawable/shape_frame_bg_black"
            />
        <TextView
            android:id="@+id/modelName"
            style="@style/textStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toTopOf="@+id/backgroundView"
            app:layout_constraintBottom_toBottomOf="@+id/backgroundView"
            android:layout_marginStart="26px"
            android:text="Model:dp750"
            />
        <TextView
            android:id="@+id/SN"
            style="@style/textStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="@+id/backgroundView"
            app:layout_constraintBottom_toBottomOf="@+id/backgroundView"
            app:layout_constraintRight_toRightOf="parent"
            android:layout_marginRight="26px"
            android:text="SN:32000001"
            />
        <View
            android:id="@+id/divider2"
            android:layout_width="match_parent"
            android:layout_height="2px"
            android:layout_marginTop="16px"
            android:layout_marginStart="21px"
            android:layout_marginEnd="21px"
            android:background="@drawable/bg_right_layout_divider"
            app:layout_constraintTop_toBottomOf="@id/backgroundView"
            android:visibility="gone"
            />
        
        <TextView
            android:id="@+id/lblType"
            style="@style/textStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/probe_Type"
            app:layout_constraintTop_toTopOf="@id/ProbeType"
            app:layout_constraintBottom_toBottomOf="@id/ProbeType"
            app:layout_constraintLeft_toLeftOf="parent"
            android:layout_marginStart="21px"
            android:visibility="gone"
            />

        <com.micsig.tbook.ui.rightslipmenu.RightViewSelect
            android:id="@+id/ProbeType"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@id/divider2"
            app:layout_constraintRight_toRightOf="parent"
            android:layout_marginStart="40px"
            android:layout_marginTop="24px"
            android:layout_marginEnd="21px"
            app:array="@array/Probe_Type"
            app:arrayOrientation="horizontalEachRow2"
            app:itemStartAndEndBgHalfCorner="true"
            app:itemHalfCornerEach="each_120_60"
            app:itemHeight="60px"
            app:itemWidth="120px"
            android:visibility="gone"
            />


        <View
            android:id="@+id/divider3"
            android:layout_width="match_parent"
            android:layout_height="2px"
            android:layout_marginTop="16px"
            android:layout_marginStart="21px"
            android:layout_marginEnd="21px"
            android:background="@drawable/bg_right_layout_divider"
            app:layout_constraintTop_toBottomOf="@id/ProbeType"
            />

        <TextView
            android:id="@+id/lblCal"
            style="@style/textStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/probe_calibration"
            app:layout_constraintTop_toTopOf="@id/btnCal"
            app:layout_constraintBottom_toBottomOf="@id/btnCal"
            app:layout_constraintLeft_toLeftOf="parent"
            android:layout_marginStart="21px"
            />
        <Button
            android:id="@+id/btnCal"
            style="@style/buttonStyle"
            android:layout_width="132px"
            android:layout_height="60px"
            android:text="@string/probe_calibration"
            app:layout_constraintTop_toBottomOf="@id/divider3"
            app:layout_constraintRight_toRightOf="parent"
            android:layout_marginRight="21px"
            android:layout_marginTop="24px"
            />

        <View
            android:id="@+id/divider4"
            android:layout_width="match_parent"
            android:layout_height="2px"
            android:layout_marginTop="16px"
            android:layout_marginStart="21px"
            android:layout_marginEnd="21px"
            android:background="@drawable/bg_right_layout_divider"
            app:layout_constraintTop_toBottomOf="@id/btnCal"
            app:layout_goneMarginTop="24px"
            />

        <TextView
            android:id="@+id/lblBandWidth"
            style="@style/textStyle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/channelBandWidth"
            app:layout_constraintTop_toBottomOf="@id/divider4"
            app:layout_constraintLeft_toLeftOf="parent"
            android:layout_marginTop="5px"
            android:layout_marginStart="21px"
            />
        <com.micsig.tbook.ui.rightslipmenu.RightViewSelect
            android:id="@+id/bandWidth"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="21px"
            android:layout_marginEnd="11px"
            app:array="@array/channelBandWidth"
            app:arrayOrientation="horizontalEachRow3"
            app:itemMargin="8px"
            app:itemHeight="68px"
            app:itemWidth="136px"
            app:layout_constraintTop_toBottomOf="@id/lblBandWidth"
            app:layout_constraintLeft_toLeftOf="parent"

            />


    </androidx.constraintlayout.widget.ConstraintLayout>
</AbsoluteLayout>