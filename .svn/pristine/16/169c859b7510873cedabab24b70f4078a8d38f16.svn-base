    public void calcPgaStep(int flag){
        hw.calcPgaSetp(flag);
    }
    public void calcGain(int flag){
        hw.calcGain(flag);
    }


    private double [] newInputV = {-1,-1,-1,-1,-1,-1,-1,-1};

    private double [] chAmpV = {-1,-1,-1,-1,-1,-1,-1,-1};

    public synchronized void setChAmp(int ch,double v){
        if(ch >= 0 && ch < chAmpV.length) {
            chAmpV[ch] = v;
        }
    }
    public synchronized double getChAmp(int ch){
        return chAmpV[ch];
    }
    public void setNewInputV(double v){
        synchronized (this){
            Arrays.fill(newInputV,v);
        }
    }
    public void setNewInputV(double [] v){
        synchronized (this){
            if(v.length == newInputV.length){
                System.arraycopy(v,0,newInputV,0,v.length);
            }
        }
    }
    public double getNewInputV(int ch){
        synchronized (this){
            if(ch >=0 && ch < newInputV.length) {
                return newInputV[ch];
            }else{
                return -1;
            }
        }
    }
}
