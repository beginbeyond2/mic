    }

    public synchronized void saveCalibrationStateParam(){

        if(!mHandler.hasMessages(SAVE_STATE_PARAM)){
            mHandler.sendEmptyMessage(SAVE_STATE_PARAM);
        }
    }
    public synchronized void loadCalibrationState(){
        hw.loadCalibrationState();
    }

    private static volatile CabteRegister instance = null;


    public static CabteRegister getInstance(Context context) {
        if (instance == null) {
            synchronized (CabteRegister.class) {
                if (instance == null && context != null) {
                    instance = new CabteRegister(context);
                    instance.verifyAll();

                }
            }
        }
        return instance;
    }
    public static CabteRegister getInstance() {
        return instance;
    }
//    private CabteRegisterBean cabteRegister;
    private Context mContext;

    private HandlerThread handlerThread;
    private Handler mHandler;

    private static final int SAVE_FACTORY_PARAM = 0x1001;
    private static final int SAVE_USER_PARAM = SAVE_FACTORY_PARAM + 1;

    private static final int SAVE_STATE_PARAM = SAVE_USER_PARAM + 1;
    private CabteRegister(Context context){

        mContext = context;
        //cabteRegister = new CabteRegisterBean(context);
        hw = HwConfig.getInstance().getHW();
        hw.loadCalibration();
        hw.loadCalibrationState();
        handlerThread = new HandlerThread("CabteRegister");
        handlerThread.start();
        mHandler = new Handler(handlerThread.getLooper()){
            @Override
            public void handleMessage(@NonNull Message msg) {
                super.handleMessage(msg);
                switch (msg.what){
                    case SAVE_FACTORY_PARAM:
                        saveFactoryCalibrate();
                        saveUserCalibrate();
                        break;
                    case SAVE_USER_PARAM:
                        saveUserCalibrate();
                        break;
                    case SAVE_STATE_PARAM:
                        saveCalibrationState();
                        break;
                }
            }
        };
    }

    public float getChannelCoef(int chIdx,int dang,int idx){
        return hw.getChannelCoef(chIdx,dang,idx);
    }
    public void setChannelCoef(int chIdx,int dang,int idx,float val){
        hw.setChannelCoef(chIdx,dang,idx,val);
    }


    public synchronized void setChannelZero(int chIdx,int dwIdx,int pga,float val){
        hw.setChannelZero(chIdx,dwIdx,pga,val);
    }

    public synchronized float getChannelZero(int chIdx,int dwIdx,int pga) {
        return hw.getChannelZero(chIdx,dwIdx,pga);
    }



    public synchronized void setAdOffset(int chIdx,int chmode,int adIdx,int val){
