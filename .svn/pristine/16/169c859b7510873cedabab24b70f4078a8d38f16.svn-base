        return hw.vol_ChannelCoef_default(resistanceType,dang);
    }

    public static int getRatioIdx(int resistanceType,double v){
        return getInstance().getHw().getRatioIdx(resistanceType,v);
    }

    public static int getRatioIdx2Dang(int resistanceType,int idx){
        return getInstance().getHw().getRatioIdx2Dang(resistanceType,idx);
