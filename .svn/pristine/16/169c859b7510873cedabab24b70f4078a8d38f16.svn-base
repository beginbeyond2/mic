        hw.defaultVal_coefChannel(ch,dang,resistanceType);
    }

    public double calc_coefChannel(int chIdx,double scaleVal,int idx){
        double coef;
        coef = hw.calc_coefChannel(chIdx,scaleVal,idx);
        return coef;
    }

    public void calc_pga_fs_gain(int chIdx,double scaleVal,int []result){
        hw.calc_pga_fs_gain(chIdx,scaleVal,result);
    }


    public String getCabteTime(){
        return hw.getCabteTime();
    }


