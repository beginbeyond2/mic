public class FPGAReg_BUS_CAN extends FPGAReg_BUS {
    public FPGAReg_BUS_CAN(int addr) {
        super(addr,20);
    }
    public void setSrc(int val){
        setVal(0,2,val);
    }
    public void setISO(boolean bISO) { setVal(2,1,bISO?0:1);}
    public void setDlc(int val){
        setVal(4,4,val);
    }
    public void setTriggerMode(int val){
        setVal(8,4,val);
    }
    public void setBaudN(int val){
        setVal(16,4,val);
    }
    public void setBaudN2(int val){
        setVal(20,4,val);
    }
    public void setBaudN3(int val){
        setVal(24,4,val);
    }
    public void setId(int val){
        setVal(1,val);
    }
    public void setData(int idx,int val){
        setVal(idx+2,val);
    }
    public void setSamplePlace(int val){
        setVal(4,0,14,val);
    }
    public void setBaud(int val){
        setVal(4,14,14,val);
    }
    public void setSel(int val) { setVal(4,28,4,val); }
    public void setFDData(int idx,int val){
        setVal(2,0,16,val);
        setVal(2,16,16,idx);
    }
    public void setFDMask(int idx,int val){
        setVal(3,0,16,val);
        setVal(3,0,16,val);
    }

/*    void Bus_Can_setBaudRate(int bit_rate,int val,double s){

