<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <com.micsig.tbook.ui.top.view.radioGroup.TopViewRadioGroup
        android:id="@+id/triggerSource"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="45px"
        app:array="@array/triggerSource"
        app:head="@string/triggerSource" />

    <com.micsig.tbook.ui.top.view.radioGroup.TopViewRadioGroup
        android:id="@+id/polar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/triggerSource"
        android:layout_marginStart="45px"
        android:layout_marginTop="10px"
        app:array="@array/triggerPulsewidthPolar"
        app:head="@string/triggerPulsewidthPolar" />

    <com.micsig.tbook.ui.top.view.radioGroup.TopViewRadioGroup
        android:id="@+id/condition"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/polar"
        android:layout_marginStart="45px"
        android:layout_marginTop="10px"
        app:array="@array/triggerPulsewidthCondition"
        app:head="@string/triggerPulsewidthCondition" />

    <TextView
        android:id="@+id/pulsewidth"
        style="@style/editTextStyleRight"
        android:layout_width="120px"
        android:layout_height="60px"
        android:layout_alignBottom="@id/condition"
        android:layout_marginStart="40px"
        android:layout_marginBottom="0px"
        android:layout_toEndOf="@+id/condition"
        android:gravity="center"
        android:text="@string/view_trigger_pulsewidth" />

    <LinearLayout
        android:id="@+id/layoutPulseWidthTimeHigh"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/polar"
        android:layout_marginStart="35px"
        android:layout_marginTop="10px"
        android:layout_toEndOf="@+id/pulsewidth"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/owerangeTimeHead"
            style="@style/textStyle"
            android:layout_width="100px"
            android:layout_height="60px"
            android:layout_marginRight="14px"
            android:gravity="center_vertical|right"
            android:text="@string/triggerpulsewidth_timehigh" />

        <TextView
            android:id="@+id/timeHighDetail"
            style="@style/editTextStyleRight"
            android:layout_width="120px"
            android:layout_height="60px"
            android:layout_toEndOf="@+id/owerangeTimeHead"
            android:text="@string/view_trigger_pulsewidth" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutPulseWidthTimeLow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/polar"
        android:layout_marginStart="35px"
        android:layout_marginTop="10px"
        android:layout_toEndOf="@id/layoutPulseWidthTimeHigh"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/owerangeTimeLow"
            style="@style/textStyle"
            android:layout_width="100px"
            android:layout_height="60px"
            android:layout_marginRight="14px"
            android:gravity="center_vertical|right"
            android:text="@string/triggerpulsewidth_timelow" />

        <TextView
            android:id="@+id/timeLowDetail"
            style="@style/editTextStyleRight"
            android:layout_width="120px"
            android:layout_height="60px"
            android:text="@string/view_trigger_pulsewidth" />
    </LinearLayout>

</RelativeLayout>