package com.micsig.tbook.tbookscope.menu;

/**
 * Created by liwb on 2018/8/30.
 */

public class MainMsgSliderZone {
    public static final int MENUSLIP_LEFT = 0x01;
    public static final int MENUSLIP_TOP = MENUSLIP_LEFT + 1;
    public static final int MENUSLIP_BOTTOM = MENUSLIP_TOP + 1;
    public static final int MENUSLIP_CH1 = MENUSLIP_BOTTOM + 1;
    public static final int MENUSLIP_CH2 = MENUSLIP_CH1 + 1;
    public static final int MENUSLIP_CH3 = MENUSLIP_CH2 + 1;
    public static final int MENUSLIP_CH4 = MENUSLIP_CH3 + 1;
    public static final int MENUSLIP_CH5 = MENUSLIP_CH4 + 1;
    public static final int MENUSLIP_CH6 = MENUSLIP_CH5 + 1;
    public static final int MENUSLIP_CH7 = MENUSLIP_CH6 + 1;
    public static final int MENUSLIP_CH8 = MENUSLIP_CH7 + 1;
    public static final int MENUSLIP_MATH1 = MENUSLIP_CH8 + 1;
    public static final int MENUSLIP_MATH2 = MENUSLIP_MATH1 + 1;
    public static final int MENUSLIP_MATH3 = MENUSLIP_MATH2 + 1;
    public static final int MENUSLIP_MATH4 = MENUSLIP_MATH3 + 1;
    public static final int MENUSLIP_MATH5 = MENUSLIP_MATH4 + 1;
    public static final int MENUSLIP_MATH6 = MENUSLIP_MATH5 + 1;
    public static final int MENUSLIP_MATH7 = MENUSLIP_MATH6 + 1;
    public static final int MENUSLIP_MATH8 = MENUSLIP_MATH7 + 1;
    public static final int MENUSLIP_REF1 = MENUSLIP_MATH8 + 1;
    public static final int MENUSLIP_REF2 = MENUSLIP_REF1 + 1;
    public static final int MENUSLIP_REF3 = MENUSLIP_REF2 + 1;
    public static final int MENUSLIP_REF4 = MENUSLIP_REF3 + 1;
    public static final int MENUSLIP_REF5 = MENUSLIP_REF4 + 1;
    public static final int MENUSLIP_REF6 = MENUSLIP_REF5 + 1;
    public static final int MENUSLIP_REF7 = MENUSLIP_REF6 + 1;
    public static final int MENUSLIP_REF8 = MENUSLIP_REF7 + 1;

    public static final int MENUSLIP_S1 = MENUSLIP_REF8 + 1;
    public static final int MENUSLIP_S2 = MENUSLIP_S1 + 1;
    public static final int MENUSLIP_S3 = MENUSLIP_S2 + 1;
    public static final int MENUSLIP_S4 = MENUSLIP_S3 + 1;

    private int menuIndex;
    private boolean enableSlip;

    public MainMsgSliderZone(int menuIndex, boolean enableSlip) {
        this.menuIndex = menuIndex;
        this.enableSlip = enableSlip;
    }

    public int getMenuIndex() {
        return menuIndex;
    }

    public boolean isEnableSlip() {
        return enableSlip;
    }
}
