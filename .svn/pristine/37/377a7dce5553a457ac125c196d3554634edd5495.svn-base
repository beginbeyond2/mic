    {.pattern = ":BUS#:CAN:LEVel?", .callback = BUS_CAN_LEVQ,},
    {.pattern = ":BUS#:CAN:ISO", .callback = BUS_CAN_ISO,},
    {.pattern = ":BUS#:CAN:ISO?", .callback = BUS_CAN_ISOQ,},

    {.pattern=":BUS#:IIC:SDA",.callback=BUS_IIC_SDA},
    {.pattern=":BUS#:IIC:SDA?",.callback=BUS_IIC_SDAQ},
    {.pattern=":BUS#:IIC:SCL",.callback=BUS_IIC_SCL},
    {.pattern=":BUS#:IIC:SCL?",.callback=BUS_IIC_SCLQ},
    {.pattern =":BUS#:IIC:CLKLevel", .callback = BUS_IIC_LEVCLK,},
    {.pattern =":BUS#:IIC:CLKLevel?", .callback = BUS_IIC_LEVCLKQ,},
    {.pattern =":BUS#:IIC:DATLevel", .callback = BUS_IIC_LEVDAT,},
    {.pattern =":BUS#:IIC:DATLevel?", .callback = BUS_IIC_LEVDATQ,},

    {.pattern=":BUS#:1553B:SOURce",.callback=BUS_1553B_CHAN},
    {.pattern=":BUS#:1553B:SOURce?",.callback=BUS_1553B_CHANQ},
    {.pattern=":BUS#:1553B:DISPlay",.callback=BUS_1553B_DISP},
    {.pattern=":BUS#:1553B:DISPlay?",.callback=BUS_1553B_DISPQ},
    {.pattern = ":BUS#:1553B:LEVEl",.callback = BUS_1553B_LEV,},
    {.pattern = ":BUS#:1553B:LEVEl?",.callback = BUS_1553B_LEVQ,},

    {.pattern=":BUS#:429:SOURce",.callback=BUS_429_SOURce},
    {.pattern=":BUS#:429:SOURce?",.callback=BUS_429_SOURceQ},
    {.pattern=":BUS#:429:FORMat",.callback=BUS_429_FORMat},
    {.pattern=":BUS#:429:FORMat?",.callback=BUS_429_FORMatQ},
    {.pattern=":BUS#:429:DISPlay",.callback=BUS_429_DISP},
    {.pattern=":BUS#:429:DISPlay?",.callback=BUS_429_DISPQ},
    {.pattern=":BUS#:429:BANDrate",.callback=BUS_429_BAND},
    {.pattern=":BUS#:429:BANDrate?",.callback=BUS_429_BANDQ},
    {.pattern = ":BUS#:429:HLEVel",.callback = BUS_429_HLEV,},
    {.pattern = ":BUS#:429:HLEVel?",.callback = BUS_429_HLEVQ,},
    {.pattern = ":BUS#:429:LLEVel",.callback = BUS_429_LLEV,},
    {.pattern = ":BUS#:429:LLEVel?",.callback = BUS_429_LLEVQ,},

    {.pattern=":ware",.callback=PRO_WARE,},
    {.pattern=":application",.callback=PRO_APP,},
    {.pattern=":SYS:WRITe?",.callback=PRO_SYS_WRITEQ,},
    {.pattern=":SYS:SN?",.callback=PRO_SYS_SNQ,},
    {.pattern=":SYS:WDATe",.callback=PRO_SYS_WDATE,},
    {.pattern=":PRIVate:UUID?",.callback=PRO_PRIV_UUIDQ,},
    {.pattern=":PRIVate:HWVersion?",.callback=PRO_PRIV_HWVERSIONQ,},
    {.pattern=":PRIVate:SERiaino?",.callback=PRO_PRIV_SERIAINOQ,},
    {.pattern=":PRIVate:STRingcode",.callback=PRO_PRIV_STRINGCODE,},
    {.pattern=":PRIVate:DISPlay:SERiaino",.callback=PRO_PRIV_DISPLAY_SERIAINO,},
    {.pattern=":PRIVate:MACHinetype",.callback=PRO_PRIV_MACHINETYPE,},
    {.pattern="PRIVate:STAR",.callback=PRO_PRIV_STAR,},
    {.pattern="PRIVate:STAT?",.callback=PRO_PRIV_STARQ,},
    {.pattern="PRIVate:STOP", .callback=PRO_PRIV_STOP,},
    {.pattern="PRIVate:BANDwidth",.callback=PRO_PRIV_BANDWIDTH,},
    {.pattern="PRIVate:SETTing:CLEar",.callback=PRO_PRIV_SETT_CLE,},
    {.pattern=":PRIVate:SYSID?",.callback=PRO_SYS_IDQ,},
    {.pattern=":INTeface:TIME", .callback=PRO_INT_TIME,},
    {.pattern=":INTeface:CLEAn",.callback=PRO_INT_CLEA,},
    {.pattern=":INTeface:SHUTdown",.callback=PRO_INT_SHUTDOWN,},
    {.pattern=":INTeface:RESTart",.callback=PRO_INT_REBOOT,},
    {.pattern=":INTeface:STANdby",.callback=PRO_INT_STANDBY,},
    {.pattern=":INTeface:WAKEup",.callback=PRO_INT_WAKEUP,},
    {.pattern=":INTeface:LOCK",.callback=PRO_INT_LOCK,},
    {.pattern=":INTeface:UNLock",.callback=PRO_INT_UNLOCK,},
    {.pattern=":SYS:Temperature?",.callback=PRO_SYS_TEMPERATUREQ,},
