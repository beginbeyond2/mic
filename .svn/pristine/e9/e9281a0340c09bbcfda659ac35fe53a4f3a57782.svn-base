package com.micsig.tbook.scope.fpga;

import com.micsig.tbook.hardware.HardwareProduct;

public class FPGAReg_SPI_EXT extends FPGAReg{
    public final static int SPI_EXT_PLL = (1<<0);
    public final static int SPI_EXT_AD = (1<<1);
    public final static int SPI_EXT_CHCTRL = (1<<2);
    public final static int SPI_EXT_CHGAIN = (1<<3);
    public final static int SPI_EXT_UART = (1<<4);
    public final static int SPI_EXT_CHPD = (1<<5);

    public final static int SPI_EXT_CLKINOUT = (1<<6);

    int voffset = 16;
    int vmask = 0xFFFF;
    public FPGAReg_SPI_EXT() {
        super(FPGA_SPI_EXT, 40);
        if(HardwareProduct.isMHO68V2()){
            voffset = 8;
            vmask = 0xFF;
        }
    }
    public FPGAReg_SPI_EXT(int len){super(FPGA_SPI_EXT,len);}

    public void setType(int t){
        setVal(0,0);
        setVal(0,0,8,t);
    }
    public void setCh(int val){
        setVal(0,8,4,val);
    }
    public void setVGAIdx(int idx){
        setVal(0,12,1,idx);
    }
    // 0 ,1,2,3
    public void setWriteAd(int val){
        setVal(0,8,4,val);
    }
    public void setCalibrationAd(int val){
        setVal(0,12,4, val);
    }
    public void adSync(){

        setVal(0,16,1,1);
    }
    public void setPowerDownAd(int val){
        setVal(0,16,4,val);
    }
    public void setPowerDownQAd(int val){
        setVal(0,20,4,val);
    }
    public void setDataLength(int len){
        setVal(0,24,6,len);
    }
    public void setByteValid(int n){
        setVal(0,30,2,n);
    }
    public void setAdData(int addr,int val)
    {
        setVal(1, (addr  << voffset)|(val & vmask));
    }



    public void setADMode(int val,int v){
        setVal(0,20,4,val);
        setVal(1,0,16,v);
    }
}
