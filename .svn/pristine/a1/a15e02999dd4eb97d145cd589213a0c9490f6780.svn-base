        ExternalKeysNode add = new ExternalKeysNode();
        add.setPlace(list.size(), 1719, 224 + offset, 54, 54);
        add.setName("Math-Add" + mathNumber);
        add.setType(ExternalKeysNode.TYPE_RECEIVE_MSG);
