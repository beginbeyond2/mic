            fdBrPercent.getChildNodes().get(16).setVisible(false);
            fdBrPercent.getChildNodes().get(19).setVisible(false);
            fdBrPercent.getChildNodes().get(20).setVisible(false);
            fdBrPercent.getChildNodes().get(21).setVisible(false);
