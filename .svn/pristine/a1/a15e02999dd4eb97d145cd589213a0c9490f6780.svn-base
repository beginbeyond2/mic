        int positionY = (int) channelLayout.getY();

        for (int i = 0; i < arrays.length; i++) {
            ExternalKeysNode channel = new ExternalKeysNode();
            int x = positionX + 22 + 106 * (i % 8);
            int y = positionY + 12 + 68 * (i / 8);
