package com.micsig.tbook.tbookscope.top.layout.trigger.serials.bean;

/**
 * Created by yangj on 2017/5/17.
 */

public class SerialsDetailM1553bRtAddr implements ISerialsDetail {
    private DataBean m1553bRtAddrRtAddr;
    private String m1553bRtAddrRtAddrTitle;

    public String getM1553bRtAddrRtAddrTitle() {
        return m1553bRtAddrRtAddrTitle;
    }

    public void setM1553bRtAddrRtAddrTitle(String m1553bRtAddrRtAddrTitle) {
        this.m1553bRtAddrRtAddrTitle = m1553bRtAddrRtAddrTitle;
    }

    public DataBean getM1553bRtAddrRtAddr() {
        return m1553bRtAddrRtAddr;
    }

    public void setM1553bRtAddrRtAddr(int digits, String value) {
        if (this.m1553bRtAddrRtAddr == null) {
            this.m1553bRtAddrRtAddr = new DataBean();
        }
        this.m1553bRtAddrRtAddr.setDigits(digits);
        this.m1553bRtAddrRtAddr.setValue(value);
    }

    @Override
    public String toString() {
        return "SerialsDetailM1553bRtAddr{" +
                "m1553bRtAddrRtAddr='" + m1553bRtAddrRtAddr + '\'' +
                '}';
    }
}
