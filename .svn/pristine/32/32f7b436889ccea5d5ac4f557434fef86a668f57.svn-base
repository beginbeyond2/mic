<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <com.micsig.tbook.ui.top.view.radioGroup.TopViewRadioGroup
        android:id="@+id/measureCounterType"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10px"
        app:head="@string/measureCounterType"
        app:array="@array/measureCounterType"
        app:headWidth="100px" />

    <Button
        android:id="@+id/reset"
        style="@style/textStyle"
        android:layout_width="60px"
        android:layout_height="30px"
        android:layout_alignParentEnd="true"
        android:layout_alignParentTop="true"
        android:layout_marginTop="10px"
        android:layout_marginBottom="10px"
        android:layout_marginStart="10px"
        android:layout_marginEnd="20px"
        android:background="@drawable/bg_button_measure_clear"
        android:textColor="@drawable/selector_text_color"
        android:text="@string/measureStaticsReset"
        android:textAllCaps="false" />

    <com.micsig.tbook.ui.top.view.radioGroup.TopViewRadioGroup
        android:id="@+id/measureCounterSource"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10px"
        android:layout_below="@+id/measureCounterType"
        app:head="@string/triggerSource"
        app:array="@array/channelsNameFour"
        app:headWidth="100px" />

</RelativeLayout>