    private void structToParam(int serialBusType) {
        switch (serialBusType) {
            case SerialBusStruct.SerialBusType_UART: {
                if (Scope.getInstance().isRun()) {
                    this.encoding = uartSettingStruct.getEncoding();
                    this.bits = uartSettingStruct.getUartLength();
                    this.checked = uartSettingStruct.isChecked();
                }
            }
            break;
            case SerialBusStruct.SerialBusType_LIN: {
                this.encoding = linSettingStruct.getEncoding();
            }
            break;
            case SerialBusStruct.SerialBusType_CAN: {
                this.encoding = canSettingStruct.getEncoding();
            }
            break;
            case SerialBusStruct.SerialBusType_SPI: {
                if (Scope.getInstance().isRun()) {
                    this.encoding = spiSettingStruct.getEncoding();
                    this.bits = spiSettingStruct.getDataBit();
                }
            }
            break;
            case SerialBusStruct.SerialBusType_I2C: {
                this.encoding = i2cSettingStruct.getEncoding();
            }
            break;
            case SerialBusStruct.SerialBusType_429: {
                this.encoding = arinc429SettingStruct.getEncoding();
            }
            break;
            case SerialBusStruct.SerialBusType_1553B: {
                this.encoding = milSID1553bSettingStruct.getEncoding();
            }
            break;
        }
    }
    //region ISerialBus

    private PorterDuffXfermode clearMode = new PorterDuffXfermode(PorterDuff.Mode.CLEAR);
    private PorterDuffXfermode srcMode = new PorterDuffXfermode(PorterDuff.Mode.SRC);

    @Override
    public void OnTitleChange(int chNo, int serialBusType) {
        //模拟数据
        if (bytes != null && bytes.limit() != 0 && bytes.capacity() != 0) {
            SerialImageBuffer sib = SerialImageDoubleCache.getInstance().getLastCache(chNo);
            if (sib!=null) {
                sib.setDeal(false);
                SerialImageDoubleCache.getInstance().put(chNo, sib);
            }else {
                bytes.limit(0);
            }
        }
        this.serialBusType = serialBusType;
        toParseRunnable.chNo=chNo;
        fixedThreadPool.execute(toParseRunnable);
    }

    @Override
    public void OnDataChange(int chNo, ByteBuffer bytes, long timeToPix, int startX, int endX) {
        this.bytes = bytes;
        toParseRunnable.chNo=chNo;
        fixedThreadPool.execute(toParseRunnable);
    }

    public void forceDrawLastData(int iwaveCh){
        //模拟数据
            SerialImageBuffer sib = SerialImageDoubleCache.getInstance().getLastCache(iwaveCh);
            if (sib!=null) {
                sib.setDeal(false);
                SerialImageDoubleCache.getInstance().put(iwaveCh, sib);
            }
        toParseRunnable.chNo=iwaveCh;
        fixedThreadPool.execute(toParseRunnable);
    }


    @Override
    public void OnTxtDataChange(int chNo, ByteBuffer bytes) {
    }

    private void drawSerialBus(int chNo) {

        structToParam(serialBusType);
        if (this.visible) {
            String titleName = "";
            switch (serialBusType) {
                case SerialBusStruct.SerialBusType_UART:
                    titleName = TChan.getChannelName(chNo) + " UART";
                    break;
                case SerialBusStruct.SerialBusType_LIN:
                    titleName = TChan.getChannelName(chNo) + " LIN";
                    break;
                case SerialBusStruct.SerialBusType_CAN:
                    titleName = TChan.getChannelName(chNo) + " CAN";
                    break;
                case SerialBusStruct.SerialBusType_SPI:
                    titleName = TChan.getChannelName(chNo) + " SPI";
                    break;
                case SerialBusStruct.SerialBusType_I2C:
                    titleName = TChan.getChannelName(chNo) + " I2C";
                    break;
                case SerialBusStruct.SerialBusType_429:
                    titleName = TChan.getChannelName(chNo) + " 429";
                    break;
                case SerialBusStruct.SerialBusType_1553B:
                    titleName = TChan.getChannelName(chNo) + " 1553B";
                    break;
            }

            synchronized (lock) {
                int titleLen = getTextWidth(titleName) + 16;
                boolean noPermission = (!ScopeConfig.getConfig().isBusEnable(serialBusType) && !App.IsDebug());
                if (bytes == null || bytes.limit() == 0 || bytes.capacity() == 0 || noPermission) {
                    mPaint.setXfermode(clearMode);
                    canvasData.drawPaint(mPaint);
                    mPaint.setXfermode(srcMode);
                    if (startX < titleLen) startX = titleLen;
                    if (endX < startX) endX = startX;
                    if (startX == endX) endX = GlobalVar.get().getScreen().width();
                    if (!noPermission)
                        canvasData.drawLine(startX, bmpData.getHeight() / 2, endX, bmpData.getHeight() / 2, mPaint);
                } else {
                    //这里解析数据进行画图
//                    String ch = this.getLineNameID() == TChan.S1 ? SerialBusManage.SerialBus_STRINGSHOWS1 : SerialBusManage.SerialBus_STRINGSHOWS2;
                    int ch = this.getLineNameID();
                    for (SerialImageBuffer sib : SerialImageDoubleCache.getInstance().getCache(chNo).values()) {
                        if (sib.isDeal() || sib.getBytes() == null) continue;
                        sib.setDoing(true);
                        mPaint.setXfermode(clearMode);
                        canvasData.drawPaint(mPaint);
                        mPaint.setXfermode(srcMode);
                        ByteBuffer bytes = sib.getBytes();
                        long timeToPix = sib.getTimeToPix();
                        int startX = sib.getStartX();
                        int endX = sib.getEndX();
                        serialBusStructParse.toParse(ch, titleLen, serialBusType, canvasData, mPaint, bytes, timeToPix, encoding, bits, checked, startX, endX);
//                           Tools.saveImgOverlap(bmpData,"S"+this.getLineNameID()+".jpeg", App.get().getApplicationContext());
                        sib.setDeal(true);
                        sib.setDoing(false);
                        SerialImageDoubleCache.getInstance().put(chNo, sib.getKey(), sib);
                    }
                }
                mPaint.setXfermode(srcMode);
                mPaint.setStrokeWidth(4.0f);
                mPaint.setColor(Color.BLACK);
                mPaint.setStyle(Paint.Style.STROKE);
                float x = (float) titleLen / 2;
                float y = (float) ((bmpData.getHeight() - Tools.getTextRect(titleName, mPaint).height()) / 2 + Tools.getTextRect(titleName, mPaint).height());
                canvasData.drawText(titleName, x, y, mPaint);//画title描边
                mPaint.setStrokeWidth(0);
                mPaint.setColor(this.color);
                mPaint.setStyle(Paint.Style.FILL);
                canvasData.drawText(titleName, x, y, mPaint);//画title
                canvasData.drawBitmap(resBmp[chNo - TChan.S1][selected ? 3 : 0], 0, (bmpData.getHeight() - resBmp[chNo - TChan.S1][3].getHeight()) / 2, mPaint);
                isChanageBitmap = true;
                onRefresh();
//                Tools.saveImgOverlap(bmpData,"serialbus"+chNo+".jpg",App.get().getApplicationContext());
            }
        }
//        isChanageBitmap = true;
    }

    public void putBytesToQueue(ByteBuffer bytes) throws InterruptedException {
        serialTxtBuffer.putBytesToQueue(bytes);
        boolean b = SerialBusTxtStructParse.getInstance().getParsing(this.getLineNameID());

        //if (!b)
        {
            String chName=TChan.getChannelName(this.getLineNameID());
            SerialBusTxtStructParse.getInstance().toParseByRunable(chName, serialTxtBuffer, this.serialBusType, encoding, bits, checked);
        }
    }
