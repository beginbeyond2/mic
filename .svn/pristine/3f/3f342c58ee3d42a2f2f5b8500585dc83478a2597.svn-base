    @Override
    public void draw(ICanvasGL canvas) {
        if (visible) {
            synchronized (lock) {
                canvasGL = canvas;
                if(isChanageBitmap){
                    canvas.invalidateTextureContent(bmpData,null);
                }
                canvas.drawBitmap(bmpData, 0, (int) Math.round(this.getPosY() * ScopeBase.getToUICoff()));
                isChanageBitmap = false;
            }

        }
    }

