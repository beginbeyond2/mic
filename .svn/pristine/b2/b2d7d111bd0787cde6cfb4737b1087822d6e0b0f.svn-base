<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android"
    >
    <item>
        <shape>
            <solid android:color="@android:color/transparent"/>
        </shape>
    </item>

    <item
        android:bottom="5px"
        android:height="2px"
        android:gravity="bottom"
        >
        <shape >
            <solid  android:color="@color/red"/>
        </shape>
    </item>
</layer-list>