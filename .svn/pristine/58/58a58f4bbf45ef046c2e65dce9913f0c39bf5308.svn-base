package com.micsig.tbook.tbookscope.top.layout.save;

/**
 * @auother Liwb
 * @description:
 * @data:2022-3-5 11:09
 */
public class TopMsgSaveSegments implements ISaveDetail {
    private boolean isVisibleSegments = true;
    private boolean isEnableTypeWav = true;
    private boolean isEnableTypeCsv = true;
    private boolean isEnableTypeBin = true;

    public boolean isVisibleSegments() {
        return isVisibleSegments;
    }

    public void setVisibleSegments(boolean visibleSegments) {
        isVisibleSegments = visibleSegments;
    }

    public boolean isEnableTypeWav() {
        return isEnableTypeWav;
    }

    public void setEnableTypeWav(boolean enableTypeWav) {
        isEnableTypeWav = enableTypeWav;
    }

    public boolean isEnableTypeCsv() {
        return isEnableTypeCsv;
    }

    public void setEnableTypeCsv(boolean enableTypeCsv) {
        isEnableTypeCsv = enableTypeCsv;
    }

    public boolean isEnableTypeBin() {
        return isEnableTypeBin;
    }

    public void setEnableTypeBin(boolean enableTypeBin) {
        isEnableTypeBin = enableTypeBin;
    }

    @Override
    public String toString() {
        return "TopMsgSaveSegments{" +
                "isVisibleSegments=" + isVisibleSegments +
                ", isEnableTypeWav=" + isEnableTypeWav +
                ", isEnableTypeCsv=" + isEnableTypeCsv +
                ", isEnableTypeBin=" + isEnableTypeBin +
                '}';
    }
}
