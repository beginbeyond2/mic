<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:drawable="@drawable/halfcorner_120_60_left_disable" android:state_enabled="false" />
    <item android:drawable="@drawable/halfcorner_120_60_left_check" android:state_checked="true" />
    <item android:drawable="@drawable/halfcorner_120_60_left_check" android:state_selected="true" />
    <item android:drawable="@drawable/halfcorner_120_60_left_check" android:state_pressed="true" />
    <item android:drawable="@drawable/halfcorner_120_60_left_uncheck" />
</selector>