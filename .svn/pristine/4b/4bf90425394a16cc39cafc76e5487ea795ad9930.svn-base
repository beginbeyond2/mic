<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <com.micsig.tbook.ui.top.view.radioGroup.TopViewRadioGroup
        android:id="@+id/triggerSource"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="45px"
        app:array="@array/triggerSource"
        app:head="@string/triggerSource" />

    <com.micsig.tbook.ui.top.view.radioGroup.TopViewRadioGroup
        android:id="@+id/edge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/triggerSource"
        android:layout_marginStart="45px"
        android:layout_marginTop="10px"
        app:array="@array/triggerSlopeEdge"
        app:head="@string/triggerSlopeEdge" />

    <com.micsig.tbook.ui.top.view.radioGroup.TopViewRadioGroup
        android:id="@+id/condition"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/edge"
        android:layout_marginStart="45px"
        android:layout_marginTop="10px"
        app:array="@array/triggerSlopeCondition"
        app:head="@string/triggerSlopeCondition" />

    <LinearLayout
        android:id="@+id/layoutSlopeTimeHigh"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/edge"
        android:layout_marginStart="35px"
        android:layout_marginTop="10px"
        android:layout_toEndOf="@+id/condition"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/slopeTimeHighHead"
            style="@style/textStyle"
            android:layout_width="100px"
            android:layout_height="60px"
            android:layout_marginRight="14px"
            android:gravity="center_vertical|right"
            android:text="@string/triggerslope_timehighhead" />

        <TextView
            android:id="@+id/slopeTimeHighDetail"
            style="@style/editTextStyleRight"
            android:layout_width="120px"
            android:layout_height="60px"
            android:text="@string/view_trigger_pulsewidth" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutSlopeTimeLow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignBottom="@+id/layoutSlopeTimeHigh"
        android:layout_marginStart="35px"
        android:layout_toEndOf="@id/layoutSlopeTimeHigh"
        android:orientation="horizontal"
        android:visibility="invisible">

        <TextView
            android:id="@+id/slopeTimeLowHead"
            style="@style/textStyle"
            android:layout_width="100px"
            android:layout_height="60px"
            android:layout_marginRight="14px"
            android:gravity="center_vertical|right"
            android:text="@string/triggerslope_timelowhead" />

        <TextView
            android:id="@+id/slopeTimeLowDetail"
            style="@style/editTextStyleRight"
            android:layout_width="120px"
            android:layout_height="60px"
            android:text="@string/view_trigger_pulsewidth" />
    </LinearLayout>
</RelativeLayout>