package com.micsig.tbook.tbookscope.top.layout.trigger.serials.bean;

/**
 * Created by yangj on 2017/5/17.
 */

public class SerialsDetailArinc429Label implements ISerialsDetail {
    private DataBean arinc429LabelLabel;
    private String arinc429LabelLabelTitle;

    public String getArinc429LabelLabelTitle() {
        return arinc429LabelLabelTitle;
    }

    public void setArinc429LabelLabelTitle(String arinc429LabelLabelTitle) {
        this.arinc429LabelLabelTitle = arinc429LabelLabelTitle;
    }

    public DataBean getArinc429LabelLabel() {
        return arinc429LabelLabel;
    }

    public void setArinc429LabelLabel(int digits, String value) {
        if (this.arinc429LabelLabel == null) {
            this.arinc429LabelLabel = new DataBean();
        }
        this.arinc429LabelLabel.setDigits(digits);
        this.arinc429LabelLabel.setValue(value);
    }

    @Override
    public String toString() {
        return "SerialsDetailArinc429Label{" +
                "arinc429LabelLabel='" + arinc429LabelLabel + '\'' +
                '}';
    }
}
