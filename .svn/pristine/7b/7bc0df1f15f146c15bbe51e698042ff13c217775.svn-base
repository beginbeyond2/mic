<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:id="@+id/sourceHead"
        style="@style/rightHeadText"
        android:layout_width="120px"
        android:layout_height="54px"
        android:layout_marginStart="0px"
        android:layout_marginTop="7px"
        android:gravity="center_vertical"
        android:text="@string/serialsCanSource" />

    <com.micsig.tbook.ui.rightslipmenu.RightViewSelect
        android:id="@+id/source"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        app:array="@array/channelsNameEight"
        app:arrayOrientation="horizontalEachRow4"
        app:itemHeight="54px"
        app:itemMargin="7px"
        app:itemWidth="108px" />

    <View
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="2px"
        android:layout_below="@id/source"
        android:layout_marginVertical="7px"
        android:layout_marginEnd="7px"
        android:background="@drawable/bg_right_layout_divider" />

    <TextView
        android:id="@+id/signalHead"
        style="@style/rightHeadText"
        android:layout_width="wrap_content"
        android:layout_height="54px"
        android:layout_below="@+id/divider"
        android:layout_marginStart="0px"
        android:layout_marginTop="7px"
        android:gravity="center"
        android:text="@string/serialsCanSignal" />

    <com.micsig.tbook.ui.rightslipmenu.RightViewSelect
        android:id="@+id/signal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/divider"
        android:layout_alignParentEnd="true"
        app:array="@array/serialsCanSignal"
        app:arrayOrientation="horizontalEachRow4"
        app:firstShowCount="2"
        app:itemHeight="54px"
        app:itemMargin="7px"
        app:itemWidth="108px" />

    <View
        android:id="@+id/divider2"
        android:layout_width="match_parent"
        android:layout_height="2px"
        android:layout_below="@id/signal"
        android:layout_marginVertical="7px"
        android:layout_marginEnd="7px"
        android:background="@drawable/bg_right_layout_divider" />

    <TextView
        android:id="@+id/baudRateHead"
        style="@style/rightHeadText"
        android:layout_width="wrap_content"
        android:layout_height="54px"
        android:layout_below="@+id/divider2"
        android:layout_marginStart="0px"
        android:layout_marginTop="7px"
        android:gravity="center"
        android:text="@string/serialsCanBaudRate" />

    <TextView
        android:id="@+id/baudRatePercent"
        style="@style/editTextStyle"
        android:layout_width="108px"
        android:layout_height="54px"
        android:layout_below="@+id/divider2"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="7px"
        android:layout_marginEnd="7px"
        android:clickable="true"
        android:gravity="center"
        android:text="10%" />

    <com.micsig.tbook.ui.rightslipmenu.RightViewSelect
        android:id="@+id/baudRate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/baudRateHead"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="7px"
        app:array="@array/serialsCanBaudRate"
        app:arrayOrientation="horizontalEachRow4"
        app:itemHeight="54px"
        app:itemMargin="7px"
        app:itemWidth="108px" />

    <com.micsig.tbook.ui.rightslipmenu.RightViewUserDefineEdit
        android:id="@+id/userDefineSerialsCan"
        android:layout_width="108px"
        android:layout_height="54px"
        android:layout_alignEnd="@id/baudRate"
        android:layout_alignBottom="@id/baudRate"
        android:layout_marginEnd="7px"
        android:layout_marginBottom="7px" />

    <View
        android:id="@+id/divider3"
        android:layout_width="match_parent"
        android:layout_height="2px"
        android:layout_below="@id/baudRate"
        android:layout_marginVertical="7px"
        android:layout_marginEnd="0px"
        android:background="@drawable/bg_right_layout_divider" />

    <TextView
        android:id="@+id/fdBaudRateHead"
        style="@style/rightHeadText"
        android:layout_width="wrap_content"
        android:layout_height="54px"
        android:layout_below="@+id/divider3"
        android:layout_marginStart="0px"
        android:layout_marginTop="7px"
        android:gravity="center"
        android:text="@string/serialsCanFDBaudRate" />

    <TextView
        android:id="@+id/fdPercent"
        style="@style/editTextStyle"
        android:layout_width="108px"
        android:layout_height="54px"
        android:layout_below="@+id/divider3"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="7px"
        android:layout_marginEnd="7px"
        android:clickable="true"
        android:gravity="center"
        android:text="10%" />

    <com.micsig.tbook.ui.rightslipmenu.RightViewSelect
        android:id="@+id/fdBaudRate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/fdBaudRateHead"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="7px"
        app:array="@array/serialsCanFDBaudRate"
        app:arrayOrientation="horizontalEachRow4"
        app:itemHeight="54px"
        app:itemMargin="7px"
        app:itemWidth="108px" />

    <com.micsig.tbook.ui.rightslipmenu.RightViewUserDefineEdit
        android:id="@+id/userDefineSerialsCanFD"
        android:layout_width="108px"
        android:layout_height="54px"
        android:layout_alignEnd="@id/fdBaudRate"
        android:layout_alignBottom="@id/fdBaudRate"
        android:layout_marginEnd="7px"
        android:layout_marginBottom="7px" />

    <View
        android:id="@+id/divider4"
        android:layout_width="match_parent"
        android:layout_height="2px"
        android:layout_below="@id/fdBaudRate"
        android:layout_marginVertical="7px"
        android:layout_marginEnd="7px"
        android:background="@drawable/bg_right_layout_divider" />

    <TextView
        android:id="@+id/iSOTitle"
        style="@style/rightHeadText"
        android:layout_width="wrap_content"
        android:layout_height="54px"
        android:layout_below="@+id/divider4"
        android:layout_marginStart="0px"
        android:layout_marginTop="7px"
        android:gravity="center"
        android:text="@string/serialsCanFDISO" />

    <com.micsig.tbook.ui.rightslipmenu.RightViewSelect
        android:id="@+id/iSO"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/divider4"
        android:layout_alignParentEnd="true"
        android:layout_gravity="end|center_vertical"
        android:layout_marginTop="7px"
        app:array="@array/serialsCanFDISO"
        app:arrayOrientation="horizontalEachRow2"
        app:itemHalfCornerEach="each_108_54"
        app:itemHeight="54px"
        app:itemStartAndEndBgHalfCorner="true"
        app:itemWidth="108px" />

</RelativeLayout>