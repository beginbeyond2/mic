public class MathRefWaveManage implements IWaveShowManage, IWorkMode {
    private static final String TAG = "MathRefWaveManage";
    private Bitmap[][] resBmp;

    //region 私有变量
    private Map<Integer, MathRefWave> mapChannel = new HashMap<>();
//    private Bitmap bmp;
//    private Canvas mCanvas;
//    private Paint paint;
    //endregion

    public MathRefWaveManage(Bitmap[][] resBmp, IWave.OnMovingWaveEvent onMovingWaveEvent, IWave.OnSelectChangeEvent onSelectChangeEvent) {
        this.resBmp = resBmp;
        TChan.foreachMath1ToR8((chNo)-> {
            MathRefWave channelWave = new MathRefWave(this.resBmp[chNo]);
            channelWave.setLineNameId(chNo);
            channelWave.setY(Tools.getYTChannelPositionUI(chNo));
            channelWave.setSelected(true);
            channelWave.setVisible(false);
            channelWave.setOnMovingWaveEvent(onMovingWaveEvent);
            channelWave.setOnSelectChangeEvent(onSelectChangeEvent);
            channelWave.initLabelRect();
            mapChannel.put(chNo, channelWave);
        });
    }


    public void setWaveChange(int  height) {
//        bmp = Bitmap.createScaledBitmap(bmp, GlobalVar.get().getWaveZoneWidth_Pix(WorkModeManage.getInstance().getmWorkMode()), height, true);
//        mCanvas.setBitmap(bmp);
        updateChannelPosCache();
        refresh();
    }

    private void updateChannelPosCache() {
        for (Integer i : mapChannel.keySet()) {
            MathRefWave tem = mapChannel.get(i);
            if (tem == null) continue;
            tem.changeLabelPos(tem.getLabelRect().left);
            if (CacheUtil.get().isClickFactoryReset()) {//这个值时是初始值
                tem.setYFromEventBus((int) Math.round(108 * (tem.getLineNameID() - 2 - (tem.getLineNameID() - 9) * 1.5)));
            } else {
                Tools.putChannelPosition(tem.getLineNameID(), ScopeBase.changeAccuracy(tem.getPosY() * ScopeBase.getToUICoff()));
            }
        }
        CacheUtil.get().setClickFactoryReset(false);
    }

    public void updateResBmp(int chIndex, Bitmap[][] resBmp) {
        this.resBmp = resBmp;
        MathRefWave mathRefWave = mapChannel.get(chIndex);
        if (mathRefWave == null) return;
        mathRefWave.changeBitMap(this.resBmp[chIndex]);
    }

    //region IWorkMode接口

    @Override
    public void switchWorkMode(@WorkMode int workMode) {
        for (MathRefWave c : mapChannel.values()) {
            c.switchWorkMode(workMode);
        }
    }

    //endregion

    //region IWaveShowManage接口
    @Override
    public void draw(Canvas canvas) {
        for (MathRefWave c : mapChannel.values()) {
            c.draw(canvas);
        }
        int flag = isSelected();
        if (flag != -1) {
            mapChannel.get(flag).draw(canvas);
        }
    }

    @Override
    public void draw(ICanvasGL canvas) {
        for (MathRefWave c : mapChannel.values()) {
            if (c.getVisible() == true) c.draw(canvas);
        }
        int flag = isSelected();
        if (flag != -1) {
            mapChannel.get(flag).draw(canvas);
        }
    }

    public void setVisible(int ChNo, boolean visible) {
        for (MathRefWave c : mapChannel.values()) {
            if (c.getLineNameID() == ChNo) {
                c.setVisible(visible);
            }
        }
    }

    @Override
    public int isSelected() {
        int flag = -1;
        for (Integer i : mapChannel.keySet()) {
            MathRefWave tem = mapChannel.get(i);
            if (tem.isSelected() == true) {
                flag = i;
                return flag;
            }
        }
        return flag;
    }

    @Override
    public void setOffsetY(int offsetY) {
        for (MathRefWave c : mapChannel.values()) {
            if (c.isSelected() == true) {
                c.setY(c.getY() - offsetY);
            }
        }
    }

    public void setY(int ch, double y) {
        for (MathRefWave c : mapChannel.values()) {
            if (c.getLineNameID() == ch) {
                c.setY(y);
            }
        }
    }

    public void setYFromEventBus(int ch, double y) {
        for (MathRefWave c : mapChannel.values()) {
            if (c.getLineNameID() == ch) {
                c.setYFromEventBus(y);
            }
        }
    }

    public double getY(int ch) {
        for (MathRefWave c : mapChannel.values()) {
            if (c.getLineNameID() == ch) {
                return c.getY();
            }
        }
        return 0;
    }

    public double getUIY(int ch) {
        for (MathRefWave c : mapChannel.values()) {
            if (c.getLineNameID() == ch) {
                return ScopeBase.changeAccuracy(c.getPosY() * ScopeBase.getToUICoff());
            }
        }
        return 0;
    }

    public boolean isVisible(int ch) {
        for (MathRefWave c : mapChannel.values()) {
            if (c.getLineNameID() == ch) {
                return c.getVisible();
            }
        }
        return false;
    }

    private PorterDuffXfermode clearMode = new PorterDuffXfermode(PorterDuff.Mode.CLEAR);
    private PorterDuffXfermode srcMode = new PorterDuffXfermode(PorterDuff.Mode.SRC);

