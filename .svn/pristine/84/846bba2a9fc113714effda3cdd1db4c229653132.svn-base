    //region 单例创建
    private static CacheUtil cacheUtil;

    private CacheUtil() {
        map.clear();
        otherMap.clear();
//        getCacheMap();
        getOtherMap();
        initCache();
    }

    public static CacheUtil get() {
        if (cacheUtil == null) {
            cacheUtil = new CacheUtil();
        }
        return cacheUtil;
    }
