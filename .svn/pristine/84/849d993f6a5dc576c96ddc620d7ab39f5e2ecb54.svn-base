<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <com.micsig.tbook.ui.top.view.radioGroup.TopViewRadioGroup
        android:id="@+id/trigger"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="45px"
        app:array="@array/userSetAuxOut"
        app:head="@string/userSetAuxOutTrigger" />

    <com.micsig.tbook.ui.top.view.radioGroup.TopViewRadioGroup
        android:id="@+id/clock"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="140px"
        android:layout_toEndOf="@+id/trigger"
        app:array="@array/userSetAuxOut"
        app:head="@string/userSetAuxOutClock" />

    <com.micsig.tbook.ui.top.view.radioGroup.TopViewRadioGroup
        android:id="@+id/input_imped"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="140px"
        android:layout_toEndOf="@+id/clock"
        app:array="@array/channelImped"
        app:head="@string/triggerImped" />

</RelativeLayout>