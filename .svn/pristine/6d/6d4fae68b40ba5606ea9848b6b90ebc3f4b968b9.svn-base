<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_dialog_measure_statics"
    >


    <TextView
        android:id="@+id/row1"
        android:layout_width="match_parent"
        android:layout_height="35px"
        android:background="@android:color/transparent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        />
    <TextView
        android:id="@+id/row2"
        android:layout_width="match_parent"
        android:layout_height="34px"
        android:background="#363b40"
        app:layout_constraintTop_toBottomOf="@id/row1"
        app:layout_constraintLeft_toLeftOf="parent"
        />
    <TextView
        android:id="@+id/row3"
        android:layout_width="match_parent"
        android:layout_height="34px"
        android:background="@android:color/transparent"
        app:layout_constraintTop_toBottomOf="@id/row2"
        app:layout_constraintLeft_toLeftOf="parent"
        />
    <TextView
        android:id="@+id/row4"
        android:layout_width="match_parent"
        android:layout_height="34px"
        android:background="#363b40"
        app:layout_constraintTop_toBottomOf="@id/row3"
        app:layout_constraintLeft_toLeftOf="parent"
        />
    <TextView
        android:id="@+id/row5"
        android:layout_width="match_parent"
        android:layout_height="34px"
        android:background="@android:color/transparent"
        app:layout_constraintTop_toBottomOf="@id/row4"
        app:layout_constraintLeft_toLeftOf="parent"
        />
    <TextView
        android:id="@+id/row6"
        android:layout_width="match_parent"
        android:layout_height="34px"
        android:background="#363b40"
        app:layout_constraintTop_toBottomOf="@id/row5"
        app:layout_constraintLeft_toLeftOf="parent"
        />
    <TextView
        android:id="@+id/line_title"
        android:layout_width="match_parent"
        android:layout_height="40px"
        android:background="#000000"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        />


    <com.micsig.tbook.tbookscope.main.dialog.DialogMeasureStaticsItem
        android:id="@+id/title"
        android:layout_width="100px"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        />

   <HorizontalScrollView
       android:layout_width="0dp"
       android:layout_height="wrap_content"
       app:layout_constraintTop_toTopOf="parent"
       app:layout_constraintLeft_toRightOf="@id/title"
       app:layout_constraintRight_toRightOf="parent"
       >
       <LinearLayout
           android:id="@+id/listView"
           android:layout_width="match_parent"
           android:layout_height="wrap_content"
           android:orientation="horizontal"
           android:paddingBottom="0px"
           >
