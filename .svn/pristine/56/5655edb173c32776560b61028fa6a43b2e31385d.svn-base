    public double timeScaleIdVal(int timeScaleId) {
        return timeScaleIdVal(timeScaleId, refType);
    }

    public double timeScaleIdVal(int timeScaleId, int refType) {
        if (refType == WaveData.FFT_WAVE) {
            return fftTimeScaleIdVal(timeScaleId);
        } else {
            //根据存储深度计算档位移动的处理
            double val = stdTimeScaleIdVal(timeScaleId);
//            IMemDepth memDepth = MemDepthFactory.getMemDepthObj(memDepthSet);
//            if(memDepth.isSpecialTimeScale()) {
//                double timeScaleRatio = memDepth.getTimeScaleRatio(timeScaleId, memDepthItemIdx);
//                val *= timeScaleRatio;
//            }
//            Logger.i(TAG, "timeScaleIdVal() ==>"
//                    +" timeScaleId:"+timeScaleId+" refType:"+refType
//                    +" memDepthSet:"+memDepthSet+" memDepthItemIdx:"+memDepthItemIdx+" val:"+val);
            return val;
        }
    }

    public double timeScaleVal(double timeScaleVal) {
        return timeScaleVal(timeScaleVal, refType);
    }

    public double timeScaleVal(double timeScaleVal, int refType) {
        if (refType == 2) {
            return fftTimeScaleIdVal(fftTimeScaleId(timeScaleVal));
        } else {
            return stdTimeScaleIdVal(stdTimeScaleId(timeScaleVal));
        }
    }

    public int timeScaleId(double timeScaleVal) {
        return timeScaleId(timeScaleVal, refType);
    }

    public int timeScaleId(double timeScaleVal, int refType) {
        if (refType == 2) {
            return fftTimeScaleId(timeScaleVal);
        } else {
            return stdTimeScaleId(timeScaleVal);
        }
    }

    public int timeScaleId_ui(double priTimeScaleVal, double timeScaleVal, int refType) {
        if (refType == 2) {
            return fftTimeScaleId(timeScaleVal) - fftTimeScaleId(priTimeScaleVal);
        } else {
            return stdTimeScaleId(timeScaleVal) - stdTimeScaleId(priTimeScaleVal);
        }
    }

    private double stdTimeScaleIdVal(int timeScaleId) {
        double timeScaleArray[] = {
                1000,
                500, 200, 100, 50, 20, 10, 5, 2, 1,
                500e-3, 200e-3, 100e-3, 50e-3, 20e-3, 10e-3, 5e-3, 2e-3, 1e-3,
                500e-6, 200e-6, 100e-6, 50e-6, 20e-6, 10e-6, 5e-6, 2e-6, 1e-6,
                500e-9, 200e-9, 100e-9, 50e-9, 20e-9, 10e-9, 5e-9, 2e-9, 1e-9,
                500e-12, 250e-12
        };
        if (timeScaleId < TSI_MIN) timeScaleId = TSI_MIN;
        if (timeScaleId > TSI_MAX) timeScaleId = TSI_MAX;
        return timeScaleArray[timeScaleId];
    }

    public int stdTimeScaleId(double timeScaleVal) {
        double timeScaleArray[] = {
                1000,
                500, 200, 100, 50, 20, 10, 5, 2, 1,
                500e-3, 200e-3, 100e-3, 50e-3, 20e-3, 10e-3, 5e-3, 2e-3, 1e-3,
                500e-6, 200e-6, 100e-6, 50e-6, 20e-6, 10e-6, 5e-6, 2e-6, 1e-6,
                500e-9, 200e-9, 100e-9, 50e-9, 20e-9, 10e-9, 5e-9, 2e-9, 1e-9,
                500e-12, 250e-12
        };
        int ret = TSI_MIN;
        for (int i = TSI_MIN; i <= TSI_MAX; i++) {
            if (timeScaleVal > (timeScaleArray[i] - timeScaleArray[i] / 10)) {
                ret = i;
                break;
            }
        }
        return ret;
    }


    public double fftFrequneceRatio() {
        return sampleRate / (waveLength - 1);
    }

    public double fftTimeScaleIdVal(int timeScaleId) {
        double timeScaleArray[] = {
                1000e9,
                500e9, 200e9, 100e9, 50e9, 20e9, 10e9, 5e9, 2e9, 1e9,//G
                500e6, 200e6, 100e6, 50e6, 20e6, 10e6, 5e6, 2e6, 1e6,//M
                500e3, 200e3, 100e3, 50e3, 20e3, 10e3, 5e3, 2e3, 1e3,//K
                500, 200, 100, 50, 20, 10, 5, 2, 1
        };
        if (timeScaleId < TSI_HZ_MIN) timeScaleId = TSI_HZ_MIN;
        if (timeScaleId > TSI_HZ_MAX) timeScaleId = TSI_HZ_MAX;
        return timeScaleArray[timeScaleId];
    }

    public int fftTimeScaleId(double timeScaleVal) {
        double timeScaleArray[] = {
                1000e9,
                500e9, 200e9, 100e9, 50e9, 20e9, 10e9, 5e9, 2e9, 1e9,//G
                500e6, 200e6, 100e6, 50e6, 20e6, 10e6, 5e6, 2e6, 1e6,//M
                500e3, 200e3, 100e3, 50e3, 20e3, 10e3, 5e3, 2e3, 1e3,//K
                500, 200, 100, 50, 20, 10, 5, 2, 1
        };
        int ret = 0;/*
        for (int i = 0; i < timeScaleArray.length; i++) {
            if (timeScaleVal > (timeScaleArray[i] - timeScaleArray[i] / 10)) {
                ret = i;
                break;
            }
        }
        */
        for (int i = timeScaleArray.length-1; i >= 0; i--) {
            if (timeScaleVal < timeScaleArray[i]*1.001) {
                ret = i;
                break;
            }
        }

        return ret;
    }

    public int getWPIId() {
        int id = WPI_STANDARD;
        if (Display.getInstance().isZoom())
            id = WPI_LARGE;
        return id;
    }

    public int getTimeScaleIdOfView() {
        return getTimeScaleIdOfView(getWPIId());
    }

    public void setTimeScaleIdOfView(int timeScaleId) {
        setTimeScaleIdOfView(getWPIId(), timeScaleId);
    }

    public void setTimeScaleIdOfView(int WPIId, int timeScaleId) {
        if (WPIId == WPI_LARGE) {
            timeScaleIdZoom = timeScaleId;
        } else {
            timeScaleIdMain = timeScaleId;
        }
    }

    public int getTimeScaleIdOfView(int WPIId) {
        if (WPIId == WPI_LARGE) return timeScaleIdZoom;
        return timeScaleIdMain;
    }

    public long getTimePosOfView() {
        return getTimePosOfView(getWPIId());
    }

    public void setTimePosOfView(long timePos) {
