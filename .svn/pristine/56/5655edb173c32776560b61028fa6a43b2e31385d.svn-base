    public List<Double> generateHorizontalAxis(double scaleVal) {
        return generateHorizontalAxis(scaleVal, refType);
    }

    public List<Double> generateHorizontalAxis(int baseScaleId) {
        return generateHorizontalAxis(timeScaleIdVal(baseScaleId));
    }

    public List<Double> generateHorizontalAxis(double scaleVal, int refType) {
        if (refType == 2) {
            return generateMathFftAxis(scaleVal, refType);
        } else {
            return generateChannelAxis(scaleVal, refType);
        }
    }

    private List<Double> generateChannelAxis(double scaleVal, int refType) {
        xAxis.clear();
        double val = scaleVal;
        xAxis.add(val);
        for (int i = TSI_MIN; i <= TSI_MAX; i++) {
            val = timeScaleIdVal(i, refType);
            if(val < scaleVal) {
                xAxis.add(val);
            }
        }
        return xAxis;
    }

    private List<Double> generateMathFftAxis(double freqVal, int refType) {
        xAxis.clear();
        double val = freqVal;
        int i=TSI_HZ_MAX;
        for(; i>=TSI_HZ_MIN; i--) {
            val = fftTimeScaleIdVal(i);
            if(freqVal < val*1.001) {
                xAxis.add(val);
                i++;
                break;
            }
        }
        for(; i<=TSI_HZ_MAX; i++) {
            val = fftTimeScaleIdVal(i);
            xAxis.add(val);
        }
        return xAxis;

    }

