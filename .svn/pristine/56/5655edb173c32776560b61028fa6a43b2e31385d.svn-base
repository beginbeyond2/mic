    private void initAxis() {
        generateHorizontalAxis(0);
    }

    public List<Double> getxAxis() {
        synchronized (this) {
            return new ArrayList<>(xAxis);
        }
    }

    public List<Double> getxAxisRatio() {
        synchronized (this) {
            return xAxisRatio;
