    @Override
    public void update(Observable observable, Object data) {
        EventBase eventBase = (EventBase) data;
        switch (eventBase.getId()) {
            case EventFactory.EVENT_CHANNEL_OPEN:
            case EventFactory.EVENT_CHANNEL_CLOSE:
            case EventFactory.EVENT_CHANNEL_ACTIVE:
                break;
            case EventFactory.EVENT_REF_WAVE_UPDATE:
                // TODO 刷新xAxis内容
                break;
        }
    }

    //档位标准化函数：分解原档位值
    static double decomposeStandardScale(double scale, int rank, int littleRank) {
        rank = 0;
        while (scale > 1e3) {
            scale /= 1e3;
            (rank)++;
        }
        while (scale < 1 && scale != 0) {
            scale *= 1e3;
            (rank)--;
        }
        littleRank = 0;
        while (scale > 10) {
            scale /= 10;
            (littleRank)++;
        }
        if (10 - scale < 1) {//防止出现9.99的现象
            scale /= 10;
            (littleRank)++;
        }
        return scale;
    }

    //档位标准化函数：还原分解值
    static double combinateStandardScale(double scale, int rank, int littleRank) {
        while (littleRank > 0) {
            scale *= 10;
            littleRank--;
        }
        while (rank != 0) {
            if (rank > 0) {
                scale *= 1e3;
                rank--;
            } else {
                scale *= 1e-3;
                rank++;
            }
        }
        return scale;
    }
}
