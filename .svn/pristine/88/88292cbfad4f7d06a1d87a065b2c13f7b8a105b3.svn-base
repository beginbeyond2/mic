package com.micsig.tbook.scope.probe;

import android.content.Context;

import com.micsig.base.FileValidateUtil;
import com.micsig.base.HttpUtil;
import com.micsig.base.Utils;
import com.micsig.base.ZipUtils;
import com.micsig.tbook.scope.BuildConfig;
import com.micsig.tbook.scope.R;

import org.json.JSONException;
import org.json.JSONObject;

import java.io.File;
import java.io.FileInputStream;
import java.io.FilenameFilter;
import java.io.IOException;
import java.io.InputStream;
import java.util.Locale;

public class ProbeUtils {

    public static String PROBE_PATH = "";
    public static String PROBE_CACHE_PATH = "";
    public static final String PROBE_INFO = "probezip.json";
    public static final String PROBE_ZIP = "probe.zip";
    public static class ProbeInfoBean{
        private String md5;
        private int version;

        public ProbeInfoBean(){

        }
        public String getMd5() {
            return md5;
        }

        public void setMd5(String md5) {
            this.md5 = md5;
        }

        public int getVersion() {
            return version;
        }

        public void setVersion(int version) {
            this.version = version;
        }
    }

    public static void unRawProbeZip(Context context,String path){

        File f = new File(path,"probe");
        if(f.exists()){
            Utils.delFile(f);
        }
        InputStream is = context.getResources().openRawResource(R.raw.probe);
        ZipUtils.UnZipFolder(is,path);
        is = context.getResources().openRawResource(R.raw.probezip);
        Utils.saveFile(is,path + File.separator + PROBE_INFO);
    }
    public static ProbeInfoBean getRawMD5(Context context){
        InputStream is = context.getResources().openRawResource(R.raw.probezip);
        return getProbeMD5(Utils.readAll(is));
    }
    public static boolean isUnRawProbeZip(ProbeInfoBean rawbean){
        File f = new File(PROBE_PATH, PROBE_INFO);
        if (!f.exists()){
            return true;
        }

        f = new File(PROBE_PATH + File.separator + "probe" + File.separator + "probe.json");
        if(!f.exists()){
            return true;
        }

        ProbeInfoBean bean = getProbeMD5(Utils.readAll(PROBE_PATH + File.separator + PROBE_INFO));
        if(bean == null){
            return true;
        }
        if(rawbean != null){
            if(rawbean.getVersion() > bean.getVersion()){
                return true;
            }
        }
        if(BuildConfig.DEBUG){
            return true;
        }
        return false;
    }

    public static String loadProbe(Context context) {
        PROBE_PATH = context.getExternalFilesDir(null).getAbsolutePath();
        PROBE_CACHE_PATH = context.getExternalCacheDir().getAbsolutePath();

        if(isUnRawProbeZip(getRawMD5(context))){
            unRawProbeZip(context,PROBE_PATH);
        }

        return Utils.readAll(PROBE_PATH + File.separator + "probe" + File.separator + "probe.json");
    }

    public static void downloadProbe(final String md5){
        String url = getBaseUrl() + "/download/probe/probe.zip";
        HttpUtil.get().download(url, PROBE_CACHE_PATH, PROBE_ZIP, new HttpUtil.OnDownloadListener() {
            @Override
            public void onDownloadSuccess(File file) {
                if(FileValidateUtil.validateFile(FileValidateUtil.TypeEnum.MD5,md5,file)){
                    synchronized (ProbeUtils.class) {
                        Utils.delFile(new File(PROBE_PATH + File.separator + PROBE_INFO));
                        Utils.delFile(new File(PROBE_PATH + File.separator + "probe"));
                        ZipUtils.UnZipFolder(PROBE_CACHE_PATH + File.separator + PROBE_ZIP, PROBE_PATH);
                        Utils.copyFile(PROBE_CACHE_PATH + File.separator + PROBE_INFO,
                                PROBE_PATH + File.separator + PROBE_INFO);
                    }
                }
            }

            @Override
            public void onDownloading(int progress) {

            }

            @Override
            public void onDownloadFailed(Exception e) {

            }
        });
    }
    public static void downloadProbe(){
        String url = getBaseUrl() + "/download/probe/probezip.json";

        Utils.delFile(new File(PROBE_CACHE_PATH + File.separator + PROBE_INFO));
        Utils.delFile(new File(PROBE_CACHE_PATH + File.separator + PROBE_ZIP));

        HttpUtil.get().download(url, PROBE_CACHE_PATH, PROBE_INFO, new HttpUtil.OnDownloadListener() {
            @Override
            public void onDownloadSuccess(File file) {
                ProbeInfoBean bean1 = getProbeMD5(Utils.readAll(PROBE_CACHE_PATH + File.separator + PROBE_INFO));
                ProbeInfoBean bean2 = getProbeMD5(Utils.readAll(PROBE_PATH + File.separator + PROBE_INFO));
                if(bean1 != null && bean2 != null){
                    if(bean1.getVersion() > bean2.getVersion()){
                        if(!bean1.getMd5().equalsIgnoreCase(bean2.getMd5())){
                            downloadProbe(bean1.getMd5());
                        }
                    }
                }
            }

            @Override
            public void onDownloading(int progress) {

            }

            @Override
            public void onDownloadFailed(Exception e) {

            }
        });
    }

    private static ProbeInfoBean getProbeMD5(String str){
        try {
            if(str != null && !str.isEmpty()) {
                ProbeInfoBean bean = new ProbeInfoBean();
                JSONObject jsonObject = new JSONObject(str);
                String md5 = jsonObject.getString("md5");
                int ver = jsonObject.getInt("version");
                bean.setVersion(ver);
                bean.setMd5(md5.toLowerCase());
                return bean;
            }
        } catch (JSONException e) {
            e.printStackTrace();
        }
        return null;
    }

    private static String getLanguage() {
        Locale l = Locale.getDefault();
        return l.getLanguage().toLowerCase() +"_"+ l.getCountry().toLowerCase();
    }
    public static String getBaseUrl(){
        String str = getLanguage();
        if(str.startsWith("zh_cn")){
            return "http://www.micsig.com.cn";
        }
        return "http://www.micsig.com";
    }
    public static byte [] readBin(String hw,int vercode,int mcuidx){
        synchronized (ProbeUtils.class) {
            final String s = "app_" + hw + "_" + String.format("%03d_%02d.bin", vercode, mcuidx);
            File f = new File(PROBE_PATH + File.separator + "probe");
            if (f.exists()) {
                File[] list = f.listFiles(new FilenameFilter() {
                    @Override
                    public boolean accept(File dir, String name) {
                        return name.equalsIgnoreCase(s);
                    }
                });
                if (list != null && list.length > 0) {
                    f = list[0];
                    int size = (int) f.length();
                    int n = size % 128;
                    if (n > 0) {
                        size += 128 - n;
                    }
                    byte[] bytes = new byte[size];

                    FileInputStream fileInputStream = null;

                    try {
                        fileInputStream = new FileInputStream(f);
                        int r = 0;
                        n = 0;
                        size = (int) f.length();
                        while (n < size) {
                            r = fileInputStream.read(bytes, n, size - n);
                            if (r <= 0) {
                                break;
                            }
                            n += r;
                        }
                    } catch (IOException e) {
                        e.printStackTrace();
                    } finally {
                        if (fileInputStream != null) {
                            try {
                                fileInputStream.close();
                            } catch (IOException e) {
                                e.printStackTrace();
                            }
                        }
                    }
                    if (n == size) {
                        for (int i = n; i < bytes.length; i++) {
                            bytes[i] = (byte) 0xFF;
                        }
                        return bytes;
                    }
                }
            }
            return null;
        }
    }


    public static int findBinVerCode(String hw,int vercode){
        synchronized (ProbeUtils.class) {
            File f = new File(PROBE_PATH + File.separator + "probe");
            if (f.exists()) {
                String[] list = f.list(new FilenameFilter() {
                    @Override
                    public boolean accept(File dir, String name) {
                        String s = name.toLowerCase();
                        return s.startsWith("app_") && s.endsWith(".bin");
                    }
                });
                if (list != null && list.length > 0) {
                    for (String s : list) {
                        String[] v = s.split("\\.|_");
                        if (v != null && v.length > 0) {
                            if (hw.equalsIgnoreCase(v[1])) {
                                int c = 0;
                                try {
                                    c = Integer.parseInt(v[2]);
                                } catch (NumberFormatException e) {
                                    e.printStackTrace();
                                }
                                if (c > vercode) {
                                    vercode = c;
                                }
                            }
                        }
                    }
                }
            }
            return vercode;
        }
    }

}
