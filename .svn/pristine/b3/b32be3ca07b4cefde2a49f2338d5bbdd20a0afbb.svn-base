<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/startCondition"
    android:layout_width="match_parent"
    android:layout_height="54px">


    <TextView
        android:id="@+id/yearInput"
        style="@style/editTextStyleNoStork"
        android:layout_width="60px"
        android:layout_height="54px"
        android:gravity="center"
        android:maxLines="1"
        android:text="2025" />

    <TextView
        android:id="@+id/yearLabel"
        style="@style/textStyle"
        android:layout_width="50px"
        android:layout_height="match_parent"
        android:gravity="center"
        android:text="@string/Year"
        android:textColor="@color/textColorNewTopViewEnable" />

    <TextView
        android:id="@+id/monthInput"
        style="@style/editTextStyleNoStork"
        android:layout_width="50px"
        android:layout_height="54px"
        android:gravity="center"
        android:maxLines="1"
        android:text="1" />

    <TextView
        android:id="@+id/monthLabel"
        style="@style/textStyle"
        android:layout_width="50px"
        android:layout_height="match_parent"
        android:gravity="center"
        android:text="@string/Month"
        android:textColor="@color/textColorNewTopViewEnable" />

    <TextView
        android:id="@+id/dayInput"
        style="@style/editTextStyleNoStork"
        android:layout_width="50px"
        android:layout_height="54px"
        android:gravity="center"
        android:maxLines="1"
        android:text="1" />

    <TextView
        android:id="@+id/dayLabel"
        style="@style/textStyle"
        android:layout_width="50px"
        android:layout_height="match_parent"
        android:gravity="center"
        android:text="@string/Day"
        android:textColor="@color/textColorNewTopViewEnable" />

    <TextView
        android:id="@+id/hourInput"
        style="@style/editTextStyleNoStork"
        android:layout_width="50px"
        android:layout_height="54px"
        android:gravity="center"
        android:maxLines="1"
        android:text="1" />

    <TextView
        android:id="@+id/hourLabel"
        style="@style/textStyle"
        android:layout_width="50px"
        android:layout_height="match_parent"
        android:gravity="center"
        android:text="@string/Hour"
        android:textColor="@color/textColorNewTopViewEnable" />

    <TextView
        android:id="@+id/minuteInput"
        style="@style/editTextStyleNoStork"
        android:layout_width="50px"
        android:layout_height="54px"
        android:gravity="center"
        android:maxLines="1"
        android:text="1" />

    <TextView
        android:id="@+id/minuteLabel"
        style="@style/textStyle"
        android:layout_width="50px"
        android:layout_height="match_parent"
        android:gravity="center"
        android:text="@string/Minute"
        android:textColor="@color/textColorNewTopViewEnable" />

    <TextView
        android:id="@+id/secondInput"
        style="@style/editTextStyleNoStork"
        android:layout_width="50px"
        android:layout_height="54px"
        android:gravity="center"
        android:maxLines="1"
        android:text="1" />

    <TextView
        android:id="@+id/secondLabel"
        style="@style/textStyle"
        android:layout_width="50px"
        android:layout_height="match_parent"
        android:gravity="center"
        android:text="@string/Second"
        android:textColor="@color/color_Time_Text_whiter" />
</LinearLayout>