<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="android:Theme.Material.Light.DarkActionBar">
        <!-- Customize your theme here. -->
    </style>

    <style name="textStyleMiddlebarRight">
        <item name="android:textColor">@color/textColor</item>
        <item name="android:textSize">11px</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="textStyleMiddlebarRightMain">
        <item name="android:textColor">@color/textColor</item>
        <item name="android:textSize">14px</item>
        <item name="android:textStyle">bold</item>
        <item name="android:gravity">center</item>
    </style>

    <style name="scrollViewStyle">
        <item name="android:overScrollMode">never</item>
        <item name="android:scrollbars">none</item>
    </style>

    <style name="measure_statics_dialog_title">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">40px</item>
        <item name="android:layout_marginLeft">18px</item>
        <item name="android:layout_marginRight">18px</item>
        <item name="android:textSize">20px</item>
        <item name="android:visibility">visible</item>
        <item name="android:lines">1</item>
        <item name="android:ellipsize">end</item>
        <item name="android:gravity">center</item>

    </style>
    <style name="measure_statics_dialog_content">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">30px</item>
        <item name="android:textSize">20px</item>
        <item name="android:layout_marginTop">4px</item>
        <item name="android:ellipsize">end</item>
        <item name="android:lines">1</item>
        <item name="android:gravity">center</item>
    </style>

</resources>
