<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <View
        android:id="@+id/dividerTop"
        android:layout_width="match_parent"
        android:layout_height="1px"
        android:layout_marginStart="2px"
        android:layout_marginEnd="2px"
        />

    <TextView
        android:id="@+id/title"
        style="@style/textStylePrompt"
        android:layout_width="match_parent"
        android:layout_height="40px"
        android:layout_below="@+id/dividerTop"
        android:gravity="center"
        android:maxLines="1"
        android:text="Ref1" />

    <TextView
        android:id="@+id/time"
        style="@style/textStylePrompt"
        android:layout_width="match_parent"
        android:layout_height="25px"
        android:layout_below="@+id/title"
        android:layout_marginBottom="5px"
        android:gravity="center"
        android:maxLines="1"
        android:text="2017-03-16  10:30:52"
        android:textSize="13px" />

    <View
        android:id="@+id/dividerBottom"
        android:layout_width="match_parent"
        android:layout_height="1px"
        android:layout_marginStart="2px"
        android:layout_marginEnd="2px"
        android:layout_below="@+id/time" />

    <View
        android:id="@+id/dividerLeft"
        android:layout_width="1px"
        android:layout_height="wrap_content"
        android:layout_marginStart="2px"
        android:layout_alignParentStart="true"
        android:layout_alignTop="@+id/dividerTop"
        android:layout_alignBottom="@+id/dividerBottom" />

    <View
        android:id="@+id/dividerRight"
        android:layout_width="1px"
        android:layout_height="wrap_content"
        android:layout_marginEnd="2px"
        android:layout_alignParentEnd="true"
        android:layout_alignTop="@+id/dividerTop"
        android:layout_alignBottom="@+id/dividerBottom" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1px"
        android:layout_below="@+id/dividerBottom"
        android:background="@color/color_division_line_1f1f1f"
        android:layout_marginStart="11px"
        android:layout_marginEnd="11px"
        />
    <View
        android:layout_width="match_parent"
        android:layout_height="1px"
        android:layout_below="@+id/dividerBottom"
        android:background="@color/bgNewTopAllLayout"
        android:layout_marginStart="11px"
        android:layout_marginEnd="11px"
        />
</RelativeLayout>