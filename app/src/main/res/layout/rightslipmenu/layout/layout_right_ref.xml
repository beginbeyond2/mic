            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintLeft_toLeftOf="@+id/r4EditLayout"
            app:layout_constraintRight_toRightOf="@+id/r4EditLayout"
            />

        <TextView
            android:id="@+id/r4RecallHead"
            style="@style/textStylePrompt"
            android:layout_width="104px"
            android:layout_height="120px"
            android:layout_marginBottom="10px"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/r4Title"
            android:gravity="center"
            android:text="@string/refRecall" />

        <LinearLayout
            android:id="@+id/r4EditLayout"
            android:layout_width="320px"
            android:layout_height="120px"
            android:background="@drawable/bg_rightslipmenu_ref_edit"
            android:orientation="vertical"
            app:layout_constraintLeft_toRightOf="@+id/r4RecallHead"
            app:layout_constraintTop_toBottomOf="@id/r4Title"
            >

            <TextView
                android:id="@+id/r4EditTop"
