<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextView
        android:id="@+id/linTypeHead"
        style="@style/rightHeadText"
        android:layout_width="120px"
        android:layout_height="54px"
        android:layout_marginStart="0px"
        android:layout_marginTop="7px"
        android:gravity="center_vertical"
        android:text="@string/serialsLinType" />

    <com.micsig.tbook.ui.rightslipmenu.RightViewSelect
        android:id="@+id/linType"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        app:array="@array/serialsLinType"
        app:arrayOrientation="horizontalEachRow3"
        app:itemHeight="54px"
        app:itemMargin="7px"
        app:itemWidth="108px" />

    <View
        android:id="@+id/divider0"
        android:layout_width="match_parent"
        android:layout_height="2px"
        android:layout_below="@id/linType"
        android:layout_marginVertical="7px"
        android:layout_marginEnd="7px"
        android:background="@drawable/bg_right_layout_divider" />

    <TextView
        android:id="@+id/sourceHead"
        style="@style/rightHeadText"
        android:layout_width="120px"
        android:layout_height="54px"
        android:layout_below="@+id/divider0"
        android:layout_marginStart="0px"
        android:layout_marginTop="7px"
        android:gravity="center_vertical"
        android:text="@string/serialsLinSource" />

    <com.micsig.tbook.ui.rightslipmenu.RightViewSelect
        android:id="@+id/source"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/divider0"
        android:layout_alignParentEnd="true"
        app:array="@array/channelsNameEight"
        app:arrayOrientation="horizontalEachRow4"
        app:itemHeight="54px"
        app:itemMargin="7px"
        app:itemWidth="108px" />

    <View
        android:id="@+id/divider1"
        android:layout_width="match_parent"
        android:layout_height="2px"
        android:layout_below="@id/source"
        android:layout_marginVertical="7px"
        android:layout_marginEnd="7px"
        android:background="@drawable/bg_right_layout_divider" />

    <LinearLayout
        android:id="@+id/idleLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/divider1"
        android:layout_marginVertical="7px"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            style="@style/rightHeadText"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginStart="0px"
            android:gravity="center"
            android:text="@string/serialsUartIdle" />

        <View
            android:layout_width="0dp"
            android:layout_height="1px"
            android:layout_weight="1" />

        <com.micsig.tbook.ui.rightslipmenu.RightViewSelect
            android:id="@+id/idle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end|center_vertical"
            app:array="@array/serialsUartIdle"
            app:arrayOrientation="horizontalEachRow2"
            app:itemHalfCornerEach="each_108_54"
            app:itemHeight="54px"
            app:itemStartAndEndBgHalfCorner="true"
            app:itemWidth="108px" />
    </LinearLayout>

    <View
        android:id="@+id/divider2"
        android:layout_width="match_parent"
        android:layout_height="2px"
        android:layout_below="@id/idleLayout"
        android:layout_marginVertical="7px"
        android:layout_marginEnd="7px"
        android:background="@drawable/bg_right_layout_divider" />

    <TextView
        android:id="@+id/baudRateHead"
        style="@style/rightHeadText"
        android:layout_width="wrap_content"
        android:layout_height="54px"
        android:layout_below="@id/divider2"
        android:layout_marginStart="0px"
        android:layout_marginTop="7px"
        android:gravity="center_vertical"
        android:text="@string/serialsLinBaudRate" />

    <com.micsig.tbook.ui.rightslipmenu.RightViewSelect
        android:id="@+id/baudRate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/divider2"
        android:layout_alignParentEnd="true"
        android:layout_marginStart="25px"
        app:array="@array/serialsLinBaudRate"
        app:arrayOrientation="horizontalEachRow4"
        app:itemHeight="54px"
        app:itemMargin="7px"
        app:itemWidth="108px" />

    <com.micsig.tbook.ui.rightslipmenu.RightViewUserDefineEdit
        android:id="@+id/userDefineSerialsLin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/baudRate"
        android:layout_alignEnd="@id/baudRate"
        android:layout_marginTop="7px"
        android:layout_marginEnd="7px" />
</RelativeLayout>