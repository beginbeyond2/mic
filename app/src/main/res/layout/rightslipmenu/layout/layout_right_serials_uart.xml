<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">


    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/rxHead"
            style="@style/rightHeadText"
            android:layout_width="120px"
            android:layout_height="54px"
            android:layout_marginStart="0px"
            android:layout_marginTop="7px"
            android:gravity="center_vertical"
            android:text="@string/serialsUartRx" />

        <com.micsig.tbook.ui.rightslipmenu.RightViewSelect
            android:id="@+id/rx"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            app:array="@array/channelsNameEight"
            app:arrayOrientation="horizontalEachRow4"
            app:itemHeight="54px"
            app:itemMargin="7px"
            app:itemWidth="108px" />

    </RelativeLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="2px"
        android:layout_marginVertical="7px"
        android:layout_marginEnd="7px"
        android:background="@drawable/bg_right_layout_divider" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginVertical="7px"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            style="@style/rightHeadText"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginStart="0px"
            android:gravity="center"
            android:text="@string/serialsUartIdle" />

        <View
            android:layout_width="0dp"
            android:layout_height="1px"
            android:layout_weight="1" />

        <com.micsig.tbook.ui.rightslipmenu.RightViewSelect
            android:id="@+id/idle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end|center_vertical"
            android:layout_marginEnd="7px"
            app:array="@array/serialsUartIdle"
            app:arrayOrientation="horizontalEachRow2"
            app:itemHalfCornerEach="each_108_54"
            app:itemHeight="54px"
            app:itemStartAndEndBgHalfCorner="true"
            app:itemWidth="108px" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="2px"
        android:layout_marginVertical="7px"
        android:layout_marginEnd="7px"
        android:background="@drawable/bg_right_layout_divider" />


    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            style="@style/rightHeadText"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginStart="0px"
            android:gravity="center"
            android:text="@string/serialsUartCheck" />

        <View
            android:layout_width="0dp"
            android:layout_height="1px"
            android:layout_weight="1" />

        <com.micsig.tbook.ui.rightslipmenu.RightViewSelect
            android:id="@+id/check"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:array="@array/serialsUartCheck"
            app:arrayOrientation="horizontalEachRow3"
            app:itemHeight="54px"
            app:itemMargin="7px"
            app:itemWidth="108px" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="2px"
        android:layout_marginVertical="7px"
        android:layout_marginEnd="7px"
        android:background="@drawable/bg_right_layout_divider" />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <TextView
            android:id="@+id/bitsHead"
            style="@style/rightHeadText"
            android:layout_width="wrap_content"
            android:layout_height="70px"
            android:layout_marginStart="0px"
            android:gravity="center"
            android:text="@string/serialsUartBits" />

        <com.micsig.tbook.ui.rightslipmenu.RightViewSelect
            android:id="@+id/bits"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentEnd="true"
            app:array="@array/serialsUartBits"
            app:arrayOrientation="horizontalEachRow4"
            app:firstShowCount="1"
            app:itemHeight="54px"
            app:itemMargin="7px"
            app:itemWidth="108px" />
    </RelativeLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="2px"
        android:layout_marginVertical="7px"
        android:layout_marginEnd="7px"
        android:background="@drawable/bg_right_layout_divider" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <TextView
            style="@style/textStylePrompt"
            android:layout_width="wrap_content"
            android:layout_height="54px"
            android:layout_below="@+id/driver3"
            android:gravity="center_vertical"
            android:text="@string/serialsUartBaudRate" />


        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center|right">

            <com.micsig.tbook.ui.rightslipmenu.RightViewSelect
                android:id="@+id/baudRate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:array="@array/serialsUartBaudRate"
                app:arrayOrientation="horizontalEachRow4"
                app:itemHeight="54px"
                app:itemMargin="7px"
                app:itemWidth="108px" />

            <com.micsig.tbook.ui.rightslipmenu.RightViewUserDefineEdit
                android:id="@+id/userDefineSerialsUart"
                android:layout_width="230px"
                android:layout_height="54px"
                android:layout_alignEnd="@+id/baudRate"
                android:layout_alignBottom="@+id/baudRate"
                android:layout_marginEnd="7px"
                android:layout_marginBottom="7px" />
        </RelativeLayout>

    </LinearLayout>


    <View
        android:layout_width="match_parent"
        android:layout_height="2px"
        android:layout_marginVertical="7px"
        android:layout_marginEnd="7px"
        android:background="@drawable/bg_right_layout_divider" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <TextView
            style="@style/rightHeadText"
            android:layout_width="wrap_content"
            android:layout_height="54px"
            android:layout_marginStart="0px"
            android:gravity="center"
            android:text="@string/serialsUartDisplay" />

        <View
            android:layout_width="0dp"
            android:layout_height="1px"
            android:layout_weight="1" />

        <com.micsig.tbook.ui.rightslipmenu.RightViewSelect
            android:id="@+id/display"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:array="@array/serialsUartDisplay"
            app:arrayOrientation="horizontalEachRow3"
            app:itemHeight="54px"
            app:itemMargin="7px"
            app:itemWidth="108px" />
    </LinearLayout>

</LinearLayout>