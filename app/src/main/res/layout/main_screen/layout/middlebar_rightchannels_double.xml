<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/middlebarChannel"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main_outside"
    android:clickable="true"
    android:orientation="vertical">

    <com.micsig.tbook.tbookscope.main.mainright.MainRightLayoutItemChannel
        android:id="@+id/ch1Layout_doubleChannel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/mainRightChannelDoubleItemMargin"
        app:bgLeftChecked="@drawable/l_ch1"
        app:bgLeftUnChecked="@drawable/l_unclick"
        app:bgProbeDetail="@drawable/ch1_10x"
        app:bgRightBottomTouchDown="@drawable/ch1_v_press"
        app:bgRightBottomTouchUp="@drawable/ch1_v"
        app:bgRightTopTouchDown="@drawable/ch1_mv_press"
        app:bgRightTopTouchUp="@drawable/ch1_mv"
        app:checked="false"
        app:showLayoutMarginTop="@dimen/mainRightChannelDoubleItemTextMargin"
        app:text="CH1" />

    <com.micsig.tbook.tbookscope.main.mainright.MainRightLayoutItemChannel
        android:id="@+id/ch2Layout_doubleChannel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="@dimen/mainRightChannelDoubleItemMargin"
        app:bgLeftChecked="@drawable/l_ch2"
        app:bgLeftUnChecked="@drawable/l_unclick"
        app:bgProbeDetail="@drawable/ch2_10x"
        app:bgRightBottomTouchDown="@drawable/ch2_v_press"
        app:bgRightBottomTouchUp="@drawable/ch2_v"
        app:bgRightTopTouchDown="@drawable/ch2_mv_press"
        app:bgRightTopTouchUp="@drawable/ch2_mv"
        app:checked="false"
        app:showLayoutMarginTop="@dimen/mainRightChannelDoubleItemTextMargin"
        app:text="CH2" />

    <TextView
        android:id="@+id/sample_doubleChannel"
        style="@style/textStyleMiddlebarRight"
        android:layout_width="56px"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/mainRightSample"
        android:textSize="12px" />
</RelativeLayout>
