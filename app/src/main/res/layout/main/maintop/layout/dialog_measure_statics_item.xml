<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    >
    <TextView
        android:id="@+id/txt_row1"
        android:layout_width="match_parent"
        android:layout_height="30px"
        style="@style/measure_statics_dialog_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        android:text="row1"
        />
    <TextView
        android:id="@+id/txt_row2"
        android:layout_width="match_parent"
        android:layout_height="30px"
        style="@style/measure_statics_dialog_content"
        app:layout_constraintTop_toBottomOf="@+id/txt_row1"
        app:layout_constraintLeft_toLeftOf="parent"
        android:text="row2"
        />
    <TextView
        android:id="@+id/txt_row3"
        android:layout_width="match_parent"
        android:layout_height="30px"
        style="@style/measure_statics_dialog_content"
        app:layout_constraintTop_toBottomOf="@+id/txt_row2"
        app:layout_constraintLeft_toLeftOf="parent"
        android:text="row3"
        />
    <TextView
        android:id="@+id/txt_row4"
        android:layout_width="match_parent"
        android:layout_height="30px"
        style="@style/measure_statics_dialog_content"
        app:layout_constraintTop_toBottomOf="@+id/txt_row3"
        app:layout_constraintLeft_toLeftOf="parent"
        android:text="row4"
        />
    <TextView
        android:id="@+id/txt_row5"
        android:layout_width="match_parent"
        android:layout_height="30px"
        style="@style/measure_statics_dialog_content"
        app:layout_constraintTop_toBottomOf="@+id/txt_row4"
        app:layout_constraintLeft_toLeftOf="parent"
        android:text="row5"
        />
    <TextView
        android:id="@+id/txt_row6"
        android:layout_width="match_parent"
        android:layout_height="30px"
        style="@style/measure_statics_dialog_content"
        app:layout_constraintTop_toBottomOf="@+id/txt_row5"
        app:layout_constraintLeft_toLeftOf="parent"
        android:text="row6"
        />
    <TextView
        android:id="@+id/txt_title"
        android:layout_width="match_parent"
        android:layout_height="40px"
        style="@style/measure_statics_dialog_title"
        app:layout_constraintTop_toBottomOf="@id/txt_row6"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        android:gravity="center"
        android:text="title"
        />


</androidx.constraintlayout.widget.ConstraintLayout>