<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <Button
        android:id="@+id/clear"
        style="@style/buttonStyle"
        android:layout_width="@dimen/formBtnClearWidth"
        android:layout_height="@dimen/formBtnClearHeight"
        android:layout_alignParentBottom="true"
        android:layout_alignParentEnd="true"
        android:layout_marginBottom="@dimen/formBtnClearMarginBottomNew"
        android:layout_marginEnd="@dimen/formBtnClearMarginEnd"
        android:text="@string/serialsWordClear"
        android:textAllCaps="false" />

    <TextView
        android:id="@+id/msg"
        android:layout_width="match_parent"
        android:layout_height="@dimen/formMsgHeight"
        android:layout_alignParentBottom="true"
        android:background="@drawable/shape_frame_bg_black"
        android:gravity="center_vertical"
        android:paddingStart="15px"
        android:textColor="@color/textSerialsWordMsg"
        android:textStyle="bold" />

    <View
        android:id="@+id/dividerY"
        android:layout_width="match_parent"
        android:layout_height="@dimen/serials_word_divider_width"
        android:layout_marginTop="@dimen/formHeightTitle"
        android:background="@color/color_division_line_41464D" />

    <View
        android:id="@+id/dividerX1"
        android:layout_width="@dimen/serials_word_divider_width"
        android:layout_height="match_parent"
        android:layout_above="@+id/msg"
        android:layout_marginStart="@dimen/lin_ch_width"
        android:background="@color/color_division_line_41464D" />

    <View
        android:id="@+id/dividerX2"
        android:layout_width="@dimen/serials_word_divider_width"
        android:layout_height="match_parent"
        android:layout_above="@+id/msg"
        android:layout_toEndOf="@+id/dividerX1"
        android:layout_marginStart="@dimen/lin_time_width"
        android:background="@color/color_division_line_41464D" />

    <View
        android:id="@+id/dividerX3"
        android:layout_width="@dimen/serials_word_divider_width"
        android:layout_height="match_parent"
        android:layout_above="@+id/msg"
        android:layout_toEndOf="@+id/dividerX2"
        android:layout_marginStart="@dimen/lin_id_width"
        android:background="@color/color_division_line_41464D" />

    <View
        android:id="@+id/dividerX4"
        android:layout_width="@dimen/serials_word_divider_width"
        android:layout_height="match_parent"
        android:layout_above="@+id/msg"
        android:layout_alignParentEnd="true"
        android:layout_marginEnd="@dimen/lin_trigger_width"
        android:background="@color/color_division_line_41464D" />

    <View
        android:id="@+id/dividerX5"
        android:layout_width="@dimen/serials_word_divider_width"
        android:layout_height="match_parent"
        android:layout_above="@+id/msg"
        android:layout_toStartOf="@+id/dividerX4"
        android:layout_marginEnd="@dimen/lin_crc_width"
        android:background="@color/color_division_line_41464D" />

    <View
        android:id="@+id/dividerX6"
        android:layout_width="@dimen/serials_word_divider_width"
        android:layout_height="match_parent"
        android:layout_above="@+id/msg"
        android:layout_toStartOf="@+id/dividerX5"
        android:layout_marginEnd="@dimen/lin_error_width"
        android:background="@color/color_division_line_41464D" />

    <View
        android:id="@+id/dividerY2"
        android:layout_width="match_parent"
        android:layout_height="@dimen/serials_word_divider_width"
        android:layout_above="@+id/msg"
        android:background="@color/color_division_line_41464D" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/formHeightTitle"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/ch"
            style="@style/textStyle"
            android:layout_width="@dimen/lin_id_width"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="@string/serialsWordLinTitleCh" />

        <TextView
            android:id="@+id/time"
            style="@style/textStyle"
            android:layout_width="@dimen/lin_time_width"
            android:layout_height="match_parent"
            android:gravity="center"
            android:layout_marginStart="@dimen/serials_word_divider_width"
            android:text="@string/serialsWordLinTitleTime" />

        <TextView
            android:id="@+id/id"
            style="@style/textStyle"
            android:layout_width="@dimen/lin_id_width"
            android:layout_height="match_parent"
            android:gravity="center"
            android:layout_marginStart="@dimen/serials_word_divider_width"
            android:text="@string/serialsWordLinTitleId" />

        <TextView
            android:id="@+id/data"
            style="@style/textStyle"
            android:layout_width="0px"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:layout_marginEnd="@dimen/serials_word_divider_width"
            android:layout_marginStart="@dimen/serials_word_divider_width"
            android:text="@string/serialsWordLinTitleData" />

        <TextView
            android:id="@+id/error"
            style="@style/textStyle"
            android:layout_width="@dimen/lin_error_width"
            android:layout_height="match_parent"
            android:gravity="center"
            android:layout_marginEnd="@dimen/serials_word_divider_width"
            android:text="@string/serialsWordLinTitleError" />

        <TextView
            android:id="@+id/check"
            style="@style/textStyle"
            android:layout_width="@dimen/lin_crc_width"
            android:layout_height="match_parent"
            android:gravity="center"
            android:layout_marginEnd="@dimen/serials_word_divider_width"
            android:text="@string/serialsWordLinTitleCheck" />

        <TextView
            android:id="@+id/trigger"
            style="@style/textStyle"
            android:layout_width="@dimen/lin_trigger_width"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="@string/serialsWordLinTitleTrigger" />
    </LinearLayout>

    <com.micsig.tbook.tbookscope.main.maincenter.serialsword.UnFlingRecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/msg"
        android:layout_below="@+id/dividerY"
        android:background="@android:color/transparent"
        android:fadeScrollbars="false"
        android:overScrollMode="never"
        android:scrollbars="vertical"
        android:scrollbarThumbVertical="@color/scaleDivider"
    />

    <com.micsig.tbook.tbookscope.main.maincenter.serialsword.SerialsWordLinSingleScreenTextView
        android:id="@+id/singleScreenTextView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/msg"
        android:layout_below="@+id/dividerY"
        android:background="@android:color/transparent" />

    <RelativeLayout
        android:id="@+id/scrollBarLayout"
        android:layout_width="50px"
        android:layout_height="match_parent"
        android:layout_above="@+id/msg"
        android:layout_alignParentEnd="true"
        android:layout_below="@+id/dividerY"
        android:clickable="true">

        <View
            android:id="@+id/scrollBarView"
            android:layout_width="5px"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_alignParentEnd="true"
            android:background="@color/scaleDivider" />
    </RelativeLayout>
</RelativeLayout>