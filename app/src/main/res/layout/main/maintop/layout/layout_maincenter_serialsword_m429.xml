<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

<!--    <Button-->
<!--        android:id="@+id/clear"-->
<!--        style="@style/buttonStyle"-->
<!--        android:layout_width="@dimen/formBtnClearWidth"-->
<!--        android:layout_height="@dimen/formBtnClearHeight"-->
<!--        android:layout_alignParentBottom="true"-->
<!--        android:layout_alignParentEnd="true"-->
<!--        android:layout_marginBottom="@dimen/formBtnClearMarginBottom"-->
<!--        android:layout_marginEnd="@dimen/formBtnClearMarginEnd"-->
<!--        android:text="@string/serialsWordClear"-->
<!--        android:textAllCaps="false" />-->

    <RelativeLayout
        android:id="@+id/msgLayout"
        android:layout_width="match_parent"
        android:layout_height="@dimen/formMsgHeight"
        android:layout_alignParentBottom="true"
        android:background="@drawable/shape_frame_bg_black" >

        <TextView
            android:id="@+id/m429WordTitle"
            style="@style/textStyle"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:gravity="center"
            android:paddingStart="15px"
            android:text="字数:"/>

        <TextView
            android:id="@+id/m429WordDetail"
            style="@style/textStyle"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_toEndOf="@+id/m429WordTitle"
            android:gravity="center"
            android:text="0000000000"/>

        <TextView
            android:id="@+id/m429ErrorTitle"
            style="@style/textStyle"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_marginStart="900px"
            android:gravity="center"
            android:text="Error:"/>

        <TextView
            android:id="@+id/m429ErrorDetail"
            style="@style/textStyle"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:layout_toEndOf="@+id/m429ErrorTitle"
            android:layout_marginEnd="15px"
            android:gravity="center"
            android:text="0000000000"/>

        <Button
            android:id="@+id/clear"
            style="@style/buttonStyle"
            android:layout_width="@dimen/formBtnClearWidth"
            android:layout_height="@dimen/formBtnClearHeight"
            android:layout_alignParentBottom="true"
            android:layout_alignParentEnd="true"
            android:layout_marginBottom="@dimen/formBtnClearMarginBottomNew"
            android:layout_marginEnd="@dimen/formBtnClearMarginEnd"
            android:text="@string/serialsWordClear"
            android:textAllCaps="false" />

    </RelativeLayout>

    <View
        android:id="@+id/dividerY"
        android:layout_width="match_parent"
        android:layout_height="@dimen/serials_word_divider_width"
        android:layout_marginTop="@dimen/formHeightTitle"
        android:background="@color/color_division_line_41464D" />

    <View
        android:id="@+id/dividerX1"
        android:layout_width="@dimen/serials_word_divider_width"
        android:layout_height="match_parent"
        android:layout_above="@+id/msgLayout"
        android:layout_marginStart="@dimen/arin429_ch_width"
        android:background="@color/color_division_line_41464D" />

    <View
        android:id="@+id/dividerX2"
        android:layout_width="@dimen/serials_word_divider_width"
        android:layout_height="match_parent"
        android:layout_above="@+id/msgLayout"
        android:layout_toEndOf="@+id/dividerX1"
        android:layout_marginStart="@dimen/arin429_time_width"
        android:background="@color/color_division_line_41464D" />

    <View
        android:id="@+id/dividerX3"
        android:layout_width="@dimen/serials_word_divider_width"
        android:layout_height="match_parent"
        android:layout_above="@+id/msgLayout"
        android:layout_toEndOf="@+id/dividerX2"
        android:layout_marginStart="@dimen/arin429_label_width"
        android:background="@color/color_division_line_41464D" />

    <View
        android:id="@+id/dividerX4"
        android:layout_width="@dimen/serials_word_divider_width"
        android:layout_height="match_parent"
        android:layout_above="@+id/msgLayout"
        android:layout_toEndOf="@+id/dividerX3"
        android:layout_marginStart="@dimen/arin429_sdi_width"
        android:background="@color/color_division_line_41464D" />

    <View
        android:id="@+id/dividerX5"
        android:layout_width="@dimen/serials_word_divider_width"
        android:layout_height="match_parent"
        android:layout_above="@+id/msgLayout"
        android:layout_alignParentEnd="true"
        android:layout_marginEnd="@dimen/arin429_trigger_width"
        android:background="@color/color_division_line_41464D" />

    <View
        android:id="@+id/dividerX6"
        android:layout_width="@dimen/serials_word_divider_width"
        android:layout_height="match_parent"
        android:layout_above="@+id/msgLayout"
        android:layout_toStartOf="@+id/dividerX5"
        android:layout_marginEnd="@dimen/arin429_error_width"
        android:background="@color/color_division_line_41464D" />

    <View
        android:id="@+id/dividerX7"
        android:layout_width="@dimen/serials_word_divider_width"
        android:layout_height="match_parent"
        android:layout_above="@+id/msgLayout"
        android:layout_toStartOf="@+id/dividerX6"
        android:layout_marginEnd="@dimen/arin429_ssm_width"
        android:background="@color/color_division_line_41464D" />

    <View
        android:id="@+id/dividerY2"
        android:layout_width="match_parent"
        android:layout_height="@dimen/serials_word_divider_width"
        android:layout_above="@+id/msgLayout"
        android:background="@color/color_division_line_41464D" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="@dimen/formHeightTitle"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/ch"
            style="@style/textStyle"
            android:layout_width="@dimen/arin429_ch_width"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="@string/serialsWordM429TitleCh" />

        <TextView
            android:id="@+id/time"
            style="@style/textStyle"
            android:layout_width="@dimen/arin429_time_width"
            android:layout_height="match_parent"
            android:gravity="center"
            android:layout_marginStart="@dimen/serials_word_divider_width"
            android:text="@string/serialsWordM429TitleTime" />

        <TextView
            android:id="@+id/label"
            style="@style/textStyle"
            android:layout_width="@dimen/arin429_label_width"
            android:layout_height="match_parent"
            android:gravity="center"
            android:layout_marginStart="@dimen/serials_word_divider_width"
            android:text="@string/serialsWordM429TitleLabel" />

        <TextView
            android:id="@+id/sdi"
            style="@style/textStyle"
            android:layout_width="@dimen/arin429_sdi_width"
            android:layout_height="match_parent"
            android:gravity="center"
            android:layout_marginStart="@dimen/serials_word_divider_width"
            android:text="@string/serialsWordM429TitleSdi" />

        <TextView
            android:id="@+id/data"
            style="@style/textStyle"
            android:layout_width="0px"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:layout_marginEnd="@dimen/serials_word_divider_width"
            android:layout_marginStart="@dimen/serials_word_divider_width"
            android:text="@string/serialsWordM429TitleData" />

        <TextView
            android:id="@+id/ssm"
            style="@style/textStyle"
            android:layout_width="@dimen/arin429_ssm_width"
            android:layout_height="match_parent"
            android:gravity="center"
            android:layout_marginEnd="@dimen/serials_word_divider_width"
            android:text="@string/serialsWordM429TitleSsm" />

        <TextView
            android:id="@+id/error"
            style="@style/textStyle"
            android:layout_width="@dimen/arin429_error_width"
            android:layout_height="match_parent"
            android:gravity="center"
            android:layout_marginEnd="@dimen/serials_word_divider_width"
            android:text="@string/serialsWordM429TitleError" />

        <TextView
            android:id="@+id/trigger"
            style="@style/textStyle"
            android:layout_width="@dimen/arin429_trigger_width"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="@string/serialsWordM429TitleTrigger" />
    </LinearLayout>

    <com.micsig.tbook.tbookscope.main.maincenter.serialsword.UnFlingRecyclerView
        android:id="@+id/recyclerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/msgLayout"
        android:layout_below="@+id/dividerY"
        android:background="@android:color/transparent"
        android:fadeScrollbars="false"
        android:overScrollMode="never"
        android:scrollbars="vertical"
        android:scrollbarThumbVertical="@color/scaleDivider"
        />

    <com.micsig.tbook.tbookscope.main.maincenter.serialsword.SerialsWordM429SingleScreenTextView
        android:id="@+id/singleScreenTextView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/msgLayout"
        android:layout_below="@+id/dividerY"
        android:background="@android:color/transparent" />

    <RelativeLayout
        android:id="@+id/scrollBarLayout"
        android:layout_width="50px"
        android:layout_height="match_parent"
        android:layout_above="@+id/msgLayout"
        android:layout_alignParentEnd="true"
        android:layout_below="@+id/dividerY"
        android:clickable="true">

        <View
            android:id="@+id/scrollBarView"
            android:layout_width="5px"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:layout_alignParentEnd="true"
            android:background="@android:color/darker_gray" />
    </RelativeLayout>
</RelativeLayout>