<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <ImageView
        android:id="@+id/leftArrow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        android:background="@drawable/measure_slide_l"
        android:visibility="gone"
        />
<!--    <HorizontalScrollView-->
<!--        android:id="@+id/scrollView"-->
<!--        android:layout_width="0dp"-->
<!--        android:layout_height="match_parent"-->
<!--        android:maxWidth="@dimen/mainCenterWidth"-->
<!--        android:scrollbars="horizontal"-->
<!--        app:layout_constraintLeft_toRightOf="@id/leftArrow"-->
<!--        app:layout_constraintRight_toLeftOf="@id/rightArrow"-->
<!--        >-->

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/measureSpaceLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent">


        <GridLayout
            android:id="@+id/listView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:alignmentMode="alignMargins"
            android:background="@drawable/shape_frame_bg_black"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            android:columnCount="10"
            android:rowCount="4" />

    </androidx.constraintlayout.widget.ConstraintLayout>

<!--    </HorizontalScrollView>-->



    <ImageView
        android:id="@+id/rightArrow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:background="@drawable/measure_slide_r"
        android:visibility="gone"
        />


</androidx.constraintlayout.widget.ConstraintLayout>