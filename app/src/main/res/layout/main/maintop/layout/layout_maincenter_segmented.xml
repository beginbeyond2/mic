<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:ui="http://schemas.android.com/apk/res-auto">
    <LinearLayout
        android:layout_width="226px"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        >

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/dialogSegmentedDisplayTitle"
                style="@style/textStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="32px"
                android:layout_marginTop="25px"
                android:gravity="center"
                android:text="拟合"
                android:textSize="24px"
                android:textColor="@color/color_Text_white" />

            <com.micsig.tbook.ui.MSwitchBox
                android:id="@+id/dialogSegmentedDisplayDetail"
                android:layout_width="72px"
                android:layout_height="36px"
                android:layout_alignParentEnd="true"
                android:layout_marginTop="25px"
                android:layout_marginEnd="33px" />
        </RelativeLayout>

        <RelativeLayout
            android:id="@+id/dialogSegmentedSingleLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="1px"
            android:layout_marginEnd="1px"
            android:layout_marginTop="14px">

            <TextView
                android:id="@+id/singlePlaySpeed"
                style="@style/textStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="33px"
                android:text="X1"
                android:textSize="24px"
                android:textColor="@color/color_Text_white" />

            <Button
                android:id="@+id/singlePlayBtn"
                style="@style/buttonStyle"
                android:layout_width="42px"
                android:layout_height="42px"
                android:layout_alignParentEnd="true"
                android:layout_marginEnd="52px"
                android:background="@drawable/play_normal"
                android:button="@null" />

            <TextView
                android:id="@+id/dialogSingleFirstTime"
                style="@style/textStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/singlePlayBtn"
                android:layout_centerHorizontal="true"
                android:layout_marginTop="15px"
                android:text="0520  11:22:35"
                android:textColor="@color/color_Text_white"
                android:textSize="20px" />

            <RelativeLayout
                android:id="@+id/dialogSingleSmallLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@id/dialogSingleFirstTime">

                <com.micsig.tbook.ui.main.MainViewSegmentedSingleSmall
                    android:id="@+id/dialogSingleSmallView"
                    android:layout_width="160px"
                    android:layout_height="60px"
                    android:layout_centerHorizontal="true"
                    android:layout_marginStart="7px"
                    android:layout_marginTop="7px"
                    android:layout_marginEnd="7px"
                    android:layout_marginBottom="7px"
                    />

                <View
                    android:id="@+id/dialogIconSingleCurLeft"
                    android:layout_width="16px"
                    android:layout_height="wrap_content"
                    android:layout_toLeftOf="@+id/dialogSingleSmallView"
                    android:layout_alignTop="@id/dialogSingleSmallView"
                    android:layout_alignBottom="@id/dialogSingleSmallView"
                    android:layout_marginTop="9px"
                    android:layout_marginBottom="9px"
                    android:background="@drawable/ic_segmentedleft" />

                <View
                    android:id="@+id/dialogIconSingleCurRight"
                    android:layout_width="16px"
                    android:layout_height="wrap_content"
                    android:layout_alignTop="@id/dialogSingleSmallView"
                    android:layout_alignBottom="@id/dialogSingleSmallView"
                    android:layout_toRightOf="@id/dialogSingleSmallView"
                    android:layout_marginTop="9px"
                    android:layout_marginBottom="9px"
                    android:background="@drawable/ic_segmentedright" />

            </RelativeLayout>

            <com.micsig.tbook.ui.main.MainViewSegmentedSingleLarge
                android:id="@+id/dialogSingleLargeView"
                android:layout_width="160px"
                android:layout_height="540px"
                android:layout_centerHorizontal="true"
                android:layout_below="@id/dialogSingleSmallLayout" />

            <TextView
                android:id="@+id/dialogSingleFrameCount"
                style="@style/textStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/dialogSingleLargeView"
                android:layout_centerHorizontal="true"
                android:layout_marginStart="10px"
                android:layout_marginTop="5px"
                android:text="999999"
                android:textColor="@color/color_Text_white"
                android:textSize="24px"/>

            <com.micsig.tbook.ui.MButton_CheckBox
                android:id="@+id/dialogSingleSlip"
                android:layout_width="match_parent"
                android:layout_height="32px"
                android:layout_below="@id/dialogSingleFrameCount"
                android:layout_marginTop="5px"
                ui:checkedBitmap="@drawable/button_up"
                ui:unCheckedBitmap="@drawable/button_lower" />
        </RelativeLayout>

        <RelativeLayout
            android:id="@+id/dialogSegmentedFitLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/dialogFitFirstTime"
                style="@style/textStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                android:text="0520 11:22:35"
                android:textColor="@color/color_Text_white"
                android:textSize="20px" />

            <TextView
                android:id="@+id/dialogFitStartTitle"
                style="@style/textStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/dialogFitFirstTime"
                android:layout_alignParentEnd="true"
                android:layout_marginEnd="32px"
                android:text="@string/centerSegmentedStart"
                android:textColor="@color/color_Text_white"
                android:textSize="24px" />

            <com.micsig.tbook.ui.main.MainLayoutSegmentedFit
                android:id="@+id/dialogFitStartLayout"
                android:layout_width="160px"
                android:layout_height="60px"
                android:layout_centerHorizontal="true"
                android:layout_below="@id/dialogFitStartTitle"
                />

            <TextView
                android:id="@+id/dialogFitEndTitle"
                style="@style/textStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/dialogFitStartLayout"
                android:layout_alignParentEnd="true"
                android:layout_marginTop="10px"
                android:layout_marginEnd="32px"
                android:text="@string/centerSegmentedEnd"
                android:textColor="@color/color_Text_white"
                android:textSize="24px" />

            <com.micsig.tbook.ui.main.MainLayoutSegmentedFit
                android:id="@+id/dialogFitEndLayout"
                android:layout_width="160px"
                android:layout_height="60px"
                android:layout_centerHorizontal="true"
                android:layout_below="@id/dialogFitEndTitle"
                />

            <TextView
                android:id="@+id/dialogFitFrameCount"
                style="@style/textStyle"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/dialogFitEndLayout"
                android:layout_marginStart="10px"
                android:layout_marginBottom="10px"
                android:layout_centerHorizontal="true"
                android:text="999999"
                android:textColor="@color/color_Text_white"
                android:textSize="24px"/>
        </RelativeLayout>

    </LinearLayout>

    <TextView
        android:id="@+id/icon"
        android:layout_width="@dimen/mainTopCenterRadioIconWidth"
        android:layout_height="@dimen/mainTopCenterRadioIconWidth"
        android:layout_margin="@dimen/dividerSize"
        android:background="@drawable/current_dot" />
</merge>