<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android">

    <View
        android:id="@+id/outView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <LinearLayout
        android:id="@+id/showKeyBoardLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_x="0px"
        android:layout_y="@dimen/rightDialogFloatKeyBoardRow0"
        android:clickable="true"
        android:background="@drawable/shape_frame_bg_black"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/ll_input"
            style="@style/editTextStyle"
            android:layout_width="596px"
            android:layout_height="72px"
            android:layout_marginStart="17px"
            android:layout_marginTop="17px"
            android:layout_marginEnd="17px"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/symbol"
                style="@style/textStyle"
                android:layout_width="10px"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="-"
                android:textStyle="bold" />

            <EditText
                android:id="@+id/show"
                style="@style/textStyle"
                android:layout_width="0px"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:gravity="center_vertical|start"
                android:inputType="textNoSuggestions"
                android:maxLines="1"
                android:text="20.0"
                android:digits="0123456789.fpnukmMGT-"
                />
        </LinearLayout>

        <RelativeLayout
            android:id="@+id/gridView"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginStart="9px"
            android:layout_marginTop="9px"
            android:layout_marginEnd="9px"
            android:layout_marginBottom="9px">

            <Button
                android:id="@+id/key_7"
                style="@style/floatKeyBoardKey"
                android:layout_alignParentStart="true"
                android:layout_alignParentTop="true"
                android:tag="0"
                android:text="7" />

            <Button
                android:id="@+id/key_8"
                style="@style/floatKeyBoardKey"
                android:layout_alignParentTop="true"
                android:layout_toEndOf="@id/key_7"
                android:tag="1"
                android:text="8" />

            <Button
                android:id="@+id/key_9"
                style="@style/floatKeyBoardKey"
                android:layout_alignParentTop="true"
                android:layout_toEndOf="@id/key_8"
                android:tag="2"
                android:text="9" />

            <Switch
                android:id="@+id/key_p"
                style="@style/floatKeyBoardKey"
                android:layout_alignParentTop="true"
                android:layout_toEndOf="@id/key_9"
                android:tag="3"
                android:text="p"
                android:thumb="@null"
                android:track="@null" />

            <Switch
                android:id="@+id/key_k"
                style="@style/floatKeyBoardKey"
                android:layout_alignParentTop="true"
                android:layout_toEndOf="@id/key_p"
                android:tag="4"
                android:text="k"
                android:thumb="@null"
                android:track="@null" />

            <Button
                android:id="@+id/key_negative"
                style="@style/floatKeyBoardKey"
                android:layout_alignParentTop="true"
                android:layout_toEndOf="@id/key_k"
                android:tag="5"
                android:text="-" />

            <Button
                android:id="@+id/key_4"
                style="@style/floatKeyBoardKey"
                android:layout_below="@id/key_7"
                android:layout_alignParentStart="true"
                android:tag="6"
                android:text="4" />

            <Button
                android:id="@+id/key_5"
                style="@style/floatKeyBoardKey"
                android:layout_below="@id/key_7"
                android:layout_toEndOf="@id/key_7"
                android:tag="7"
                android:text="5" />

            <Button
                android:id="@+id/key_6"
                style="@style/floatKeyBoardKey"
                android:layout_below="@id/key_7"
                android:layout_toEndOf="@id/key_8"
                android:tag="8"
                android:text="6" />

            <Switch
                android:id="@+id/key_n"
                style="@style/floatKeyBoardKey"
                android:layout_below="@id/key_7"
                android:layout_toEndOf="@id/key_9"
                android:tag="9"
                android:text="n"
                android:thumb="@null"
                android:track="@null" />

            <Switch
                android:id="@+id/key_M"
                style="@style/floatKeyBoardKey"
                android:layout_below="@id/key_7"
                android:layout_toEndOf="@id/key_p"
                android:tag="10"
                android:text="M"
                android:thumb="@null"
                android:track="@null" />

            <Button
                android:id="@+id/key_positive"
                style="@style/floatKeyBoardKey"
                android:layout_below="@id/key_7"
                android:layout_toEndOf="@id/key_k"
                android:tag="11"
                android:text="+" />

            <Button
                android:id="@+id/key_1"
                style="@style/floatKeyBoardKey"
                android:layout_below="@id/key_4"
                android:layout_alignParentStart="true"
                android:tag="12"
                android:text="1" />

            <Button
                android:id="@+id/key_2"
                style="@style/floatKeyBoardKey"
                android:layout_below="@id/key_4"
                android:layout_toEndOf="@id/key_7"
                android:tag="13"
                android:text="2" />

            <Button
                android:id="@+id/key_3"
                style="@style/floatKeyBoardKey"
                android:layout_below="@id/key_4"
                android:layout_toEndOf="@id/key_8"
                android:tag="14"
                android:text="3" />

            <Switch
                android:id="@+id/key_u"
                style="@style/floatKeyBoardKey"
                android:layout_below="@id/key_4"
                android:layout_toEndOf="@id/key_9"
                android:tag="15"
                android:text="μ"
                android:thumb="@null"
                android:track="@null" />

            <Switch
                android:id="@+id/key_G"
                style="@style/floatKeyBoardKey"
                android:layout_below="@id/key_4"
                android:layout_toEndOf="@id/key_p"
                android:tag="16"
                android:text="G"
                android:thumb="@null"
                android:track="@null" />

            <Button
                android:id="@+id/key_del"
                style="@style/floatKeyBoardKey"
                android:layout_below="@id/key_4"
                android:layout_toEndOf="@id/key_k"
                android:tag="17"
                android:text="←" />

            <Button
                android:id="@+id/key_0"
                style="@style/floatKeyBoardKey"
                android:layout_below="@id/key_1"
                android:layout_alignParentStart="true"
                android:tag="18"
                android:text="0" />

            <Button
                android:id="@+id/key_point"
                style="@style/floatKeyBoardKey"
                android:layout_below="@id/key_1"
                android:layout_toEndOf="@id/key_7"
                android:tag="19"
                android:text="." />

            <Switch
                android:id="@+id/key_f"
                style="@style/floatKeyBoardKey"
                android:layout_below="@id/key_1"
                android:layout_toEndOf="@id/key_8"
                android:tag="20"
                android:text="f"
                android:thumb="@null"
                android:track="@null" />

            <Switch
                android:id="@+id/key_m"
                style="@style/floatKeyBoardKey"
                android:layout_below="@id/key_1"
                android:layout_toEndOf="@id/key_9"
                android:tag="21"
                android:text="m"
                android:thumb="@null"
                android:track="@null" />

            <Switch
                android:id="@+id/key_T"
                style="@style/floatKeyBoardKey"
                android:layout_below="@id/key_1"
                android:layout_toEndOf="@id/key_p"
                android:tag="22"
                android:text="T"
                android:thumb="@null"
                android:track="@null" />

            <Button
                android:id="@+id/key_Enter"
                style="@style/floatKeyBoardKey"
                android:layout_below="@id/key_1"
                android:layout_toEndOf="@id/key_k"
                android:tag="23"
                android:text="Enter" />
        </RelativeLayout>

    </LinearLayout>
</merge>