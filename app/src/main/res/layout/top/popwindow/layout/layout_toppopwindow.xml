<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content" >

    <com.micsig.tbook.ui.top.view.title.TopViewTitleWithScroll
        android:id="@+id/topPopTitleWithHead"
        android:layout_width="match_parent"
        android:layout_height="70px"
        android:background="@color/color_Math"
        app:itemBgViewFlag="firstTitle"
        />

    <RelativeLayout
        android:id="@+id/topPopDetailPopwindow"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/topPopTitleWithHead"
        android:background="@color/color_backcolor_mainMenu_center" />

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:background="@color/color_Backcolor_MainMenu2"
        android:scaleType="center"
        android:visibility="gone"
        android:src="@drawable/top_layout_down_icon" />

    <View
        android:id="@+id/topSlipBoundary"
        android:layout_width="match_parent"
        android:layout_height="1px"
        android:layout_below="@+id/topPopDetailPopwindow"
        android:background="@color/frame_color" />

    <View
        android:id="@+id/topSlipBoundaryTop"
        android:layout_width="match_parent"
        android:layout_height="2px"
        android:background="@color/frame_color" />

    <View
        android:id="@+id/topSlipBoundaryLeft"
        android:layout_width="1px"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_alignBottom="@+id/topSlipBoundary"
        android:background="@color/frame_color"  />

    <View
        android:id="@+id/topSlipBoundaryRight"
        android:layout_width="1px"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_alignBottom="@+id/topSlipBoundary"
        android:layout_alignParentEnd="true"
        android:background="@color/frame_color"  />
</RelativeLayout>