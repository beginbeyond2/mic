<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android">

    <View
        android:id="@+id/outView"
        android:layout_width="match_parent"
        android:layout_height="525px"
        android:layout_weight="1"/>
    <TextView
        android:id="@+id/createFolderTitle"
        style="@style/editTextStyle"
        android:layout_width="match_parent"
        android:layout_height="50px"
        android:layout_margin="0px"
        android:gravity="center_vertical|start"
        android:text="@string/new_folder"
        android:textSize="30px"
        android:visibility="invisible"
        android:maxLines="1"
        android:textColor="@color/textColorNewTopTitleUnSelect" />

    <com.micsig.tbook.tbookscope.top.popwindow.keyboardtext.TopDialogCandidatesWord
        android:id="@+id/candidatesWordView"
        android:layout_width="match_parent"
        android:layout_height="100px" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="455px"
        android:background="@drawable/shape_frame_bg_black"
        android:orientation="vertical">

        <EditText
            android:id="@+id/show"
            style="@style/editTextStyle"
            android:layout_width="match_parent"
            android:layout_height="60px"
            android:layout_margin="10px"
            android:gravity="center_vertical|start"
            android:inputType="textNoSuggestions"
            android:maxLines="1"
            android:textColor="@color/textColorNewTopTitleUnSelect" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/gridView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="10px"
            android:overScrollMode="never"
            android:scrollbars="none"
            android:focusable="true"
            android:focusableInTouchMode="true" />
    </LinearLayout>
</merge>