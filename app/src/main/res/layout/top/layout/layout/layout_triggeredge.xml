<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <com.micsig.tbook.ui.top.view.radioGroup.TopViewRadioGroup
        android:id="@+id/triggerSource"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="45px"
        app:array="@array/triggerSource"
        app:head="@string/triggerSource" />

    <com.micsig.tbook.ui.top.view.radioGroup.TopViewRadioGroup
        android:id="@+id/triggerEdge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/triggerSource"
        android:layout_marginStart="45px"
        android:layout_marginTop="10px"
        app:array="@array/triggerEdge"
        app:head="@string/triggerEdge" />

    <com.micsig.tbook.ui.top.view.radioGroup.TopViewRadioGroup
        android:id="@+id/triggerCouple"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/triggerSource"
        android:layout_marginStart="124px"
        android:layout_marginTop="10px"
        android:layout_toRightOf="@+id/triggerEdge"
        app:array="@array/triggerCouple"
        app:head="@string/triggerCouple" />
</RelativeLayout>