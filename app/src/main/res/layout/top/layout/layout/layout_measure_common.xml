<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <com.micsig.tbook.ui.MMainMenuChannel
        android:id="@+id/chanMeasureCommon"
        android:layout_width="match_parent"
        android:layout_height="90px"
        android:layout_marginLeft="33px"
        android:layout_marginRight="33px"
        />

    <Button
        android:id="@+id/indicator"
        style="@style/textStyle"
        android:layout_width="120px"
        android:layout_height="60px"
        android:layout_alignParentEnd="true"
        android:layout_alignParentRight="true"
        android:layout_marginTop="16px"
        android:layout_marginBottom="10px"
        android:layout_marginStart="10px"
        android:layout_marginEnd="40px"
        android:background="@drawable/bg_button_measure_clear"
        android:text="@string/measure_indicator"
        android:textAllCaps="false"
        android:textColor="@android:color/holo_red_dark" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/chanMeasureCommon"
        android:background="@color/color_Backcolor_MainMenu3">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/measureList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:overScrollMode="never"
            android:paddingStart="33px"
            android:paddingTop="5px"
            android:paddingEnd="2px"
            android:paddingBottom="5px"
            android:scrollbars="none"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <View
            android:id="@+id/divider"
            android:layout_width="match_parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/measureList"
            android:layout_height="2px"
            android:layout_marginStart="20px"
            android:layout_marginEnd="20px"
            android:layout_marginTop="15px"
            android:visibility="invisible"
            android:background="@drawable/divider_measure_common" />

        <Button
            android:id="@+id/clear"
            style="@style/buttonStyleTop"
            android:layout_width="120px"
            android:layout_height="60px"
            app:layout_constraintBottom_toBottomOf="@+id/divider"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="32px"
            android:layout_marginStart="20px"
            android:layout_marginEnd="40px"
            android:layout_marginBottom="27px"
            android:background="@drawable/selector_rightslip_button"
            android:text="@string/measure_clear"
            android:textAllCaps="false" />
<!--            android:textColor="@android:color/holo_red_dark"-->
<!--            android:background="@drawable/bg_button_measure_clear"-->

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/measureSelectList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16px"
            android:layout_marginEnd="200px"
            android:overScrollMode="never"
            android:paddingStart="33px"
            android:paddingEnd="2px"
            android:scrollbars="none"
            android:visibility="gone"
            app:layout_constraintRight_toLeftOf="@+id/clear"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/divider" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</RelativeLayout>