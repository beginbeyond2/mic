    <com.micsig.tbook.ui.top.view.TopViewEdit
        android:id="@+id/arinc429LabelSdiLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:layout_marginStart="10px"
        app:editHint="000"
        app:head="@string/topSerialsHeadLabel" />

    <com.micsig.tbook.ui.top.view.TopViewEdit
        android:id="@+id/arinc429LabelSdiSdi"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerVertical="true"
        android:layout_toEndOf="@id/arinc429LabelSdiLabel"
        android:layout_marginStart="20px"
        app:editHint="00"
        app:head="@string/topSerialsHeadSdi" />
</RelativeLayout>