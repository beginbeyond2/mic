<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <com.micsig.tbook.ui.top.view.radioGroup.TopViewRadioGroup
        android:id="@+id/triggerSource"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="45px"
        app:array="@array/triggerSource"
        app:head="@string/triggerSource" />

    <com.micsig.tbook.ui.top.view.radioGroup.TopViewRadioGroup
        android:id="@+id/polar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@+id/triggerSource"
        android:layout_marginStart="45px"
        android:layout_marginTop="20px"
        app:array="@array/triggerTimeoutPolar"
        app:head="@string/triggerTimeoutPolar" />

    <TextView
        android:id="@+id/timeoutTimeHead"
        style="@style/textStyle"
        android:layout_width="100px"
        android:layout_height="60px"
        android:layout_alignBottom="@+id/polar"
        android:layout_marginStart="124px"
        android:layout_marginEnd="16px"
        android:layout_toEndOf="@+id/polar"
        android:gravity="center_vertical|end"
        android:text="@string/trigger_overTime" />

    <TextView
        android:id="@+id/timeoutTimeDetail"
        style="@style/editTextStyleRight"
        android:layout_width="120px"
        android:layout_height="60px"
        android:layout_alignTop="@+id/timeoutTimeHead"
        android:layout_alignBottom="@+id/timeoutTimeHead"
        android:layout_toEndOf="@+id/timeoutTimeHead"
        android:text="@string/view_trigger_pulsewidth" />

</RelativeLayout>