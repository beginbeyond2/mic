<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <TextView
        android:id="@+id/openChannelTitle"
        style="@style/textStyle"
        android:layout_width="160px"
        android:layout_height="60px"
        android:gravity="center_vertical|end"
        android:text="@string/autoSettingOpenChannel"
        android:layout_marginStart="5px"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.micsig.tbook.ui.MSwitchBox
        android:id="@+id/openChannelDetail"
        android:layout_width="72px"
        android:layout_height="36px"
        android:layout_marginTop="10px"
        android:layout_marginStart="16px"
        android:layout_toEndOf="@+id/openChannelTitle" />

    <TextView
        android:id="@+id/levelHead"
        style="@style/textStyle"
        android:layout_width="120px"
        android:layout_height="60px"
        android:layout_alignBottom="@id/openChannelTitle"
        android:gravity="center_vertical|right"
        android:text="@string/autosetting_levelhead"
        android:layout_toEndOf="@id/openChannelDetail"
        android:layout_marginStart="100px" />

    <TextView
        android:id="@+id/levelDetail"
        style="@style/editTextStyleRight"
        android:layout_width="120px"
        android:layout_height="60px"
        android:layout_alignBottom="@+id/levelHead"
        android:layout_marginStart="16px"
        android:layout_marginTop="5px"
        android:text="@string/autosetting_leveldetail"
        android:layout_toEndOf="@+id/levelHead" />

    <com.micsig.tbook.ui.top.view.radioGroup.TopViewRadioGroup
        android:id="@+id/levelSelect"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@id/levelDetail"
        android:layout_marginStart="16px"
        app:array="@array/autoSettingLevelSelect"
        />

    <com.micsig.tbook.ui.top.view.radioGroup.TopViewRadioGroup
        android:id="@+id/triggerSource"
        android:layout_width="wrap_content"
        android:layout_height="60px"
        android:layout_marginStart="100px"
        android:layout_toEndOf="@+id/levelSelect"
        app:headWidth="160px"
        app:head="@string/autoSettingTriggerSource"
        app:array="@array/autoSettingTriggerSource" />

</RelativeLayout>