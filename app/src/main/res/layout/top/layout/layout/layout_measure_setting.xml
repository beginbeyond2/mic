<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <TextView
        android:id="@+id/lblInd"
        style="@style/textStyle"
        android:layout_width="120px"
        android:layout_height="wrap_content"
        android:gravity="center|right"
        android:text="@string/measureSettingIndicator"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="@id/indicator"
        app:layout_constraintBottom_toBottomOf="@+id/indicator"
        android:layout_marginLeft="37px"

        />
    <com.micsig.tbook.ui.MSwitchBox
        android:id="@+id/indicator"
        android:layout_width="72px"
        android:layout_height="36px"
        app:layout_constraintLeft_toRightOf="@+id/lblInd"
        app:layout_constraintTop_toTopOf="parent"
        android:layout_marginTop="16px"
        android:layout_marginLeft="30px"

        />

    <com.micsig.tbook.ui.top.view.radioGroup.TopViewRadioGroup
        android:id="@+id/range"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="45px"
        app:head="@string/measureSettingRange"
        app:array="@array/measureSettingRange"
        app:layout_constraintTop_toTopOf="@id/indicator"
        app:layout_constraintBottom_toBottomOf="@id/indicator"
        app:layout_constraintLeft_toRightOf="@+id/indicator"
        android:layout_marginLeft="458px"
        app:headWidth="150px"
        />

    <View
        android:id="@+id/divider"
        android:layout_width="match_parent"
        android:layout_height="2px"
        android:background="@drawable/bg_right_layout_divider"
        app:layout_constraintTop_toBottomOf="@+id/indicator"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        android:layout_marginLeft="21px"
        android:layout_marginRight="21px"
        android:layout_marginTop="34px"
        />
    <Button
        android:id="@+id/btnReset"
        style="@style/textStyle"
        android:layout_width="120px"
        android:layout_height="60px"
        android:background="@drawable/selector_rightslip_button"
        android:textColor="@drawable/selector_text_color"
        app:layout_constraintTop_toBottomOf="@id/chanMeasureSetting"
        app:layout_constraintRight_toRightOf="parent"
        android:text="@string/measureCounterReset"
        android:textAllCaps="false"
        android:layout_marginRight="81px"
        />
    <com.micsig.tbook.ui.MMainMenuChannel
        android:id="@+id/chanMeasureSetting"
        android:layout_width="match_parent"
        android:layout_height="90px"
        android:overScrollMode="never"
        android:layout_marginStart="33px"
        android:layout_marginEnd="33px"
        android:scrollbars="none"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toLeftOf="@+id/btnReset"
        app:layout_constraintTop_toBottomOf="@id/divider"
        />

    <com.micsig.tbook.ui.top.view.radioGroup.TopViewRadioGroup
        android:id="@+id/Threshold"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="37px"
        app:head="@string/measureSettingThresholds"
        app:array="@array/measureSettingThresholds"
        app:layout_constraintTop_toBottomOf="@id/chanMeasureSetting"
        app:layout_constraintLeft_toLeftOf="parent"
        android:layout_marginLeft="37px"
        app:headWidth="120px"
        />

    <TextView
        android:id="@+id/lblHigh"
        style="@style/textStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/measureSettingHigh"
        app:layout_constraintRight_toLeftOf="@id/txtHigh"
        app:layout_constraintTop_toTopOf="@id/Threshold"
        app:layout_constraintBottom_toBottomOf="@+id/Threshold"
        android:layout_marginRight="10px"
        />
    <TextView
        android:id="@+id/txtHigh"
        style="@style/editTextStyle"
        android:layout_width="120px"
        android:layout_height="60px"
        android:gravity="center"
        app:layout_constraintLeft_toRightOf="@id/Threshold"
        app:layout_constraintTop_toTopOf="@id/Threshold"
        app:layout_constraintBottom_toBottomOf="@+id/Threshold"
        android:layout_marginLeft="286px"
        android:text="90%"

        />
    <TextView
        android:id="@+id/lblMiddle"
        style="@style/textStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        app:layout_constraintRight_toLeftOf="@id/txtMiddle"
        app:layout_constraintTop_toTopOf="@id/Threshold"
        app:layout_constraintBottom_toBottomOf="@+id/Threshold"
        android:layout_marginRight="10px"
        android:text="@string/measureSettingMiddle"
        />
    <TextView
        android:id="@+id/txtMiddle"
        style="@style/editTextStyle"
        android:layout_width="120px"
        android:layout_height="60px"
        android:text="50%"
        android:gravity="center"
        app:layout_constraintLeft_toRightOf="@+id/txtHigh"
        app:layout_constraintTop_toTopOf="@id/Threshold"
        app:layout_constraintBottom_toBottomOf="@+id/Threshold"
        android:layout_marginLeft="100px"
        />
    <TextView
        android:id="@+id/lblLow"
        style="@style/textStyle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/measureSettingLower"
        app:layout_constraintRight_toLeftOf="@id/txtLow"
        app:layout_constraintTop_toTopOf="@id/Threshold"
        app:layout_constraintBottom_toBottomOf="@+id/Threshold"
        android:layout_marginRight="10px"
        />
    <TextView
        android:id="@+id/txtLow"
        style="@style/editTextStyle"
        android:layout_width="120px"
        android:layout_height="60px"
        android:text="10%"
        android:gravity="center"
        app:layout_constraintLeft_toRightOf="@+id/txtMiddle"
        app:layout_constraintTop_toTopOf="@id/Threshold"
        app:layout_constraintBottom_toBottomOf="@+id/Threshold"
        android:layout_marginLeft="100px"
        />


</androidx.constraintlayout.widget.ConstraintLayout>