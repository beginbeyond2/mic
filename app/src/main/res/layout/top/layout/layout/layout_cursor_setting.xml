<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <com.micsig.tbook.ui.MTextView
        android:id="@+id/lblCurSorTraceTitle"
        style="@style/textStyle"
        android:layout_width="120px"
        android:layout_height="60px"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:gravity="center_vertical|end"
        android:layout_marginStart="33px"
        android:textColor="@color/textColorTop"
        android:text="@string/cursorTrance"
        />
    <com.micsig.tbook.ui.MSwitchBox
        android:id="@+id/radioCursorTrace"
        android:layout_width="72px"
        android:layout_height="36px"
        app:layout_constraintLeft_toRightOf="@+id/lblCurSorTraceTitle"
        app:layout_constraintTop_toTopOf="@id/lblCurSorTraceTitle"
        app:layout_constraintBottom_toBottomOf="@id/lblCurSorTraceTitle"
        android:layout_marginStart="16px"
        />


    <com.micsig.tbook.ui.MTextView
        android:id="@+id/labelFollowCursorTitle"
        style="@style/textStyle"
        android:layout_width="120px"
        android:layout_height="60px"
        android:layout_marginLeft="52dp"
        android:gravity="center_vertical|end"
        android:text="@string/labelFollowMode"
        android:textColor="@color/textColorTop"
        app:layout_constraintBottom_toBottomOf="@id/lblCurSorTraceTitle"
        app:layout_constraintLeft_toLeftOf="@id/radioCursorTrace"
        app:layout_constraintTop_toTopOf="@id/lblCurSorTraceTitle"
        app:layout_constraintVertical_bias="0.0" />

    <com.micsig.tbook.ui.MSwitchBox
        android:id="@+id/radioCursorMode"
        android:layout_width="72px"
        android:layout_height="36px"
        app:layout_constraintLeft_toRightOf="@+id/labelFollowCursorTitle"
        app:layout_constraintTop_toTopOf="@id/labelFollowCursorTitle"
        app:layout_constraintBottom_toBottomOf="@id/labelFollowCursorTitle"
        android:layout_marginStart="16px"
        />



</androidx.constraintlayout.widget.ConstraintLayout>