<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <TextView
        android:id="@+id/displayFftInfoTitle"
        style="@style/textStyle"
        android:layout_width="120px"
        android:layout_height="60px"
        android:layout_alignParentLeft="true"
        android:layout_marginStart="25px"
        android:layout_marginRight="16px"
        android:gravity="center_vertical|right"
        android:visibility="gone"
        android:text="@string/topLayoutDisplayFftInfo" />

    <com.micsig.tbook.ui.MSwitchBox
        android:id="@+id/switchFftInfo"
        android:layout_width="72px"
        android:layout_height="36px"
        android:visibility="gone"
        android:layout_alignTop="@+id/displayFftInfo"
        android:layout_alignBottom="@+id/displayFftInfo"
        android:layout_toEndOf="@+id/displayFftInfoTitle" />

    <com.micsig.tbook.ui.top.view.radioGroup.TopViewRadioGroup
        android:id="@+id/displayFftInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="33px"
        android:layout_alignParentLeft="true"
        app:array="@array/topLayoutDisplayFftInfo"
        app:head="@string/topLayoutDisplayFftInfo"
        app:headWidth="100px" />


</RelativeLayout>