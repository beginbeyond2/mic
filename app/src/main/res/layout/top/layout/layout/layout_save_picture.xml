<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingTop="10px"
    android:paddingHorizontal="10px">

    <com.micsig.tbook.ui.top.view.TopViewSpinner
        android:id="@+id/topSpinner"
        android:layout_width="wrap_content"
        android:layout_height="60px"
        android:layout_marginStart="28px"
        android:layout_marginTop="12px"
        app:editWidth="600px"
        app:headWidth="100px"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <Button
        android:id="@+id/btn_browse"
        style="@style/buttonStyleTop"
        android:layout_width="120px"
        android:layout_height="60px"
        android:layout_marginStart="50px"
        android:background="@drawable/selector_rightslip_button"
        android:text="@string/top_save_browse"
        app:layout_constraintBottom_toBottomOf="@+id/topSpinner"
        app:layout_constraintStart_toEndOf="@+id/topSpinner"
        app:layout_constraintTop_toTopOf="@+id/topSpinner" />

    <com.micsig.tbook.ui.top.view.TopViewEdit
        android:id="@+id/saveName"
        android:layout_width="wrap_content"
        android:layout_height="54px"
        android:layout_marginStart="26px"
        android:layout_marginTop="12px"
        app:editCenter="true"
        app:editWidth="360px"
        app:head="@string/view_savewithhead_title"
        app:headViewGravityLeft="false"
        app:headTextSize="20px"
        app:headWidth="90px"
        app:layout_constraintStart_toStartOf="@+id/topSpinner"
        app:layout_constraintTop_toBottomOf="@+id/topSpinner" />

    <CheckBox
        android:id="@+id/check_file_name_add"
        android:layout_width="214px"
        android:layout_height="54px"
        android:layout_marginStart="50px"
        android:button="@null"
        android:checked="false"
        android:drawablePadding="10px"
        android:gravity="center_vertical"
        android:text="@string/top_save_file_name_add"
        android:textColor="@color/textColor"
        android:textSize="@dimen/textSizeCur"
        app:layout_constraintBottom_toBottomOf="@+id/saveName"
        app:layout_constraintStart_toEndOf="@+id/saveName"
        app:layout_constraintTop_toTopOf="@+id/saveName" />

    <TextView
        android:id="@+id/txt_index_num"
        style="@style/editTextStyle"
        android:layout_width="120px"
        android:layout_height="54px"
        android:layout_marginStart="26px"
        android:gravity="center"
        android:maxLines="1"
        android:text="999"
        app:layout_constraintBottom_toBottomOf="@+id/saveName"
        app:layout_constraintStart_toEndOf="@+id/check_file_name_add"
        app:layout_constraintTop_toTopOf="@+id/saveName" />


    <Button
        android:id="@+id/btn_save"
        style="@style/buttonStyleTop"
        android:layout_width="120px"
        android:layout_height="54px"
        android:layout_marginStart="50px"
        android:background="@drawable/selector_rightslip_button"
        android:text="@string/view_savewithhead_confirm"
        android:textAllCaps="false"
        app:layout_constraintBottom_toBottomOf="@+id/saveName"
        app:layout_constraintStart_toEndOf="@+id/txt_index_num"
        app:layout_constraintTop_toTopOf="@+id/saveName" />

    <TextView
        android:id="@+id/savePictureTimestampTitle"
        style="@style/textStyle"
        android:layout_width="128px"
        android:layout_height="54px"
        android:gravity="center_vertical|end"
        android:text="@string/saveTimestamp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/saveName" />

    <com.micsig.tbook.ui.MSwitchBox
        android:id="@+id/savePictureTimestampDetail"
        android:layout_width="72px"
        android:layout_height="36px"
        android:layout_marginStart="10px"
        app:layout_constraintBottom_toBottomOf="@+id/savePictureTimestampTitle"
        app:layout_constraintStart_toEndOf="@+id/savePictureTimestampTitle"
        app:layout_constraintTop_toTopOf="@+id/savePictureTimestampTitle" />

    <TextView
        android:id="@+id/savePictureInverseColorTitle"
        style="@style/textStyle"
        android:layout_width="120px"
        android:layout_height="54px"
        android:layout_marginStart="40px"
        android:layout_marginRight="16px"
        android:gravity="center_vertical|end"
        android:text="@string/saveInverseColor"
        app:layout_constraintBottom_toBottomOf="@+id/savePictureTimestampTitle"
        app:layout_constraintStart_toEndOf="@+id/savePictureTimestampDetail"
        app:layout_constraintTop_toTopOf="@+id/savePictureTimestampTitle" />

    <com.micsig.tbook.ui.MSwitchBox
        android:id="@+id/savePictureInverseColorDetail"
        android:layout_width="72px"
        android:layout_height="36px"
        android:layout_marginStart="16px"
        app:layout_constraintBottom_toBottomOf="@+id/savePictureInverseColorTitle"
        app:layout_constraintStart_toEndOf="@+id/savePictureInverseColorTitle"
        app:layout_constraintTop_toTopOf="@+id/savePictureInverseColorTitle" />

    <TextView
        android:id="@+id/savePictureThumbnailTitle"
        style="@style/textStyle"
        android:layout_width="120px"
        android:layout_height="54px"
        android:layout_marginStart="40px"
        android:layout_marginRight="16px"
        android:gravity="center_vertical|end"
        android:text="@string/saveThumbnail"
        app:layout_constraintBottom_toBottomOf="@+id/savePictureTimestampTitle"
        app:layout_constraintStart_toEndOf="@+id/savePictureInverseColorDetail"
        app:layout_constraintTop_toTopOf="@+id/savePictureTimestampTitle" />

    <com.micsig.tbook.ui.MSwitchBox
        android:id="@+id/savePictureThumbnailDetail"
        android:layout_width="72px"
        android:layout_height="36px"
        android:layout_marginStart="16px"
        app:layout_constraintBottom_toBottomOf="@+id/savePictureThumbnailTitle"
        app:layout_constraintStart_toEndOf="@+id/savePictureThumbnailTitle"
        app:layout_constraintTop_toTopOf="@+id/savePictureThumbnailTitle" />


</androidx.constraintlayout.widget.ConstraintLayout>