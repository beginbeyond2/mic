  <diagram id="data_flow" name="数据流向图">
    <mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="900" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        
        <!-- 标题 -->
        <mxCell id="title4" value="逻辑触发器数据流向图" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=20;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="500" y="20" width="400" height="40" as="geometry"/>
        </mxCell>
        
        <!-- 用户配置 -->
        <mxCell id="config_start" value="用户配置参数&#xa;━━━━━━━━━━━━━━━━━━&#xa;CH1-CH4 = HIGH&#xa;逻辑关系 = AND&#xa;触发条件 = &lt; (小于)&#xa;时间 = 100ms" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;align=left;spacingLeft=10" vertex="1" parent="1">
          <mxGeometry x="80" y="100" width="200" height="120" as="geometry"/>
        </mxCell>
        
        <!-- 用户操作 -->
        <mxCell id="user_op" value="用户操作" style="ellipse;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="80" y="260" width="200" height="60" as="geometry"/>
        </mxCell>
        
        <!-- TopLayoutTriggerLogic处理 -->
        <mxCell id="toplayout_process" value="TopLayoutTriggerLogic&#xa;━━━━━━━━━━━━━━━━━━&#xa;onSelectChanged()处理&#xa;━━━━━━━━━━━━━━━━━━&#xa;1. Command.Status()&#xa;   → 发送硬件命令&#xa;2. CacheUtil.putMap()&#xa;   → 保存配置到缓存&#xa;3. triggerLogic.setLogicValids()&#xa;   → 同步到TriggerLogic&#xa;   → 触发triggerParamChange()&#xa;4. triggerDetail.setCh1()&#xa;   → 更新数据模型&#xa;5. sendMsg(false)&#xa;   → 通知外部监听器" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=11;align=left;spacingLeft=10" vertex="1" parent="1">
          <mxGeometry x="320" y="100" width="280" height="220" as="geometry"/>
        </mxCell>
        
        <!-- 三条并行路径 -->
        <mxCell id="path_header" value="三条并行路径" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="640" y="100" width="160" height="30" as="geometry"/>
        </mxCell>
        
        <!-- 路径1: 硬件命令 -->
        <mxCell id="path1" value="路径1: 硬件命令&#xa;━━━━━━━━━━━━━━━━━━&#xa;Command_Trigger_Logic&#xa;━━━━━━━━━━━━━━━━━━&#xa;Status(0, 0, false)&#xa;• 更新内部状态&#xa;• status[0] = 0&#xa;• isUpdateUI=false&#xa;  → 不发送RxBus消息&#xa;━━━━━━━━━━━━━━━━━━&#xa;注意: Command层只保存&#xa;状态，不直接发送FPGA&#xa;消息。FPGA消息由&#xa;TriggerLogic发送" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=left;spacingLeft=10" vertex="1" parent="1">
          <mxGeometry x="640" y="140" width="280" height="180" as="geometry"/>
        </mxCell>
        
        <!-- 路径2: 缓存保存 -->
        <mxCell id="path2" value="路径2: 缓存保存&#xa;━━━━━━━━━━━━━━━━━━&#xa;CacheUtil&#xa;━━━━━━━━━━━━━━━━━━&#xa;putMap(CH1, &quot;0&quot;)&#xa;• 保存到SharedPreferences&#xa;• 用于下次启动恢复" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;align=left;spacingLeft=10" vertex="1" parent="1">
          <mxGeometry x="640" y="340" width="280" height="120" as="geometry"/>
        </mxCell>
        
        <!-- 路径3: FPGA消息 -->
        <mxCell id="path3" value="路径3: FPGA消息发送&#xa;━━━━━━━━━━━━━━━━━━&#xa;TriggerLogic → TriggerAction&#xa;━━━━━━━━━━━━━━━━━━&#xa;setLogicValids(0, LOGIC_HIGH)&#xa;• logicValids[0] = LOGIC_HIGH&#xa;• InitTriggerSrc()&#xa;  → triggerSource[0] = 0&#xa;• triggerParamChange()&#xa;━━━━━━━━━━━━━━━━━━&#xa;TriggerAction.triggerParamChange()&#xa;• sendFpgaMsg(FPGA_CMD_TRIG)&#xa;  → 构建FPGA命令数据包&#xa;  → 发送到硬件消息队列&#xa;  → FPGA接收并更新配置&#xa;• sendEvent(EVENT_TRIGGER_PARAM)&#xa;  → EventFactory发送事件&#xa;  → UI观察者刷新" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=11;align=left;spacingLeft=10" vertex="1" parent="1">
          <mxGeometry x="960" y="100" width="280" height="260" as="geometry"/>
        </mxCell>
        
        <!-- FPGA处理 -->
        <mxCell id="fpga_process" value="FPGA硬件&#xa;━━━━━━━━━━━━━━━━━━&#xa;接收FPGA_CMD_TRIG命令&#xa;━━━━━━━━━━━━━━━━━━&#xa;解析参数:&#xa;• 触发类型: LOGIC&#xa;• 触发源: CH1-CH4&#xa;• 逻辑状态: HIGH,HIGH,HIGH,HIGH&#xa;• 逻辑关系: AND&#xa;• 触发条件: LESS&#xa;• 时间阈值: 100ms&#xa;━━━━━━━━━━━━━━━━━━&#xa;触发逻辑:&#xa;CH1=高 AND CH2=高&#xa;AND CH3=高 AND CH4=高&#xa;持续时间 &lt; 100ms&#xa;→ 触发波形采集" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=left;spacingLeft=10" vertex="1" parent="1">
          <mxGeometry x="1280" y="100" width="240" height="260" as="geometry"/>
        </mxCell>
        
        <!-- 连接箭头 -->
        <mxCell id="flow1" value="" style="endArrow=classic;html=1;rounded=0;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;fontSize=10" edge="1" parent="1">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="180" y="220" as="sourcePoint"/>
            <mxPoint x="180" y="260" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        
        <mxCell id="flow2" value="" style="endArrow=classic;html=1;rounded=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;fontSize=10" edge="1" parent="1">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="280" y="290" as="sourcePoint"/>
            <mxPoint x="320" y="200" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        
        <mxCell id="flow3" value="" style="endArrow=classic;html=1;rounded=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;fontSize=10" edge="1" parent="1">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="600" y="200" as="sourcePoint"/>
            <mxPoint x="640" y="200" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        
        <mxCell id="flow4" value="" style="endArrow=classic;html=1;rounded=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;fontSize=10" edge="1" parent="1">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="920" y="200" as="sourcePoint"/>
            <mxPoint x="960" y="200" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        
        <mxCell id="flow5" value="" style="endArrow=classic;html=1;rounded=0;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;fontSize=10;dashed=1" edge="1" parent="1">
          <mxGeometry width="50" height="50" relative="1" as="geometry">
            <mxPoint x="1240" y="200" as="sourcePoint"/>
            <mxPoint x="1280" y="200" as="targetPoint"/>
          </mxGeometry>
        </mxCell>
        
        <!-- isFromEventBus说明 -->
        <mxCell id="isfromeventbus" value="isFromEventBus参数说明&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;• false: 用户操作触发，需要发送硬件命令&#xa;• true: 硬件同步触发，不发送硬件命令(避免循环)&#xa;━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━&#xa;用户操作 → isFromEventBus=false → 发送硬件命令&#xa;硬件同步 → isFromEventBus=true → 不发送硬件命令" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;align=left;spacingLeft=10" vertex="1" parent="1">
          <mxGeometry x="80" y="400" width="520" height="120" as="geometry"/>
        </mxCell>
        
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>