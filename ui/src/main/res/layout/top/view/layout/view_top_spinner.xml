<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android">

    <TextView
        android:id="@+id/headView"
        style="@style/textStyle"
        android:layout_width="100px"
        android:layout_height="60px"
        android:layout_marginRight="16px"
        android:gravity="center_vertical|right" />


    <Spinner
        android:id="@+id/action_spinner"
        android:layout_width="600px"
        android:layout_height="60px"
        android:layout_alignTop="@+id/saveType"
        android:layout_alignBottom="@+id/saveType"
        android:layout_toRightOf="@+id/saveType"
        android:background="@drawable/selector_for_spinner"
        android:popupBackground="@drawable/shape_frame_bg_black"
        android:spinnerMode="dropdown" />

</merge>