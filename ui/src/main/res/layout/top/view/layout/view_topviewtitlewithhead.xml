<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android">

    <com.micsig.tbook.ui.top.view.title.TopViewHorScroll
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:overScrollMode="never"
        android:scrollbars="none">

    </com.micsig.tbook.ui.top.view.title.TopViewHorScroll>

    <View
        android:id="@+id/topViewTitleDivider"
        android:layout_width="match_parent"
        android:layout_height="1px"
        android:layout_alignParentBottom="true"
        android:background="@color/divider" />

    <RelativeLayout
        android:id="@+id/leftLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_above="@id/topViewTitleDivider"
        android:layout_alignParentStart="true"
        android:layout_alignParentTop="true"
        android:background="@color/color_Backcolor_MainMenu1">

        <TextView
            android:id="@+id/selectTitleLeft"
            android:layout_width="145px"
            android:layout_height="match_parent"
            android:gravity="center"
            android:paddingEnd="2px"
            android:textColor="@color/textColorNewTopTitleSelect"
            android:textSize="20px" />
    </RelativeLayout>

    <ImageView
        android:id="@+id/firstTitleFlag"
        android:layout_width="115px"
        android:layout_height="8px"
        android:layout_alignParentBottom="true"
        android:layout_alignParentStart="true"
        android:src="@drawable/top_menu_first_select"/>

    <RelativeLayout
        android:id="@+id/rightLayout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_above="@id/topViewTitleDivider"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:background="@color/color_Backcolor_MainMenu1">

        <TextView
            android:id="@+id/selectTitleRight"
            android:layout_width="145px"
            android:layout_height="match_parent"
            android:gravity="center"
            android:paddingEnd="1px"
            android:textColor="@color/textColorNewTopTitleSelect"
            android:textSize="14px" />
    </RelativeLayout>
</merge>