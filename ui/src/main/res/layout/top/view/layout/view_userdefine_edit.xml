<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <TextView
        android:id="@+id/editClickView"
        style="@style/editTextStyle"
        android:layout_width="230px"
        android:layout_height="54px"
        android:clickable="true" />

    <TextView
        android:id="@+id/editUserDefineView"
        style="@style/editTextUserDefaultStyle"
        android:layout_width="230px"
        android:layout_height="match_parent"
        android:layout_alignTop="@+id/editClickView"
        android:layout_alignBottom="@+id/editClickView"
        android:gravity="center"
        android:includeFontPadding="false"
        android:maxLines="2"
        android:text="@string/serialsUserDefine"
        android:textColor="@color/textcolor_edittext" />

</RelativeLayout>