<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout android:layout_height="match_parent"
    android:layout_width="match_parent"
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@drawable/boarder"
    >

    <LinearLayout
        android:id="@+id/linl_main_layout_area"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_above="@id/frameLayout_handle_area"
        android:layout_marginTop="2px"
        android:layout_marginStart="2px"
        android:layout_marginEnd="2px"
        android:layout_marginBottom="1px"
        >

        <FrameLayout
            android:id="@+id/frameLayout_titlebar_area"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            />
        <View
            android:layout_width="match_parent"
            android:layout_height="1px"
            android:background="@color/frame_color" />

        <FrameLayout
            android:id="@+id/frameLayout_tabbar_area"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <View
            android:layout_width="match_parent"
            android:layout_height="1px"
            android:background="@color/frame_color" />


        <FrameLayout
            android:id="@+id/frameLayout_file_show_area"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />
    </LinearLayout>


    <FrameLayout
        android:id="@+id/frameLayout_handle_area"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        />
</RelativeLayout>