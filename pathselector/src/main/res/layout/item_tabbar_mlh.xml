<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@android:color/transparent">

    <RelativeLayout
        android:id="@+id/relatl_item_tabbar_mlh"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_width="wrap_content"
        android:layout_height="25dp">

        <ImageView
            android:id="@+id/imgv_item_tabbar_mlh"
            android:layout_width="10dp"
            android:layout_height="8dp"
            android:src="@drawable/arrow"
            android:clickable="false"
            android:layout_toRightOf="@id/tv_item_tabbar"
            android:layout_marginStart="10dp"
            android:layout_centerVertical="true" />

        <TextView
            android:id="@+id/tv_item_tabbar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10dp"
            android:background="@drawable/style_click_rectangle_transp_gray_mlh"
            android:minWidth="10dp"
            android:text="@string/test_text_mlh"
            android:textColor="@color/folder_text_color"
            android:textSize="14sp" />
    </RelativeLayout>


</RelativeLayout>